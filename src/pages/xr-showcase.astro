---
import BaseLayout from "../layouts/BaseLayout.astro";
import { publicXRShowcaseItems, xrShowcaseFilters } from "../data/xr-showcase";

const pageTitle = "XR Showcase";
const pageDescription =
  "A growing collection of extended-reality projects, immersive installations, fashion experiments, research, exhibitions, and creative references that we are learning from.";

const filters = xrShowcaseFilters.filter((filter) => filter !== "All");
---

<BaseLayout title={pageTitle} description={pageDescription} bodyClass="xr-showcase-page">
  <header class="xr-page-header">
    <p class="xr-kicker">Creative reference library</p>
    <h1>{pageTitle}</h1>
    <p>
      A growing collection of extended-reality projects, immersive installations,
      fashion experiments, research, exhibitions, and creative references that we
      are learning from.
    </p>
  </header>

  <section class="xr-topic-strip" aria-label="XR showcase topics">
    {filters.map((filter) => <span>{filter}</span>)}
  </section>

  <section class="xr-link-list" aria-label="XR showcase references">
    {publicXRShowcaseItems.map((item) => {
      const href = item.canonicalUrl || item.url;
      const source = item.source || item.domain || new URL(href).hostname.replace(/^www\./, "");

      return (
        <article class="xr-link-item">
          <div>
            <p class="xr-link-item__genre">{item.primaryGenre}</p>
            <h2>
              <a href={href} target="_blank" rel="noopener noreferrer">
                {item.title}
              </a>
            </h2>
            {item.description && <p>{item.description}</p>}
          </div>

          <footer>
            <span>{source}</span>
            <span class="xr-link-item__tags">
              {item.tags.slice(0, 5).map((tag) => <span>{tag}</span>)}
            </span>
          </footer>
        </article>
      );
    })}
  </section>
</BaseLayout>

<style>
  :global(.xr-showcase-page .page-content) {
    max-width: 1040px;
  }

  .xr-page-header {
    max-width: 780px;
    padding: clamp(2rem, 5vw, 4.5rem) 0 1.5rem;
  }

  .xr-kicker,
  .xr-link-item__genre,
  .xr-link-item footer {
    font-family: var(--font-ui);
  }

  .xr-kicker {
    margin: 0 0 0.7rem;
    color: var(--text-tertiary);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .xr-page-header h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2.7rem, 8vw, 5.8rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.96;
  }

  .xr-page-header p:last-child {
    margin: 1.1rem 0 0;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    line-height: 1.65;
  }

  .xr-topic-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    padding: 0 0 clamp(1.5rem, 4vw, 2.5rem);
  }

  .xr-topic-strip span,
  .xr-link-item__tags span {
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    color: var(--text-tertiary);
    font: 700 0.78rem/1 var(--font-ui);
  }

  .xr-topic-strip span {
    padding: 0.48rem 0.72rem;
  }

  .xr-link-list {
    display: grid;
    border-top: 1px solid var(--border-subtle);
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  .xr-link-item {
    display: grid;
    gap: 1rem;
    border-bottom: 1px solid var(--border-subtle);
    padding: clamp(1.2rem, 3vw, 2rem) 0;
  }

  .xr-link-item__genre {
    margin: 0 0 0.45rem;
    color: var(--theme-color-accent);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .xr-link-item h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 3vw, 2.35rem);
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.05;
  }

  .xr-link-item h2 a {
    color: var(--text-primary);
    text-decoration-color: color-mix(in srgb, var(--text-primary) 25%, transparent);
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.14em;
  }

  .xr-link-item h2 a:hover {
    text-decoration-color: currentColor;
  }

  .xr-link-item p:not(.xr-link-item__genre) {
    max-width: 760px;
    margin: 0.65rem 0 0;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.62;
  }

  .xr-link-item footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 0.8rem;
    align-items: center;
    color: var(--text-tertiary);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .xr-link-item__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .xr-link-item__tags span {
    padding: 0.25rem 0.5rem;
  }
</style>
