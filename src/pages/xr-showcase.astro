---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import XRShowcaseGrid from "../components/xr-showcase/XRShowcaseGrid.astro";
import { xrShowcaseFilters } from "../data/xr-showcase";
import { getPublicXRShowcaseItems } from "../lib/xr-showcase/services";

const pageTitle = "XR Showcase";
const pageDescription =
  "A growing collection of some amazing XR projects + resources around art, culture, fashion, travel and immersive experiences.";
Astro.response.headers.set("Cache-Control", "no-store, max-age=0");
const enrichedItems = await getPublicXRShowcaseItems();
---

<BaseLayout title={pageTitle} description={pageDescription} bodyClass="xr-showcase-page">
  <header class="xr-page-header">
    <p class="xr-kicker">Creative reference library</p>
    <h1>{pageTitle}</h1>
    <p>
      A growing collection of some amazing XR projects + resources around art,
      culture, fashion, travel and immersive experiences.
    </p>
  </header>

  <XRShowcaseGrid items={enrichedItems} filters={xrShowcaseFilters} />
</BaseLayout>

<style is:global>
  .xr-showcase-page .page-content {
    max-width: 1160px;
  }

  .xr-page-header {
    max-width: 760px;
    padding: clamp(2rem, 5vw, 4.5rem) 0 1.75rem;
  }

  .xr-kicker {
    margin: 0 0 0.7rem;
    color: var(--text-tertiary);
    font-family: var(--font-ui);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .xr-page-header h1 {
    margin: 0;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(2.7rem, 8vw, 5.8rem);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.96;
  }

  .xr-page-header p:last-child {
    margin: 1.1rem 0 0;
    color: var(--text-secondary);
    font-family: var(--font-sans);
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    line-height: 1.65;
  }

  .xr-showcase {
    --xr-accent-soft: #dce8b5;
    --xr-source-text: #edf2e4;
    padding-bottom: clamp(4rem, 8vw, 7rem);
  }

  [data-theme="light"] .xr-showcase {
    --xr-accent-soft: #52682d;
    --xr-source-text: #2e3525;
  }

  .xr-controls {
    margin-bottom: 0.8rem;
  }

  .xr-search {
    position: relative;
    display: block;
  }

  .xr-search svg {
    position: absolute;
    top: 50%;
    left: 1rem;
    width: 1.08rem;
    height: 1.08rem;
    color: var(--text-tertiary);
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    transform: translateY(-50%);
    pointer-events: none;
  }

  .xr-search input {
    width: 100%;
    border: 1px solid var(--border-subtle);
    border-radius: 10px;
    background: color-mix(in srgb, var(--bg-surface) 88%, transparent);
    color: var(--text-primary);
    font: 500 1rem/1.2 var(--font-ui);
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      box-shadow 160ms ease;
  }

  .xr-search input {
    min-height: 3.2rem;
    padding: 0.8rem 1rem 0.8rem 2.85rem;
  }

  .xr-search input:focus,
  .xr-chip:focus-visible,
  .xr-reset:focus-visible,
  .xr-card:focus-visible {
    outline: 2px solid var(--border-focus);
    outline-offset: 3px;
  }

  .xr-filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    max-width: 100%;
    margin: 0;
    padding: 0.15rem 0 0.6rem;
  }

  .xr-chip,
  .xr-reset {
    flex: 0 0 auto;
    max-width: 100%;
    border: 1px solid var(--border-subtle);
    border-radius: 100px;
    padding: 8px 16px;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    font: 500 0.8rem/1 var(--font-ui);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    white-space: nowrap;
    transition: all 0.2s ease;
  }

  .xr-chip:hover,
  .xr-reset:hover {
    border-color: var(--text-primary);
    color: var(--text-primary);
  }

  .xr-chip--active {
    border-color: var(--text-primary);
    background: var(--text-primary);
    color: var(--text-inverse);
  }

  .xr-result-count {
    margin: 0.65rem 0 1.5rem;
    color: var(--text-tertiary);
    font: 600 0.88rem/1.4 var(--font-ui);
  }

  .xr-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.6rem, 3.4vw, 2.65rem);
    align-items: stretch;
  }

  .xr-card {
    display: grid;
    grid-template-rows: auto 1fr;
    height: 100%;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    background: color-mix(in srgb, var(--bg-surface) 92%, transparent);
    color: inherit;
    text-decoration: none;
    transition: transform 150ms ease;
  }

  .xr-card[hidden],
  .xr-card--filtered-out {
    display: none;
  }

  .xr-card:hover {
    transform: translateY(-2px);
  }

  .xr-card__image-shell {
    position: relative;
    display: block;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    isolation: isolate;
    background: var(--bg-surface-hover);
  }

  .xr-card__gradient {
    position: absolute;
    inset: -12%;
    z-index: 0;
    display: block;
    background:
      radial-gradient(
        circle at 18% 15%,
        var(--xr-gradient-a) 0%,
        color-mix(in srgb, var(--xr-gradient-a) 72%, transparent) 34%,
        transparent 66%
      ),
      radial-gradient(
        circle at 82% 85%,
        var(--xr-gradient-b) 0%,
        color-mix(in srgb, var(--xr-gradient-b) 76%, transparent) 36%,
        transparent 68%
      ),
      linear-gradient(135deg, var(--xr-gradient-a), var(--xr-gradient-b));
    filter: blur(12px) saturate(0.94);
    transform: scale(1.08);
  }

  .xr-card__image {
    position: absolute;
    inset: -2px;
    z-index: 1;
    display: block;
    width: calc(100% + 4px);
    height: calc(100% + 4px);
    object-fit: cover;
    object-position: center;
    opacity: 1;
    transform: scale(1.04);
  }

  .xr-card__body {
    display: grid;
    grid-template-rows: auto auto minmax(2.25rem, 1fr) auto;
    gap: 0.72rem;
    min-height: 13rem;
    padding: clamp(1.3rem, 2.8vw, 1.75rem);
  }

  .xr-card__genre {
    color: var(--xr-accent-soft);
    font: 750 0.74rem/1.2 var(--font-ui);
    letter-spacing: 0.095em;
    text-transform: uppercase;
  }

  .xr-card__title {
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    font-weight: 750;
    letter-spacing: 0;
    line-height: 1.08;
  }

  .xr-card__source {
    display: flex;
    width: 100%;
    align-items: baseline;
    align-self: end;
    justify-content: flex-start;
    gap: 0.32rem;
    border-top: 1px solid var(--border-subtle);
    padding: 0.9rem 0;
    color: var(--xr-source-text);
    font: 400 0.82rem/1.5 var(--font-ui);
  }

  .xr-card__source-label {
    min-width: 0;
    overflow-wrap: anywhere;
    font-weight: 400;
    text-decoration-line: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.22em;
    transition: text-decoration-color 160ms ease;
  }

  .xr-card:hover .xr-card__source-label,
  .xr-card:focus-visible .xr-card__source-label {
    text-decoration-color: currentColor;
  }

  .xr-card__tags {
    display: flex;
    flex-wrap: wrap;
    align-content: flex-end;
    gap: 0.42rem;
    align-self: stretch;
    padding-top: 0.45rem;
  }

  .xr-card__tag {
    border: 1px solid var(--border-subtle);
    border-radius: 999px;
    padding: 0.3rem 0.62rem;
    color: var(--text-tertiary);
    font: 650 0.75rem/1 var(--font-ui);
  }

  .xr-empty {
    margin: 2rem 0 0;
    border: 1px solid var(--border-subtle);
    border-radius: 12px;
    padding: 2rem;
    color: var(--text-secondary);
    background: var(--bg-surface);
    font: 600 1rem/1.5 var(--font-ui);
  }

  .xr-card__image-shell {
    aspect-ratio: 4 / 3;
  }

  .xr-card__body {
    min-height: 14rem;
    padding: clamp(1.15rem, 2vw, 1.4rem);
  }

  .xr-card__title {
    font-size: clamp(1.25rem, 1.8vw, 1.55rem);
  }

  @media (max-width: 860px) {
    .xr-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .xr-card__image-shell {
      aspect-ratio: 16 / 9;
    }

    .xr-card__body {
      min-height: 13rem;
      padding: clamp(1.3rem, 2.8vw, 1.75rem);
    }

    .xr-card__title {
      font-size: clamp(1.35rem, 2.5vw, 1.85rem);
    }
  }

  @media (max-width: 760px) {
    .xr-grid {
      grid-template-columns: 1fr;
    }

    .xr-card__body {
      min-height: 12rem;
      padding: 1.25rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .xr-card,
    .xr-chip,
    .xr-reset,
    .xr-search input {
      transition: none;
    }

    .xr-card:hover {
      transform: none;
    }
  }
</style>
