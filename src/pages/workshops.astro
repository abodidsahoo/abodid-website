---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    breadcrumbJsonLd,
    externalProfiles,
    personJsonLd,
    serviceJsonLd,
} from "../lib/seoData";

const pageTitle = "Workshops, Tutoring & Mentorship";
const description =
    "Paid online workshops and tutoring with Abodid Sahoo for Obsidian, research workflows, video editing, visual storytelling, and creative technology.";
const contactHref =
    "/contact?from=%2Fworkshops&source_name=workshops&cta=workshop-inquiry";
const superprofHref = externalProfiles.superprof;
const structuredData = [
    personJsonLd(),
    breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Workshops", path: "/workshops" },
    ]),
    serviceJsonLd({
        path: "/workshops",
        name: "Workshops, Tutoring, and Mentorship",
        description,
        serviceType:
            "Obsidian tutoring, research workflow classes, video editing mentorship, and creative technology workshops",
    }),
];

const workshops = [
    {
        title: "Obsidian for Deep Research",
        description:
            "Build a connected research system for notes, readings, applications, thesis work, and long-term ideas.",
        price: "₹15,000",
        duration: "4 Sessions",
        href: "/workshops/obsidian",
        features: [
            "Atomic notes and clean vault setup",
            "Tags, backlinks, graph view, and templates",
            "Research, writing, and application workflows",
            "One month of doubt-clearing support",
        ],
        highlight: false,
    },
    {
        title: "One-to-One Obsidian Tutoring",
        description:
            "Personal classes for students, researchers, writers, and professionals who want a research system shaped around their actual work.",
        price: "Custom",
        duration: "1:1 Sessions",
        href: "/obsidian-tutoring",
        features: [
            "Vault setup and cleanup",
            "Research notes, tags, templates, and dashboards",
            "Thesis, application, essay, and writing workflows",
            "Follow-up support between sessions",
        ],
        highlight: true,
    },
    {
        title: "Adobe Premiere Pro for Storytelling",
        description:
            "A seven-week Premiere Pro masterclass for learning video editing through rhythm, sound, narrative, titles, color, delivery, and polished Adobe workflows.",
        price: "Enquire",
        duration: "7 Modules",
        href: "/premiere-pro-masterclass",
        features: [
            "Modules 1-3: clean cuts, basic sound, simple export",
            "Modules 4-7: titles, captions, color, speed, and delivery",
            "Story-first Premiere Pro workflow",
            "Practice exports and capstone project options",
        ],
        highlight: true,
    },
];
---

<BaseLayout title={pageTitle} description={description} structuredData={structuredData}>
    <div class="workshops-page">
        <header class="page-header">
            <span class="eyebrow">Education / paid classes</span>
            <h1>{pageTitle}</h1>
            <p class="subtitle">{description}</p>
            <div class="header-actions">
                <a href={contactHref} class="header-btn primary">Ask about a class</a>
                {
                    superprofHref ? (
                        <a href={superprofHref} class="header-btn secondary" target="_blank" rel="noopener noreferrer">
                            View Superprof profile
                        </a>
                    ) : (
                        <span class="header-note">Prefer booking through Superprof? Ask me for the profile link.</span>
                    )
                }
            </div>
        </header>

        <div class="workshops-grid">
            {
                workshops.map((workshop) => (
                    <div
                        class={`workshop-card ${workshop.highlight ? "highlight" : ""}`}
                    >
                        <div class="card-header">
                            <h3>{workshop.title}</h3>
                            <p class="description">{workshop.description}</p>
                        </div>

                        <div class="card-details">
                            <div class="meta-row">
                                <span class="price">{workshop.price}</span>
                                <span class="duration-badge">
                                    {workshop.duration}
                                </span>
                            </div>

                            <ul class="features-list">
                                {workshop.features.map((feature) => (
                                    <li>
                                        <span class="check">✓</span> {feature}
                                    </li>
                                ))}
                            </ul>
                        </div>

                        <div class="card-footer">
                            <a
                                href={workshop.href}
                                class="book-btn"
                            >
                                {workshop.href.startsWith("/workshops/") || workshop.href.startsWith("/obsidian") || workshop.href.startsWith("/premiere-pro-masterclass")
                                    ? "View Details"
                                    : "Book a Slot"}
                            </a>
                        </div>
                    </div>
                ))
            }
        </div>
    </div>
</BaseLayout>

<style>
    .workshops-page {
        max-width: 1000px;
        margin: 0 auto;
        padding: 4rem 1.5rem 8rem 1.5rem;
    }

    .page-header {
        text-align: center;
        margin-bottom: 5rem;
        max-width: 600px;
        margin-left: auto;
        margin-right: auto;
    }

    .eyebrow {
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.15em;
        color: var(--text-tertiary);
        font-weight: 600;
        margin-bottom: 1rem;
        display: block;
    }

    h1 {
        font-family: var(--font-display);
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 1rem;
        color: var(--text-primary);
    }

    .subtitle {
        font-size: 1.1rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .header-actions {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 1.5rem;
    }

    .header-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        border-radius: 8px;
        padding: 0.82rem 1.05rem;
        font-weight: 700;
        text-decoration: none;
    }

    .header-btn.primary {
        background: var(--text-primary);
        color: var(--bg-color);
    }

    .header-btn.secondary {
        border: 1px solid var(--border-strong);
        color: var(--text-primary);
    }

    .header-note {
        color: var(--text-tertiary);
        font-size: 0.9rem;
    }

    /* Grid Layout */
    .workshops-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 2rem;
    }

    .workshop-card {
        background: var(--bg-surface);
        border: 1px solid var(--border-subtle);
        border-radius: 16px;
        padding: 2.5rem;
        display: flex;
        flex-direction: column;
        transition:
            transform 0.3s ease,
            border-color 0.3s ease;
        height: 100%;
    }

    .workshop-card:hover {
        transform: translateY(-5px);
        border-color: var(--text-secondary);
    }

    .workshop-card.highlight {
        background: linear-gradient(
            145deg,
            rgba(255, 255, 255, 0.03),
            var(--bg-surface)
        );
        border: 1px solid rgba(255, 209, 64, 0.4); /* Gold/Yellow accent */
        position: relative;
    }

    /* .workshop-card.highlight::before {
    content: "Recommended";
    position: absolute;
    top: -12px;
    right: 2rem;
    background: #ffd140;
    color: #000;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
  } */

    .card-header {
        margin-bottom: 2rem;
    }

    .workshop-card h3 {
        font-family: var(--font-display);
        font-size: 1.5rem;
        margin-bottom: 1rem;
        color: var(--text-primary);
        line-height: 1.3;
    }

    .description {
        font-size: 0.95rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .card-details {
        flex-grow: 1;
        margin-bottom: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border-subtle);
    }

    .meta-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }

    .price {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        font-family: var(--font-ui);
    }

    .duration-badge {
        background: rgba(255, 255, 255, 0.05);
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-size: 0.8rem;
        color: var(--text-secondary);
        border: 1px solid var(--border-subtle);
    }

    .features-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .features-list li {
        font-size: 0.9rem;
        color: var(--text-secondary);
        margin-bottom: 0.8rem;
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        line-height: 1.5;
    }

    .check {
        color: #4ade80; /* Green check */
        font-weight: bold;
    }

    .book-btn {
        display: block;
        width: 100%;
        padding: 1rem;
        text-align: center;
        background: var(--text-primary);
        color: var(--bg-color);
        text-decoration: none;
        font-weight: 600;
        border-radius: 8px;
        transition: opacity 0.2s;
    }

    .book-btn:hover {
        opacity: 0.9;
    }

    .workshop-card.highlight .book-btn {
        background: #ffd140; /* Yellow button for highlight */
        color: #000;
    }
</style>
