---
import BaseLayout from "../../layouts/BaseLayout.astro";
import RouteQuickGuide from "../../components/supercutclub/RouteQuickGuide.astro";

const pageTitle = "Supercut Club";
const pageDescription =
  "An infographic-style landing page for Supercut Club, an AI-assisted network for sourcing and matching video editors across India.";

const statCards = [
  {
    value: "70+",
    label: "Founding editors",
    tone: "emerald",
  },
  {
    value: "10x",
    label: "Faster sourcing",
    tone: "blue",
  },
  {
    value: "100%",
    label: "Creative-fit focus",
    tone: "amber",
  },
];

const painPoints = [
  "Geographically restricted networks",
  "Unknown hardware and workflow readiness",
  "Mismatch between musical taste and pacing instincts",
];

const flowSteps = [
  "Client enters the brief, delivery timeline, and budget range.",
  "The project gets paired with mood boards, reference cuts, and soundtrack cues.",
  "The matching engine reads timing, taste, and technical constraints together.",
  "A shortlist of available editors appears by region, rig, and creative fit.",
];

const communityItems = [
  {
    eyebrow: "Reputation layer",
    title: "Two-way testimonials",
    description:
      "Editors review clients and clients review editors, so strong working relationships become visible over time.",
    illustration: "reputation",
  },
  {
    eyebrow: "Risk signaling",
    title: "Quiet red-flag system",
    description:
      "The platform can surface patterns around payment issues, broken briefs, or communication failures before a match is made.",
    illustration: "risk",
  },
  {
    eyebrow: "Inclusive hiring",
    title: "Signals beyond the reel",
    description:
      "Profiles can highlight identity-safe hiring preferences and working styles that matter in real production environments.",
    illustration: "inclusive",
  },
];

const futureModules = [
  {
    path: "/supercutclub/editors",
    eyebrow: "For editors",
    title: "Editor profiles",
    description:
      "Verified portfolios, workstation specs, software stack, and availability windows.",
    available: true,
    cta: "Open editor profiles",
    illustration: "editors",
  },
  {
    path: "/supercutclub/matching",
    eyebrow: "For developers",
    title: "Matching engine",
    description:
      "A developer-facing explanation of how briefs, reference media, and filters shape the shortlist.",
    available: true,
    cta: "Open matching PRD",
    illustration: "matching",
  },
  {
    path: "/supercutclub/community",
    eyebrow: "For members",
    title: "Community systems",
    description:
      "Reputation, subscriptions, moderation rules, and why the platform avoids a race-to-the-bottom marketplace.",
    available: true,
    cta: "Open community blueprint",
    illustration: "community",
  },
];

const sectionNavItems = [
  { id: "overview", label: "Overview" },
  { id: "problem", label: "Problem" },
  { id: "solution", label: "How it works" },
  { id: "vibe", label: "Creative fit" },
  { id: "community", label: "Community" },
  { id: "paths", label: "Get involved" },
];

const quickAccessItems = [
  {
    path: "/supercutclub/editors",
    eyebrow: "Editors",
    title: "Go to editor profiles",
    description: "For profile browsing and editor onboarding.",
  },
  {
    path: "/supercutclub/matching",
    eyebrow: "Developers",
    title: "Go to matching PRD",
    description: "For product logic and build planning.",
  },
  {
    path: "/supercutclub/community",
    eyebrow: "Members",
    title: "Go to community blueprint",
    description: "For referrals, trust, and feedback systems.",
  },
];

const quickGuideItems = [
  {
    path: "/supercutclub/editors",
    eyebrow: "For editors",
    title: "Editor profiles",
    description: "Browse the live profile feed.",
  },
  {
    path: "/supercutclub/matching",
    eyebrow: "For developers",
    title: "Matching engine",
    description: "Read how the search algorithm works.",
  },
  {
    path: "/supercutclub/community",
    eyebrow: "For members",
    title: "Community systems",
    description: "See the rules for invites and trust.",
  },
];

const quickGuideIntroTail = "Choose the route that matches what you need.";

const genreLegendItems = [
  {
    percentage: "20%",
    title: "Documentary",
    description:
      "Long-form editors focused on interviews, observation, and slower pacing.",
    swatchClass: "scc-swatch-docu",
    barClass: "scc-bar-docu",
  },
  {
    percentage: "25%",
    title: "Fashion and beauty",
    description:
      "Editors shaping rhythm-heavy cuts for campaigns, talent reels, and style films.",
    swatchClass: "scc-swatch-fashion",
    barClass: "scc-bar-fashion",
  },
  {
    percentage: "30%",
    title: "Commercial and ad",
    description:
      "Fast-turnaround editors for branded storytelling, launch films, and ad spots.",
    swatchClass: "scc-swatch-commercial",
    barClass: "scc-bar-commercial",
  },
  {
    percentage: "10%",
    title: "Narrative shorts",
    description:
      "Editors tuned to scene construction, emotional beats, and cinematic pacing.",
    swatchClass: "scc-swatch-narrative",
    barClass: "scc-bar-narrative",
  },
  {
    percentage: "15%",
    title: "Social media and reels",
    description:
      "Editors specialising in vertical formats, high-density hooks, and creator-led edits.",
    swatchClass: "scc-swatch-social",
    barClass: "scc-bar-social",
  },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  imageAlt="Supercut Club project overview"
  useDynamicOgImage={false}
  fullWidth={true}
  hideHeader={true}
  showGlobalGrid={false}
  showNewsletterPopup={false}
  showCursorFollower={false}
  bodyClass="supercutclub-page"
>
  <div class="scc-shell">
    <header class="scc-masthead">
      <div class="scc-masthead-inner">
        <a class="scc-wordmark" href="/">
          <span class="scc-wordmark-kicker">abodid.com</span>
          <span class="scc-wordmark-title">Supercut Club</span>
        </a>

        <div class="scc-masthead-actions">
          <nav class="scc-nav" aria-label="Supercut Club sections">
            {
              sectionNavItems.map((item) => (
                <a href={`#${item.id}`} data-section-link={item.id}>
                  {item.label}
                </a>
              ))
            }
          </nav>

          <div class="scc-role-shortcuts" aria-label="Role-based quick paths">
            {
              quickAccessItems.map((item) => (
                <a class="scc-role-shortcut" href={item.path}>
                  <span>{item.eyebrow}</span>
                  <strong>{item.title}</strong>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </header>

    <section id="overview" class="scc-hero" data-nav-section="Overview">
      <div class="scc-hero-grid">
        <div class="scc-hero-copy">
          <p class="scc-eyebrow">Client-facing overview</p>
          <h1>
            Stop searching.
            <span>Start cutting with the right editor.</span>
          </h1>
          <p class="scc-lead">
            Supercut Club is a focused matching layer for directors, producers,
            and hiring managers who need video editors with the right location,
            machine setup, budget fit, and aesthetic language, not just somebody
            who was forwarded in a WhatsApp group.
          </p>

          <div class="scc-stat-grid">
            {
              statCards.map((card) => (
                <article class={`scc-stat-card scc-stat-card-${card.tone}`}>
                  <strong>{card.value}</strong>
                  <span>{card.label}</span>
                </article>
              ))
            }
          </div>
        </div>

        <aside class="scc-hero-panel">
          <div class="scc-panel-label">What this page is doing</div>
          <h2>Version one is an infographic.</h2>
          <p>
            This route now works as the client-facing concept page for the
            project, and the folder structure leaves space for editor,
            developer, and community pages underneath <code>/supercutclub</code
            >.
          </p>

          <div class="scc-signal-list">
            <div>
              <span>Region-aware</span>
              <p>Search by city, travel needs, or on-site presence.</p>
            </div>
            <div>
              <span>Hardware-aware</span>
              <p>Filter editors by workstation strength and software stack.</p>
            </div>
            <div>
              <span>Taste-aware</span>
              <p>Use reference cuts and music to find the right rhythm.</p>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section id="problem" class="scc-section" data-nav-section="Problem">
      <div class="scc-section-copy scc-copy-panel">
        <p class="scc-eyebrow">The problem</p>
        <h2>The friction of word-of-mouth hiring</h2>
        <p>
          The current search process still depends on personal circles, last
          minute referrals, and partial information. That works until you need a
          very specific editor in a very specific place with a very specific
          sense of rhythm.
        </p>
        <p>
          Supercut Club turns a scattered recommendation hunt into a structured,
          filterable match process that can happen in minutes instead of weeks.
        </p>

        <ul class="scc-pain-list">
          {painPoints.map((point) => <li>{point}</li>)}
        </ul>
      </div>

      <article class="scc-card scc-card-chart">
        <div class="scc-card-head">
          <p class="scc-card-kicker">Speed comparison</p>
          <h3>Average time to hire</h3>
          <p>
            A verified match shortens the search because location, availability,
            technical setup, and creative fit are already part of the first
            pass.
          </p>
        </div>
        <div class="scc-chart-wrap">
          <canvas id="timeToHireChart" aria-label="Average time to hire chart"
          ></canvas>
        </div>
      </article>
    </section>

    <section
      id="solution"
      class="scc-section scc-section-stack"
      data-nav-section="How it works"
    >
      <div class="scc-section-heading scc-section-heading-center">
        <p class="scc-eyebrow">The solution</p>
        <h2>The architecture of a match</h2>
        <p>
          The platform reads technical requirements and creative references at
          the same time, so the shortlist reflects both production reality and
          aesthetic compatibility.
        </p>
      </div>

      <div class="scc-solution-grid">
        <article class="scc-card scc-flow-card">
          <div class="scc-card-head">
            <p class="scc-card-kicker">Routing flow</p>
            <h3>How the brief gets translated</h3>
            <p>
              A cleaner four-step handoff from brief to shortlist, designed to
              explain the logic without overwhelming the page.
            </p>
          </div>

          <ol class="scc-flow-list">
            {
              flowSteps.map((step, index) => (
                <li>
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <p>{step}</p>
                </li>
              ))
            }
          </ol>
        </article>

        <article class="scc-card scc-card-chart scc-card-chart-large">
          <div class="scc-card-head">
            <p class="scc-card-kicker">Calibrated editor skills profile</p>
            <h3>What the shortlist actually tells a producer</h3>
            <p>
              This view compares secondary strengths across two editor types so
              a hiring team can quickly see whether they need an all-round
              operator or a specialist whose main strength is narrative rhythm.
            </p>
          </div>
          <div class="scc-chart-wrap">
            <canvas id="skillsRadarChart" aria-label="Editor skills radar chart"
            ></canvas>
          </div>
        </article>
      </div>
    </section>

    <section
      id="vibe"
      class="scc-section scc-vibe-block"
      data-nav-section="Creative fit"
    >
      <div class="scc-vibe-copy">
        <p class="scc-eyebrow scc-eyebrow-dark">The vibe matrix</p>
        <h2>Creative taste becomes a usable signal</h2>
        <p>
          Aesthetics are subjective, but portfolios still reveal measurable
          patterns. Music tempo, cut density, energy level, and pacing style can
          help cluster editors for documentary work, fashion edits, slow-burn
          narratives, or high-energy commercial jobs.
        </p>
        <p>
          The chart below visualizes how a reference soundtrack and editorial
          rhythm could help narrow the shortlist before anybody sends another
          desperate message asking who is free this week.
        </p>
        <div class="scc-vibe-helper">
          Hover over a dot to meet a sample editor persona and see what kind of
          project they would be strongest on.
        </div>
      </div>

      <div class="scc-vibe-chart">
        <canvas id="vibeScatterChart" aria-label="Editor vibe scatter plot"
        ></canvas>
      </div>
    </section>

    <div class="scc-section-divider" aria-hidden="true">
      <span></span>
      <i>↓</i>
      <span></span>
    </div>

    <section
      id="community"
      class="scc-section scc-section-stack scc-community-graph-section"
      data-nav-section="Community"
    >
      <article class="scc-card scc-card-chart scc-card-chart-full">
        <div class="scc-card-head">
          <p class="scc-card-kicker">Community makeup</p>
          <h3>Platform talent distribution</h3>
          <p>
            An early snapshot of how the founding editor pool could be
            distributed across specialties.
          </p>
        </div>
        <div class="scc-chart-wrap scc-chart-wrap-community">
          <canvas
            id="genreDistributionChart"
            aria-label="Editor genre distribution chart"></canvas>
        </div>
        <div class="scc-community-bar-grid" aria-label="Editor genre legend">
          {
            genreLegendItems.map((item) => (
              <article class="scc-community-bar-card">
                <div class="scc-genre-heading">
                  <strong>{item.title}</strong>
                  <span>{item.percentage}</span>
                </div>
                <div class="scc-community-bar-track">
                  <div
                    class={`scc-community-bar-fill ${item.barClass}`}
                    style={`width:${item.percentage};`}
                  />
                </div>
                <p>{item.description}</p>
              </article>
            ))
          }
        </div>
      </article>
    </section>

    <div class="scc-section-divider" aria-hidden="true">
      <span></span>
      <i>↓</i>
      <span></span>
    </div>

    <section class="scc-section scc-section-stack scc-values-section">
      <div class="scc-section-copy scc-copy-panel scc-values-copy">
        <p class="scc-eyebrow">Why it matters</p>
        <h2>A community, not a commodity directory</h2>
        <p>
          Supercut Club is imagined as a high-trust network rather than an open
          bidding pit. Subscription logic, mutual feedback, and shared standards
          create a marketplace where good collaboration is part of the product.
        </p>
      </div>

      <div class="scc-community-grid">
        {
          communityItems.map((item) => (
            <article class="scc-community-card">
              <div
                class={`scc-community-illustration scc-community-illustration-${item.illustration}`}
              >
                <span />
                <span />
                <span />
              </div>
              <p class="scc-community-eyebrow">{item.eyebrow}</p>
              <h3>{item.title}</h3>
              <p>{item.description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <div class="scc-section-divider" aria-hidden="true">
      <span></span>
      <i>↓</i>
      <span></span>
    </div>

    <section
      id="paths"
      class="scc-section scc-section-stack scc-future-section"
      data-nav-section="Get involved"
    >
      <div class="scc-section-heading scc-section-heading-center">
        <p class="scc-eyebrow">Product parts</p>
        <h2>Three routes, one product.</h2>
        <p>
          This landing page tells the client story. The three routes below open
          the editor-facing interface, the developer PRD, and the community
          system without over-explaining the path structure.
        </p>
      </div>

      <div class="scc-future-grid">
        {
          futureModules.map((module) =>
            module.available ? (
              <a
                class="scc-future-card scc-future-card-link"
                href={module.path}
              >
                <div
                  class={`scc-future-illustration scc-future-illustration-${module.illustration}`}
                  aria-hidden="true"
                >
                  <span />
                  <span />
                  <span />
                </div>
                <div class="scc-future-card-headline">
                  <span class="scc-future-card-eyebrow">{module.eyebrow}</span>
                </div>
                <h3>{module.title}</h3>
                <p>{module.description}</p>
                <span class="scc-card-link-cta">{module.cta}</span>
              </a>
            ) : (
              <article class="scc-future-card">
                <div
                  class={`scc-future-illustration scc-future-illustration-${module.illustration}`}
                  aria-hidden="true"
                >
                  <span />
                  <span />
                  <span />
                </div>
                <div class="scc-future-card-headline">
                  <span class="scc-future-card-eyebrow">{module.eyebrow}</span>
                </div>
                <h3>{module.title}</h3>
                <p>{module.description}</p>
                <span class="scc-card-link-cta scc-card-link-cta-muted">
                  {module.cta}
                </span>
              </article>
            ),
          )
        }
      </div>
    </section>

    <RouteQuickGuide
      currentLabel="Overview"
      items={quickGuideItems}
      theme="light"
      panelLabel="Route picker"
      title="Pick a route."
      introLead="You are on"
      introTail={quickGuideIntroTail}
    />

    <section class="scc-cta-band">
      <div class="scc-cta-copy">
        <p class="scc-eyebrow scc-eyebrow-dark">Work with Abodid</p>
        <h2>Want to build Supercut Club for real?</h2>
        <p>
          This is a concept build. If you are a studio, platform, or founder
          who wants to take it further, reach out directly.
        </p>
      </div>

      <div class="scc-cta-actions">
        <a class="scc-cta-link scc-cta-link-solid" href="mailto:hi@abodid.com"
          >Get in touch</a
        >
      </div>
    </section>
  </div>

  <script
    src="https://cdn.jsdelivr.net/npm/chart.js@4.4.9/dist/chart.umd.min.js"
  ></script>

  <script is:inline>
    function wrapLabel(label, maxChars = 16) {
      const words = label.split(" ");
      const lines = [];
      let currentLine = "";

      words.forEach((word) => {
        if ((currentLine + word).length > maxChars) {
          if (currentLine) {
            lines.push(currentLine.trim());
          }
          currentLine = `${word} `;
          return;
        }

        currentLine += `${word} `;
      });

      if (currentLine) {
        lines.push(currentLine.trim());
      }

      return lines;
    }

    function createCharts() {
      if (!window.Chart) {
        return;
      }

      const Chart = window.Chart;
      Chart.defaults.font.family =
        "'Satoshi-Variable', 'Satoshi-Regular', 'Poppins', sans-serif";
      Chart.defaults.color = "#4b433b";

      const commonOptions = {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            labels: {
              color: "#5e5b57",
              boxWidth: 14,
              boxHeight: 14,
              usePointStyle: true,
            },
          },
        },
      };

      const timeCanvas = document.getElementById("timeToHireChart");
      if (timeCanvas) {
        new Chart(timeCanvas, {
          type: "bar",
          data: {
            labels: [
              wrapLabel("Traditional networking"),
              wrapLabel("Cold emailing"),
              wrapLabel("Supercut Club AI"),
            ],
            datasets: [
              {
                label: "Average search and hire time (days)",
                data: [14, 21, 2],
                backgroundColor: ["#d3cbc0", "#b9c9d6", "#ee5a36"],
                borderRadius: 14,
                maxBarThickness: 72,
              },
            ],
          },
          options: {
            ...commonOptions,
            plugins: {
              ...commonOptions.plugins,
              legend: { display: false },
            },
            scales: {
              y: {
                beginAtZero: true,
                grid: {
                  color: "rgba(22, 22, 22, 0.08)",
                },
                ticks: {
                  color: "#5e5b57",
                },
              },
              x: {
                grid: {
                  display: false,
                },
                ticks: {
                  color: "#5e5b57",
                },
              },
            },
          },
        });
      }

      const radarCanvas = document.getElementById("skillsRadarChart");
      if (radarCanvas) {
        new Chart(radarCanvas, {
          type: "radar",
          data: {
            labels: [
              wrapLabel("Motion graphics"),
              wrapLabel("Color grading"),
              wrapLabel("Sound design"),
              wrapLabel("Narrative pacing"),
              wrapLabel("Montage speed"),
              wrapLabel("VFX cleanups"),
            ],
            datasets: [
              {
                label: "One-man-army editor",
                data: [8, 7, 8, 6, 7, 5],
                backgroundColor: "rgba(37, 99, 235, 0.16)",
                borderColor: "#2563eb",
                pointBackgroundColor: "#2563eb",
                pointBorderColor: "#fffaf4",
                borderWidth: 2,
              },
              {
                label: "Pure cinematic cutter",
                data: [2, 4, 3, 10, 4, 1],
                backgroundColor: "rgba(15, 118, 110, 0.16)",
                borderColor: "#0f766e",
                pointBackgroundColor: "#0f766e",
                pointBorderColor: "#fffaf4",
                borderWidth: 2,
              },
            ],
          },
          options: {
            ...commonOptions,
            scales: {
              r: {
                min: 0,
                max: 10,
                ticks: {
                  display: false,
                },
                angleLines: {
                  color: "rgba(22, 22, 22, 0.09)",
                },
                grid: {
                  color: "rgba(22, 22, 22, 0.09)",
                },
                pointLabels: {
                  color: "#5e5b57",
                  font: {
                    size: 11,
                  },
                },
              },
            },
          },
        });
      }

      const vibeCanvas = document.getElementById("vibeScatterChart");
      if (vibeCanvas) {
        new Chart(vibeCanvas, {
          type: "scatter",
          data: {
            datasets: [
              {
                label: "Editor portfolios",
                data: [
                  {
                    x: 60,
                    y: 20,
                    name: "Aarav Mehta",
                    city: "Mumbai",
                    role: "Documentary editor",
                    summary:
                      "Uses patient pacing, ambient sound beds, and long emotional holds.",
                    bestFor:
                      "Best for social documentaries, interviews, and NGO films.",
                  },
                  {
                    x: 75,
                    y: 30,
                    name: "Ishita Nair",
                    city: "Kochi",
                    role: "Human-story editor",
                    summary:
                      "Balances warmth and clarity with steady rhythm and softer transitions.",
                    bestFor:
                      "Best for portraits, cultural stories, and education films.",
                  },
                  {
                    x: 85,
                    y: 45,
                    name: "Rohan Kulkarni",
                    city: "Pune",
                    role: "Narrative short editor",
                    summary:
                      "Keeps scenes breathing while still sharpening emotional turning points.",
                    bestFor:
                      "Best for indie shorts, dramatic scenes, and performance-led films.",
                  },
                  {
                    x: 95,
                    y: 50,
                    name: "Sneha Verma",
                    city: "Delhi",
                    role: "Story-first editor",
                    summary:
                      "Works with mid-tempo music and clean continuity-focused cuts.",
                    bestFor:
                      "Best for branded mini-films and scripted digital stories.",
                  },
                  {
                    x: 120,
                    y: 80,
                    name: "Tara Singh",
                    city: "Chandigarh",
                    role: "Fashion editor",
                    summary:
                      "Builds energy through music-led edits, beauty inserts, and stylised motion.",
                    bestFor:
                      "Best for fashion campaigns, lookbooks, and launch teasers.",
                  },
                  {
                    x: 125,
                    y: 85,
                    name: "Kabir Rao",
                    city: "Bengaluru",
                    role: "Commercial rhythm editor",
                    summary:
                      "Cuts fast with product emphasis, sync-heavy beats, and polished transitions.",
                    bestFor:
                      "Best for startup ads, product films, and performance marketing.",
                  },
                  {
                    x: 140,
                    y: 90,
                    name: "Ananya Ghosh",
                    city: "Kolkata",
                    role: "High-energy commercial editor",
                    summary:
                      "Pushes pace with dense cuts, sound hits, and energetic visual punctuation.",
                    bestFor:
                      "Best for youth campaigns, trailers, and music-driven ads.",
                  },
                  {
                    x: 150,
                    y: 95,
                    name: "Dev Malhotra",
                    city: "Jaipur",
                    role: "Reels and promo editor",
                    summary:
                      "Optimised for sharp hooks, punchy captions, and high-retention short edits.",
                    bestFor:
                      "Best for creator campaigns, reels, and launch bursts.",
                  },
                ],
                backgroundColor: "#e9b949",
                borderColor: "#101522",
                borderWidth: 2,
                pointRadius: 7,
                pointHoverRadius: 10,
              },
            ],
          },
          options: {
            ...commonOptions,
            plugins: {
              ...commonOptions.plugins,
              legend: {
                labels: {
                  color: "#d9d5ce",
                  usePointStyle: true,
                },
              },
              tooltip: {
                callbacks: {
                  title: function (tooltipItems) {
                    const item = tooltipItems[0];
                    return `${item.raw.name} / ${item.raw.city}`;
                  },
                  label: function (context) {
                    return [
                      `${context.raw.role}`,
                      `${context.raw.summary}`,
                      `${context.raw.bestFor}`,
                      `Signal: ${context.raw.x} BPM / pace score ${context.raw.y}`,
                    ];
                  },
                },
              },
            },
            scales: {
              x: {
                title: {
                  display: true,
                  text: "Average audio BPM",
                  color: "#d9d5ce",
                },
                grid: {
                  color: "rgba(255, 250, 244, 0.12)",
                },
                ticks: {
                  color: "#d9d5ce",
                },
              },
              y: {
                title: {
                  display: true,
                  text: "Cut density / pacing score",
                  color: "#d9d5ce",
                },
                grid: {
                  color: "rgba(255, 250, 244, 0.12)",
                },
                ticks: {
                  color: "#d9d5ce",
                },
              },
            },
          },
        });
      }

      const communityCanvas = document.getElementById("genreDistributionChart");
      if (communityCanvas) {
        new Chart(communityCanvas, {
          type: "bar",
          data: {
            labels: [
              wrapLabel("Documentary"),
              wrapLabel("Fashion and beauty"),
              wrapLabel("Commercial and ad"),
              wrapLabel("Narrative shorts"),
              wrapLabel("Social media and reels"),
            ],
            datasets: [
              {
                data: [20, 25, 30, 10, 15],
                backgroundColor: [
                  "#2563eb",
                  "#0f766e",
                  "#ee5a36",
                  "#e9b949",
                  "#334155",
                ],
                borderRadius: 16,
                maxBarThickness: 40,
              },
            ],
          },
          options: {
            ...commonOptions,
            indexAxis: "y",
            plugins: {
              ...commonOptions.plugins,
              legend: {
                display: false,
              },
            },
            scales: {
              x: {
                beginAtZero: true,
                max: 35,
                grid: {
                  color: "rgba(22, 22, 22, 0.08)",
                },
                ticks: {
                  callback: function (value) {
                    return `${value}%`;
                  },
                },
              },
              y: {
                grid: {
                  display: false,
                },
                ticks: {
                  color: "#2f2a25",
                },
              },
            },
          },
        });
      }
    }

    function setupSectionGuide() {
      const trackedSections = Array.from(
        document.querySelectorAll("[data-nav-section]"),
      );
      const navLinks = Array.from(
        document.querySelectorAll("[data-section-link]"),
      );
      const currentSectionNodes = Array.from(
        document.querySelectorAll("[data-guide-current]"),
      );

      if (!trackedSections.length) {
        return;
      }

      const setActiveSection = (section) => {
        const activeId = section.id;
        const activeLabel = section.dataset.navSection || "Overview";

        navLinks.forEach((link) => {
          link.classList.toggle(
            "is-active",
            link.dataset.sectionLink === activeId,
          );
        });

        currentSectionNodes.forEach((node) => {
          node.textContent = activeLabel;
        });
      };

      const updateGuideVisibility = () => {
        const showGuide =
          window.scrollY > Math.max(window.innerHeight * 0.35, 220);
        quickGuide.classList.toggle("is-visible", showGuide);
      };

      const setCollapsed = (collapsed) => {
        quickGuide.classList.toggle("is-collapsed", collapsed);
        toggleButton.setAttribute("aria-expanded", String(!collapsed));
      };

      const observer = new IntersectionObserver(
        (entries) => {
          const activeEntry = entries
            .filter((entry) => entry.isIntersecting)
            .sort((a, b) => {
              if (b.intersectionRatio !== a.intersectionRatio) {
                return b.intersectionRatio - a.intersectionRatio;
              }

              return a.boundingClientRect.top - b.boundingClientRect.top;
            })[0];

          if (activeEntry) {
            setActiveSection(activeEntry.target);
          }
        },
        {
          rootMargin: "-30% 0px -52% 0px",
          threshold: [0.2, 0.45, 0.7],
        },
      );

      trackedSections.forEach((section) => observer.observe(section));

      setActiveSection(trackedSections[0]);
    }

    function initPage() {
      createCharts();
      setupSectionGuide();
    }

    if (document.readyState === "complete") {
      initPage();
    } else {
      window.addEventListener("load", initPage, { once: true });
    }
  </script>
</BaseLayout>

