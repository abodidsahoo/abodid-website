---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Moon, Sun, Download } from "lucide-react";
import uk2026 from "../data/uk2026.json";

const heroTitleLines = uk2026.title.split(", ");
const essayDate = "20th May 2026";
const allParagraphs = uk2026.chapters.flatMap((chapter) => chapter.paragraphs);
const wordCount = allParagraphs.reduce((s, p) => s + p.trim().split(/\s+/).length, 0);
const readingMins = Math.ceil(wordCount / 220);

const getLinkedSegments = (paragraph) => {
  const matches = [];
  const urlPattern = /https?:\/\/[^\s)]+/g;
  let urlMatch;

  while ((urlMatch = urlPattern.exec(paragraph)) !== null) {
    let text = urlMatch[0];
    let end = urlMatch.index + text.length;
    const trailing = text.match(/[.,;:!?]+$/);

    if (trailing) {
      text = text.slice(0, -trailing[0].length);
      end -= trailing[0].length;
    }

    matches.push({
      start: urlMatch.index,
      end,
      href: text,
      text,
    });
  }

  const sortedMatches = matches
    .sort((a, b) => a.start - b.start || b.end - a.end)
    .filter((match, index, all) => {
      const previous = all[index - 1];
      return !previous || match.start >= previous.end;
    });

  const segments = [];
  let cursor = 0;

  sortedMatches.forEach((match) => {
    if (match.start > cursor) {
      segments.push({ type: "text", text: paragraph.slice(cursor, match.start) });
    }

    segments.push({
      type: "link",
      text: match.text,
      href: match.href,
    });
    cursor = match.end;
  });

  if (cursor < paragraph.length) {
    segments.push({ type: "text", text: paragraph.slice(cursor) });
  }

  return segments.length ? segments : [{ type: "text", text: paragraph }];
};
const pullQuotes = new Map(
  uk2026.pullQuotes.map((quote) => [
    quote.afterParagraph,
    quote.text || allParagraphs[quote.paragraph - 1],
  ]),
);

let paragraphIndex = 0;
---

<BaseLayout
  title={uk2026.title}
  description="A long-form personal essay from UK 2026."
  type="article"
  fullWidth={true}
  hideHeader={false}
  hideSideMenuRail={false}
  hideFooter={false}
  hideThemeToggle={false}
  showNewsletterPopup={false}
  showGlobalGrid={true}
  bodyClass="uk2026-page"
>
  <article class="memoir-shell">
    <aside class="toc-panel" aria-label="Table of contents">
      <p class="toc-kicker">Contents</p>
      <nav class="toc-list">
        {
          uk2026.chapters.map((chapter) => (
            <a href={`#${chapter.id}`} data-chapter-link={chapter.id}>
              <span>{chapter.number}</span>
              {chapter.title}
            </a>
          ))
        }
      </nav>
    </aside>

    <div class="anim-panels" id="anim-panels" data-word-count={wordCount} aria-hidden="true">
      <div class="anim-book-icon">
        <svg id="book-svg" viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <!-- clip mask that always matches the live flip polygon -->
            <clipPath id="page-text-clip">
              <polygon id="clip-polygon" points="42,8 76,8 76,54 42,54"/>
            </clipPath>
          </defs>
          <rect x="4" y="8" width="34" height="46" fill="currentColor" fill-opacity="0.04" stroke="currentColor" stroke-width="1.5"/>
          <rect x="42" y="8" width="34" height="46" fill="currentColor" fill-opacity="0.03" stroke="currentColor" stroke-width="1.5"/>
          <line x1="38" y1="8" x2="42" y2="8" stroke="currentColor" stroke-width="1.5"/>
          <line x1="38" y1="54" x2="42" y2="54" stroke="currentColor" stroke-width="1.5"/>
          <line x1="5" y1="55" x2="75" y2="55" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
          <rect x="3" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <rect x="37" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <rect x="41" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <rect x="75" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <!-- left page text lines -->
          <line x1="8" y1="18" x2="34" y2="18" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="24" x2="28" y2="24" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="30" x2="34" y2="30" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="36" x2="26" y2="36" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="42" x2="34" y2="42" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <!-- right base page text lines (visible when flip page has swept away) -->
          <line x1="46" y1="16" x2="72" y2="16" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="22" x2="68" y2="22" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="28" x2="72" y2="28" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="34" x2="66" y2="34" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="40" x2="72" y2="40" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="46" x2="70" y2="46" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <!-- dynamic flipping page: polygon + fold-apex pixel dot -->
          <polygon id="flip-polygon" points="42,8 76,8 76,54 42,54" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="1.5"/>
          <!-- flipping page: just 2 lines clipped to live polygon shape -->
          <g clip-path="url(#page-text-clip)">
            <line x1="46" y1="22" x2="72" y2="22" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
            <line x1="46" y1="36" x2="68" y2="36" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          </g>
          <rect id="flip-dot" x="75" y="7" width="2" height="2" fill="currentColor" opacity="0.7"/>
        </svg>
      </div>
      <div class="anim-pct-block">
        <div class="anim-pct-number"><span id="read-pct">0</span><span class="anim-pct-sign">%</span></div>
        <p class="anim-pct-label">read</p>
      </div>
    </div>

    <div class="memoir-main">
      <header class="memoir-hero">
        <p class="hero-kicker">UK 2026</p>
        <h1 aria-label={uk2026.title}>
          {heroTitleLines.map((line) => (
            <span>{line}</span>
          ))}
        </h1>
        <p class="hero-byline">
          Written by <a href="/about/">{uk2026.author}</a>.
        </p>
        <p class="hero-date">{essayDate}</p>
        <div class="hero-pdf-download">
          <span>Want to read later?</span>
          <a href="https://jwipqbjxpmgyevfzpjjx.supabase.co/storage/v1/object/public/misc/written%20docs/Till%20we%20meet%20again,%20my%20beloved%20ramen%20-%20UK%202026.pdf" target="_blank" rel="noopener noreferrer">
            <Download size={13} strokeWidth={2.5} aria-hidden="true" />
            Download PDF
          </a>
        </div>
      </header>

      <nav class="mobile-toc" aria-label="Table of contents">
        {
          uk2026.chapters.map((chapter) => (
            <a href={`#${chapter.id}`} data-chapter-link={chapter.id}>
              <span>{chapter.number}</span>
              {chapter.title}
            </a>
          ))
        }
      </nav>

      <div class="chapter-stack">
        {
          uk2026.chapters.map((chapter) => (
            <section id={chapter.id} class="chapter-section">
              <header class="chapter-header">
                <p>{chapter.number}</p>
                <h2>{chapter.title}</h2>
              </header>

              <div class="prose-flow">
                {chapter.paragraphs.map((paragraph) => {
                  paragraphIndex += 1;
                  const quote = pullQuotes.get(paragraphIndex);
                  const segments = getLinkedSegments(paragraph);

                  return (
                    <>
                      <p>
                        {segments.map((segment) =>
                          segment.type === "link" ? (
                            <a class="text-link" href={segment.href} target="_blank" rel="noopener noreferrer">{segment.text}</a>
                          ) : (
                            segment.text
                          ),
                        )}
                      </p>
                      {quote && <blockquote>{quote}</blockquote>}
                    </>
                  );
                })}
              </div>
            </section>
          ))
        }
      </div>
    </div>
    <div class="reader-toggle reader-toggle--floating" aria-label="Reader mode">
      <button type="button" data-reader-theme-button="light">
        <Sun size={14} strokeWidth={2} aria-hidden="true" />
        <span>Light</span>
      </button>
      <button type="button" data-reader-theme-button="dark">
        <Moon size={14} strokeWidth={2} aria-hidden="true" />
        <span>Dark</span>
      </button>
    </div>
  </article>
</BaseLayout>

<script>
  const chapterSections = Array.from(
    document.querySelectorAll(".chapter-section"),
  );
  const chapterLinks = Array.from(
    document.querySelectorAll("[data-chapter-link]"),
  );
  const tocContainers = Array.from(
    document.querySelectorAll(".toc-list, .mobile-toc"),
  );
  const readerButtons = Array.from(
    document.querySelectorAll("[data-reader-theme-button]"),
  );
  const readerStorageKey = "uk2026-reader-theme";
  const chapterClickLockMs = 2400;
  let lockedChapterId = null;
  let scrollUnlockTimer;
  let scrollUnlockMaxTimer;

  const setReaderTheme = (theme) => {
    const nextTheme = theme === "dark" || theme === "night" ? "dark" : "light";
    document.documentElement.dataset.uk2026Reader = nextTheme;
    document.documentElement.style.colorScheme =
      nextTheme === "dark" ? "dark" : "light";
    readerButtons.forEach((button) => {
      const isActive = button.dataset.readerThemeButton === nextTheme;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });
    try {
      localStorage.setItem(readerStorageKey, nextTheme);
    } catch (_error) {
      // no-op
    }
  };

  let savedReaderTheme = "light";
  try {
    savedReaderTheme = localStorage.getItem(readerStorageKey) || "light";
  } catch (_error) {
    savedReaderTheme = "light";
  }
  setReaderTheme(savedReaderTheme);

  readerButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setReaderTheme(button.dataset.readerThemeButton);
    });
  });

  const updateTocHighlights = () => {
    tocContainers.forEach((container) => {
      const activeLink = container.querySelector("a.is-active");

      if (!activeLink) {
        container.style.setProperty("--highlight-opacity", "0");
        return;
      }

      container.style.setProperty("--highlight-opacity", "1");
      container.style.setProperty("--highlight-x", `${activeLink.offsetLeft}px`);
      container.style.setProperty("--highlight-y", `${activeLink.offsetTop}px`);
      container.style.setProperty(
        "--highlight-width",
        `${activeLink.offsetWidth}px`,
      );
      container.style.setProperty(
        "--highlight-height",
        `${activeLink.offsetHeight}px`,
      );
    });
  };

  const setActiveChapter = (id) => {
    if (!id) return;
    chapterLinks.forEach((link) => {
      const isActive = link.dataset.chapterLink === id;
      link.classList.toggle("is-active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "true");
      } else {
        link.removeAttribute("aria-current");
      }
    });
    window.requestAnimationFrame(updateTocHighlights);
  };

  const getCurrentChapterId = () => {
    const marker = window.innerHeight * 0.36;
    let current = chapterSections[0]?.id;

    chapterSections.forEach((section) => {
      if (section.getBoundingClientRect().top <= marker) {
        current = section.id;
      }
    });

    return current;
  };

  let activeTicking = false;
  const updateActiveChapter = () => {
    activeTicking = false;
    if (lockedChapterId) {
      return;
    }
    const id = getCurrentChapterId();
    if (id) setActiveChapter(id);
  };

  const requestActiveUpdate = () => {
    if (activeTicking) return;
    activeTicking = true;
    window.requestAnimationFrame(updateActiveChapter);
  };

  const releaseChapterLock = () => {
    lockedChapterId = null;
    window.clearTimeout(scrollUnlockTimer);
    window.clearTimeout(scrollUnlockMaxTimer);
    requestActiveUpdate();
  };

  const lockChapterDuringScroll = (id) => {
    lockedChapterId = id;
    window.clearTimeout(scrollUnlockTimer);
    window.clearTimeout(scrollUnlockMaxTimer);
    scrollUnlockMaxTimer = window.setTimeout(
      releaseChapterLock,
      chapterClickLockMs,
    );
  };

  chapterLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      const chapterId = link.dataset.chapterLink;
      const section = document.getElementById(chapterId);
      if (!section) return;

      event.preventDefault();
      lockChapterDuringScroll(chapterId);
      setActiveChapter(chapterId);
      history.pushState(null, "", `#${chapterId}`);
      section.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  window.addEventListener(
    "scroll",
    () => {
      if (lockedChapterId) {
        window.clearTimeout(scrollUnlockTimer);
        scrollUnlockTimer = window.setTimeout(releaseChapterLock, 180);
        return;
      }
      requestActiveUpdate();
    },
    { passive: true },
  );
  window.addEventListener("resize", () => {
    requestActiveUpdate();
    window.requestAnimationFrame(updateTocHighlights);
  });
  window.addEventListener("load", updateTocHighlights);
  window.addEventListener("hashchange", requestActiveUpdate);

  const hashId = window.location.hash.replace("#", "");
  if (hashId) {
    setActiveChapter(hashId);
    requestActiveUpdate();
  } else if (chapterSections[0]) {
    setActiveChapter(chapterSections[0].id);
  }

  // ── Smooth book flip & reading progress ────────────────────────
  const flipPolygonEl = document.getElementById('flip-polygon');
  const clipPolygonEl = document.getElementById('clip-polygon');
  const flipDotEl     = document.getElementById('flip-dot');
  const readPctEl     = document.getElementById('read-pct');
  const memoirMainEl  = document.querySelector('.memoir-main');
  const animPanelEl   = document.getElementById('anim-panels');

  // One page flip per ~300 words — feels like every few lines of reading
  const wc = parseInt(animPanelEl?.dataset.wordCount || '6000', 10);
  const flipsTotal = Math.max(8, Math.ceil(wc / 300));

  const getReadProgress = () => {
    if (!memoirMainEl) return 0;
    const top = memoirMainEl.offsetTop;
    const h   = memoirMainEl.offsetHeight;
    const vy  = window.scrollY;
    const vh  = window.innerHeight;
    const end = top + h - vh;
    if (end <= 0) return 1;
    return Math.max(0, Math.min(1, (vy - top + vh * 0.1) / (end - top + vh * 0.1)));
  };

  const updateAnimations = () => {
    const progress = getReadProgress();

    // Big % counter
    if (readPctEl) readPctEl.textContent = Math.round(progress * 100);

    // Smooth continuous page flip — cycles flipsTotal times across the full article
    if (flipPolygonEl && flipDotEl) {
      const cycle = (progress * flipsTotal) % 1; // 0→1 repeating

      // foldX: free edge sweeps 76→4 (right to left)
      const foldX = 76 - cycle * 72;
      // arch: page rises above book top as it crosses the spine (peaks at cycle=0.5)
      const arch  = Math.sin(cycle * Math.PI) * 11;
      // tilt: bottom of page lags behind top (perspective lean)
      const tilt  = Math.sin(cycle * Math.PI) * 3;

      const topFX = Math.max(4, Math.min(76, foldX));
      const botFX = Math.max(4, Math.min(76, foldX + tilt));
      const topFY = 8 - arch;

      // Polygon: spine anchor (42,8)/(42,54) + fold edge top/bottom
      const pts = cycle < 0.5
        ? `42,8 ${topFX.toFixed(1)},${topFY.toFixed(1)} ${botFX.toFixed(1)},54 42,54`
        : `${topFX.toFixed(1)},${topFY.toFixed(1)} 42,8 42,54 ${botFX.toFixed(1)},54`;

      flipPolygonEl.setAttribute('points', pts);
      if (clipPolygonEl) clipPolygonEl.setAttribute('points', pts);
      // Pixel dot tracks the fold apex
      flipDotEl.setAttribute('x', (topFX - 1).toFixed(1));
      flipDotEl.setAttribute('y', (topFY - 1).toFixed(1));
    }
  };

  window.addEventListener('scroll', updateAnimations, { passive: true });
  window.addEventListener('resize', updateAnimations);
  updateAnimations();
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body.uk2026-page) {
    background: #f8faf7 !important;
    color: #282b27;
  }

  .memoir-shell {
    --toc-width: clamp(280px, 24vw, 360px);
    --page-bg: #f8faf7;
    --paper: #fffefb;
    --panel-bg: rgba(248, 250, 247, 0.92);
    --mobile-panel-bg: rgba(248, 250, 247, 0.94);
    --brand-red: var(--color-brand-red, #a30021);
    --ink: #282b27;
    --muted: #667067;
    --line: #dfe6dc;
    --sage: #536b58;
    --clay: #9d5d4d;
    --quote-ink: #713342;
    --grid-line: rgba(83, 107, 88, 0.07);
    --accent: var(--brand-red);
    --accent-strong: var(--brand-red);
    --active-bg: #e9dfcf;
    --active-border: #d7c7b2;
    --active-ink: #302a21;
    --active-number: #6b5a43;
    --active-shadow: rgba(147, 124, 91, 0.18);
    --hover-bg: rgba(255, 254, 251, 0.86);
    min-height: 100vh;
    background:
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
      var(--page-bg);
    background-size: clamp(28px, 4vw, 54px) 100%;
  }

  :global(html[data-uk2026-reader="dark"] body.uk2026-page) {
    background: #040404 !important;
    color: #f8fafc;
  }

  :global(html[data-uk2026-reader="dark"]) .memoir-shell {
    --page-bg: #040404;
    --paper: #0a0a0a;
    --panel-bg: rgba(5, 5, 5, 0.92);
    --mobile-panel-bg: rgba(5, 5, 5, 0.94);
    --brand-red: var(--color-brand-red, #a30021);
    --ink: #f8fafc;
    --muted: #9ba9bb;
    --line: #2a2a2a;
    --sage: #9ba9bb;
    --clay: #d3dce8;
    --quote-ink: #d3dce8;
    --grid-line: rgba(255, 255, 255, 0.035);
    --accent: #c9183a;
    --accent-strong: #ff6a83;
    --active-bg: #151515;
    --active-border: #3f3f3f;
    --active-ink: #f8fafc;
    --active-number: #d3dce8;
    --active-shadow: rgba(0, 0, 0, 0.32);
    --hover-bg: rgba(21, 21, 21, 0.92);
  }

  .toc-panel {
    position: fixed;
    top: calc(var(--app-header-offset, 88px) + 2.5rem);
    left: 2.5rem;
    z-index: 20;
    width: calc(var(--toc-width) - 2rem);
    max-height: calc(100vh - var(--app-header-offset, 88px) - 10rem);
    padding: 1.5rem 1.35rem;
    border: 1px solid var(--line);
    background: var(--panel-bg);
    backdrop-filter: blur(18px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(83, 107, 88, 0.28) transparent;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.02);
  }

  .toc-kicker {
    margin: 0 0 0.5rem;
    padding-left: 0.75rem;
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clay);
  }

  .hero-kicker,
  .chapter-header p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clay);
  }

  .toc-list,
  .mobile-toc {
    --highlight-x: 0px;
    --highlight-y: 0px;
    --highlight-width: 0px;
    --highlight-height: 0px;
    --highlight-opacity: 0;
    position: relative;
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
  }

  .toc-list::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    width: var(--highlight-width);
    height: var(--highlight-height);
    border: 1px solid var(--active-border);
    border-radius: 0px;
    background: var(--active-bg);
    box-shadow: 0 4px 14px var(--active-shadow);
    opacity: var(--highlight-opacity);
    pointer-events: none;
    transform: translate3d(var(--highlight-x), var(--highlight-y), 0);
    transition:
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
      width 560ms cubic-bezier(0.22, 1, 0.36, 1),
      height 560ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .mobile-toc::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    width: var(--highlight-width);
    height: var(--highlight-height);
    border: 1px solid var(--active-border);
    border-radius: 8px;
    background: var(--active-bg);
    box-shadow: 0 10px 24px var(--active-shadow);
    opacity: var(--highlight-opacity);
    pointer-events: none;
    transform: translate3d(var(--highlight-x), var(--highlight-y), 0);
    transition:
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
      width 560ms cubic-bezier(0.22, 1, 0.36, 1),
      height 560ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .reader-toggle {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.28rem;
    padding: 0.28rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--paper);
  }

  .reader-toggle--floating {
    position: fixed;
    right: clamp(1rem, 2vw, 1.5rem);
    bottom: clamp(1rem, 2vw, 1.5rem);
    z-index: 40;
    width: min(210px, calc(100vw - 2rem));
    background: var(--panel-bg);
    box-shadow: 0 14px 34px rgba(40, 43, 39, 0.12);
    backdrop-filter: blur(18px);
    opacity: 0.78;
    transition:
      opacity 160ms ease,
      box-shadow 160ms ease;
  }

  .reader-toggle--floating:hover,
  .reader-toggle--floating:focus-within {
    opacity: 1;
    box-shadow: 0 18px 42px rgba(40, 43, 39, 0.16);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle--floating {
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.45);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle--floating:hover,
  :global(html[data-uk2026-reader="dark"]) .reader-toggle--floating:focus-within {
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.58);
  }

