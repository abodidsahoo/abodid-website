---
import BaseLayout from "../layouts/BaseLayout.astro";
import { BookOpen, Download } from "lucide-react";
import uk2026 from "../data/uk2026.json";

const heroTitleLines = uk2026.title.split(", ");
const allParagraphs = uk2026.chapters.flatMap((chapter) => chapter.paragraphs);
const wordCount = allParagraphs.reduce((s, p) => s + p.trim().split(/\s+/).length, 0);
const readingMins = Math.ceil(wordCount / 220);
const pdfDownloadUrl = "https://jwipqbjxpmgyevfzpjjx.supabase.co/storage/v1/object/public/misc/written%20docs/Till%20we%20meet%20again,%20my%20beloved%20ramen%20-%20UK%202026.pdf";

const getLinkedSegments = (paragraph) => {
  const matches = [];
  const urlPattern = /https?:\/\/[^\s)]+/g;
  let urlMatch;

  while ((urlMatch = urlPattern.exec(paragraph)) !== null) {
    let text = urlMatch[0];
    let end = urlMatch.index + text.length;
    const trailing = text.match(/[.,;:!?]+$/);

    if (trailing) {
      text = text.slice(0, -trailing[0].length);
      end -= trailing[0].length;
    }

    matches.push({
      start: urlMatch.index,
      end,
      href: text,
      text,
    });
  }

  const sortedMatches = matches
    .sort((a, b) => a.start - b.start || b.end - a.end)
    .filter((match, index, all) => {
      const previous = all[index - 1];
      return !previous || match.start >= previous.end;
    });

  const segments = [];
  let cursor = 0;

  sortedMatches.forEach((match) => {
    if (match.start > cursor) {
      segments.push({ type: "text", text: paragraph.slice(cursor, match.start) });
    }

    segments.push({
      type: "link",
      text: match.text,
      href: match.href,
    });
    cursor = match.end;
  });

  if (cursor < paragraph.length) {
    segments.push({ type: "text", text: paragraph.slice(cursor) });
  }

  return segments.length ? segments : [{ type: "text", text: paragraph }];
};
const pullQuotes = new Map(
  uk2026.pullQuotes.map((quote) => [
    quote.afterParagraph,
    quote.text || allParagraphs[quote.paragraph - 1],
  ]),
);

let paragraphIndex = 0;
---

<BaseLayout
  title={uk2026.title}
  description="A brief memoir of my UK academic journey, from Cambridge’s Cultural Heritage Data School 2026 to my first international conference with the British Sociological Association."
  image="/images/og/uk2026.jpg"
  imageAlt="Abodid Sahoo presenting an illustrated textile during Cambridge Data School 2026."
  type="article"
  useDynamicOgImage={false}
  fullWidth={true}
  hideHeader={false}
  hideSideMenuRail={false}
  hideFooter={false}
  hideThemeToggle={false}
  showNewsletterPopup={false}
  showGlobalGrid={true}
  bodyClass="uk2026-page"
>
  <article class="memoir-shell">
    <aside class="toc-panel" aria-label="Table of contents">
      <p class="toc-kicker">Contents</p>
      <nav class="toc-list">
        {
          uk2026.chapters.map((chapter) => (
            <a href={`#${chapter.id}`} data-chapter-link={chapter.id}>
              <span>{chapter.number}</span>
              {chapter.title}
            </a>
          ))
        }
      </nav>
    </aside>

    <div class="reading-nudges" data-reading-nudges aria-live="polite" aria-hidden="true">
      <div class="reading-nudge-card reading-nudge-card--bookmark" data-reading-nudge-card="bookmark" aria-hidden="true">
        <p>Bookmark the page to read later.</p>
      </div>
      <div class="reading-nudge-card reading-nudge-card--download" data-reading-nudge-card="download" aria-hidden="true">
        <p>Want to read it later?</p>
        <a class="reading-nudge-button" href={pdfDownloadUrl} target="_blank" rel="noopener noreferrer" download>
          <Download size={13} strokeWidth={2.4} aria-hidden="true" />
          Download PDF
        </a>
      </div>
    </div>

    <div class="anim-panels" id="anim-panels" data-word-count={wordCount} aria-hidden="true">
      <div class="anim-book-icon">
        <svg id="book-svg" viewBox="0 0 80 60" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <!-- clip mask that always matches the live flip polygon -->
            <clipPath id="page-text-clip">
              <polygon id="clip-polygon" points="42,8 76,8 76,54 42,54"/>
            </clipPath>
          </defs>
          <rect x="4" y="8" width="34" height="46" fill="currentColor" fill-opacity="0.04" stroke="currentColor" stroke-width="1.5"/>
          <rect x="42" y="8" width="34" height="46" fill="currentColor" fill-opacity="0.03" stroke="currentColor" stroke-width="1.5"/>
          <line x1="38" y1="8" x2="42" y2="8" stroke="currentColor" stroke-width="1.5"/>
          <line x1="38" y1="54" x2="42" y2="54" stroke="currentColor" stroke-width="1.5"/>
          <line x1="5" y1="55" x2="75" y2="55" stroke="currentColor" stroke-width="1" stroke-opacity="0.3"/>
          <rect x="3" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <rect x="37" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <rect x="41" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <rect x="75" y="7" width="2" height="2" fill="currentColor" opacity="0.55"/>
          <!-- left page text lines -->
          <line x1="8" y1="18" x2="34" y2="18" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="24" x2="28" y2="24" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="30" x2="34" y2="30" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="36" x2="26" y2="36" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="8" y1="42" x2="34" y2="42" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <!-- right base page text lines (visible when flip page has swept away) -->
          <line x1="46" y1="16" x2="72" y2="16" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="22" x2="68" y2="22" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="28" x2="72" y2="28" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="34" x2="66" y2="34" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="40" x2="72" y2="40" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <line x1="46" y1="46" x2="70" y2="46" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          <!-- dynamic flipping page: polygon + fold-apex pixel dot -->
          <polygon id="flip-polygon" points="42,8 76,8 76,54 42,54" fill="currentColor" fill-opacity="0.08" stroke="currentColor" stroke-width="1.5"/>
          <!-- flipping page: just 2 lines clipped to live polygon shape -->
          <g clip-path="url(#page-text-clip)">
            <line x1="46" y1="22" x2="72" y2="22" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
            <line x1="46" y1="36" x2="68" y2="36" stroke="currentColor" stroke-width="0.8" stroke-opacity="0.22"/>
          </g>
          <rect id="flip-dot" x="75" y="7" width="2" height="2" fill="currentColor" opacity="0.7"/>
        </svg>
      </div>
      <div class="anim-pct-block">
        <div class="anim-pct-number"><span id="read-pct">0</span><span class="anim-pct-sign">%</span></div>
        <p class="anim-pct-label">read</p>
      </div>
    </div>

    <div class="memoir-main">
      <header class="memoir-hero">
        <p class="hero-kicker">UK 2026</p>
        <h1 aria-label={uk2026.title}>
          {heroTitleLines.map((line) => (
            <span>{line}</span>
          ))}
        </h1>
        <p class="hero-byline">
          Written by <a href="/about/">{uk2026.author}</a>.
        </p>
      </header>

      <nav class="mobile-toc" aria-label="Table of contents">
        {
          uk2026.chapters.map((chapter) => (
            <a href={`#${chapter.id}`} data-chapter-link={chapter.id}>
              <span>{chapter.number}</span>
              {chapter.title}
            </a>
          ))
        }
      </nav>

      <div class="chapter-stack">
        {
          uk2026.chapters.map((chapter) => (
            <section id={chapter.id} class="chapter-section">
              <header class="chapter-header">
                <p>{chapter.number}</p>
                <h2>{chapter.title}</h2>
              </header>

              <div class="prose-flow">
                {chapter.paragraphs.map((paragraph) => {
                  paragraphIndex += 1;
                  const quote = pullQuotes.get(paragraphIndex);
                  const segments = getLinkedSegments(paragraph);

                  return (
                    <>
                      <p>
                        {segments.map((segment) =>
                          segment.type === "link" ? (
                            <a class="text-link" href={segment.href} target="_blank" rel="noopener noreferrer">{segment.text}</a>
                          ) : (
                            segment.text
                          ),
                        )}
                      </p>
                      {quote && <blockquote>{quote}</blockquote>}
                    </>
                  );
                })}
              </div>
            </section>
          ))
        }
      </div>

      <div class="reader-download">
        <span>Want to read later?</span>
        <a href={pdfDownloadUrl} target="_blank" rel="noopener noreferrer" download>
          <Download size={13} strokeWidth={2.5} aria-hidden="true" />
          Download PDF
        </a>
      </div>
    </div>
    <div class="reader-toggle reader-toggle--floating" aria-label="Reader mode">
      <button
        type="button"
        data-reader-mode-button
        title="Enable dark mode"
      >
        <BookOpen size={17} strokeWidth={2.1} aria-hidden="true" />
        <span data-reader-mode-label>Enable dark mode</span>
      </button>
    </div>
  </article>
</BaseLayout>

<script>
  const chapterSections = Array.from(
    document.querySelectorAll(".chapter-section"),
  );
  const chapterLinks = Array.from(
    document.querySelectorAll("[data-chapter-link]"),
  );
  const tocContainers = Array.from(
    document.querySelectorAll(".toc-list, .mobile-toc"),
  );
  const readerModeButton = document.querySelector("[data-reader-mode-button]");
  const readerModeLabel = document.querySelector("[data-reader-mode-label]");
  const chapterClickLockMs = 2400;
  let lockedChapterId = null;
  let scrollUnlockTimer;
  let scrollUnlockMaxTimer;

  const setReaderTheme = (theme) => {
    const nextTheme = theme === "dark" || theme === "night" ? "dark" : "light";
    document.documentElement.dataset.uk2026Reader = nextTheme;
    document.documentElement.style.colorScheme =
      nextTheme === "dark" ? "dark" : "light";
    if (readerModeButton) {
      const nextAction =
        nextTheme === "dark" ? "Enable light mode" : "Enable dark mode";
      readerModeButton.setAttribute("aria-label", nextAction);
      readerModeButton.setAttribute("title", nextAction);
      if (readerModeLabel) {
        readerModeLabel.textContent = nextAction;
      }
    }
  };

  setReaderTheme("light");

  readerModeButton?.addEventListener("click", () => {
    const currentTheme =
      document.documentElement.dataset.uk2026Reader === "dark"
        ? "dark"
        : "light";
    setReaderTheme(currentTheme === "dark" ? "light" : "dark");
  });

  const updateTocHighlights = () => {
    tocContainers.forEach((container) => {
      const activeLink = container.querySelector("a.is-active");

      if (!activeLink) {
        container.style.setProperty("--highlight-opacity", "0");
        return;
      }

      container.style.setProperty("--highlight-opacity", "1");
      container.style.setProperty("--highlight-x", `${activeLink.offsetLeft}px`);
      container.style.setProperty("--highlight-y", `${activeLink.offsetTop}px`);
      container.style.setProperty(
        "--highlight-width",
        `${activeLink.offsetWidth}px`,
      );
      container.style.setProperty(
        "--highlight-height",
        `${activeLink.offsetHeight}px`,
      );
    });
  };

  const setActiveChapter = (id) => {
    if (!id) return;
    chapterLinks.forEach((link) => {
      const isActive = link.dataset.chapterLink === id;
      link.classList.toggle("is-active", isActive);
      if (isActive) {
        link.setAttribute("aria-current", "true");
      } else {
        link.removeAttribute("aria-current");
      }
    });
    window.requestAnimationFrame(updateTocHighlights);
  };

  const getCurrentChapterId = () => {
    const marker = window.innerHeight * 0.36;
    let current = chapterSections[0]?.id;

    chapterSections.forEach((section) => {
      if (section.getBoundingClientRect().top <= marker) {
        current = section.id;
      }
    });

    return current;
  };

  let activeTicking = false;
  const updateActiveChapter = () => {
    activeTicking = false;
    if (lockedChapterId) {
      return;
    }
    const id = getCurrentChapterId();
    if (id) setActiveChapter(id);
  };

  const requestActiveUpdate = () => {
    if (activeTicking) return;
    activeTicking = true;
    window.requestAnimationFrame(updateActiveChapter);
  };

  const releaseChapterLock = () => {
    lockedChapterId = null;
    window.clearTimeout(scrollUnlockTimer);
    window.clearTimeout(scrollUnlockMaxTimer);
    requestActiveUpdate();
  };

  const lockChapterDuringScroll = (id) => {
    lockedChapterId = id;
    window.clearTimeout(scrollUnlockTimer);
    window.clearTimeout(scrollUnlockMaxTimer);
    scrollUnlockMaxTimer = window.setTimeout(
      releaseChapterLock,
      chapterClickLockMs,
    );
  };

  chapterLinks.forEach((link) => {
    link.addEventListener("click", (event) => {
      const chapterId = link.dataset.chapterLink;
      const section = document.getElementById(chapterId);
      if (!section) return;

      event.preventDefault();
      lockChapterDuringScroll(chapterId);
      setActiveChapter(chapterId);
      history.pushState(null, "", `#${chapterId}`);
      section.scrollIntoView({ behavior: "smooth", block: "start" });
    });
  });

  window.addEventListener(
    "scroll",
    () => {
      if (lockedChapterId) {
        window.clearTimeout(scrollUnlockTimer);
        scrollUnlockTimer = window.setTimeout(releaseChapterLock, 180);
        return;
      }
      requestActiveUpdate();
    },
    { passive: true },
  );
  window.addEventListener("resize", () => {
    requestActiveUpdate();
    window.requestAnimationFrame(updateTocHighlights);
  });
  window.addEventListener("load", updateTocHighlights);
  window.addEventListener("hashchange", requestActiveUpdate);

  const hashId = window.location.hash.replace("#", "");
  if (hashId) {
    setActiveChapter(hashId);
    requestActiveUpdate();
  } else if (chapterSections[0]) {
    setActiveChapter(chapterSections[0].id);
  }

  // ── Smooth book flip & reading progress ────────────────────────
  const flipPolygonEl = document.getElementById('flip-polygon');
  const clipPolygonEl = document.getElementById('clip-polygon');
  const flipDotEl     = document.getElementById('flip-dot');
  const readPctEl     = document.getElementById('read-pct');
  const memoirMainEl  = document.querySelector('.memoir-main');
  const animPanelEl   = document.getElementById('anim-panels');
  const readingNudgesEl = document.querySelector('[data-reading-nudges]');
  const readingNudgeCards = {
    bookmark: document.querySelector('[data-reading-nudge-card="bookmark"]'),
    download: document.querySelector('[data-reading-nudge-card="download"]'),
  };

  // One page flip per ~300 words — feels like every few lines of reading
  const wc = parseInt(animPanelEl?.dataset.wordCount || '6000', 10);
  const flipsTotal = Math.max(8, Math.ceil(wc / 300));

  const getReadProgress = () => {
    if (!memoirMainEl) return 0;
    const top = memoirMainEl.offsetTop;
    const h   = memoirMainEl.offsetHeight;
    const vy  = window.scrollY;
    const vh  = window.innerHeight;
    const end = top + h - vh;
    if (end <= 0) return 1;
    return Math.max(0, Math.min(1, (vy - top + vh * 0.1) / (end - top + vh * 0.1)));
  };

  const chapterIndexById = new Map(
    chapterSections.map((section, index) => [section.id, index]),
  );
  const readingIntentState = {
    startedAt: performance.now(),
    lastY: window.scrollY,
    lastTs: performance.now(),
    maxChapterIndex: 0,
    fastScrollBursts: 0,
    scrollDistance: 0,
    bookmarkScrollDistance: 0,
    skippedChapters: 0,
    samples: [],
    bookmarkShownAt: 0,
    bookmarkProgress: 0,
    hasBookmark: false,
    hasDownload: false,
  };

  const showReadingNudge = (type) => {
    if (!readingNudgesEl) return;
    readingNudgesEl.classList.add("is-visible");
    readingNudgesEl.classList.add(`has-${type}`);
    readingNudgesEl.setAttribute("aria-hidden", "false");

    const card = readingNudgeCards[type];
    if (card) {
      card.setAttribute("aria-hidden", "false");
    }

    if (type === "bookmark" && !readingIntentState.hasBookmark) {
      readingIntentState.hasBookmark = true;
      readingIntentState.bookmarkShownAt = performance.now();
      readingIntentState.bookmarkProgress = getReadProgress();
      readingIntentState.bookmarkScrollDistance =
        readingIntentState.scrollDistance;
    }

    if (type === "download") {
      readingIntentState.hasDownload = true;
    }
  };

  const trackReadingIntent = () => {
    if (!readingNudgesEl || window.innerWidth <= 980) return;

    const now = performance.now();
    const scrollY = window.scrollY;
    const elapsed = (now - readingIntentState.startedAt) / 1000;
    const dt = Math.max((now - readingIntentState.lastTs) / 1000, 0.1);
    const scrollDelta = Math.abs(scrollY - readingIntentState.lastY);
    const speed = scrollDelta / dt;
    const progress = getReadProgress();
    const currentChapterIndex =
      chapterIndexById.get(getCurrentChapterId()) ?? readingIntentState.maxChapterIndex;

    if (speed > window.innerHeight * 1.1) {
      readingIntentState.fastScrollBursts += 1;
    } else {
      readingIntentState.fastScrollBursts = Math.max(
        0,
        readingIntentState.fastScrollBursts - 0.35,
      );
    }
    readingIntentState.scrollDistance += scrollDelta;

    if (currentChapterIndex > readingIntentState.maxChapterIndex + 1) {
      readingIntentState.skippedChapters +=
        currentChapterIndex - readingIntentState.maxChapterIndex;
    }
    readingIntentState.maxChapterIndex = Math.max(
      readingIntentState.maxChapterIndex,
      currentChapterIndex,
    );

    readingIntentState.samples.push({
      ts: now,
      progress,
      chapterIndex: currentChapterIndex,
      scrollY,
    });
    readingIntentState.samples = readingIntentState.samples.filter(
      (sample) => now - sample.ts <= 22000,
    );

    const firstRecentSample = readingIntentState.samples[0];
    const recentProgressGain = firstRecentSample
      ? progress - firstRecentSample.progress
      : 0;
    const averageProgressPerSecond = elapsed > 0 ? progress / elapsed : 0;
    const slowEarlyRead =
      elapsed > 38 &&
      progress > 0.035 &&
      progress < 0.22 &&
      averageProgressPerSecond < 0.0023;
    const earlyChapterSkim =
      readingIntentState.maxChapterIndex >= 2 &&
      elapsed < 140 &&
      progress > 0.08 &&
      (readingIntentState.fastScrollBursts >= 1 ||
        readingIntentState.skippedChapters >= 1 ||
        recentProgressGain > 0.05);
    const earlyFastScan =
      elapsed < 70 &&
      progress > 0.025 &&
      (readingIntentState.fastScrollBursts >= 2 ||
        recentProgressGain > 0.018);
    const earlyDistanceScan =
      elapsed < 90 &&
      progress > 0.008 &&
      readingIntentState.scrollDistance > window.innerHeight * 4;
    const fastLateSkim =
      progress > 0.28 &&
      elapsed < 110 &&
      (readingIntentState.fastScrollBursts >= 2 || recentProgressGain > 0.2);

    if (
      !readingIntentState.hasBookmark &&
      progress > 0.008 &&
      (slowEarlyRead ||
        earlyChapterSkim ||
        earlyFastScan ||
        earlyDistanceScan ||
        fastLateSkim)
    ) {
      showReadingNudge("bookmark");
    }

    if (readingIntentState.hasBookmark && !readingIntentState.hasDownload) {
      const secondsSinceBookmark =
        (now - readingIntentState.bookmarkShownAt) / 1000;
      const progressSinceBookmark =
        progress - readingIntentState.bookmarkProgress;
      const scrollSinceBookmark =
        readingIntentState.scrollDistance -
        readingIntentState.bookmarkScrollDistance;
      const continuedSkimming =
        secondsSinceBookmark > 7 &&
        (readingIntentState.fastScrollBursts >= 3 ||
          readingIntentState.skippedChapters >= 3 ||
          progressSinceBookmark > 0.14 ||
          (readingIntentState.maxChapterIndex >= 3 &&
            progressSinceBookmark > 0.06));
      const quickPostNudgeJump =
        secondsSinceBookmark > 12 &&
        progressSinceBookmark > 0.09 &&
        recentProgressGain > 0.08;
      const fastPostNudgeScan =
        secondsSinceBookmark > 7 &&
        progressSinceBookmark > 0.018 &&
        recentProgressGain > 0.015;
      const distancePostNudgeScan =
        secondsSinceBookmark > 7 &&
        scrollSinceBookmark > window.innerHeight * 2.4;

      if (
        continuedSkimming ||
        quickPostNudgeJump ||
        fastPostNudgeScan ||
        distancePostNudgeScan
      ) {
        showReadingNudge("download");
      }
    }

    readingIntentState.lastY = scrollY;
    readingIntentState.lastTs = now;
  };

  const updateAnimations = () => {
    const progress = getReadProgress();

    // Big % counter
    if (readPctEl) readPctEl.textContent = Math.round(progress * 100);
    trackReadingIntent();

    // Smooth continuous page flip — cycles flipsTotal times across the full article
    if (flipPolygonEl && flipDotEl) {
      const cycle = (progress * flipsTotal) % 1; // 0→1 repeating

      // foldX: free edge sweeps 76→4 (right to left)
      const foldX = 76 - cycle * 72;
      // arch: page rises above book top as it crosses the spine (peaks at cycle=0.5)
      const arch  = Math.sin(cycle * Math.PI) * 11;
      // tilt: bottom of page lags behind top (perspective lean)
      const tilt  = Math.sin(cycle * Math.PI) * 3;

      const topFX = Math.max(4, Math.min(76, foldX));
      const botFX = Math.max(4, Math.min(76, foldX + tilt));
      const topFY = 8 - arch;

      // Polygon: spine anchor (42,8)/(42,54) + fold edge top/bottom
      const pts = cycle < 0.5
        ? `42,8 ${topFX.toFixed(1)},${topFY.toFixed(1)} ${botFX.toFixed(1)},54 42,54`
        : `${topFX.toFixed(1)},${topFY.toFixed(1)} 42,8 42,54 ${botFX.toFixed(1)},54`;

      flipPolygonEl.setAttribute('points', pts);
      if (clipPolygonEl) clipPolygonEl.setAttribute('points', pts);
      // Pixel dot tracks the fold apex
      flipDotEl.setAttribute('x', (topFX - 1).toFixed(1));
      flipDotEl.setAttribute('y', (topFY - 1).toFixed(1));
    }
  };

  window.addEventListener('scroll', updateAnimations, { passive: true });
  window.addEventListener('resize', updateAnimations);
  window.setInterval(trackReadingIntent, 4000);
  updateAnimations();
</script>

<style>
  :global(html) {
    scroll-behavior: smooth;
  }

  :global(body.uk2026-page) {
    background: #ffffff !important;
    color: #282b27;
  }

  .memoir-shell {
    --toc-width: clamp(280px, 24vw, 360px);
    --page-bg: #ffffff;
    --paper: #fffefb;
    --panel-bg: rgba(255, 255, 255, 0.94);
    --mobile-panel-bg: rgba(255, 255, 255, 0.96);
    --brand-red: var(--color-brand-red, #a30021);
    --ink: #282b27;
    --muted: #667067;
    --line: #dfe6dc;
    --sage: #536b58;
    --clay: #9d5d4d;
    --quote-ink: #713342;
    --grid-line: rgba(83, 107, 88, 0.055);
    --accent: var(--brand-red);
    --accent-strong: var(--brand-red);
    --active-bg: #e9dfcf;
    --active-border: #d7c7b2;
    --active-ink: #302a21;
    --active-number: #6b5a43;
    --active-shadow: rgba(147, 124, 91, 0.18);
    --hover-bg: rgba(255, 254, 251, 0.86);
    min-height: 100vh;
    background:
      linear-gradient(90deg, var(--grid-line) 1px, transparent 1px),
      var(--page-bg);
    background-size: clamp(28px, 4vw, 54px) 100%;
  }

  :global(html[data-uk2026-reader="dark"] body.uk2026-page) {
    background: #040404 !important;
    color: #f8fafc;
  }

  :global(html[data-uk2026-reader="dark"]) .memoir-shell {
    --page-bg: #040404;
    --paper: #0a0a0a;
    --panel-bg: rgba(5, 5, 5, 0.92);
    --mobile-panel-bg: rgba(5, 5, 5, 0.94);
    --brand-red: var(--color-brand-red, #a30021);
    --ink: #f8fafc;
    --muted: #9ba9bb;
    --line: #2a2a2a;
    --sage: #9ba9bb;
    --clay: #d3dce8;
    --quote-ink: #d3dce8;
    --grid-line: rgba(255, 255, 255, 0.035);
    --accent: #c9183a;
    --accent-strong: #ff6a83;
    --active-bg: #151515;
    --active-border: #3f3f3f;
    --active-ink: #f8fafc;
    --active-number: #d3dce8;
    --active-shadow: rgba(0, 0, 0, 0.32);
    --hover-bg: rgba(21, 21, 21, 0.92);
  }

  .toc-panel {
    position: fixed;
    top: calc(var(--app-header-offset, 88px) + 2.5rem);
    left: 2.5rem;
    z-index: 20;
    width: calc(var(--toc-width) - 2rem);
    max-height: calc(100vh - var(--app-header-offset, 88px) - 10rem);
    padding: 1.5rem 1.35rem;
    border: 1px solid var(--line);
    background: var(--panel-bg);
    backdrop-filter: blur(18px);
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(83, 107, 88, 0.28) transparent;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.02);
  }

  .toc-kicker {
    margin: 0 0 0.5rem;
    padding-left: 0.75rem;
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--clay);
  }

  .hero-kicker,
  .chapter-header p {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--clay);
  }

  .toc-list,
  .mobile-toc {
    --highlight-x: 0px;
    --highlight-y: 0px;
    --highlight-width: 0px;
    --highlight-height: 0px;
    --highlight-opacity: 0;
    position: relative;
  }

  .toc-list {
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
  }

  .toc-list::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    width: var(--highlight-width);
    height: var(--highlight-height);
    border: 1px solid var(--active-border);
    border-radius: 0px;
    background: var(--active-bg);
    box-shadow: 0 4px 14px var(--active-shadow);
    opacity: var(--highlight-opacity);
    pointer-events: none;
    transform: translate3d(var(--highlight-x), var(--highlight-y), 0);
    transition:
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
      width 560ms cubic-bezier(0.22, 1, 0.36, 1),
      height 560ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .mobile-toc::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    z-index: 0;
    width: var(--highlight-width);
    height: var(--highlight-height);
    border: 1px solid var(--active-border);
    border-radius: 8px;
    background: var(--active-bg);
    box-shadow: 0 10px 24px var(--active-shadow);
    opacity: var(--highlight-opacity);
    pointer-events: none;
    transform: translate3d(var(--highlight-x), var(--highlight-y), 0);
    transition:
      transform 560ms cubic-bezier(0.22, 1, 0.36, 1),
      width 560ms cubic-bezier(0.22, 1, 0.36, 1),
      height 560ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease;
  }

  .reader-toggle {
    display: inline-flex;
    padding: 0.34rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.88);
  }

  .reader-toggle--floating {
    position: fixed;
    right: clamp(1rem, 2vw, 1.5rem);
    bottom: clamp(1rem, 2vw, 1.5rem);
    z-index: 40;
    width: auto;
    max-width: calc(100vw - 2rem);
    box-shadow: 0 14px 34px rgba(40, 43, 39, 0.12);
    backdrop-filter: blur(18px);
    opacity: 0.84;
    transition:
      opacity 160ms ease,
      border-color 160ms ease,
      box-shadow 160ms ease;
  }

  .reader-toggle--floating:hover,
  .reader-toggle--floating:focus-within {
    opacity: 1;
    border-color: var(--active-border);
    box-shadow: 0 18px 42px rgba(40, 43, 39, 0.16);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle--floating {
    border-color: rgba(255, 255, 255, 0.14);
    background: rgba(10, 10, 10, 0.74);
    box-shadow: 0 18px 42px rgba(0, 0, 0, 0.45);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle--floating:hover,
  :global(html[data-uk2026-reader="dark"]) .reader-toggle--floating:focus-within {
    border-color: rgba(255, 255, 255, 0.26);
    box-shadow: 0 20px 48px rgba(0, 0, 0, 0.58);
  }

  .reader-toggle button {
    min-height: 42px;
    padding: 0 0.95rem;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--muted);
    font-family: var(--font-sans);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.38rem;
    transition:
      color 160ms ease,
      background-color 160ms ease;
  }

  .reader-toggle button svg {
    color: var(--brand-red);
  }

  .reader-toggle button:hover,
  .reader-toggle button:focus-visible {
    background: var(--active-bg);
    color: var(--active-ink);
    outline: none;
  }

  .reader-toggle button.is-active {
    background: var(--active-bg);
    color: var(--active-ink);
  }

  .reader-toggle button.is-active svg {
    color: var(--accent);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle button {
    color: rgba(255, 255, 255, 0.86);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle button svg {
    color: #fffefb;
  }

  :global(html[data-uk2026-reader="dark"]) .reader-toggle button:hover,
  :global(html[data-uk2026-reader="dark"]) .reader-toggle button:focus-visible {
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
  }

  .toc-list a {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: baseline;
    gap: 0.55rem;
    padding: 0.52rem 0.75rem;
    text-decoration: none;
    color: var(--muted);
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.82rem;
    font-weight: 400;
    line-height: 1.45;
    white-space: normal;
    overflow: visible;
    border-radius: 0px;
    border: 1px solid transparent;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .mobile-toc a {
    position: relative;
    z-index: 1;
    text-decoration: none;
    color: var(--muted);
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
    border-radius: 8px;
    border: 1px solid transparent;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .toc-list a:hover,
  .toc-list a:focus-visible {
    background: var(--hover-bg);
    color: var(--ink);
    border-color: rgba(83, 107, 88, 0.22);
    border-radius: 0px;
    outline: none;
  }

  .mobile-toc a:hover,
  .mobile-toc a:focus-visible {
    background: var(--hover-bg);
    color: var(--ink);
    border-color: rgba(83, 107, 88, 0.22);
    outline: none;
  }

  .toc-list a.is-active {
    background: transparent;
    border-color: transparent;
    color: var(--active-ink);
    transform: none;
    box-shadow: none;
  }

  .mobile-toc a.is-active {
    background: transparent;
    border-color: transparent;
    color: var(--active-ink);
    transform: none;
    box-shadow: none;
  }

  .toc-list span {
    display: inline-block;
    flex-shrink: 0;
    margin-bottom: 0;
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--sage);
  }

  .mobile-toc span {
    display: block;
    margin-bottom: 0.18rem;
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--sage);
  }

  .toc-list a.is-active span {
    color: var(--active-number);
  }

  .mobile-toc a.is-active span {
    color: var(--active-number);
  }

  .reading-nudges {
    position: fixed;
    left: 2.5rem;
    bottom: calc(2.5rem + 6.25rem);
    z-index: 21;
    width: calc(var(--toc-width) - 2rem);
    display: grid;
    gap: 0.65rem;
    max-height: 0;
    margin-top: 0;
    opacity: 0;
    overflow: hidden;
    pointer-events: none;
    transform: translateY(0.75rem);
    transition:
      max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
      margin-top 260ms ease,
      opacity 220ms ease,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reading-nudges.is-visible {
    max-height: 320px;
    margin-top: 0.42rem;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  .reading-nudge-card {
    border: 1px solid var(--line);
    background: var(--paper);
    padding: 0.86rem 0.9rem;
    box-shadow: 0 8px 22px rgba(40, 43, 39, 0.06);
    opacity: 0;
    transform: translateY(0.8rem);
    transition:
      opacity 260ms ease,
      transform 420ms cubic-bezier(0.22, 1, 0.36, 1),
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .reading-nudge-card p {
    margin: 0;
    color: var(--ink);
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.45;
    letter-spacing: 0;
  }

  .reading-nudges.has-bookmark .reading-nudge-card--bookmark,
  .reading-nudges.has-download .reading-nudge-card--download {
    opacity: 1;
    transform: translateY(0);
  }

  .reading-nudge-card--download {
    display: grid;
    gap: 0.62rem;
    border-color: var(--active-border);
    background: var(--active-bg);
  }

  .reading-nudge-card--download p {
    color: var(--active-ink);
  }

  .reading-nudge-button {
    width: fit-content;
    min-height: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    gap: 0.32rem;
    border: 0;
    background: transparent;
    color: var(--active-ink);
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.2;
    text-decoration-line: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.18em;
    transition:
      opacity 160ms ease,
      text-decoration-thickness 160ms ease;
  }

  .reading-nudge-button:hover,
  .reading-nudge-button:focus-visible {
    opacity: 0.82;
    outline: none;
    text-decoration-thickness: 0.12em;
  }

  :global(html[data-uk2026-reader="dark"]) .reading-nudge-card {
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.28);
  }

  @media (max-width: 980px) {
    .reading-nudges {
      display: none;
    }
  }

  .memoir-main {
    min-width: 0;
    margin-left: calc(var(--toc-width) + 2rem);
    padding: 0 clamp(1rem, 4vw, 4rem) 6rem;
  }

  .memoir-hero {
    max-width: 980px;
    min-height: 42vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(2.5rem, 6vw, 4.5rem) 0 clamp(2.5rem, 6vw, 4rem);
  }

  .memoir-hero h1 {
    max-width: 820px;
    margin: 1rem 0 0;
    font-family: "Poppins", var(--font-sans), sans-serif;
    font-size: clamp(2.45rem, 5vw, 5.45rem);
    font-weight: 600;
    line-height: 1.05;
    letter-spacing: 0;
    color: var(--ink);
  }

  .memoir-hero h1 span {
    display: block;
    width: fit-content;
    max-width: 100%;
    white-space: nowrap;
  }

  .hero-byline {
    margin: 1.2rem 0 0;
    font-family: "Crimson Pro", Georgia, serif;
    font-size: clamp(1.1rem, 1rem + 0.35vw, 1.35rem);
    line-height: 1.45;
    color: var(--muted);
  }

  .hero-byline a {
    color: var(--ink);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  .hero-byline a:hover,
  .hero-byline a:focus-visible {
    color: var(--accent);
    text-decoration-color: var(--accent);
    outline: none;
  }

  :global(html[data-uk2026-reader="dark"]) .hero-byline a {
    color: var(--ink);
  }

  :global(html[data-uk2026-reader="dark"]) .hero-byline a:hover,
  :global(html[data-uk2026-reader="dark"]) .hero-byline a:focus-visible {
    color: var(--accent-strong);
    text-decoration-color: var(--accent-strong);
  }

  .mobile-toc {
    display: none;
  }

  .chapter-stack {
    display: flex;
    flex-direction: column;
  }

  .chapter-section {
    scroll-margin-top: 2rem;
    display: grid;
    grid-template-columns: minmax(130px, 18vw) minmax(0, 710px);
    gap: clamp(1.5rem, 4vw, 4rem);
    padding: clamp(4rem, 10vw, 7rem) 0;
    border-top: 1px solid var(--line);
  }

  .chapter-header {
    position: sticky;
    top: 2rem;
    align-self: start;
  }

  .chapter-header h2 {
    max-width: 260px;
    margin: 0.65rem 0 0;
    font-family: "Crimson Pro", Georgia, serif;
    font-size: clamp(1.65rem, 2.5vw, 2.45rem);
    font-weight: 500;
    line-height: 1.04;
    letter-spacing: 0;
    color: var(--ink);
  }

  .prose-flow {
    max-width: 700px;
  }

  .prose-flow p {
    margin: 0 0 1.55rem;
    font-family: "Crimson Pro", Georgia, serif;
    font-size: clamp(1.18rem, 1rem + 0.55vw, 1.42rem);
    font-weight: 400;
    line-height: 1.72;
    letter-spacing: 0;
    color: var(--ink);
  }

  .prose-flow .text-link {
    color: var(--brand-red);
    font-weight: 600;
    text-decoration-line: underline;
    text-decoration-thickness: 0.08em;
    text-underline-offset: 0.16em;
    overflow-wrap: anywhere;
    transition:
      color 160ms ease,
      text-decoration-color 160ms ease;
  }

  .prose-flow .text-link:hover,
  .prose-flow .text-link:focus-visible {
    color: var(--accent-strong);
    text-decoration-color: var(--accent-strong);
    outline: none;
  }

  .prose-flow blockquote {
    position: relative;
    margin: clamp(2rem, 5vw, 3.6rem) 0;
    padding: 0 0 0 clamp(2.2rem, 4vw, 3rem);
    border: 0;
    background: transparent;
    color: var(--quote-ink);
    font-family: "Crimson Pro", Georgia, serif;
    font-size: clamp(1.38rem, 1.05rem + 0.75vw, 1.85rem);
    font-style: italic;
    font-weight: 400;
    line-height: 1.36;
    letter-spacing: 0;
  }

  .prose-flow blockquote::before {
    content: "“";
    position: absolute;
    top: -0.32em;
    left: 0;
    color: var(--accent);
    font-family: "Crimson Pro", Georgia, serif;
    font-size: clamp(3.5rem, 8vw, 5.5rem);
    font-style: normal;
    font-weight: 600;
    line-height: 1;
  }

  .prose-flow blockquote::after {
    content: "”";
    color: var(--accent);
    font-style: normal;
    font-weight: 600;
  }

  @media (max-width: 980px) {
    .memoir-shell {
      display: block;
    }

    .toc-panel {
      display: none;
    }

    .memoir-main {
      margin-left: 0;
      padding: 0 clamp(1rem, 5vw, 2rem) 4rem;
    }

    .memoir-hero {
      min-height: 40vh;
      padding-top: 2rem;
    }

    .mobile-toc {
      position: sticky;
      top: 0;
      z-index: 5;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(148px, 1fr);
      gap: 0.55rem;
      overflow-x: auto;
      margin: 0 -1rem;
      padding: 0.85rem 1rem;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      background: var(--mobile-panel-bg);
      backdrop-filter: blur(16px);
      scrollbar-width: none;
      -ms-overflow-style: none;
    }

    :global(.mobile-toc::-webkit-scrollbar) {
      display: none;
      width: 0;
      height: 0;
    }

    .mobile-toc a {
      min-height: 68px;
      padding: 0.72rem 0.78rem;
      border: 1px solid var(--line);
      background: var(--paper);
    }

    .chapter-section {
      display: block;
      padding: 4rem 0;
    }

    .chapter-header {
      position: static;
      margin-bottom: 2rem;
    }

    .chapter-header h2 {
      max-width: 640px;
    }
  }

  @media (max-width: 560px) {
    .memoir-hero h1 {
      font-size: 2.35rem;
      line-height: 1.08;
    }

    .prose-flow p {
      font-size: 1.16rem;
      line-height: 1.7;
    }

    .prose-flow blockquote {
      font-size: 1.3rem;
    }
  }

  @media (max-width: 380px) {
    .memoir-hero h1 {
      font-size: 2.08rem;
    }
  }

  @media (max-width: 340px) {
    .memoir-hero h1 {
      font-size: 1.88rem;
    }
  }

  .reader-download {
    max-width: 700px;
    margin: clamp(3.5rem, 8vw, 6rem) 0 0 calc(max(130px, 18vw) + clamp(1.5rem, 4vw, 4rem));
    padding-top: 1.35rem;
    border-top: 1px solid var(--line);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.85rem;
    color: var(--muted);
  }

  .reader-download a {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    color: var(--brand-red);
    font-weight: 700;
    text-decoration: none;
    border-bottom: 1.5px solid transparent;
    padding-bottom: 2px;
    transition: all 160ms ease;
  }

  .reader-download a:hover {
    color: var(--accent-strong);
    border-bottom-color: var(--accent-strong);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-download a {
    color: var(--accent-strong);
  }

  :global(html[data-uk2026-reader="dark"]) .reader-download a:hover {
    color: #ff8ca3;
    border-bottom-color: #ff8ca3;
  }

  @media (max-width: 980px) {
    .reader-download {
      margin-left: 0;
    }
  }

  /* Footer layout alignment on desktop */
  @media (min-width: 981px) {
    :global(.uk2026-page .site-footer) {
      margin-left: calc(var(--toc-width) + 2rem);
    }
  }

  /* Header overrides for cohesive dark reader mode style */
  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-bar) {
    background: #050505 !important;
    color: #ffffff !important;
    border-color: rgba(255, 255, 255, 0.12) !important;
    box-shadow: 0 14px 36px rgba(0, 0, 0, 0.2) !important;
  }

  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-line),
  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-scroll-bar) {
    background: #ffffff !important;
  }

  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-primary-link) {
    color: rgba(255, 255, 255, 0.78) !important;
  }

  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-primary-link:hover),
  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-primary-link:focus-visible) {
    color: #fff4f1 !important;
  }

  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-breadcrumbs .breadcrumbs-nav.mobile .breadcrumb-list) {
    color: rgba(255, 255, 255, 0.68) !important;
  }

  :global(html[data-uk2026-reader="dark"]) :global(.top-menu-primary-link::after) {
    background: var(--color-glitch-red) !important;
  }

  /* ── Compact reading widget (book flip + % read) ── */
  .anim-panels {
    position: fixed;
    left: 2.5rem;
    bottom: 2.5rem;
    z-index: 20;
    width: calc(var(--toc-width) - 2rem);
    padding: 0.7rem 1rem;
    border: 1px solid var(--line);
    background: var(--panel-bg);
    backdrop-filter: blur(18px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.03);
    display: none;
    align-items: center;
    gap: 0.9rem;
  }

  @media (min-width: 981px) {
    .anim-panels {
      display: flex;
    }
  }

