        <header class="hero" aria-labelledby="page-title">
            <video
                class="hero-video"
                src="/videos/showreel-2025.mp4"
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                aria-hidden="true"
            ></video>
            <div class="hero-scrim"></div>
            <div class="hero-inner">
                <p class="eyebrow">Abodid Masterclass / Premiere Pro</p>
                <h1 id="page-title">Adobe Premiere Pro for Storytelling</h1>
                <p class="hero-subtitle">
                    A seven-week, beginner-friendly course plan for learning
                    video editing through rhythm, sound, narrative, and elegant
                    visual polish.
                </p>
                <div class="hero-actions" aria-label="Primary actions">
                    <a href={contactHref} class="primary-action">
                        Enquire about the masterclass
                    </a>
                    <a href="#curriculum" class="secondary-action">
