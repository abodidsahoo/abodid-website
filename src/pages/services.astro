---
import BaseLayout from "../layouts/BaseLayout.astro";
import { breadcrumbJsonLd, personJsonLd, serviceJsonLd } from "../lib/seoData";

const title = "Strategic Creative Services";
const description =
    "Hire Abodid Sahoo for strategic creative services across photography, film, exhibition design, creative technology, research, visual storytelling, and teaching.";
const contactHref =
    "/contact?from=%2Fservices&source_name=services&cta=hire-abodid";

const coreStrengths = [
    "Visual storytelling",
    "Portrait photography",
    "Documentary photography",
    "Campaign photography",
    "Event photography",
    "Exhibition design",
    "Exhibition production",
    "Spatial design",
    "XR setups",
    "Lighting design",
    "Video editing",
    "Colour grading",
    "Sound design",
    "Creative direction",
    "UX design",
    "Creative prototyping",
    "Qualitative research",
    "Cultural research",
    "AI ethics",
    "Workshops and mentoring",
];

const technicalToolkit = [
    "Adobe Lightroom",
    "Adobe Photoshop",
    "Adobe Illustrator",
    "Adobe InDesign",
    "Adobe Premiere Pro",
    "Adobe After Effects",
    "Adobe Audition",
    "DaVinci Resolve",
    "HTML / CSS / JavaScript",
    "Python",
    "Supabase",
    "Obsidian",
    "Notion",
    "Blender",
    "Sony Alpha / FX",
    "Rode Audio",
    "Zoom H6",
    "Gemini",
    "Google Antigravity",
    "Codex by OpenAI",
];

const proofPoints = [
    {
        figure: "6+ years",
        title: "Film production and exhibition design",
        bodyLead:
            "Directed films, music videos, documentaries, and non-fiction content for lifestyle brands, design studios, artists, and cultural organisations across",
        bodyEnding: "India and the UK.",
    },
    {
        figure: "10+ spaces / 700+ students",
        title: "RCA exhibition production",
        bodyLead:
            "Supported technical execution across Royal College of Art graduate shows, helping teams streamline digital media exhibitions, installations, and",
        bodyEnding: "health and safety workflows.",
    },
    {
        figure: "Selected contexts",
        title: "Brands, institutions, and cultural platforms",
        bodyLead:
            "Work and collaborations include Wieden+Kennedy, Odisha Tourism, Guatemala Tourism, Educate Girls, Outernet London, Frameless, Royal College of Art,",
        bodyEnding: "and BFI London.",
    },
    {
        figure: "Research-led practice",
        title: "RCA, BSA, and Cambridge Digital Humanities",
        bodyLead:
            "RCA alumnus and Apple Scholarship recipient, British Sociological Association presenter and session chair, and Cambridge Cultural Heritage",
        bodyEnding: "Data School bursary recipient.",
    },
];

const structuredData = [
    personJsonLd(),
    breadcrumbJsonLd([
        { name: "Home", path: "/" },
        { name: "Services", path: "/services/" },
    ]),
    serviceJsonLd({
        path: "/services/",
        name: "Strategic Creative Services Across Image, Film, Space, and Emerging Technology",
        description,
        serviceType:
            "Photography, filmmaking, post-production, exhibition design, creative technology, prototyping, cultural research, workshops, and creative mentoring",
    }),
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
    <main class="services-page">
        <header class="services-hero">
            <div class="hero-topline">
                <p class="eyebrow">Services</p>
            </div>

            <h1>
                Bespoke Creative Direction for Experiential Storytelling Projects.
            </h1>

            <div class="hero-copy">
                <p>
                    I work with institutions, brands, artists, and creative teams
                    to create public-facing work across photography, film,
                    exhibitions, events, and creative technology.
                </p>

                <p>
                    I bring together visual storytelling, spatial thinking,
                    research, production planning, and technical delivery. This
                    is for projects that need a clear creative eye, a sensitive
                    understanding of culture, and the ability to move from idea
                    to final outcome.
                </p>
            </div>

            <div class="hero-actions">
                <a href={contactHref} class="primary-action">Contact Abodid</a>
            </div>
        </header>

        <section class="proof-section" aria-labelledby="proof-title">
            <div class="section-heading proof-heading">
                <p class="eyebrow">Selected experience</p>
                <h2 id="proof-title">
                    Proof that the creative, technical, and research parts can
                    move together.
                </h2>
            </div>

            <div class="proof-grid">
                {
                    proofPoints.map((point) => (
                        <article class="proof-card">
                            <p class="proof-figure">{point.figure}</p>
                            <h3>{point.title}</h3>
                            <p>
                                {point.bodyLead} {point.bodyEnding}
                            </p>
                        </article>
                    ))
                }
            </div>
        </section>

        <section class="capability-section" aria-labelledby="capability-title">
            <div class="section-heading narrow">
                <p class="eyebrow">Core strengths</p>
                <h2 id="capability-title">
                    The practical skill set behind the work.
                </h2>
            </div>

            <div class="list-columns">
                <div class="list-block">
                    <h3>Creative and Strategic Strengths</h3>
                    <ul class="bullet-list">
                        {coreStrengths.map((item) => <li>{item}</li>)}
                    </ul>
                </div>

                <div class="list-block">
                    <h3>Technical Toolkit</h3>
                    <ul class="bullet-list">
                        {technicalToolkit.map((item) => <li>{item}</li>)}
                    </ul>
                </div>
            </div>
        </section>

    </main>
</BaseLayout>

<style>
    .services-page {
        max-width: 1120px;
        margin: 0 auto;
        padding: clamp(3.5rem, 7vw, 6rem) 24px 8rem;
    }

    .services-hero {
        padding-bottom: clamp(4rem, 8vw, 6.5rem);
        border-bottom: 1px solid var(--border-subtle);
    }

    .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--text-tertiary);
        margin: 0 0 1rem;
    }

    .hero-topline {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem 1.25rem;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 1rem;
    }

    .hero-topline .eyebrow {
        margin: 0;
    }

    h1,
    h2,
    h3,
    p {
        letter-spacing: 0;
        text-wrap: pretty;
    }

    h1 {
        max-width: 980px;
        margin: 0;
        font-family: var(--font-display);
        font-size: 3.5rem;
        line-height: 1.08;
        font-weight: 600;
        letter-spacing: -0.02em;
        color: var(--text-primary);
        text-wrap: balance;
    }

    .hero-copy {
        display: grid;
        gap: 1.15rem;
        max-width: 760px;
        margin-top: clamp(2rem, 5vw, 3.5rem);
    }

    .hero-copy p {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--text-secondary);
        font-size: 1.1rem;
        line-height: 1.6;
    }

    strong {
        color: var(--text-primary);
        font-weight: 700;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 2rem;
    }

    .primary-action,
    .secondary-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        border-radius: 8px;
        padding: 0.82rem 1.05rem;
        font-weight: 700;
        line-height: 1.2;
        text-decoration: none;
    }

    .primary-action {
        background: var(--text-primary);
        color: var(--bg-color);
    }

    .secondary-action {
        border: 1px solid var(--border-strong);
        color: var(--text-primary);
    }

    .proof-section,
    .capability-section {
        margin-top: clamp(5rem, 10vw, 8rem);
    }

    .section-heading {
        max-width: 880px;
        margin-bottom: clamp(2.5rem, 5vw, 4rem);
    }

    .section-heading.narrow {
        max-width: 720px;
    }

    .proof-heading {
        max-width: 980px;
    }

    .section-heading h2 {
        margin: 0;
        color: var(--text-primary);
        font-size: clamp(2.1rem, 5vw, 4.2rem);
        line-height: 1.05;
        font-weight: 700;
    }

    .proof-heading h2 {
        font-family: var(--font-display);
        font-size: 3.5rem;
        line-height: 1.08;
        font-weight: 600;
        letter-spacing: -0.02em;
        text-wrap: balance;
    }

    .proof-card h3,
    .list-block h3 {
        margin: 0;
        color: var(--text-primary);
        font-size: clamp(1.25rem, 2.1vw, 1.65rem);
        line-height: 1.18;
        font-weight: 700;
    }

    .proof-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .proof-card {
        display: grid;
        gap: 0.85rem;
        padding: clamp(1.15rem, 3vw, 1.65rem);
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        background: var(--bg-surface);
    }

    .proof-figure {
        margin: 0;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.4;
        text-transform: uppercase;
        color: var(--text-tertiary);
    }

    .proof-card p:last-child {
        margin: 0;
        font-family: var(--font-sans);
        color: var(--text-secondary);
        font-size: 1.1rem;
        line-height: 1.6;
    }

    .list-columns {
        display: grid;
        grid-template-columns: 1fr;
        gap: clamp(3rem, 6vw, 4.5rem);
        align-items: start;
    }

    .list-block {
        display: grid;
        gap: 1.35rem;
    }

    .bullet-list {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        grid-auto-rows: 1fr;
        gap: 0.75rem;
        list-style: none;
        margin: 0;
        padding: 0;
        color: var(--text-secondary);
    }

    .bullet-list li {
        display: flex;
        align-items: center;
        min-height: 3.4rem;
        height: 100%;
        padding: 0.72rem 0.85rem;
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        background: var(--bg-surface);
        font-size: 1rem;
        line-height: 1.35;
    }

    @media (max-width: 820px) {
        .services-page {
            padding-top: 3rem;
        }

        .proof-grid {
            grid-template-columns: 1fr;
        }

        .bullet-list {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

    }

    @media (max-width: 700px) {
        .bullet-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (max-width: 600px) {
        .services-page {
            padding-right: 16px;
            padding-left: 16px;
        }

        h1 {
            max-width: 100%;
            font-size: 1.9rem;
            text-wrap: pretty;
        }

        .section-heading h2 {
            font-size: clamp(2rem, 10vw, 3rem);
        }

        .proof-heading h2 {
            font-size: 2.5rem;
        }

        .primary-action,
        .secondary-action {
            width: 100%;
        }
    }

    @media (max-width: 460px) {
        .bullet-list {
            grid-template-columns: 1fr;
        }
    }

</style>
