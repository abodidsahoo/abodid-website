---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import portfolioManifest from "../data/photographyPortfolios.generated.json";

const pageTitle = "Photography Collaboration";
const pageDescription =
  "Downloadable photography portfolios for commissions, editorials, and visual collaborations.";

const { summary, collections, stories } = portfolioManifest;

const artCover = stories.find((story) => story.hasArt)?.coverImage || stories[0]?.coverImage || "";
const commercialCover =
  stories.find(
    (story) => story.hasCommercial && story.coverImage !== artCover,
  )?.coverImage ||
  stories.find((story) => story.coverImage !== artCover)?.coverImage ||
  artCover;
const completeCover =
  stories.find(
    (story) =>
      story.coverImage &&
      story.coverImage !== artCover &&
      story.coverImage !== commercialCover,
  )?.coverImage ||
  stories[0]?.coverImage ||
  "";

const collectionCards = collections.map((collection) => ({
  ...collection,
  isExternalDownload: /^https?:\/\//.test(collection.downloadUrl),
  coverImage:
    collection.id === "art"
      ? artCover
      : collection.id === "commercial"
        ? commercialCover
        : completeCover,
}));

const storyCards = stories.map((story) => ({
  ...story,
  isExternalDownload: /^https?:\/\//.test(story.downloadUrl),
}));

const statItems = [
  { label: "Photographs", value: summary.totalImages },
  { label: "Series", value: summary.seriesCount },
  { label: "Art", value: summary.artImageCount },
  { label: "Commercial", value: summary.commercialImageCount },
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  showNewsletterPopup={false}
  showGlobalGrid={false}
  showCursorFollower={false}
  fullWidth={true}
  bodyClass="collaboration-downloads-page"
>
  <section class="collaboration-page">
    <header class="page-header">
      <div class="page-header__copy">
        <p class="page-kicker">Collaboration</p>
        <h1>Downloadable Photography Portfolio</h1>
        <p class="page-subheading">
          For commissions, editorials, and visual collaborations.
        </p>
      </div>

      <div class="stats-row" aria-label="Portfolio summary">
        {statItems.map((item) => (
          <div class="stat-chip">
            <span>{item.value}</span>
            <small>{item.label}</small>
          </div>
        ))}
      </div>
    </header>

    <section class="downloads-section" aria-labelledby="featured-downloads">
      <div class="section-heading">
        <p class="section-kicker">Featured Downloads</p>
        <h2 id="featured-downloads">Three ready-to-send portfolio PDFs.</h2>
      </div>

      <div class="portfolio-grid portfolio-grid--featured">
        {collectionCards.map((collection) => (
          <article class="portfolio-card portfolio-card--featured">
            <div class="portfolio-card__media">
              {collection.coverImage ? (
                <img
                  src={collection.coverImage}
                  alt={`${collection.title} cover`}
                  loading="lazy"
                />
              ) : (
                <div class="portfolio-card__media-fallback" aria-hidden="true" />
              )}
            </div>

            <div class="portfolio-card__body">
              <div class="portfolio-card__topline">
                <span>{collection.imageCount} images</span>
                <div class="tag-row">
                  {collection.labels.slice(0, 3).map((label) => (
                    <span class="tag">{label}</span>
                  ))}
                </div>
              </div>

              <div class="portfolio-card__bottom">
                <h3>{collection.title}</h3>

                <a
                  class="download-button"
                  href={collection.downloadUrl}
                  download={collection.isExternalDownload ? undefined : collection.downloadName}
                  target={collection.isExternalDownload ? "_blank" : undefined}
                  rel={collection.isExternalDownload ? "noreferrer" : undefined}
                >
                  <span class="download-button__icon" aria-hidden="true">↓</span>
                  <span>Download PDF</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="downloads-section" aria-labelledby="series-pdfs">
      <div class="section-heading">
        <p class="section-kicker">Series PDFs</p>
        <h2 id="series-pdfs">One clean download per story.</h2>
      </div>

      <div class="portfolio-grid">
        {storyCards.map((story) => (
          <article class="portfolio-card">
            <div class="portfolio-card__media">
              <img
                src={story.coverImage}
                alt={`${story.title} cover`}
                loading="lazy"
              />
            </div>

            <div class="portfolio-card__body">
              <div class="portfolio-card__topline">
                <span>{story.imageCount} images</span>
                <div class="tag-row">
                  {story.labels.slice(0, 4).map((label) => (
                    <span class="tag">{label}</span>
                  ))}
                </div>
              </div>

              <div class="portfolio-card__bottom">
                <div class="portfolio-card__title-group">
                  <h3>{story.title}</h3>
                  <a class="series-link" href={story.projectHref}>
                    Open series
                  </a>
                </div>

                <a
                  class="download-button"
                  href={story.downloadUrl}
                  download={story.isExternalDownload ? undefined : story.downloadName}
                  target={story.isExternalDownload ? "_blank" : undefined}
                  rel={story.isExternalDownload ? "noreferrer" : undefined}
                >
                  <span class="download-button__icon" aria-hidden="true">↓</span>
                  <span>Download PDF</span>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  :global(body.collaboration-downloads-page) {
    background: #050505;
    color: #ffffff;
  }

  :global(body.collaboration-downloads-page .site-footer) {
    background: #050505;
    border-top-color: rgba(255, 255, 255, 0.08);
  }

  .collaboration-page {
    --page-shell: #050505;
    --page-surface: #0b0b0b;
    --page-surface-strong: #101010;
    --page-line: rgba(255, 255, 255, 0.09);
    --page-line-strong: rgba(255, 255, 255, 0.16);
    --page-text: #ffffff;
    --page-muted: rgba(255, 255, 255, 0.7);
    --page-muted-soft: rgba(255, 255, 255, 0.52);
    --page-accent: var(--color-brand-red);
    width: min(1440px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 0 0 4rem;
    color: var(--page-text);
  }

  .page-header {
    display: grid;
    gap: 1rem;
    padding: 0.2rem 0 1.25rem;
  }

  .page-header__copy {
    display: grid;
    gap: 0.45rem;
  }

  .page-kicker,
  .section-kicker,
  .portfolio-card__topline > span,
  .series-link {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--page-muted-soft);
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--page-text);
  }

  h1 {
    font-size: clamp(2.2rem, 5vw, 4.4rem);
    line-height: 0.95;
    max-width: 11ch;
  }

  .page-subheading {
    margin: 0;
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.55;
    color: var(--page-muted);
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .stat-chip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    min-height: 3.3rem;
    padding: 0.8rem 0.95rem;
    border: 1px solid var(--page-line);
    border-radius: 14px;
    background: var(--page-surface);
  }

  .stat-chip span {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1;
    color: var(--page-text);
  }

  .stat-chip small {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--page-muted-soft);
  }

  .downloads-section {
    margin-top: 1.5rem;
  }

  .section-heading {
    display: grid;
    gap: 0.2rem;
    margin-bottom: 0.9rem;
  }

  h2 {
    font-size: clamp(1.4rem, 2vw, 1.9rem);
    line-height: 1;
  }

  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(270px, 1fr));
    gap: 0.9rem;
  }

  .portfolio-grid--featured {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .portfolio-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--page-line);
    border-radius: 18px;
    background: var(--page-surface);
    min-height: 100%;
  }

  .portfolio-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    background:
      linear-gradient(160deg, rgba(163, 0, 33, 0.45), rgba(255, 255, 255, 0.04)),
      #111111;
    overflow: hidden;
  }

  .portfolio-card__media img,
  .portfolio-card__media-fallback {
    width: 100%;
    height: 100%;
    display: block;
  }

  .portfolio-card__media img {
    object-fit: cover;
  }

  .portfolio-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem;
    background: #050505;
    border-top: 1px solid var(--page-line);
  }

  .portfolio-card__topline {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    min-height: 1.8rem;
    padding: 0.1rem 0.55rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    background: rgba(163, 0, 33, 0.12);
    color: rgba(255, 255, 255, 0.88);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .portfolio-card__bottom {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .portfolio-card__title-group {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  h3 {
    font-size: clamp(1.15rem, 1.6vw, 1.4rem);
    line-height: 1.02;
    color: #ffffff;
  }

  .series-link {
    width: fit-content;
    text-decoration: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .series-link:hover,
  .series-link:focus-visible {
    color: #ffffff;
    border-bottom-color: rgba(255, 255, 255, 0.44);
    outline: none;
  }

  .download-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    width: 100%;
    min-height: 3rem;
    padding: 0.7rem 0.95rem;
    border-radius: 12px;
    border: 1px solid transparent;
    background: var(--page-accent);
    color: #ffffff;
    font-family: var(--font-ui);
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      transform 0.16s ease,
      background 0.16s ease,
      border-color 0.16s ease;
  }

  .download-button:hover,
  .download-button:focus-visible {
    transform: translateY(-1px);
    background: #c11439;
    outline: none;
  }

  .download-button__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 10px;
    background: rgba(0, 0, 0, 0.18);
    font-size: 1rem;
    line-height: 1;
  }

  @media (max-width: 1120px) {
    .portfolio-grid--featured {
      grid-template-columns: 1fr;
    }

    .stats-row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .collaboration-page {
      width: calc(100vw - 1rem);
      padding-bottom: 2.5rem;
    }

    .stats-row {
      grid-template-columns: 1fr;
    }

    .portfolio-grid {
      grid-template-columns: 1fr;
    }

    .portfolio-card__body {
      padding: 0.85rem;
    }
  }
</style>
