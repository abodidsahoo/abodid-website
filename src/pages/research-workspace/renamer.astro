---
import BaseLayout from "../../layouts/BaseLayout.astro";
import MinimalRenamerPage from "../../components/research-workspace/MinimalRenamerPage";
import "../../styles/research-workspace.css";

const title = "Research Paper Renamer";
const description =
    "Upload research papers, clean their filenames, and download organized copies.";
---

<BaseLayout
    title={title}
    description={description}
    showGlobalGrid={false}
    showCursorFollower={false}
    bodyClass="research-workspace-route"
>
    <MinimalRenamerPage client:load />
</BaseLayout>
