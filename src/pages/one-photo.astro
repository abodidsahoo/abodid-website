---
import BaseLayout from "../layouts/BaseLayout.astro";
import OnePhotoSubmissionForm from "../components/one-photo/OnePhotoSubmissionForm";
import "../styles/paper-renamer.css";
import "../styles/one-photo.css";

const pageTitle = "One Photo That Stays With You";
const pageDescription =
    "A simple BSA response page for sharing the one photograph that stays with you, through image, text, or audio.";
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    showCursorFollower={false}
    showGlobalGrid={false}
    showNewsletterPopup={false}
    hideHeader={true}
    hideFooter={true}
    bodyClass="paper-renamer-route one-photo-route"
>
    <section class="rw-page one-photo-page">
        <div class="rw-stage one-photo-stage">
            <div class="one-photo-shell">
                <a class="rw-eyebrow one-photo-home-link" href="/">
                    <span>abodid.com</span>
                </a>

                <header class="rw-mini-hero one-photo-hero">
                    <div class="rw-eyebrow">
                        <span>BSA Poster Response</span>
                    </div>
                    <h1>Share the one photo that stays with you.</h1>
                    <p>
                        This page accompanies my British Sociological Association project on
                        photography, memory, and emotionally weighted images. You can upload one
                        image, write the story behind it, record an audio note, or share any one of
                        those.
                    </p>
                    <p class="one-photo-note">
                        Keep it simple. At least one of text, audio, or image is enough.
                    </p>
                </header>

                <section class="rw-workspace-card one-photo-workspace">
                    <OnePhotoSubmissionForm client:load />
                </section>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .one-photo-page {
        padding-top: clamp(4rem, 8vw, 6rem);
    }

    :global(body.one-photo-route) {
        --rw-page-surface: linear-gradient(180deg, #fbf8f4 0%, #f3eee7 100%);
        --rw-panel-surface: rgba(255, 255, 255, 0.98);
        --rw-panel-border: rgba(35, 28, 24, 0.1);
        --rw-muted: #564d46;
        --rw-subtle-text: #6d635b;
        --rw-text: #1e1815;
        --rw-accent: var(--color-brand-red);
        --rw-accent-soft: rgba(163, 0, 33, 0.08);
        --bg-canvas: #f4efe8;
        --bg-color: #f4efe8;
        --bg-surface: #fffdfb;
        --text-primary: #1e1815;
        --text-secondary: #564d46;
        --border-subtle: #ddd5cb;
        background: #f4efe8;
        color: #1e1815;
    }

    :global(body.one-photo-route main) {
        padding-bottom: 4rem;
    }

    .one-photo-stage {
        max-width: 920px;
        border: 1px solid rgba(35, 28, 24, 0.08);
        background: linear-gradient(180deg, #fcfaf7 0%, #f5efe8 100%);
        box-shadow:
            0 20px 48px rgba(36, 24, 15, 0.08),
            inset 0 1px 0 rgba(255, 255, 255, 0.72);
    }

    .one-photo-stage::before {
        width: 200px;
        height: 200px;
        top: -92px;
        left: -80px;
        background: rgba(163, 0, 33, 0.07);
        filter: blur(10px);
    }

    .one-photo-stage::after {
        width: 180px;
        height: 180px;
        right: -60px;
        bottom: -80px;
        background: rgba(163, 0, 33, 0.05);
        filter: blur(10px);
    }

    .one-photo-shell {
        position: relative;
        z-index: 1;
        display: grid;
        gap: 1.4rem;
    }

    .one-photo-home-link {
        width: fit-content;
        text-decoration: none;
        color: var(--color-brand-red);
        border-color: rgba(163, 0, 33, 0.16);
        background: rgba(255, 255, 255, 0.96);
    }

    .one-photo-hero {
        max-width: 680px;
    }

    .one-photo-hero h1 {
        color: var(--rw-text);
    }

    .one-photo-hero p {
        color: var(--rw-muted);
    }

    .one-photo-note {
        font-size: 0.94rem;
        color: var(--rw-subtle-text);
    }

    .one-photo-workspace {
        padding: clamp(1rem, 2.2vw, 1.4rem);
        border-radius: 24px;
        border-color: rgba(35, 28, 24, 0.08);
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 14px 32px rgba(36, 24, 15, 0.06);
    }

    :global(.rw-eyebrow) {
        border-color: rgba(163, 0, 33, 0.14);
        background: rgba(255, 255, 255, 0.96);
        color: var(--color-brand-red);
    }

    :global(.rw-label) {
        color: var(--rw-text);
    }

    :global(.rw-textarea) {
        border-color: rgba(35, 28, 24, 0.12);
        background: #ffffff;
        color: var(--rw-text);
    }

    :global(.rw-textarea::placeholder) {
        color: #7b726b;
    }

    :global(.rw-textarea:focus-visible),
    :global(.rw-button:focus-visible),
    :global(.one-photo-upload-card:focus-within),
    :global(.one-photo-media-card__meta button:focus-visible) {
        outline: none;
        border-color: rgba(163, 0, 33, 0.38);
        box-shadow: 0 0 0 4px rgba(163, 0, 33, 0.08);
    }

    :global(.rw-button--primary) {
        background: var(--color-brand-red);
        color: #ffffff;
        box-shadow: 0 12px 24px rgba(163, 0, 33, 0.16);
    }

    :global(.rw-button--primary:hover:not(:disabled)) {
        box-shadow: 0 14px 28px rgba(163, 0, 33, 0.2);
    }

    :global(.rw-button--secondary) {
        background: #ffffff;
        color: var(--rw-text);
        border-color: rgba(35, 28, 24, 0.12);
    }

    :global(.one-photo-form) {
        display: grid;
        gap: 1rem;
    }

    :global(.one-photo-helper-card) {
        display: grid;
        gap: 0.45rem;
        padding: 1rem 1.05rem;
        border-radius: 22px;
        border: 1px solid rgba(22, 28, 38, 0.08);
        background: #fffaf7;
    }

    :global(.one-photo-helper-card p) {
        margin: 0;
        color: var(--rw-muted);
        line-height: 1.65;
    }

    :global(.one-photo-hidden-field) {
        display: none;
    }

    :global(.one-photo-inline-note) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        width: fit-content;
        padding: 0.8rem 1rem;
        border-radius: 999px;
        border: 1px solid rgba(22, 28, 38, 0.08);
        background: #fffaf8;
        color: var(--rw-text);
    }

    :global(.one-photo-field) {
        display: grid;
        gap: 0.55rem;
    }

    :global(.one-photo-panel) {
        display: grid;
        gap: 0.9rem;
        padding: 1rem 1.05rem;
        border-radius: 22px;
        border: 1px solid rgba(22, 28, 38, 0.08);
        background: #ffffff;
    }

    :global(.one-photo-panel__header) {
        display: grid;
        gap: 0.35rem;
    }

    :global(.one-photo-panel__header p) {
        margin: 0;
        color: var(--rw-muted);
        line-height: 1.65;
    }

    :global(.one-photo-panel__title) {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--rw-text);
    }

    :global(.one-photo-recorder-live) {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.85rem;
        flex-wrap: wrap;
    }

    :global(.one-photo-status) {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        width: fit-content;
        padding: 0.75rem 0.95rem;
        border-radius: 999px;
        border: 1px solid rgba(22, 28, 38, 0.08);
        background: #fffaf8;
        color: var(--rw-text);
        font-size: 0.94rem;
        font-weight: 600;
    }

    :global(.one-photo-status strong) {
        font-size: 0.9rem;
    }

    :global(.one-photo-status--success) {
        background: #eef8f1;
        border-color: rgba(55, 112, 66, 0.16);
    }

    :global(.one-photo-status-dot) {
        width: 0.65rem;
        height: 0.65rem;
        border-radius: 999px;
        background: var(--color-brand-red);
        box-shadow: 0 0 0 0 rgba(163, 0, 33, 0.3);
        animation: one-photo-pulse 1.4s infinite;
    }

    :global(.one-photo-media-card) {
        display: grid;
        gap: 0.8rem;
        padding: 1rem;
        border-radius: 18px;
        border: 1px solid rgba(22, 28, 38, 0.08);
        background: #fffaf8;
    }

    :global(.one-photo-media-card audio) {
        width: 100%;
    }

    :global(.one-photo-media-card__meta) {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        flex-wrap: wrap;
        color: var(--rw-muted);
        font-size: 0.92rem;
    }

    :global(.one-photo-media-card__meta button) {
        appearance: none;
        border: 0;
        background: transparent;
        color: var(--rw-text);
        font: inherit;
        font-weight: 600;
        cursor: pointer;
    }

    :global(.one-photo-image-card) {
        display: grid;
        gap: 0.75rem;
    }

    :global(.one-photo-image-card img) {
        display: block;
        width: 100%;
        max-height: 340px;
        object-fit: cover;
        border-radius: 18px;
        border: 1px solid rgba(22, 28, 38, 0.08);
        background: #f6f2ec;
    }

    :global(.one-photo-upload-card) {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.9rem;
        padding: 1rem 1.05rem;
        border-radius: 20px;
        border: 1px dashed rgba(22, 28, 38, 0.16);
        background: #fffdfb;
        cursor: pointer;
        transition:
            transform 0.2s ease,
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    :global(.one-photo-upload-card:hover) {
        transform: translateY(-1px);
        border-color: rgba(163, 0, 33, 0.24);
        box-shadow: 0 12px 24px rgba(36, 24, 15, 0.05);
    }

    :global(.one-photo-upload-card input) {
        position: absolute;
        inset: 0;
        opacity: 0;
        cursor: pointer;
    }

    :global(.one-photo-upload-card__icon) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: rgba(163, 0, 33, 0.08);
        color: var(--color-brand-red);
        flex-shrink: 0;
    }

    :global(.one-photo-upload-card__copy) {
        display: grid;
        gap: 0.18rem;
    }

    :global(.one-photo-upload-card__copy strong) {
        color: var(--rw-text);
        font-size: 0.98rem;
    }

    :global(.one-photo-upload-card__copy span) {
        color: var(--rw-muted);
        font-size: 0.92rem;
    }

    :global(.one-photo-submit-row) {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
    }

    :global(.one-photo-submit-note) {
        margin: 0;
        max-width: 34rem;
        color: var(--rw-muted);
        font-size: 0.94rem;
        line-height: 1.65;
    }

    :global(.one-photo-submit-button) {
        min-width: 210px;
    }

    :global(.one-photo-success) {
        display: grid;
        gap: 1rem;
    }

    :global(.one-photo-success h2) {
        margin: 0;
        font-family: "Crimson Pro", var(--font-display);
        font-size: clamp(2rem, 4vw, 2.8rem);
        line-height: 1.02;
        letter-spacing: -0.04em;
        color: var(--rw-text);
    }

    :global(.one-photo-success p) {
        margin: 0;
        color: var(--rw-muted);
        line-height: 1.7;
    }

    :global(.one-photo-actions) {
        margin-top: 0.2rem;
    }

    :global(.one-photo-reference) {
        font-size: 0.84rem;
        color: var(--rw-subtle-text);
    }

    @keyframes one-photo-pulse {
        0% {
            box-shadow: 0 0 0 0 rgba(163, 0, 33, 0.28);
        }
        70% {
            box-shadow: 0 0 0 10px rgba(163, 0, 33, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(163, 0, 33, 0);
        }
    }

    @media (max-width: 960px) {
        .one-photo-stage {
            max-width: 100%;
        }
    }

    @media (max-width: 720px) {
        .one-photo-page {
            padding-top: 4.25rem;
        }

        .one-photo-stage {
            padding: 1rem 0.95rem;
            border-radius: 24px;
        }

        .one-photo-workspace {
            padding: 0.95rem;
            border-radius: 22px;
        }

        .one-photo-hero {
            gap: 0.8rem;
        }

        .one-photo-hero h1 {
            font-size: clamp(2rem, 12vw, 3rem);
        }

        :global(.one-photo-recorder-live),
        :global(.one-photo-media-card__meta),
        :global(.one-photo-submit-row) {
            align-items: stretch;
            flex-direction: column;
        }

        :global(.one-photo-submit-button) {
            width: 100%;
        }

        :global(.one-photo-actions) {
            display: grid;
        }

        :global(.rw-button-row.one-photo-actions .rw-button) {
            width: 100%;
        }
    }

    @media (max-width: 540px) {
        .one-photo-page {
            padding-inline: 14px;
        }

        :global(.one-photo-panel),
        :global(.one-photo-helper-card) {
            padding: 0.95rem;
            border-radius: 18px;
        }

        :global(.one-photo-upload-card) {
            align-items: flex-start;
        }
    }
</style>
