---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Obsidian Tag Cloud Case Study";
const pageDescription =
    "Portfolio case study sample for the Obsidian Tag Cloud experiment, a creative-coding prototype that grew into a navigable public interface for a personal knowledge vault.";

const evidenceScreens = [
    {
        src: "/case-studies/obsidian-tag-cloud/visual-tag-cloud-desktop.jpg",
        alt: "Visual Tag Cloud Generator page with cursor-spawned Obsidian tags floating around the hero.",
        label: "Ambient discovery",
        body: "The original experiment uses cursor movement, collision checks, fading tags, sound, and confetti to make a vault taxonomy feel alive.",
    },
    {
        src: "/case-studies/obsidian-tag-cloud/vault-split-desktop.jpg",
        alt: "Obsidian Vault page showing a split interface with notes on the left and tags on the right.",
        label: "Structured browsing",
        body: "The vault page turns the same source material into a practical notes-and-tags interface backed by GitHub data.",
    },
    {
        src: "/case-studies/obsidian-tag-cloud/tag-search-desktop.jpg",
        alt: "Obsidian Vault tag page showing an animated scan for notes linked to a selected tag.",
        label: "Concept search",
        body: "Tag pages scan backlinks and wiki-link references so a visitor can move from a concept into related notes.",
    },
];

const pageOutline = [
    "Open with a private Obsidian taxonomy becoming a public, touchable knowledge surface.",
    "Show the Visual Tag Cloud Generator as the first playful prototype.",
    "Name the design question: how can a vault invite exploration without becoming a dashboard?",
    "Explain the system path from GitHub folders to tags, notes, tag search, and public pages.",
    "Compare ambient discovery, split browsing, and tag-specific results as three browsing modes.",
    "Use browser screenshots as evidence of interaction, information architecture, and system maturity.",
    "Close with next iterations around tag weighting, accessibility, public/private review, and conversational retrieval.",
];

const journey = [
    {
        step: "01",
        title: "Make the vault felt",
        body: "Cursor movement spawns real Obsidian tags as transient objects, turning a static taxonomy into an ambient interface.",
    },
    {
        step: "02",
        title: "Ground play in data",
        body: "The tag trail fetches live vault tags when available and falls back cleanly when secrets or network access are missing.",
    },
    {
        step: "03",
        title: "Give visitors a map",
        body: "The vault page pairs notes and tags side by side, with infinite loading and mobile view switching for dense archives.",
    },
    {
        step: "04",
        title: "Reveal relationships",
        body: "Tag pages search wiki-link references and backlinks, then animate a note stack that makes conceptual paths visible.",
    },
];

const systemNotes = [
    {
        title: "Interaction layer",
        body: "React handles cursor sampling, spacing rules, active tag lifetimes, unique-tag progress, audio unlock, and celebration states.",
    },
    {
        title: "Content layer",
        body: "Astro pages read vault tags and notes from GitHub folders, using cache and fallback strategies to keep the interface resilient.",
    },
    {
        title: "Knowledge layer",
        body: "A chunk and embedding schema prepares the archive for conversational retrieval while preserving public/private filtering.",
    },
];

const implementationDetails = [
    "Dynamic tags come from `/api/vault-tags.json`, with local fallback tags for development.",
    "Notes and tags map to the vault folders `6 - Main Notes` and `3 - Tags`.",
    "Tag search extracts `[[wiki links]]` and builds a cached tag index over fetched notes.",
    "The RAG layer uses `obsidian_chunks`, embeddings, tag filters, and public-only controls.",
];

const deckSlides = [
    "A private taxonomy became a public interface.",
    "The first prototype made tags feel alive.",
    "The design question was exploration, not decoration.",
    "Live vault data grounded the interaction.",
    "The experience expanded into three browsing modes.",
    "The system connects GitHub, Astro, tag search, and retrieval.",
    "Browser screenshots show current evidence.",
    "Design decisions balance play, clarity, and scale.",
    "The portfolio value is creative coding plus research infrastructure.",
    "Next iterations make the archive more legible and accessible.",
];
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    bodyClass="obsidian-tag-cloud-case-study"
    showGlobalGrid={false}
>
    <article class="case-study-page">
        <header class="case-hero">
            <div class="hero-copy">
                <p class="eyebrow">Portfolio case study sample</p>
                <h1>Obsidian Tag Cloud makes a private vault feel explorable.</h1>
                <p class="lede">
                    This case study reframes a playful cursor experiment as a
                    larger research interface: a way to translate an Obsidian
                    taxonomy into ambient discovery, structured browsing, and
                    concept-led navigation.
                </p>

                <div class="meta-grid" aria-label="Project metadata">
                    <div>
                        <span>Role</span>
                        <strong>Creative coding, UX, knowledge architecture</strong>
                    </div>
                    <div>
                        <span>Medium</span>
                        <strong>Interactive Astro and React prototype</strong>
                    </div>
                    <div>
                        <span>Focus</span>
                        <strong>Obsidian, tags, public research systems</strong>
                    </div>
                </div>
            </div>

            <figure class="hero-shot">
                <img
                    src="/case-studies/obsidian-tag-cloud/visual-tag-cloud-desktop.jpg"
                    alt="Visual Tag Cloud Generator with floating vault tags around the page hero."
                    loading="eager"
                />
                <figcaption>Browser capture of the current tag-cloud experiment.</figcaption>
            </figure>
        </header>

        <section class="case-section intro-section">
            <p class="section-kicker">Case study thesis</p>
            <h2>The portfolio story is the movement from atmosphere to architecture.</h2>
            <p>
                The tag cloud starts as a tactile invitation: move through the
                page and the vault answers with fragments of its own vocabulary.
                The stronger case study shows what happened next, when that
                ambient gesture became part of a larger public knowledge system
                with notes, tag references, search, and retrieval infrastructure.
            </p>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Web page outline</p>
                <h2>Recommended case-study flow</h2>
            </div>
            <ol class="outline-list">
                {
                    pageOutline.map((item, index) => (
                        <li>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{item}</p>
                        </li>
                    ))
                }
            </ol>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Evidence from the browser</p>
                <h2>The current product already shows three levels of discovery.</h2>
            </div>
            <div class="evidence-grid">
                {
                    evidenceScreens.map((screen) => (
                        <figure class="evidence-card">
                            <img src={screen.src} alt={screen.alt} loading="lazy" />
                            <figcaption>
                                <strong>{screen.label}</strong>
                                <span>{screen.body}</span>
                            </figcaption>
                        </figure>
                    ))
                }
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Experience map</p>
                <h2>The prototype grew by adding structure without removing play.</h2>
            </div>
            <div class="journey-grid">
                {
                    journey.map((item) => (
                        <div class="journey-card">
                            <span>{item.step}</span>
                            <h3>{item.title}</h3>
                            <p>{item.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section system-section">
            <div class="section-heading">
                <p class="section-kicker">System model</p>
                <h2>The interface sits on three connected layers.</h2>
            </div>
            <div class="system-grid">
                {
                    systemNotes.map((note) => (
                        <section>
                            <h3>{note.title}</h3>
                            <p>{note.body}</p>
                        </section>
                    ))
                }
            </div>
        </section>

        <section class="case-section split-section">
            <div>
                <p class="section-kicker">Implementation evidence</p>
                <h2>The codebase turns a visual experiment into research infrastructure.</h2>
            </div>
            <ul class="detail-list">
                {implementationDetails.map((detail) => <li>{detail}</li>)}
            </ul>
        </section>

        <section class="case-section deck-section">
            <div class="section-heading">
                <p class="section-kicker">Presentation deck</p>
                <h2>The slide story builds from gesture to system.</h2>
            </div>
            <div class="deck-list" aria-label="Deck slide outline">
                {
                    deckSlides.map((slide, index) => (
                        <div>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{slide}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section close-section">
            <p class="section-kicker">Portfolio positioning</p>
            <blockquote>
                Obsidian Tag Cloud is a creative interface for a living archive:
                playful enough to invite wandering, structured enough to become
                a public research system.
            </blockquote>
        </section>
    </article>
</BaseLayout>

<style>
    :global(body.obsidian-tag-cloud-case-study) {
        background: #060706;
        color: #f7f6ef;
    }

    .case-study-page {
        width: min(1180px, calc(100vw - 48px));
        margin: 0 auto;
        padding: 48px 0 96px;
    }

    .case-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
        gap: 40px;
        align-items: center;
        min-height: 68vh;
        padding-bottom: 48px;
        border-bottom: 1px solid rgba(247, 246, 239, 0.18);
    }

    .hero-copy {
        min-width: 0;
    }

    .eyebrow,
    .section-kicker {
        margin: 0 0 14px;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.35;
        letter-spacing: 0;
        text-transform: uppercase;
        color: #75e6a0;
    }

    h1,
    h2,
    h3,
    p,
    blockquote {
        letter-spacing: 0;
    }

    h1 {
        margin: 0;
        max-width: 820px;
        font-family: var(--font-display);
        font-size: 4rem;
        line-height: 1;
        color: #f7f6ef;
    }

    .lede {
        max-width: 680px;
        margin: 24px 0 0;
        font-size: 1.2rem;
        line-height: 1.65;
        color: #c7d1c5;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 32px;
    }

    .meta-grid div {
        min-width: 0;
        padding-top: 14px;
        border-top: 1px solid rgba(247, 246, 239, 0.2);
    }

    .meta-grid span {
        display: block;
        margin-bottom: 8px;
        font-family: var(--font-mono);
        font-size: 0.74rem;
        text-transform: uppercase;
        color: #67d6e3;
    }

    .meta-grid strong {
        display: block;
        font-size: 0.96rem;
        line-height: 1.4;
        color: #f7f6ef;
    }

    .hero-shot,
    .evidence-card {
        margin: 0;
        overflow: hidden;
        border: 1px solid rgba(247, 246, 239, 0.18);
        border-radius: 8px;
        background: #11130f;
    }

    .hero-shot img,
    .evidence-card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 10;
        object-fit: cover;
        background: #141812;
    }

    .hero-shot figcaption,
    .evidence-card figcaption {
        border-top: 1px solid rgba(247, 246, 239, 0.14);
        color: #aab6a8;
    }

    .hero-shot figcaption {
        padding: 14px 16px;
        font-size: 0.88rem;
    }

    .case-section {
        padding: 72px 0;
        border-bottom: 1px solid rgba(247, 246, 239, 0.14);
    }

    .intro-section {
        max-width: 860px;
    }

    .section-heading {
        max-width: 780px;
        margin-bottom: 28px;
    }

    h2 {
        margin: 0;
        font-family: var(--font-display);
        font-size: 2.5rem;
        line-height: 1.08;
        color: #f7f6ef;
    }

    .case-section > p,
    .intro-section p,
    .split-section p {
        margin: 20px 0 0;
        font-size: 1.08rem;
        line-height: 1.75;
        color: #c7d1c5;
    }

    .outline-list {
        display: grid;
        gap: 0;
        margin: 0;
        padding: 0;
        list-style: none;
        border-top: 1px solid rgba(247, 246, 239, 0.16);
    }

    .outline-list li,
    .deck-list div {
        display: grid;
        grid-template-columns: 56px minmax(0, 1fr);
        gap: 20px;
        padding: 18px 0;
        border-bottom: 1px solid rgba(247, 246, 239, 0.12);
    }

    .outline-list span,
    .deck-list span,
    .journey-card span {
        font-family: var(--font-mono);
        color: #db3a34;
    }

    .outline-list p,
    .deck-list p {
        margin: 0;
        color: #e6e3d8;
        line-height: 1.5;
    }

    .evidence-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
    }

    .evidence-card figcaption {
        display: grid;
        gap: 8px;
        padding: 16px;
    }

    .evidence-card strong {
        color: #f7f6ef;
        font-size: 1rem;
    }

    .evidence-card span {
        font-size: 0.9rem;
        line-height: 1.55;
    }

    .journey-grid,
    .system-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .system-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .journey-card,
    .system-grid section {
        min-width: 0;
        min-height: 248px;
        padding: 20px;
        border: 1px solid rgba(247, 246, 239, 0.16);
        border-radius: 8px;
        background: #10130f;
    }

    .journey-card h3,
    .system-grid h3 {
        margin: 18px 0 10px;
        font-size: 1.1rem;
        line-height: 1.25;
        color: #f7f6ef;
    }

    .system-grid h3 {
        margin-top: 0;
        color: #75e6a0;
    }

    .journey-card p,
    .system-grid p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.58;
        color: #c7d1c5;
    }

    .split-section {
        display: grid;
        grid-template-columns: minmax(0, 0.85fr) minmax(320px, 1.15fr);
        gap: 48px;
        align-items: start;
    }

    .detail-list {
        display: grid;
        gap: 14px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .detail-list li {
        position: relative;
        padding: 18px 18px 18px 44px;
        border: 1px solid rgba(247, 246, 239, 0.16);
        border-radius: 8px;
        color: #e6e3d8;
        line-height: 1.55;
        background: #0c0f0b;
    }

    .detail-list li::before {
        content: "";
        position: absolute;
        left: 18px;
        top: 26px;
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: #67d6e3;
    }

    .deck-list {
        display: grid;
        margin-top: 4px;
    }

    .close-section {
        border-bottom: 0;
        padding-bottom: 0;
    }

    blockquote {
        max-width: 980px;
        margin: 0;
        font-family: var(--font-display);
        font-size: 2.35rem;
        line-height: 1.18;
        color: #f7f6ef;
    }

    @media (max-width: 980px) {
        .case-study-page {
            width: min(100% - 32px, 720px);
            padding-top: 32px;
        }

        .case-hero,
        .split-section {
            grid-template-columns: 1fr;
        }

        h1 {
            font-size: 3rem;
        }

        h2 {
            font-size: 2rem;
        }

        .meta-grid,
        .evidence-grid,
        .journey-grid,
        .system-grid {
            grid-template-columns: 1fr;
        }

        .journey-card,
        .system-grid section {
            min-height: auto;
        }
    }

    @media (max-width: 560px) {
        .case-study-page {
            width: min(100% - 24px, 520px);
            padding-bottom: 64px;
        }

        .case-section {
            padding: 48px 0;
        }

        h1 {
            font-size: 2.4rem;
        }

        h2,
        blockquote {
            font-size: 1.75rem;
        }

        .lede {
            font-size: 1.05rem;
        }

        .outline-list li,
        .deck-list div {
            grid-template-columns: 42px minmax(0, 1fr);
            gap: 12px;
        }
    }
</style>
