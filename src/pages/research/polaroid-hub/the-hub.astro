---
export const prerender = false;
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PolaroidScatter from "../../../components/PolaroidScatter.jsx";
import ThemeWidget from "../../../components/ThemeWidget.jsx";
import { getAllPhotography } from "../../../lib/api";
import { featuredPhotography as mockPhotography } from "../../../utils/mockData";

// Safe Fetch Helper
const safeFetch = async (fn, fallback) => {
    try {
        return await fn();
    } catch (e) {
        console.error("Data fetch failed:", e);
        return fallback;
    }
};

const portfolioProjects = await safeFetch(getAllPhotography, mockPhotography);

function hashString(value) {
    let hash = 2166136261;
    for (let i = 0; i < value.length; i += 1) {
        hash ^= value.charCodeAt(i);
        hash = Math.imul(hash, 16777619);
    }
    return (hash >>> 0).toString(36);
}

function normalizeImageUrl(value) {
    return typeof value === "string" ? value.trim() : "";
}

// Flatten into a single list of EVERY image
let allImages = [];

portfolioProjects.forEach((project) => {
    const projectKey = project.slug || project.title || 'project';
    const coverImage = normalizeImageUrl(project.image);
    // Add cover image
    if (coverImage) {
        const stableId = `polaroid-${hashString(`${projectKey}:cover:${coverImage}`)}`;
        allImages.push({
            id: stableId,
            title: project.title,
            image: coverImage,
            slug: project.slug,
            link: project.href,
            isCover: true, // Priority Flag
        });
    }
    // Add gallery images
    if (project.images && project.images.length > 0) {
        project.images.forEach((imgUrl) => {
            const normalizedImage = normalizeImageUrl(imgUrl);
            if (!normalizedImage) return;

            const stableId = `polaroid-${hashString(`${projectKey}:gallery:${normalizedImage}`)}`;
            allImages.push({
                id: stableId,
                title: project.title,
                image: normalizedImage,
                fallbackImage: coverImage || undefined,
                slug: project.slug,
                link: project.href,
                isCover: false,
            });
        });
    }
});

// Shuffle (Fisher-Yates)
for (let i = allImages.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [allImages[i], allImages[j]] = [allImages[j], allImages[i]];
}

const pageTitle = "Polaroid Hub - Polaroid Scatter";
---

<BaseLayout title={pageTitle} hideHeader={true} fullWidth={true}>
    <div class="hub-controls">
        <a href="/" class="home-button">Home</a>
        <div class="hub-instructions" aria-label="How to use Polaroid Hub">
            <p>Click and drag to uncover more portraits beneath the stack.</p>
            <p>Click any photograph to enlarge it and view its color palette.</p>
        </div>
    </div>

    <ThemeWidget client:idle />
    <main class="polaroid-hub-immersive">
        {/* Pass ALL images */}
        <PolaroidScatter items={allImages} client:load immersive={true} deepLinkParam="photo" />
    </main>
</BaseLayout>

<style>
    /* 
       Polaroid Hub specific styles to ensure full immersion.
    */
    @import url("https://fonts.googleapis.com/css2?family=Reenie+Beanie&display=swap");

    .polaroid-hub-immersive {
        position: relative;
        width: 100vw;
        min-height: 100vh;
        /* Allow scroll */
        overflow-x: hidden;
        overflow-y: auto;

        /* BACKGROUND STYLES (Migrated from React for instant load) */

        /* --- OPTION B: DARK TEXTURED STUDIO (ACTIVE - INFINITE SCROLL) --- */
        background-color: var(--polaroid-hub-bg, #080808);

        /* PERF NOTE: This many layered gradients + noise can be GPU/paint heavy,
           especially with hundreds of moving/shadowed elements on top. */
        background-image: 
            /* LAYER 1: THE GRID (Moved to Top! White, Higher Opacity, Thicker) */
            linear-gradient(
                to right,
                rgba(255, 255, 255, 0.09) 2.5px,
                transparent 2.5px
            ),
            linear-gradient(
                to bottom,
                rgba(255, 255, 255, 0.09) 2.5px,
                transparent 2.5px
            ),
            /* LAYER 2: VIGNETTE & SEAM BLENDING (Topmost blend layer for seams) */
            /* SOLID BLACK at edges to guarantee perfect tile blending */
            linear-gradient(
                    to bottom,
                    var(--polaroid-hub-bg, #080808) 0%,
                    var(--polaroid-hub-bg, #080808) 15%,
                    transparent 30%,
                    transparent 70%,
                    var(--polaroid-hub-bg, #080808) 85%,
                    var(--polaroid-hub-bg, #080808) 100%
                ),
            /* LAYER 3: NOISE TEXTURE */
            url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.07'/%3E%3C/svg%3E"),
            /* LAYER 4: CONICAL WINDOW LIGHT (Left - Bright Beige) - Centered vertically in tile */
            radial-gradient(
                    ellipse at -10% 40%,
                    rgba(245, 240, 220, 0.08) 0%,
                    transparent 60%
                ),
            /* LAYER 5: SIDE FILL LIGHT (Right - Warm Beige) - Centered vertically in tile */
            radial-gradient(
                    ellipse at 110% 60%,
                    rgba(245, 235, 210, 0.05) 0%,
                    transparent 50%
                ),
            /* LAYER 6: TEXTURE CLOUDS - Centered */
            radial-gradient(
                    circle at 40% 50%,
                    rgba(255, 255, 255, 0.015) 0%,
                    transparent 30%
                ),
            radial-gradient(
                circle at 65% 30%,
                rgba(255, 255, 255, 0.01) 0%,
                transparent 20%
            );

        background-attachment: local;
        background-blend-mode:
            normal, normal, normal, overlay, screen, screen, screen, screen;

        background-size:
            50px 50px,
            50px 50px,
            /* Grid X, Grid Y */ 100% 2500px,
            /* Vignette */ 150px 150px,
            /* Noise */ 100% 2500px,
            /* Beam Left */ 100% 2500px,
            /* Beam Right */ 100% 2500px,
            /* Clouds 1 */ 100% 2500px; /* Clouds 2 */

        background-repeat:
            repeat,
            repeat,
            /* Grid repeats everywhere */ repeat-y,
            repeat,
            repeat-y,
            repeat-y,
            repeat-y,
            repeat-y;
    }

    /* REMOVED ::before - Grid is now in main stack */
    .polaroid-hub-immersive::before {
        display: none;
    }

    .home-button {
        display: inline-block;
        background: var(--polaroid-hub-control-bg, rgba(10, 10, 10, 0.18));
        color: var(--polaroid-hub-control-text, rgba(255, 255, 255, 0.92));
        padding: 0.8rem 1.2rem;
        font-family: var(--font-mono);
        text-decoration: none;
        font-weight: 400;
        font-size: 0.95rem;
        line-height: 1.1;
        border-radius: 6px;
        border: 1px solid
            var(--polaroid-hub-control-border, rgba(255, 255, 255, 0.34));
        box-shadow: var(--polaroid-hub-control-shadow, 0 4px 16px rgba(0, 0, 0, 0.16));
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        transition:
            transform 0.2s ease,
            border-color 0.2s ease;
    }

    .home-button:hover {
        transform: translateY(-2px);
        border-color: var(--polaroid-hub-control-text, rgba(255, 255, 255, 0.92));
    }

    .hub-controls {
        position: fixed;
        top: 2rem;
        left: 2rem;
        z-index: 1000;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.65rem;
        max-width: min(20rem, calc(100vw - 4rem));
    }

    .hub-instructions {
        margin-left: 0;
        padding: 0.72rem 0.85rem 0.78rem;
        position: relative;
        overflow: hidden;
        isolation: isolate;
        background: transparent;
        color: rgba(255, 255, 255, 0.92);
        font-family: var(--font-mono);
        font-size: 0.52rem;
        line-height: 1.42;
        letter-spacing: 0.03em;
        opacity: 0.94;
        text-wrap: balance;
        pointer-events: none;
        max-width: 18rem;
        border-radius: 8px;
        border: none;
        box-shadow: 0 10px 28px rgba(0, 0, 0, 0.14);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
    }

    .hub-instructions::before {
        content: "";
        position: absolute;
        inset: 0;
        border-radius: inherit;
        z-index: 0;
        pointer-events: none;
        background: linear-gradient(
            135deg,
            var(
                --polaroid-hub-instruction-current-from,
                color-mix(in srgb, var(--color-brand-red) 78%, #ffffff 22%)
            )
                0%,
            var(
                --polaroid-hub-instruction-current-to,
                color-mix(in srgb, var(--color-brand-red) 52%, #ffffff 48%)
            )
                100%
        );
    }

    .hub-instructions p {
        margin: 0;
        position: relative;
        z-index: 1;
    }

    .hub-instructions p + p {
        margin-top: 1rem;
    }
</style>
