---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Obsidian Vault Case Study";
const pageDescription =
    "Portfolio case study sample for the Obsidian Vault experiment, a public research interface for a private note archive, tag system, and citation-aware AI search.";

const evidenceScreens = [
    {
        src: "/case-studies/obsidian-vault/second-brain-desktop.png",
        alt: "Second Brain research explanation page with launch framing.",
        label: "Research frame",
        body: "The explanation page gives the concept its thesis: notes are dialogue, not storage.",
    },
    {
        src: "/case-studies/obsidian-vault/vault-index-desktop.png",
        alt: "Obsidian Vault browser showing notes, tags, and the ask-the-vault entry point.",
        label: "Live archive",
        body: "The experiment turns a vault into a split browsing surface for notes, tags, and questions.",
    },
    {
        src: "/case-studies/obsidian-vault/vault-index-mobile.png",
        alt: "Mobile Obsidian Vault view with browse choices.",
        label: "Mobile entry",
        body: "The mobile flow starts from a choice: browse notes or browse tags, instead of forcing a dense desktop grid.",
    },
    {
        src: "/case-studies/obsidian-vault/sample-page-desktop.png",
        alt: "Obsidian Vault portfolio case study sample page.",
        label: "Case study page",
        body: "The final portfolio artifact translates the experiment into a clear product, research, and systems story.",
    },
];

const outline = [
    "Open with the public knowledge-system thesis.",
    "Name the research problem: private notes become silent storage.",
    "Show the linked explanation page and live vault browser.",
    "Map the reader journey through notes, tags, note pages, search, and citations.",
    "Explain the system pipeline from markdown to GitHub, Supabase chunks, vector retrieval, and sourced answers.",
    "Make the trust decisions visible: public filters, read-only browsing, citation remapping, and sensitive-content checks.",
    "Use browser screenshots as evidence that the work is already a usable research interface.",
    "Close with next iterations around privacy workflow, graph trails, ingestion health, and research exports.",
];

const systemFlow = [
    {
        step: "01",
        title: "Sync the vault",
        body: "The site reads markdown notes and tag files from the Obsidian repo, with local cache and stale-cache fallback for resilience.",
    },
    {
        step: "02",
        title: "Translate note grammar",
        body: "Wiki links, embedded assets, tags, and markdown are converted into public routes that still feel like a connected vault.",
    },
    {
        step: "03",
        title: "Index meaning",
        body: "The ingest script chunks public notes, removes sensitive patterns, embeds text, and writes searchable rows into Supabase.",
    },
    {
        step: "04",
        title: "Answer with sources",
        body: "The chat API combines vector and keyword retrieval, then returns cited answers, grouped source notes, and hoverable excerpts.",
    },
];

const portfolioValue = [
    {
        title: "Research systems",
        body: "A personal knowledge method becomes a public research object with visible context and constraints.",
    },
    {
        title: "Information architecture",
        body: "Notes, tags, backlinks, and search become multiple doors into the same archive.",
    },
    {
        title: "AI retrieval design",
        body: "The system treats citations, public-only filters, and fallback behavior as part of the interface.",
    },
    {
        title: "Full-stack prototype",
        body: "Astro routes, GitHub content, Supabase pgvector, and OpenRouter models work as one publishing pipeline.",
    },
];

const deckSlides = [
    "A public interface for thinking-in-progress",
    "Why private notes become silent storage",
    "The product surface and reader journey",
    "The architecture behind the archive",
    "Trust decisions built into the retrieval layer",
    "What the screenshots prove",
    "Portfolio positioning",
    "Next iteration",
];
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    bodyClass="obsidian-vault-case-study"
    showGlobalGrid={false}
>
    <article class="case-study-page">
        <header class="case-hero">
            <div class="hero-copy">
                <p class="eyebrow">Portfolio case study sample</p>
                <h1>
                    Obsidian Vault makes a private thinking system public without
                    flattening it into a blog.
                </h1>
                <p class="lede">
                    This case study reframes the experiment as a research
                    interface: a live, read-only knowledge system where notes,
                    tags, search, and AI citations help visitors move through
                    thinking-in-progress.
                </p>
                <div class="meta-grid" aria-label="Project metadata">
                    <div>
                        <span>Role</span>
                        <strong>Research systems, UX, full-stack prototype</strong>
                    </div>
                    <div>
                        <span>Stack</span>
                        <strong>Astro, GitHub API, Supabase pgvector, OpenRouter</strong>
                    </div>
                    <div>
                        <span>Focus</span>
                        <strong>Digital gardens, public knowledge, sourced AI search</strong>
                    </div>
                </div>
            </div>

            <figure class="hero-shot">
                <img
                    src="/case-studies/obsidian-vault/vault-index-desktop.png"
                    alt="Obsidian Vault browser with notes, tags, and question input."
                    loading="eager"
                />
                <figcaption>
                    Browser screenshot of the current vault experiment.
                </figcaption>
            </figure>
        </header>

        <section class="case-section intro-section">
            <p class="section-kicker">Case study thesis</p>
            <h2>
                The portfolio story is the public interface for a private
                thinking practice.
            </h2>
            <p>
                The strongest framing is not that the vault has many notes. It
                is that the interface preserves how research actually moves:
                through fragments, tags, trails, questions, and sources. The
                case study should make that movement understandable to someone
                seeing the project for the first time.
            </p>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Web page outline</p>
                <h2>Recommended page flow</h2>
            </div>
            <ol class="outline-list">
                {
                    outline.map((item, index) => (
                        <li>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{item}</p>
                        </li>
                    ))
                }
            </ol>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Evidence from the browser</p>
                <h2>The experiment already has the surfaces of a case study.</h2>
            </div>
            <div class="evidence-grid">
                {
                    evidenceScreens.map((screen) => (
                        <figure class="evidence-card">
                            <img src={screen.src} alt={screen.alt} loading="lazy" />
                            <figcaption>
                                <strong>{screen.label}</strong>
                                <span>{screen.body}</span>
                            </figcaption>
                        </figure>
                    ))
                }
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">System narrative</p>
                <h2>Explain the build as a trust pipeline.</h2>
            </div>
            <div class="flow-grid">
                {
                    systemFlow.map((item) => (
                        <div class="flow-card">
                            <span>{item.step}</span>
                            <h3>{item.title}</h3>
                            <p>{item.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section split-section">
            <div>
                <p class="section-kicker">Design argument</p>
                <h2>Browsing and asking are two research modes, not competing features.</h2>
            </div>
            <div class="split-copy">
                <p>
                    Browsing keeps the vault spatial and slow: visitors can
                    enter through tags, drift across notes, and read in public
                    without an account. Asking adds a second mode for synthesis,
                    but the answer still has to point back to source notes.
                </p>
                <p>
                    The case study should connect each technical decision to a
                    reader-facing value: public-only rows protect the archive,
                    source links keep claims inspectable, and citation popovers
                    make retrieval visible inside the interface.
                </p>
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Portfolio value</p>
                <h2>What this project proves</h2>
            </div>
            <div class="value-grid">
                {
                    portfolioValue.map((item) => (
                        <div class="value-card">
                            <h3>{item.title}</h3>
                            <p>{item.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section deck-section">
            <div class="section-heading">
                <p class="section-kicker">Presentation deck</p>
                <h2>The slide story should move from archive problem to proof.</h2>
            </div>
            <div class="deck-list" aria-label="Deck slide outline">
                {
                    deckSlides.map((slide, index) => (
                        <div>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{slide}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section close-section">
            <p class="section-kicker">Portfolio positioning</p>
            <blockquote>
                Obsidian Vault is a humane archive prototype that asks how a
                researcher's private notes can become public, searchable, and
                citable without losing their connective texture.
            </blockquote>
        </section>
    </article>
</BaseLayout>

<style>
    :global(body.obsidian-vault-case-study) {
        --bg-canvas: #050505;
        --text-primary: #f8fafc;
        --text-secondary: #d6deea;
        --text-tertiary: #9ba9bb;
        --border-subtle: #2a2a2a;
        background-color: #050505 !important;
        color: #f8fafc;
    }

    .case-study-page {
        width: min(1180px, calc(100vw - 48px));
        margin: 0 auto;
        padding: 48px 0 96px;
    }

    .case-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.92fr) minmax(360px, 1.08fr);
        gap: 40px;
        align-items: center;
        min-height: 68vh;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
        padding-bottom: 48px;
    }

    .hero-copy {
        min-width: 0;
    }

    .eyebrow,
    .section-kicker {
        margin: 0 0 14px;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.35;
        letter-spacing: 0;
        text-transform: uppercase;
        color: #f97316;
    }

    h1,
    h2,
    h3,
    p {
        letter-spacing: 0;
    }

    h1 {
        margin: 0;
        max-width: 720px;
        font-family: var(--font-display);
        font-size: 3.2rem;
        line-height: 1.05;
        font-weight: 800;
        color: #ffffff;
    }

    .lede {
        max-width: 650px;
        margin: 28px 0 0;
        font-size: 1.16rem;
        line-height: 1.7;
        color: #d6deea;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 32px;
    }

    .meta-grid div,
    .flow-card,
    .value-card {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        background: #0c0c0c;
    }

    .meta-grid div {
        padding: 16px;
        min-height: 118px;
    }

    .meta-grid span,
    .flow-card span,
    .deck-list span,
    .outline-list span {
        display: block;
        margin-bottom: 10px;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: #7adff1;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .meta-grid strong {
        display: block;
        font-size: 0.94rem;
        line-height: 1.45;
        color: #ffffff;
        font-weight: 650;
    }

    .hero-shot,
    .evidence-card {
        margin: 0;
    }

    .hero-shot {
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 8px;
        background: #090909;
        overflow: hidden;
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    }

    .hero-shot img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
    }

    figcaption {
        font-size: 0.85rem;
        line-height: 1.5;
        color: #aeb8c7;
    }

    .hero-shot figcaption {
        padding: 12px 14px 14px;
    }

    .case-section {
        padding: 72px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .intro-section {
        max-width: 820px;
    }

    .section-heading {
        max-width: 820px;
        margin-bottom: 28px;
    }

    h2 {
        margin: 0;
        max-width: 860px;
        font-size: 2.22rem;
        line-height: 1.12;
        font-weight: 760;
        color: #ffffff;
    }

    h3 {
        margin: 0;
        font-size: 1.08rem;
        line-height: 1.3;
        font-weight: 760;
        color: #ffffff;
    }

    .case-section p {
        margin: 18px 0 0;
        max-width: 760px;
        font-size: 1.02rem;
        line-height: 1.72;
        color: #c8d2df;
    }

    .outline-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .outline-list li {
        display: grid;
        grid-template-columns: 48px 1fr;
        gap: 14px;
        padding: 18px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.13);
    }

    .outline-list p {
        margin: 0;
        font-size: 1rem;
    }

    .evidence-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .evidence-card {
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 8px;
        background: #0a0a0a;
        overflow: hidden;
    }

    .evidence-card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .evidence-card figcaption {
        padding: 18px;
    }

    .evidence-card strong {
        display: block;
        margin-bottom: 8px;
        color: #ffffff;
        font-size: 1rem;
    }

    .evidence-card span {
        display: block;
    }

    .flow-grid,
    .value-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .flow-card,
    .value-card {
        padding: 20px;
    }

    .flow-card p,
    .value-card p {
        margin-top: 12px;
        font-size: 0.94rem;
        line-height: 1.58;
    }

    .split-section {
        display: grid;
        grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
        gap: 48px;
        align-items: start;
    }

    .split-copy p:first-child {
        margin-top: 0;
    }

    .deck-section {
        border-bottom-color: rgba(249, 115, 22, 0.24);
    }

    .deck-list {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .deck-list div {
        min-height: 128px;
        padding: 16px;
        border: 1px solid rgba(122, 223, 241, 0.2);
        border-radius: 8px;
        background: #071012;
    }

    .deck-list p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.45;
        color: #c8d2df;
    }

    .close-section {
        border-bottom: 0;
        padding-bottom: 0;
    }

    blockquote {
        margin: 0;
        max-width: 940px;
        font-size: 1.95rem;
        line-height: 1.32;
        color: #ffffff;
        font-weight: 780;
    }

    @media (max-width: 980px) {
        .case-study-page {
            width: min(100% - 32px, 760px);
            padding-top: 32px;
        }

        .case-hero,
        .split-section {
            grid-template-columns: 1fr;
        }

        .case-hero {
            min-height: auto;
        }

        h1 {
            font-size: 2.78rem;
        }

        .meta-grid,
        .outline-list,
        .evidence-grid,
        .flow-grid,
        .value-grid,
        .deck-list {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 620px) {
        .case-study-page {
            width: min(100% - 24px, 560px);
            padding-bottom: 72px;
        }

        .case-section {
            padding: 52px 0;
        }

        h1 {
            font-size: 2.32rem;
        }

        h2 {
            font-size: 1.78rem;
        }

        blockquote {
            font-size: 1.36rem;
        }

        .outline-list li {
            grid-template-columns: 40px 1fr;
        }
    }
</style>
