---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Invisible Punctum Case Study";
const pageDescription =
    "Portfolio case study sample for Invisible Punctum, a research-led AI experiment about photographic memory, machine vision, and emotional context.";

const evidenceScreens = [
    {
        src: "/case-studies/invisible-punctum/research-explanation-desktop.png",
        alt: "Invisible Punctum research explanation page showing the human versus AI interpretation quote block.",
        label: "Research frame",
        body: "The existing page already names the conceptual tension: humans attach memory while AI names visible objects.",
    },
    {
        src: "/case-studies/invisible-punctum/experiment-intro-desktop.png",
        alt: "Invisible Punctums experiment intro screen with start button.",
        label: "Experiment hook",
        body: "The prototype positions the work as a divergence study between human feeling and machine vision.",
    },
    {
        src: "/case-studies/invisible-punctum/experiment-selection-desktop.png",
        alt: "Invisible Punctums image selection grid with response counts.",
        label: "Participant entry",
        body: "The image grid turns a research prompt into a participatory flow with visible response density.",
    },
    {
        src: "/case-studies/invisible-punctum/architecture-note-desktop.png",
        alt: "Punctum architecture page showing the feedback loop from image and memory to vision models and consensus engine.",
        label: "System model",
        body: "The architecture page explains the core loop: image, human memory, model perception, consensus, and synthesis.",
    },
];

const outline = [
    "Open with the tension between remembered photographs and machine-readable photographs.",
    "Define the research question: what does AI miss when it sees a picture without personal memory?",
    "Show the prototype journey from image choice to human response, AI reading, and consensus score.",
    "Explain the system architecture without hiding the poetic intent behind the interface.",
    "Name the UX frictions found in the repo feedback and convert them into redesign principles.",
    "Position the project as evidence of research, interaction design, AI prototyping, and critical storytelling.",
    "Close with a next iteration that makes consent, participation, and research output stronger.",
];

const journey = [
    {
        step: "01",
        title: "Choose a photograph",
        body: "Participants begin from a pool of images, with response counts hinting that each picture already carries social memory.",
    },
    {
        step: "02",
        title: "Contribute a feeling",
        body: "The prototype accepts typed or recorded emotional responses, turning memory into analyzable material.",
    },
    {
        step: "03",
        title: "Compare two readings",
        body: "The system extracts AI and human emotion keywords, then places them side by side.",
    },
    {
        step: "04",
        title: "Reveal divergence",
        body: "A consensus score becomes the portfolio artifact: not a truth score, but a measure of interpretive distance.",
    },
];

const uxMoves = [
    {
        title: "Make consent explicit",
        body: "Add a first-step consent note for text, microphone, storage, and research use before the response moment.",
    },
    {
        title: "Clarify the record control",
        body: "Use a familiar microphone icon, recording state, timer, transcript preview, and cancel affordance.",
    },
    {
        title: "Set response boundaries",
        body: "Add a word limit, remaining image count, and a clearer prompt so participants know what quality of answer helps.",
    },
    {
        title: "Frame the score carefully",
        body: "Rename consensus as semantic alignment and explain that low alignment can be the most human result.",
    },
];

const deckSlides = [
    "Why photographs become memory, not just data",
    "The Invisible Punctum question",
    "Prototype journey and participant loop",
    "Machine vision versus human memory",
    "System architecture and model stack",
    "What the current screenshots prove",
    "UX issues found during critique",
    "Case-study page structure",
    "Portfolio positioning",
    "Next research iteration",
];
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    bodyClass="invisible-punctum-case-study"
    showGlobalGrid={false}
>
    <article class="case-study-page">
        <header class="case-hero">
            <div class="hero-copy">
                <p class="eyebrow">Portfolio case study sample</p>
                <h1>
                    Invisible Punctum turns machine vision into a memory study.
                </h1>
                <p class="lede">
                    This case study reframes an AI experiment as a research-led
                    portfolio project: a participatory interface where people
                    describe what a photograph makes them feel, then compare
                    that response against a model's visual reading.
                </p>
                <div class="meta-grid" aria-label="Project metadata">
                    <div>
                        <span>Role</span>
                        <strong>Research, UX, AI prototyping</strong>
                    </div>
                    <div>
                        <span>Medium</span>
                        <strong>Interactive web experiment</strong>
                    </div>
                    <div>
                        <span>Focus</span>
                        <strong>Memory, images, semantic alignment</strong>
                    </div>
                </div>
            </div>

            <figure class="hero-shot">
                <img
                    src="/case-studies/invisible-punctum/experiment-selection-desktop.png"
                    alt="Invisible Punctums selection screen showing a grid of photographs."
                    loading="eager"
                />
                <figcaption>
                    Browser screenshot of the current experiment flow.
                </figcaption>
            </figure>
        </header>

        <section class="case-section intro-section">
            <p class="section-kicker">Case study thesis</p>
            <h2>
                The strongest portfolio story is not the model. It is the
                mismatch.
            </h2>
            <p>
                The existing research pages already contain the central idea:
                a human might say a photograph feels like a father, while AI
                might say it contains a man near a window. The case study should
                make that mismatch legible as a designed research system, not a
                one-off visual experiment.
            </p>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Web page outline</p>
                <h2>Recommended page flow</h2>
            </div>
            <ol class="outline-list">
                {
                    outline.map((item, index) => (
                        <li>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{item}</p>
                        </li>
                    ))
                }
            </ol>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Evidence from the codebase</p>
                <h2>The project already has the ingredients of a case study.</h2>
            </div>
            <div class="evidence-grid">
                {
                    evidenceScreens.map((screen) => (
                        <figure class="evidence-card">
                            <img src={screen.src} alt={screen.alt} loading="lazy" />
                            <figcaption>
                                <strong>{screen.label}</strong>
                                <span>{screen.body}</span>
                            </figcaption>
                        </figure>
                    ))
                }
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Experience map</p>
                <h2>Turn the experiment into a clear participant journey.</h2>
            </div>
            <div class="journey-grid">
                {
                    journey.map((item) => (
                        <div class="journey-card">
                            <span>{item.step}</span>
                            <h3>{item.title}</h3>
                            <p>{item.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section split-section">
            <div>
                <p class="section-kicker">System narrative</p>
                <h2>Explain the AI stack through the human question.</h2>
            </div>
            <div class="split-copy">
                <p>
                    The architecture page describes a loop from image and audio
                    input to vision models, semantic comparison, and poetic
                    synthesis. The portfolio case study should translate that
                    into a viewer-friendly claim: the prototype measures where
                    visual description stops and personal memory starts.
                </p>
                <p>
                    The consensus score should be presented as a divergence
                    signal. High alignment means the model and people converge;
                    low alignment means the photograph may depend on private
                    context the model cannot infer.
                </p>
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Redesign moves</p>
                <h2>Use the critique as portfolio evidence.</h2>
            </div>
            <div class="ux-grid">
                {
                    uxMoves.map((move) => (
                        <div class="ux-card">
                            <h3>{move.title}</h3>
                            <p>{move.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section deck-section">
            <div class="section-heading">
                <p class="section-kicker">Presentation deck</p>
                <h2>The slide story should build from question to proof.</h2>
            </div>
            <div class="deck-list" aria-label="Deck slide outline">
                {
                    deckSlides.map((slide, index) => (
                        <div>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{slide}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section close-section">
            <p class="section-kicker">Portfolio positioning</p>
            <blockquote>
                Invisible Punctum is a critical AI interface that asks whether
                a photograph's meaning lives in the pixels, the viewer, or the
                social memory around it.
            </blockquote>
        </section>
    </article>
</BaseLayout>

<style>
    :global(body.invisible-punctum-case-study) {
        background: #050505;
        color: #f8fafc;
    }

    .case-study-page {
        width: min(1180px, calc(100vw - 48px));
        margin: 0 auto;
        padding: 48px 0 96px;
    }

    .case-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(360px, 1.1fr);
        gap: 40px;
        align-items: center;
        min-height: 68vh;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
        padding-bottom: 48px;
    }

    .hero-copy {
        min-width: 0;
    }

    .eyebrow,
    .section-kicker {
        margin: 0 0 14px;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.35;
        letter-spacing: 0;
        text-transform: uppercase;
        color: #ff425f;
    }

    h1,
    h2,
    h3,
    p {
        letter-spacing: 0;
    }

    h1 {
        margin: 0;
        max-width: 720px;
        font-family: var(--font-display);
        font-size: 3.25rem;
        line-height: 1.05;
        font-weight: 800;
        color: #ffffff;
    }

    .lede {
        max-width: 650px;
        margin: 28px 0 0;
        font-size: 1.18rem;
        line-height: 1.7;
        color: #d6deea;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 32px;
    }

    .meta-grid div,
    .journey-card,
    .ux-card {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        background: #0c0c0c;
    }

    .meta-grid div {
        padding: 16px;
        min-height: 108px;
    }

    .meta-grid span,
    .journey-card span,
    .deck-list span,
    .outline-list span {
        display: block;
        margin-bottom: 10px;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        color: #7adff1;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .meta-grid strong {
        display: block;
        font-size: 0.96rem;
        line-height: 1.45;
        color: #ffffff;
        font-weight: 600;
    }

    .hero-shot,
    .evidence-card {
        margin: 0;
    }

    .hero-shot {
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 8px;
        background: #090909;
        overflow: hidden;
    }

    .hero-shot img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
    }

    figcaption {
        font-size: 0.85rem;
        line-height: 1.5;
        color: #aeb8c7;
    }

    .hero-shot figcaption {
        padding: 12px 14px 14px;
    }

    .case-section {
        padding: 72px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .intro-section {
        max-width: 820px;
    }

    .section-heading {
        max-width: 820px;
        margin-bottom: 28px;
    }

    h2 {
        margin: 0;
        max-width: 860px;
        font-size: 2.25rem;
        line-height: 1.12;
        font-weight: 700;
        color: #ffffff;
    }

    h3 {
        margin: 0;
        font-size: 1.08rem;
        line-height: 1.3;
        font-weight: 700;
        color: #ffffff;
    }

    .case-section p {
        margin: 18px 0 0;
        max-width: 760px;
        font-size: 1.02rem;
        line-height: 1.75;
        color: #c8d2df;
    }

    .outline-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .outline-list li {
        display: grid;
        grid-template-columns: 48px 1fr;
        gap: 14px;
        padding: 18px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .outline-list p {
        margin: 0;
        font-size: 1rem;
    }

    .evidence-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
    }

    .evidence-card {
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        background: #0a0a0a;
        overflow: hidden;
    }

    .evidence-card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    }

    .evidence-card figcaption {
        padding: 18px;
    }

    .evidence-card strong {
        display: block;
        margin-bottom: 8px;
        color: #ffffff;
        font-size: 1rem;
    }

    .evidence-card span {
        display: block;
    }

    .journey-grid,
    .ux-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 14px;
    }

    .journey-card,
    .ux-card {
        padding: 20px;
    }

    .journey-card p,
    .ux-card p {
        margin-top: 12px;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    .split-section {
        display: grid;
        grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
        gap: 48px;
        align-items: start;
    }

    .split-copy p:first-child {
        margin-top: 0;
    }

    .deck-section {
        border-bottom-color: rgba(122, 223, 241, 0.22);
    }

    .deck-list {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 12px;
    }

    .deck-list div {
        min-height: 132px;
        padding: 16px;
        border: 1px solid rgba(122, 223, 241, 0.22);
        border-radius: 8px;
        background: #071012;
    }

    .deck-list p {
        margin: 0;
        font-size: 0.95rem;
        line-height: 1.45;
    }

    .close-section {
        border-bottom: 0;
        padding-bottom: 0;
    }

    blockquote {
        margin: 0;
        max-width: 920px;
        font-size: 2rem;
        line-height: 1.3;
        color: #ffffff;
        font-weight: 700;
    }

    @media (max-width: 980px) {
        .case-study-page {
            width: min(100% - 32px, 760px);
            padding-top: 32px;
        }

        .case-hero,
        .split-section {
            grid-template-columns: 1fr;
        }

        .case-hero {
            min-height: auto;
        }

        h1 {
            font-size: 2.85rem;
        }

        .meta-grid,
        .outline-list,
        .evidence-grid,
        .journey-grid,
        .ux-grid,
        .deck-list {
            grid-template-columns: 1fr;
        }
    }

    @media (max-width: 620px) {
        .case-study-page {
            width: min(100% - 24px, 560px);
            padding-bottom: 72px;
        }

        .case-section {
            padding: 52px 0;
        }

        h1 {
            font-size: 2.45rem;
        }

        h2 {
            font-size: 1.85rem;
        }

        blockquote {
            font-size: 1.45rem;
        }

        .outline-list li {
            grid-template-columns: 40px 1fr;
        }
    }
</style>
