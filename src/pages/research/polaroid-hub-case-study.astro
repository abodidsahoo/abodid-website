---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Polaroid Hub Case Study";
const pageDescription =
    "Portfolio case study sample for Polaroid Hub, a tactile photo sequencing prototype for arranging photographs like physical objects.";

const evidenceScreens = [
    {
        src: "/case-studies/polaroid-hub/research-explanation-desktop.png",
        alt: "Polaroid Hub research explanation page with the project thesis and launch button.",
        label: "Research frame",
        body: "The existing page already names the thesis: sequence, juxtaposition, and rhythm change photographic meaning.",
    },
    {
        src: "/case-studies/polaroid-hub/hub-initial-desktop.png",
        alt: "Polaroid Hub immersive canvas showing draggable photo cards on a dark grid.",
        label: "Sequencing canvas",
        body: "The live route flattens the photography archive into a tactile table of clustered, draggable polaroids.",
    },
    {
        src: "/case-studies/polaroid-hub/hub-lightbox-desktop.png",
        alt: "Polaroid Hub lightbox showing a photograph, navigation arrows, and extracted color swatches.",
        label: "Inspection state",
        body: "The lightbox turns a single click into focused inspection, sequence browsing, and palette-aware context.",
    },
];

const outline = [
    "Open with the claim that sequencing photographs is a form of writing.",
    "Define the gap between rigid gallery tools and the tactile way photographers edit on tables.",
    "Show the prototype as a live archive surface rather than a static portfolio grid.",
    "Explain the interaction model: clusters, pairs, drag, rotation, lightbox, keyboard browsing, and deep links.",
    "Use screenshots as proof that the experiment already has a working interface, not only a concept.",
    "Bring in critique around unclear click navigation, missing progress awareness, and retention after minute one.",
    "Turn critique into next-version principles: visible affordances, sequence progress, micro-rewards, and exportable authorship.",
    "Close by positioning the project as photography research, interaction design, and creative technology.",
];

const systemMoves = [
    {
        title: "Archive to surface",
        body: "The Hub route collects every cover and gallery image from the photography archive, assigns stable IDs, and sorts them into a repeatable scatter.",
    },
    {
        title: "Stories stay clustered",
        body: "The React layer groups images by project slug, then builds singles, pairs, and clusters so related photographs can appear as visual units.",
    },
    {
        title: "Manipulation stays tactile",
        body: "Framer Motion handles dragging, spring movement, z-index lifting, and corner rotation handles so the user can disturb the layout by hand.",
    },
    {
        title: "Inspection becomes sequence",
        body: "The viewer adds arrow-key browsing, shutter transitions, preloading, deep links, and palette-driven overlays for a slower editing mode.",
    },
];

const redesignMoves = [
    {
        title: "Make the first action obvious",
        body: "Add a clearer click nudge and a visible selected state so users understand that a photograph opens into a sequence.",
    },
    {
        title: "Show where the viewer is",
        body: "Add progress like 3 / 48, project grouping, and an end state so browsing feels like a photo story rather than an endless pile.",
    },
    {
        title: "Reward longer sessions",
        body: "Let people save pairings, snapshot a board, and compare contact sheets so novelty becomes tool-grade memory.",
    },
    {
        title: "Give authorship an output",
        body: "Move toward upload, saved boards, contact-sheet PDFs, and print-ready handoff once the sequencing feel is stable.",
    },
];

const deckSlides = [
    "Polaroid Hub makes sequencing feel physical.",
    "The portfolio story is authorship, not gallery browsing.",
    "The prototype turns the archive into a table.",
    "The interaction model uses clusters, pairs, and deliberate friction.",
    "The lightbox turns inspection into sequence navigation.",
    "The codebase shows the system is more than a mockup.",
    "Feedback reveals where novelty needs tool-grade polish.",
    "The page should move from question to evidence to iteration.",
    "The next version should preserve tactility while adding saved sequences and export.",
];
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    bodyClass="polaroid-hub-case-study"
    showGlobalGrid={false}
>
    <article class="case-study-page">
        <header class="case-hero">
            <div class="hero-copy">
                <p class="eyebrow">Portfolio case study sample</p>
                <h1>Polaroid Hub makes sequencing photographs feel physical.</h1>
                <p class="lede">
                    This case study reframes the existing experiment as a
                    creative-technology project: a browser-based table where
                    photographs can be clustered, disturbed, inspected, and
                    sequenced before they become a fixed gallery or photo book.
                </p>
                <div class="meta-grid" aria-label="Project metadata">
                    <div>
                        <span>Role</span>
                        <strong>Research, UX, front-end prototyping</strong>
                    </div>
                    <div>
                        <span>Medium</span>
                        <strong>Interactive photography experiment</strong>
                    </div>
                    <div>
                        <span>Focus</span>
                        <strong>Sequencing, rhythm, tactile authorship</strong>
                    </div>
                </div>
            </div>

            <figure class="hero-shot">
                <img
                    src="/case-studies/polaroid-hub/hub-initial-desktop.png"
                    alt="Polaroid Hub immersive canvas with draggable photographs."
                    loading="eager"
                />
                <figcaption>
                    Browser screenshot of the current immersive Hub canvas.
                </figcaption>
            </figure>
        </header>

        <section class="case-section thesis-section">
            <p class="section-kicker">Case study thesis</p>
            <h2>The strongest story is not the gallery. It is the edit before the gallery.</h2>
            <p>
                The original research page says that two images side by side
                create a third story. The portfolio case study should make that
                thought tangible: Polaroid Hub is an early tool for feeling
                photographic rhythm before committing to a layout, sequence, or
                printed form.
            </p>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Web page outline</p>
                <h2>Recommended case-study flow</h2>
            </div>
            <ol class="outline-list">
                {
                    outline.map((item, index) => (
                        <li>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{item}</p>
                        </li>
                    ))
                }
            </ol>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Evidence from the browser</p>
                <h2>The current experiment already contains the portfolio proof.</h2>
            </div>
            <div class="evidence-grid">
                {
                    evidenceScreens.map((screen) => (
                        <figure class="evidence-card">
                            <img src={screen.src} alt={screen.alt} loading="lazy" />
                            <figcaption>
                                <strong>{screen.label}</strong>
                                <span>{screen.body}</span>
                            </figcaption>
                        </figure>
                    ))
                }
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">System narrative</p>
                <h2>Explain the code through the user behavior it creates.</h2>
            </div>
            <div class="system-grid">
                {
                    systemMoves.map((move) => (
                        <div class="system-card">
                            <h3>{move.title}</h3>
                            <p>{move.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section split-section">
            <div>
                <p class="section-kicker">Research critique</p>
                <h2>Feedback turns the experiment into a stronger case study.</h2>
            </div>
            <div class="split-copy">
                <p>
                    Existing feedback says that Polaroid Hub's click-based
                    navigation is not yet obvious, photo stories need progress
                    awareness, and the interaction needs retention-grade polish
                    after the first minute.
                </p>
                <p>
                    Those notes should not be hidden. They make the portfolio
                    story sharper because they show how a playful prototype can
                    become a serious sequencing tool.
                </p>
            </div>
        </section>

        <section class="case-section">
            <div class="section-heading">
                <p class="section-kicker">Next iteration</p>
                <h2>Preserve tactility while adding tool-grade memory.</h2>
            </div>
            <div class="redesign-grid">
                {
                    redesignMoves.map((move) => (
                        <div class="redesign-card">
                            <h3>{move.title}</h3>
                            <p>{move.body}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section deck-section">
            <div class="section-heading">
                <p class="section-kicker">Presentation deck</p>
                <h2>The deck should build from claim to proof to iteration.</h2>
            </div>
            <div class="deck-list" aria-label="Deck slide outline">
                {
                    deckSlides.map((slide, index) => (
                        <div>
                            <span>{String(index + 1).padStart(2, "0")}</span>
                            <p>{slide}</p>
                        </div>
                    ))
                }
            </div>
        </section>

        <section class="case-section close-section">
            <p class="section-kicker">Portfolio positioning</p>
            <blockquote>
                Polaroid Hub is a tactile sequencing prototype for photographers
                who need to feel relationships between images before they lock
                them into a grid, book, or final edit.
            </blockquote>
        </section>
    </article>
</BaseLayout>

<style>
    :global(body.polaroid-hub-case-study) {
        background: #070707;
        color: #f8fafc;
    }

    .case-study-page {
        width: min(1180px, calc(100vw - 48px));
        margin: 0 auto;
        padding: 48px 0 96px;
    }

    .case-hero {
        display: grid;
        grid-template-columns: minmax(0, 0.88fr) minmax(380px, 1.12fr);
        gap: 40px;
        align-items: center;
        min-height: 68vh;
        padding-bottom: 48px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    }

    .hero-copy {
        min-width: 0;
    }

    .eyebrow,
    .section-kicker {
        margin: 0 0 14px;
        color: #ff445c;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        line-height: 1.35;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    h1,
    h2,
    h3,
    p {
        letter-spacing: 0;
    }

    h1 {
        margin: 0;
        max-width: 760px;
        color: #ffffff;
        font-family: var(--font-display);
        font-size: clamp(2.6rem, 5vw, 4.7rem);
        line-height: 0.98;
        font-weight: 800;
    }

    .lede {
        max-width: 680px;
        margin: 26px 0 0;
        color: rgba(248, 250, 252, 0.78);
        font-size: 1.08rem;
        line-height: 1.72;
    }

    .meta-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 12px;
        margin-top: 32px;
    }

    .meta-grid div {
        min-width: 0;
        padding-top: 14px;
        border-top: 1px solid rgba(255, 255, 255, 0.22);
    }

    .meta-grid span {
        display: block;
        margin-bottom: 8px;
        color: rgba(248, 250, 252, 0.5);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        text-transform: uppercase;
    }

    .meta-grid strong {
        display: block;
        color: #ffffff;
        font-size: 0.9rem;
        line-height: 1.35;
    }

    .hero-shot,
    .evidence-card {
        margin: 0;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.05);
    }

    .hero-shot img,
    .evidence-card img {
        display: block;
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
    }

    figcaption {
        display: grid;
        gap: 8px;
        padding: 14px 16px 16px;
        color: rgba(248, 250, 252, 0.68);
        font-size: 0.84rem;
        line-height: 1.45;
    }

    figcaption strong {
        color: #ffffff;
        font-size: 0.92rem;
    }

    .case-section {
        padding: 72px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .thesis-section {
        max-width: 860px;
    }

    .case-section h2 {
        margin: 0;
        max-width: 880px;
        color: #ffffff;
        font-family: var(--font-display);
        font-size: clamp(2rem, 3.6vw, 3.35rem);
        line-height: 1.05;
        font-weight: 760;
    }

    .case-section > p,
    .split-copy p {
        margin: 24px 0 0;
        color: rgba(248, 250, 252, 0.76);
        font-size: 1.05rem;
        line-height: 1.78;
    }

    .section-heading {
        display: grid;
        gap: 10px;
        margin-bottom: 28px;
    }

    .outline-list {
        display: grid;
        gap: 12px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .outline-list li,
    .deck-list div {
        display: grid;
        grid-template-columns: 58px minmax(0, 1fr);
        gap: 18px;
        align-items: start;
        padding: 18px 0;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
    }

    .outline-list span,
    .deck-list span {
        color: #ff445c;
        font-family: var(--font-mono);
        font-size: 0.78rem;
    }

    .outline-list p,
    .deck-list p {
        margin: 0;
        color: rgba(248, 250, 252, 0.82);
        font-size: 1rem;
        line-height: 1.55;
    }

    .evidence-grid,
    .system-grid,
    .redesign-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
    }

    .system-grid,
    .redesign-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .system-card,
    .redesign-card {
        padding: 22px;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.055);
    }

    .system-card h3,
    .redesign-card h3 {
        margin: 0;
        color: #ffffff;
        font-family: var(--font-display);
        font-size: 1.05rem;
        line-height: 1.2;
    }

    .system-card p,
    .redesign-card p {
        margin: 14px 0 0;
        color: rgba(248, 250, 252, 0.7);
        font-size: 0.92rem;
        line-height: 1.58;
    }

    .split-section {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: 42px;
        align-items: start;
    }

    .split-copy p:first-child {
        margin-top: 0;
    }

    .deck-list {
        display: grid;
    }

    .close-section {
        border-bottom: 0;
        padding-bottom: 0;
    }

    blockquote {
        margin: 0;
        max-width: 980px;
        color: #ffffff;
        font-family: var(--font-display);
        font-size: clamp(2rem, 4.6vw, 4.2rem);
        line-height: 1.05;
        font-weight: 760;
    }

    @media (max-width: 980px) {
        .case-hero,
        .split-section {
            grid-template-columns: 1fr;
        }

        .meta-grid,
        .evidence-grid,
        .system-grid,
        .redesign-grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 640px) {
        .case-study-page {
            width: min(100% - 28px, 1180px);
            padding-top: 28px;
        }

        .case-hero {
            min-height: auto;
            gap: 28px;
        }

        .case-section {
            padding: 54px 0;
        }

        .meta-grid,
        .evidence-grid,
        .system-grid,
        .redesign-grid {
            grid-template-columns: 1fr;
        }

        .outline-list li,
        .deck-list div {
            grid-template-columns: 44px minmax(0, 1fr);
            gap: 12px;
        }
    }
</style>
