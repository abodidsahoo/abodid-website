---
export const prerender = false;
import BaseLayout from "../../../../layouts/BaseLayout.astro";

const { tag } = Astro.params;

if (!tag) {
    return Astro.redirect("/research/obsidian-vault");
}

const activeTagSlug = decodeURIComponent(tag).replace(/\.md$/i, "");
const activeTagName = activeTagSlug.replace(/-/g, " ");
const pageTitle = `Tag: ${activeTagName}`;
---

<BaseLayout title={pageTitle}>
    <div class="note-container">
        <nav class="note-nav">
            <a href="/research/obsidian-vault" class="back-pill">← Back to Vault</a>
        </nav>

        <article class="note-content">
            <h1>{pageTitle}</h1>

            <div
                class="tag-results is-animating"
                data-tag-view
                data-tag-name={activeTagName}
                data-tag-slug={activeTagSlug}
            >
                <div class="results-rail">
                    <div class="tag-search-console is-searching" aria-live="polite">
                        <p class="search-line search-line-main" data-search-main>
                            Preparing vault scan
                        </p>
                        <p class="search-line search-line-sub" data-search-sub>
                            Loading note index and references...
                        </p>
                    </div>

                    <div
                        class="search-results-divider"
                        data-results-divider
                        aria-hidden="true"
                    ></div>

                    <div class="results-section-heading" aria-hidden="true">
                        <h2 data-results-heading>Notes</h2>
                    </div>

                    <div class="notes-column-preview">
                        <div class="vault-list" data-results-list>
                            <p class="search-pending">Waiting for vault scan...</p>
                        </div>
                    </div>

                    <div class="results-end-nav">
                        <a href="/research/obsidian-vault" class="back-pill">← Back to Vault</a>
                    </div>
                </div>
            </div>
        </article>
    </div>
</BaseLayout>

<script>
    (() => {
        let activeRunToken = 0;
        let activeController = null;
        let lastStartedAt = 0;

        const SEARCH_TIMEOUT_MS = 9000;
        const RETRY_LOCK_MS = 1200;

        const createRetryMarkup = (message) => `
            <div class="search-retry-card result-reveal is-visible">
                <p class="search-retry-card__text">${message}</p>
                <button class="search-retry-card__button" type="button" data-search-retry>
                    Search again
                </button>
            </div>
        `;

        const initTagSearch = () => {
        const tagView = document.querySelector("[data-tag-view]");
        if (!tagView) return;
        if (tagView.dataset.searchInitialized === "true") return;
        tagView.dataset.searchInitialized = "true";

        const tagName = tagView.getAttribute("data-tag-name") || "this tag";
        const tagSlug = tagView.getAttribute("data-tag-slug") || "";
        const listNode = tagView.querySelector("[data-results-list]");
        const mainLine = tagView.querySelector("[data-search-main]");
        const subLine = tagView.querySelector("[data-search-sub]");
        const searchConsole = tagView.querySelector(".tag-search-console");
        const resultsHeading = tagView.querySelector("[data-results-heading]");

        const pause = (ms) => new Promise((resolve) => setTimeout(resolve, ms));

        const updateLines = (main, sub) => {
            if (mainLine) mainLine.textContent = main;
            if (subLine) subLine.textContent = sub;
        };

        const updateResultsHeading = (count) => {
            if (!resultsHeading) return;
            resultsHeading.textContent = `Notes [${count}]`;
        };

        const renderResults = (notes) => {
            if (!listNode) return [];
            listNode.innerHTML = "";

            if (!notes.length) {
                updateResultsHeading(0);
                const empty = document.createElement("p");
                empty.className = "no-results result-reveal";
                empty.textContent = "No notes found referencing this tag.";
                listNode.appendChild(empty);
                return [empty];
            }

            updateResultsHeading(notes.length);

            const nodes = notes.map((note, index) => {
                const card = document.createElement("a");
                card.className = "note-card result-reveal";
                card.href = note.href;
                card.style.setProperty("--stagger-index", String(index));

                const info = document.createElement("div");
                info.className = "note-info";
                const title = document.createElement("h3");
                title.textContent = note.slug.replace(/-/g, " ");

                info.appendChild(title);
                card.appendChild(info);
                listNode.appendChild(card);
                return card;
            });

            return nodes;
        };

        const setRetryState = (message) => {
            if (!listNode) return;
            updateResultsHeading(0);
            listNode.innerHTML = createRetryMarkup(message);
            const retryButton = listNode.querySelector("[data-search-retry]");
            if (retryButton) {
                retryButton.addEventListener("click", () => {
                    run({ force: true });
                }, { once: true });
            }
        };

        const resetPendingState = () => {
            if (!listNode) return;
            listNode.innerHTML = '<p class="search-pending">Waiting for vault scan...</p>';
        };

        const run = async ({ force = false } = {}) => {
            const now = Date.now();
            if (!force && now - lastStartedAt < RETRY_LOCK_MS) return;
            lastStartedAt = now;

            const runToken = ++activeRunToken;
            let statusTimer = null;

            if (activeController) {
                activeController.abort();
            }

            const controller = new AbortController();
            activeController = controller;
            const timeoutId = window.setTimeout(() => {
                controller.abort("timeout");
            }, SEARCH_TIMEOUT_MS);

            tagView.classList.add("is-animating");
            tagView.classList.remove("is-complete");
            if (searchConsole) searchConsole.classList.add("is-searching");
            resetPendingState();
            updateResultsHeading("...");

            updateLines(
                `Searching tag "${tagName}"...`,
                "Extracting vault references and backlinks..."
            );

            const phases = [
                {
                    main: "Scanning note graph for exact tag matches...",
                    sub: `Reading linked notes and metadata for "${tagName}"...`,
                },
                {
                    main: "Compiling candidate notes...",
                    sub: "Merging backlinks and wiki-link references...",
                },
                {
                    main: "Finalizing ranked list...",
                    sub: "Preparing the note stack for reveal...",
                },
            ];

            let phaseIndex = 0;
            statusTimer = window.setInterval(() => {
                const phase = phases[phaseIndex % phases.length];
                updateLines(phase.main, phase.sub);
                phaseIndex += 1;
            }, 900);

            let payload = null;
            let fetchError = null;
            try {
                const response = await fetch(
                    `/api/vault-tag-search.json?tag=${encodeURIComponent(tagSlug || tagName)}`,
                    { cache: "no-store", signal: controller.signal },
                );
                payload = await response.json();
                if (!response.ok || !payload?.ok) {
                    fetchError = payload?.error || "Search failed.";
                }
            } catch (error) {
                fetchError = error?.name === "AbortError"
                    ? "Search took too long."
                    : "Network error while searching the vault.";
            } finally {
                window.clearTimeout(timeoutId);
            }

            if (statusTimer) window.clearInterval(statusTimer);
            if (runToken !== activeRunToken) return;

            if (searchConsole) searchConsole.classList.remove("is-searching");
            activeController = null;

            if (fetchError) {
                updateLines(
                    fetchError === "Search took too long." ? "Search paused." : "Search failed.",
                    fetchError === "Search took too long."
                        ? "The vault scan stalled. You can run the search again."
                        : fetchError,
                );
                setRetryState(
                    fetchError === "Search took too long."
                        ? "The search seems stuck. Try running it again."
                        : "The search hit a network problem. Please try again."
                );
                return;
            }

            const notes = Array.isArray(payload?.notes) ? payload.notes : [];
            const noteCount = typeof payload?.count === "number" ? payload.count : notes.length;
            updateResultsHeading(noteCount);

            updateLines(
                "Search complete.",
                noteCount === 0
                    ? `No matches found for "${tagName}".`
                    : `Found ${noteCount} ${noteCount === 1 ? "note" : "notes"} with "${tagName}".`,
            );
            tagView.classList.add("is-complete");

            await pause(180);

            const resultNodes = renderResults(notes);
            resultNodes.forEach((node, index) => {
                const delay = 170 * index;
                window.setTimeout(() => {
                    node.classList.add("is-visible");
                }, delay);
            });

            window.setTimeout(() => {
                tagView.classList.remove("is-animating");
            }, Math.max(700, 170 * resultNodes.length + 240));
        };

        run();

        window.addEventListener("pageshow", (event) => {
            if (event.persisted) {
                run({ force: true });
            }
        });
    };

        if (document.readyState === "loading") {
            document.addEventListener("DOMContentLoaded", initTagSearch, { once: true });
        } else {
            initTagSearch();
        }
    })();
</script>

<style>
    :root {
        --vault-pill-bg: rgba(0, 0, 0, 0.18);
        --vault-pill-hover-bg: rgba(0, 0, 0, 0.26);
        --vault-note-pattern-dot: rgba(255, 255, 255, 0.08);
        --vault-note-sheen: rgba(255, 255, 255, 0.03);
    }

    [data-theme="light"] {
        --vault-pill-bg: rgba(255, 255, 255, 0.84);
        --vault-pill-hover-bg: rgba(255, 255, 255, 0.95);
        --vault-note-pattern-dot: rgba(15, 23, 42, 0.08);
        --vault-note-sheen: rgba(255, 255, 255, 0.58);
    }

    .note-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 2rem 1rem;
    }

    .results-rail {
        width: min(100%, 34rem);
    }

    .note-nav {
        margin-bottom: 2rem;
    }

    .back-pill {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.25rem;
        padding: 0.52rem 0.9rem;
        border: 1px solid var(--border-subtle);
        border-radius: 999px;
        background: var(--bg-canvas);
        color: color-mix(in srgb, var(--text-primary) 74%, var(--text-secondary) 26%);
        text-decoration: none;
        font-size: 0.78rem;
        font-family: var(--font-ui);
        font-weight: 550;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.2s;
    }

    .back-pill:hover {
        color: var(--text-primary);
        border-color: var(--text-secondary);
        background: var(--bg-surface);
        transform: translateY(-1px);
    }

    .note-content h1 {
        font-size: 2.5rem;
        margin-bottom: 2rem;
        text-transform: capitalize;
    }

    .tag-search-console {
        border: 1px solid var(--border-subtle);
        border-radius: 10px;
        background: var(--bg-canvas);
        padding: 0.95rem 1rem;
        display: grid;
        gap: 0.25rem;
    }

    .tag-search-console.is-searching {
        animation: searchGlow 1.8s ease-in-out infinite;
        border-color: rgba(120, 170, 255, 0.45);
    }

    .search-line {
        margin: 0;
        font-family: var(--font-ui);
        letter-spacing: 0.02em;
    }

    .search-line-main {
        color: var(--text-primary);
        font-size: 0.85rem;
    }

    .tag-search-console.is-searching .search-line-main::after {
        content: "...";
        display: inline-block;
        width: 0;
        overflow: hidden;
        vertical-align: bottom;
        animation: scanDots 1.2s steps(4, end) infinite;
    }

    .search-line-sub {
        color: var(--text-secondary);
        font-size: 0.78rem;
    }

    @keyframes scanDots {
        to {
            width: 1.15em;
        }
    }

    @keyframes searchGlow {
        0% {
            box-shadow: 0 0 0 rgba(120, 170, 255, 0);
        }
        50% {
            box-shadow: 0 0 0.9rem rgba(120, 170, 255, 0.22);
        }
        100% {
            box-shadow: 0 0 0 rgba(120, 170, 255, 0);
        }
    }

    .notes-column-preview {
        min-width: 0;
        border-right: none;
        padding: 0;
    }

    .results-end-nav {
        display: flex;
        justify-content: center;
        margin-top: 4rem;
        margin-bottom: 2.75rem;
        padding-top: 0.75rem;
    }

    .results-section-heading {
        margin: 0 0 2rem;
        opacity: 0;
        transform: translateY(6px);
        transition:
            opacity 0.24s ease,
            transform 0.24s ease;
        pointer-events: none;
    }

    .results-section-heading h2 {
        margin: 0;
        font-size: 1.2rem;
        text-transform: uppercase;
        color: #9aa6bf;
        letter-spacing: 1px;
        font-weight: 500;
    }

    .search-results-divider {
        width: 100%;
        height: 0;
        margin: 0;
        background: rgba(255, 255, 255, 0.94);
        opacity: 0;
        transition:
            height 0.24s ease,
            margin 0.24s ease,
            opacity 0.24s ease;
    }

    .tag-results.is-complete .search-results-divider {
        height: 3px;
        margin: 2rem 0 2rem;
        opacity: 1;
    }

    .tag-results.is-complete .results-section-heading {
        opacity: 1;
        transform: translateY(0);
    }

    .vault-list {
        display: flex;
        flex-direction: column;
        gap: 1.2rem;
    }

    .search-pending {
        margin: 0;
        color: var(--text-tertiary);
        border: 1px dashed var(--border-subtle);
        border-radius: 8px;
        padding: 0.95rem 1rem;
        font-size: 0.82rem;
        font-family: var(--font-ui);
        background: rgba(255, 255, 255, 0.02);
    }

    /* Result cards are injected client-side, so their selectors need to stay global. */
    :global(.tag-results .note-card) {
        display: block;
        position: relative;
        overflow: hidden;
        isolation: isolate;
        padding: 1.2rem;
        border-radius: 8px;
        text-decoration: none;
        color: var(--text-primary);
        transition: transform 0.2s, background 0.2s, border-color 0.2s;
        border: 1px solid var(--border-subtle);
        background:
            linear-gradient(135deg, var(--vault-note-sheen), transparent 48%),
            var(--vault-pill-bg);
        width: 100%;
        margin-bottom: 0;
        box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    }

    :global(.tag-results .note-card::before) {
        content: "";
        position: absolute;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        opacity: 0.32;
        background-image:
            radial-gradient(circle, var(--vault-note-pattern-dot) 0.8px, transparent 0.9px);
        background-size: 10px 10px;
        background-position: 0 0;
        -webkit-mask-image: linear-gradient(112deg, transparent 0%, rgba(0, 0, 0, 0.42) 30%, rgba(0, 0, 0, 0.92) 100%);
        mask-image: linear-gradient(112deg, transparent 0%, rgba(0, 0, 0, 0.42) 30%, rgba(0, 0, 0, 0.92) 100%);
    }

    :global(.tag-results .note-card:hover) {
        transform: translateX(4px);
        background:
            linear-gradient(135deg, var(--vault-note-sheen), transparent 48%),
            var(--vault-pill-hover-bg);
        border-color: var(--text-secondary);
    }

    :global(.tag-results .note-info) {
        position: relative;
        z-index: 1;
    }

    :global(.tag-results .note-info h3) {
        font-family: var(--feature-obsidian-note-title-font, var(--font-display));
        font-weight: var(--feature-obsidian-note-title-weight, 500);
        font-size: var(--feature-obsidian-note-title-size, 1rem);
        line-height: var(--feature-obsidian-note-title-line-height, 1.3);
        letter-spacing: var(--feature-obsidian-note-title-letter-spacing, 0em);
        margin: 0;
        color: var(--feature-obsidian-note-title-color, #8a8a8a);
        text-transform: capitalize;
    }

    :global(.tag-results .result-reveal) {
        opacity: 1;
        transform: translateY(0);
        filter: none;
    }

    :global(.tag-results.is-animating .result-reveal) {
        opacity: 0;
        transform: translateY(10px);
        filter: blur(1px);
    }

    :global(.tag-results.is-animating .result-reveal.is-visible) {
        opacity: 1;
        transform: translateY(0);
        filter: none;
        transition:
            opacity 0.45s ease,
            transform 0.45s ease,
            filter 0.45s ease;
    }

    :global(.tag-results .no-results) {
        margin: 0;
        color: var(--text-secondary);
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        background:
            linear-gradient(135deg, var(--vault-note-sheen), transparent 48%),
            var(--vault-pill-bg);
        padding: 1rem;
        font-family: var(--font-ui);
        font-size: 0.86rem;
    }

    :global(.tag-results .search-retry-card) {
        display: grid;
        gap: 0.9rem;
        margin: 0;
        padding: 1rem;
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        background:
            linear-gradient(135deg, var(--vault-note-sheen), transparent 48%),
            var(--vault-pill-bg);
    }

    :global(.tag-results .search-retry-card__text) {
        margin: 0;
        color: var(--text-secondary);
        font-family: var(--font-ui);
        font-size: 0.86rem;
    }

    :global(.tag-results .search-retry-card__button) {
        justify-self: start;
        border: 1px solid var(--border-subtle);
        border-radius: 999px;
        background: var(--bg-canvas);
        color: var(--text-primary);
        padding: 0.55rem 0.95rem;
        font-family: var(--font-ui);
        font-size: 0.8rem;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        cursor: pointer;
        transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
    }

    :global(.tag-results .search-retry-card__button:hover) {
        border-color: var(--text-secondary);
        background: var(--bg-surface);
        transform: translateY(-1px);
    }

    @media (max-width: 1100px) {
        .note-container {
            padding: 1rem;
        }

        .notes-column-preview {
            padding: 0;
        }
    }
</style>
