---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Payments";
const pageDescription =
    "Payment page for Abodid Sahoo. International payments can use PayPal, and India payments can use the India checkout route.";

const paypalFrameSrcdoc = `<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <style>
    :root {
      color-scheme: light;
    }

    :root[data-theme="dark"] {
      color-scheme: dark;
    }

    html,
    body {
      margin: 0;
      padding: 0;
      background: transparent;
    }

    body {
      min-width: 0;
      overflow: hidden;
      font-family: Arial, Helvetica, sans-serif;
    }

    #paypal-container-22T4QFMFG6BDS {
      width: 100%;
      min-width: 0;
    }
  </style>
  <script src="https://www.paypal.com/sdk/js?client-id=BAAQE8TkamhCfaYjOOl_ZjtgKbY0ZCtyOzmdOe83xf_zWg30P2ZzyrL0_v1NsBdll_k9zw5wYPq9KJkXy8&components=hosted-buttons&disable-funding=venmo&currency=GBP"></script>
</head>
<body>
  <div id="paypal-container-22T4QFMFG6BDS"></div>
  <script>
    (() => {
      const notifyHeight = () => {
        const checkout = document.querySelector(
          "#paypal-container-22T4QFMFG6BDS",
        );
        const height = Math.max(
          document.body.scrollHeight,
          checkout?.scrollHeight || 0,
          360,
        );

        window.parent.postMessage(
          {
            type: "abodid:paypal-frame-height",
            height,
          },
          "*",
        );
      };

      try {
        const parentTheme =
          window.parent.document.documentElement.getAttribute("data-theme");

        if (parentTheme === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      } catch (_error) {
        // The checkout still works if the parent theme is unavailable.
      }

      const renderPayPal = () => {
        if (!window.paypal?.HostedButtons) {
          return false;
        }

        window.paypal
          .HostedButtons({
            hostedButtonId: "22T4QFMFG6BDS",
          })
          .render("#paypal-container-22T4QFMFG6BDS");

        notifyHeight();
        window.setTimeout(notifyHeight, 500);
        window.setTimeout(notifyHeight, 1500);

        if ("ResizeObserver" in window) {
          new ResizeObserver(notifyHeight).observe(document.body);
        }

        return true;
      };

      if (renderPayPal()) return;

      const intervalId = window.setInterval(() => {
        if (renderPayPal()) {
          window.clearInterval(intervalId);
        }
      }, 200);

      window.setTimeout(() => {
        window.clearInterval(intervalId);
        notifyHeight();
      }, 5000);
    })();
  </script>
</body>
</html>`;
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    noindex={true}
    showNewsletterPopup={false}
    hideFooter={true}
>
    <section class="payments-shell">
        <div class="payments-frame">
            <header class="payments-header">
                <p class="payments-kicker">Payments</p>
                <h1>Choose a payment method</h1>
                <p class="payments-intro">
                    Use PayPal for international payments. Use the India payment
                    option for UPI, Indian cards, and net banking.
                </p>
            </header>

            <div class="payment-panels" aria-label="Payment options">
                <article class="payment-panel">
                    <div class="gateway-visual gateway-visual-paypal">
                        <span>PayPal</span>
                    </div>

                    <div class="payment-details">
                        <p class="payment-region">International</p>
                        <h2>PayPal</h2>
                        <p>
                            For payments from outside India. This checkout uses
                            GBP and opens through PayPal.
                        </p>

                        <div class="payment-action">
                            <p class="payment-action-label">
                                International Payment
                            </p>
                            <div class="gateway-checkout-surface">
                                <iframe
                                    class="paypal-native-frame"
                                    data-paypal-frame
                                    title="PayPal checkout"
                                    srcdoc={paypalFrameSrcdoc}
                                    allow="payment *"
                                    allowpaymentrequest
                                    referrerpolicy="strict-origin-when-cross-origin"
                                ></iframe>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="payment-panel">
                    <div class="gateway-visual gateway-visual-india">
                        <span>Razorpay</span>
                    </div>

                    <div class="payment-details">
                        <p class="payment-region">India</p>
                        <h2>India payment</h2>
                        <p>
                            For payments from India. Use this option for UPI,
                            Indian cards, and net banking.
                        </p>

                        <div class="payment-action">
                            <p class="payment-action-label">Pay Now</p>
                            <div class="gateway-checkout-surface">
                                <form class="razorpay-widget">
                                    <script
                                        is:inline
                                        src="https://checkout.razorpay.com/v1/payment-button.js"
                                        data-payment_button_id="pl_T1pqkmNlgYnS0d"
                                        async
                                    ></script>
                                </form>
                            </div>
                        </div>
                    </div>
                </article>
            </div>
        </div>
    </section>

    <script is:inline>
        (() => {
            const frame = document.querySelector("[data-paypal-frame]");

            window.addEventListener("message", (event) => {
                const data = event.data;

                if (
                    !frame ||
                    !data ||
                    data.type !== "abodid:paypal-frame-height" ||
                    event.source !== frame.contentWindow
                ) {
                    return;
                }

                const nextHeight = Number(data.height);

                if (Number.isFinite(nextHeight)) {
                    frame.style.height = `${Math.min(
                        Math.max(Math.ceil(nextHeight), 360),
                        1200,
                    )}px`;
                }
            });
        })();
    </script>
</BaseLayout>

<style>
    .payments-shell {
        width: 100%;
        min-height: 100vh;
        padding: clamp(3.5rem, 7vh, 5.5rem) 0 clamp(3rem, 7vh, 5rem);
    }

    .payments-frame {
        max-width: 1120px;
        margin: 0 auto;
    }

    .payments-header {
        max-width: 760px;
        margin: 0 0 2rem;
    }

    .payments-kicker,
    .payment-region,
    .payment-action-label {
        margin: 0;
        font-family: var(--font-ui);
        font-size: 0.8rem;
        font-weight: 650;
        line-height: 1.2;
        letter-spacing: 0;
        color: var(--text-tertiary);
    }

    .payments-header h1 {
        margin: 0.55rem 0 0;
        font-family: var(--font-display);
        font-size: clamp(2.15rem, 4vw, 3.5rem);
        font-weight: 800;
        line-height: 1.05;
        letter-spacing: 0;
        color: var(--text-primary);
    }

    .payments-intro {
        max-width: 650px;
        margin: 1rem 0 0;
        color: var(--text-secondary);
        font-family: var(--font-body);
        font-size: 1.06rem;
        line-height: 1.7;
        letter-spacing: 0;
    }

    .payment-panels {
        display: grid;
        gap: 1.25rem;
    }

    .payment-panel {
        display: grid;
        grid-template-columns: minmax(18rem, 0.9fr) minmax(24rem, 1.1fr);
        min-height: 22rem;
        min-width: 0;
        overflow: hidden;
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        background:
            linear-gradient(
                135deg,
                color-mix(in srgb, var(--bg-surface) 96%, transparent),
                color-mix(in srgb, var(--bg-surface) 82%, transparent)
            ),
            var(--bg-surface);
        box-shadow: 0 18px 60px rgba(0, 0, 0, 0.14);
    }

    .gateway-visual {
        min-height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(2rem, 6vw, 4rem);
        border-right: 1px solid var(--border-subtle);
        font-family: var(--font-display);
        font-size: clamp(2rem, 4.5vw, 3.6rem);
        font-weight: 850;
        line-height: 1;
        letter-spacing: 0;
        text-align: center;
    }

    .gateway-visual span {
        display: inline-block;
    }

    .gateway-visual-paypal {
        color: #ffffff;
        background:
            radial-gradient(
                circle at 18% 18%,
                rgba(255, 255, 255, 0.95),
                transparent 34%
            ),
            linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.96) 0%,
                rgba(176, 211, 255, 0.94) 42%,
                rgba(0, 94, 214, 0.98) 100%
            );
        text-shadow: 0 1px 22px rgba(0, 35, 84, 0.46);
    }

    .gateway-visual-india {
        color: #1d4d77;
        background:
            radial-gradient(
                circle at 22% 18%,
                rgba(255, 255, 255, 0.98),
                transparent 36%
            ),
            linear-gradient(
                135deg,
                rgba(255, 255, 255, 0.98) 0%,
                rgba(238, 246, 255, 0.96) 54%,
                rgba(122, 166, 205, 0.92) 100%
            );
    }

    .payment-details {
        display: flex;
        min-width: 0;
        flex-direction: column;
        padding: clamp(1.25rem, 3vw, 2rem);
    }

    .payment-panel h2 {
        margin: 0.55rem 0 0;
        font-family: var(--font-display);
        font-size: clamp(1.45rem, 2.5vw, 2rem);
        font-weight: 750;
        line-height: 1.1;
        letter-spacing: 0;
        color: var(--text-primary);
    }

    .payment-panel p:not(.payment-region):not(.payment-action-label) {
        margin: 0.9rem 0 0;
        color: var(--text-secondary);
        font-family: var(--font-body);
        font-size: 0.98rem;
        line-height: 1.65;
        letter-spacing: 0;
    }

    .payment-action {
        margin-top: auto;
        padding-top: 1.5rem;
    }

    .payment-action-label {
        margin-bottom: 0.75rem;
        color: var(--text-secondary);
    }

    .gateway-checkout-surface {
        display: block;
        width: 100%;
        min-height: 4rem;
        padding: 1rem;
        border: 1px solid var(--border-subtle);
        border-radius: 8px;
        background: color-mix(in srgb, var(--bg-canvas) 30%, transparent);
    }

    .paypal-native-frame,
    .razorpay-widget {
        display: block;
        width: 100%;
        min-width: 0;
        min-height: 3.25rem;
    }

    .paypal-native-frame {
        height: 31rem;
        overflow: hidden;
        border: 0;
    }

    @media (max-width: 860px) {
        .payment-panel {
            grid-template-columns: 1fr;
        }

        .gateway-visual {
            min-height: 12rem;
            border-right: 0;
            border-bottom: 1px solid var(--border-subtle);
        }
    }

    @media (max-width: 640px) {
        .payments-shell {
            padding: 4.75rem 0 3rem;
        }

        .payments-frame {
            max-width: none;
            margin: 0;
        }

        .payments-header {
            padding: 0 1.25rem;
        }

        .payment-panels {
            gap: 1rem;
            margin-top: 1.5rem;
        }

        .payment-panel {
            border-left: 0;
            border-right: 0;
            border-radius: 0;
        }

        .gateway-visual {
            min-height: 10.5rem;
        }
    }
</style>
