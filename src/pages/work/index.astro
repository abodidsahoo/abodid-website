---
import BaseLayout from "../../layouts/BaseLayout.astro";
import WorkIndexIsland from "../../components/portfolio/WorkIndexIsland.astro";
import ProgressiveContentSkeleton from "../../components/ProgressiveContentSkeleton.astro";

const title = "Work";
const description = "A curated portfolio of multidisciplinary projects spanning research, creative direction, photography, film, exhibitions and technology.";
---

<BaseLayout title={title} description={description} bodyClass="work-index-page">
  <div class="work-page-shell">
    <header class="work-page-header">
      <h1>Work</h1>
      <div class="work-page-intro">
        <p class="intro-large">All of my projects begin with a question. And the question is usually a "Why?"</p>
        <p class="intro-small">From there, I follow the idea into whatever form it needs: a film, a photo series, a piece of writing, a performance, an exhibition, or even an interactive digital experience.</p>
      </div>
    </header>
    <WorkIndexIsland server:defer>
      <ProgressiveContentSkeleton
        slot="fallback"
        variant="work"
        count={6}
        label="Loading selected work"
      />
    </WorkIndexIsland>
  </div>
</BaseLayout>
