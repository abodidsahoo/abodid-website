---
import BaseLayout from "../layouts/BaseLayout.astro";
import MinimalRenamerPage from "../components/research-workspace/MinimalRenamerPage";
import "../styles/paper-renamer.css";

const title = "Paper Renamer";
const description =
    "Upload PDF papers, clean their filenames, and download renamed copies.";
---

<BaseLayout
    title={title}
    description={description}
    showCursorFollower={false}
    bodyClass="paper-renamer-route"
>
    <MinimalRenamerPage client:load />
</BaseLayout>
