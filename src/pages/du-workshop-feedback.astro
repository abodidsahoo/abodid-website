---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Delhi University Workshop Feedback";
const pageDescription =
    "Optional feedback form for Delhi University students after Abodid Sahoo's ethnographic filmmaking workshop.";
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    image="/images/og/du-workshop-feedback.png"
    imageAlt="Workshop feedback"
    useDynamicOgImage={false}
    fullWidth={true}
    hideSideMenuRail={true}
    hideThemeToggle={true}
    showNewsletterPopup={false}
    showGlobalGrid={false}
    showCursorFollower={false}
    altTextLogo="abodid.com"
    bodyClass="du-feedback-route"
>
    <section class="du-feedback-page" aria-labelledby="du-feedback-title">
        <div class="du-feedback-shell">
            <aside class="du-feedback-intro" aria-label="Workshop note">
                <a class="du-site-mark" href="/">abodid.com</a>

                <p class="du-kicker">Delhi University Workshop</p>
                <h1 id="du-feedback-title">
                    Thank you for joining the ethnographic filmmaking workshop.
                </h1>
                <p class="du-intro-copy">
                    I am grateful for the questions, attention, and active
                    participation you brought into the room. It was lovely to
                    see the workshop come alive through your responses.
                </p>

                <div class="du-gratitude-note">
                    <p>
                        Warm thanks to <strong>Dr. Pratyasha Sahoo</strong> for
                        inviting me to conduct this workshop.
                    </p>
                </div>

                <div class="du-slide-deck-note">
                    <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                        <polyline points="7 10 12 15 17 10"></polyline>
                        <line x1="12" y1="15" x2="12" y2="3"></line>
                    </svg>
                    <p>
                        Fill out the feedback form to download the <strong>workshop slide deck</strong>.
                    </p>
                </div>
            </aside>

            <form class="du-feedback-form" data-du-feedback-form novalidate>
                <div class="du-form-head">
                    <p class="du-form-eyebrow">Quick optional feedback</p>
                    <h2>Share what stayed with you.</h2>
                    <p>
                        Answer any one question, or all four. Name and email ID
                        are only for students who want future notes, tips, and
                        workshop updates.
                    </p>
                </div>

                <div class="du-honeypot" aria-hidden="true">
                    <label for="du-website">Website</label>
                    <input
                        id="du-website"
                        name="website"
                        type="text"
                        tabindex="-1"
                        autocomplete="off"
                    />
                </div>

                <fieldset class="du-fieldset">
                    <legend>Optional details</legend>

                    <div class="du-identity-grid">
                        <label class="du-field" for="du-name">
                            <span>Your name</span>
                            <input
                                id="du-name"
                                name="name"
                                type="text"
                                autocomplete="name"
                                placeholder="Add your name if you wish"
                            />
                        </label>

                        <label class="du-field" for="du-email">
                            <span>Email ID for future notes</span>
                            <input
                                id="du-email"
                                name="email"
                                type="email"
                                inputmode="email"
                                autocomplete="email"
                                placeholder="name@example.com"
                            />
                        </label>
                    </div>
                </fieldset>

                <fieldset class="du-fieldset du-response-fields">
                    <legend>Feedback</legend>

                    <label class="du-field du-field--textarea" for="du-best-part">
                        <span>What was the best part?</span>
                        <textarea
                            id="du-best-part"
                            name="best_part"
                            rows="5"
                            data-auto-grow
                            placeholder="Tell me what felt useful, interesting, memorable, or worth keeping."
                        ></textarea>
                    </label>

                    <label class="du-field du-field--textarea" for="du-improvements">
                        <span>What could have been improved?</span>
                        <textarea
                            id="du-improvements"
                            name="improvements"
                            rows="5"
                            data-auto-grow
                            placeholder="Share anything that needed more time, clarity, structure, or examples."
                        ></textarea>
                    </label>

                    <label class="du-field du-field--textarea" for="du-future">
                        <span>What would you love to learn in a future workshop?</span>
                        <textarea
                            id="du-future"
                            name="future_workshop_topics"
                            rows="5"
                            data-auto-grow
                            placeholder="Topics, tools, exercises, readings, film practices, or questions you want explored next."
                        ></textarea>
                    </label>

                    <label class="du-field du-field--textarea" for="du-comments">
                        <span>Any other comments?</span>
                        <textarea
                            id="du-comments"
                            name="other_comments"
                            rows="4"
                            data-auto-grow
                            placeholder="Anything else you would like to share."
                        ></textarea>
                    </label>
                </fieldset>

                <p class="du-status" data-du-feedback-status role="status" aria-live="polite"></p>

                <div class="du-form-actions">
                    <button class="du-submit-button" type="submit" data-du-feedback-submit>
                        <span>Submit feedback</span>
                    </button>
                </div>
            </form>

            <section
                class="du-thank-you-card"
                data-du-feedback-thank-you
                hidden
                tabindex="-1"
                aria-live="polite"
            >
                <p class="du-form-eyebrow">Feedback received</p>
                <h2>Thank you for sharing your insights, thoughts, and feedback.</h2>
                <p>
                    I really appreciate you taking the time to respond. Your
                    feedback helps me understand what was useful, what could be
                    clearer, and what future workshops can hold.
                </p>

                <div class="du-download-box">
                    <p class="du-form-eyebrow">Workshop Resources</p>
                    <a
                        class="du-download-button"
                        href="https://jwipqbjxpmgyevfzpjjx.supabase.co/storage/v1/object/public/misc/workshop/Ethnographic%20Filmmaking%20Workshop%20by%20Abodid%20Sahoo%20for%20Delhi%20University-Send-to-Students.pdf"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <span>Download Slide Deck (PDF)</span>
                        <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                    </a>
                </div>

                <p class="du-photo-link-note">
                    If you would love to check out some of my favorite
                    photography work,
                    <a href="/photography">visit my photography work</a>.
                </p>
            </section>
        </div>
        <div class="du-footer-spacer" aria-hidden="true"></div>
    </section>
</BaseLayout>

<style>
    :global(body.du-feedback-route) {
        --du-red: var(--palette-red, #ea2a10);
        --du-light: var(--palette-light, #f9f8f3);
        --du-dark: var(--palette-dark, #010101);
        --du-sand: var(--palette-sand, #e0dbd3);
        --du-grey: var(--palette-grey, #9e9992);
        background: var(--du-light);
        color: var(--du-dark);
    }

    :global(body.du-feedback-route main) {
        min-height: 100svh;
    }

    .du-feedback-page {
        position: relative;
        min-height: 100svh;
        overflow: clip;
        overflow-anchor: none;
        background:
            linear-gradient(90deg, rgba(234, 42, 16, 0.11) 0 3px, transparent 3px 100%),
            linear-gradient(rgba(224, 219, 211, 0.55) 1px, transparent 1px),
            linear-gradient(90deg, rgba(224, 219, 211, 0.55) 1px, transparent 1px),
            var(--du-light);
        background-size:
            100% 100%,
            42px 42px,
            42px 42px,
            auto;
    }

    .du-feedback-page::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
            linear-gradient(180deg, rgba(249, 248, 243, 0.62), rgba(249, 248, 243, 0.92)),
            linear-gradient(90deg, transparent 0 68%, rgba(1, 1, 1, 0.045) 68% 100%);
    }

    .du-feedback-shell {
        position: relative;
        z-index: 1;
        display: grid;
        grid-template-columns: minmax(260px, 0.78fr) minmax(420px, 1.22fr);
        gap: clamp(0.85rem, 2vw, 1.4rem);
        width: min(1180px, calc(100% - clamp(1rem, 3vw, 2rem)));
        min-height: 100svh;
        margin: 0 auto;
        padding: clamp(1.25rem, 6svh, 4.75rem) 0 3rem;
        align-items: start;
        overflow-anchor: none;
    }

    .du-feedback-intro {
        position: sticky;
        top: 2rem;
        display: grid;
        gap: 1.2rem;
        padding: 1.6rem;
        border-radius: 8px;
        background: var(--du-dark);
        color: var(--du-light);
        box-shadow: 0 24px 50px rgba(1, 1, 1, 0.22);
    }

    .du-site-mark {
        width: fit-content;
        color: var(--du-light);
        font-family: var(--font-ui);
        font-size: 0.96rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0;
        text-decoration: none;
        border-bottom: 2px solid var(--du-red);
        padding-bottom: 0.24rem;
    }

    .du-kicker,
    .du-form-eyebrow {
        margin: 0;
        color: var(--du-red);
        font-family: var(--font-ui);
        font-size: 0.94rem;
        font-weight: 800;
        line-height: 1.2;
        letter-spacing: 0;
    }

    .du-feedback-intro h1 {
        margin: 0;
        max-width: 10ch;
        color: var(--du-light);
        font-family: var(--font-h1);
        font-size: clamp(2.2rem, 4.2vw, 3.05rem);
        font-weight: 850;
        line-height: 1.02;
        letter-spacing: 0;
    }

    .du-intro-copy {
        margin: 0;
        max-width: 34rem;
        color: rgba(249, 248, 243, 0.86);
        font-family: var(--font-body);
        font-size: 1.14rem;
        line-height: 1.62;
        letter-spacing: 0;
    }

    .du-gratitude-note {
        border-top: 1px solid rgba(249, 248, 243, 0.18);
        padding-top: 1rem;
    }

    .du-gratitude-note p {
        margin: 0;
        color: rgba(249, 248, 243, 0.78);
        font-family: var(--font-body);
        font-size: 1.04rem;
        line-height: 1.55;
        letter-spacing: 0;
    }

    .du-gratitude-note strong {
        color: var(--du-light);
        font-weight: 800;
    }

    .du-slide-deck-note {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding-top: 1.05rem;
        border-top: 1px solid rgba(249, 248, 243, 0.18);
    }

    .du-slide-deck-note svg {
        flex-shrink: 0;
        width: 1.25rem;
        height: 1.25rem;
        color: var(--du-red);
        margin-top: 0.15rem;
    }

    .du-slide-deck-note p {
        margin: 0;
        color: rgba(249, 248, 243, 0.86);
        font-family: var(--font-body);
        font-size: 1.04rem;
        line-height: 1.55;
    }

    .du-slide-deck-note strong {
        color: var(--du-light);
        font-weight: 800;
    }

    .du-feedback-form,
    .du-thank-you-card {
        display: grid;
        gap: 1.25rem;
        border: 1px solid rgba(1, 1, 1, 0.14);
        border-radius: 8px;
        background: rgba(255, 253, 248, 0.97);
        box-shadow: 0 24px 55px rgba(1, 1, 1, 0.12);
        padding: 1.3rem;
        overflow-anchor: none;
    }

    .du-feedback-form[hidden],
    .du-thank-you-card[hidden] {
        display: none;
    }

    .du-thank-you-card {
        align-content: start;
        min-height: min(34rem, calc(100svh - 8rem));
    }

    .du-thank-you-card h2 {
        margin: 0;
        max-width: 32ch;
        color: var(--du-dark);
        font-family: var(--font-h2);
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 850;
        line-height: 1.02;
        letter-spacing: 0;
    }

    .du-thank-you-card p:not(.du-form-eyebrow) {
        margin: 0;
        max-width: 38rem;
        color: rgba(1, 1, 1, 0.72);
        font-family: var(--font-body);
        font-size: 1.08rem;
        line-height: 1.65;
        letter-spacing: 0;
    }

    .du-download-box {
        display: grid;
        gap: 0.85rem;
        margin-top: 0.5rem;
        padding-top: 1.25rem;
        border-top: 1px solid rgba(1, 1, 1, 0.1);
    }

    .du-download-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.65rem;
        min-height: 3.55rem;
        width: fit-content;
        border: 1px solid var(--du-dark);
        border-radius: 8px;
        background: var(--du-dark);
        color: var(--du-light);
        font-family: var(--font-ui);
        font-size: 1.04rem;
        font-weight: 850;
        line-height: 1;
        letter-spacing: 0;
        padding: 1rem 1.45rem;
        text-decoration: none;
        cursor: pointer;
        touch-action: manipulation;
        transition:
            transform 0.18s ease,
            box-shadow 0.18s ease,
            background 0.18s ease;
        box-shadow: 0 8px 16px rgba(1, 1, 1, 0.12);
    }

    .du-download-button:hover,
    .du-download-button:focus-visible {
        background: #1a1a1a;
        box-shadow: 0 12px 24px rgba(1, 1, 1, 0.18);
        transform: translateY(-1px);
    }

    .du-download-button:active {
        transform: translateY(1px);
    }

    .du-download-button svg {
        width: 1.15rem;
        height: 1.15rem;
    }

    .du-photo-link-note {
        padding-top: 0.65rem;
        border-top: 1px solid rgba(1, 1, 1, 0.1);
    }

    .du-photo-link-note a {
        color: var(--du-dark);
        font-weight: 800;
        text-decoration: underline;
        text-decoration-color: var(--du-red);
        text-decoration-thickness: 2px;
        text-underline-offset: 0.18em;
    }

    .du-photo-link-note a:hover,
    .du-photo-link-note a:focus-visible {
        color: var(--du-red);
    }

    .du-form-head {
        display: grid;
        gap: 0.55rem;
        padding-bottom: 1.05rem;
        border-bottom: 1px solid rgba(1, 1, 1, 0.1);
    }

    .du-form-head h2 {
        margin: 0;
        color: var(--du-dark);
        font-family: var(--font-h2);
        font-size: clamp(1.65rem, 3vw, 2rem);
        font-weight: 850;
        line-height: 1.06;
        letter-spacing: 0;
    }

    .du-form-head p:not(.du-form-eyebrow) {
        margin: 0;
        max-width: 42rem;
        color: rgba(1, 1, 1, 0.7);
        font-family: var(--font-body);
        font-size: 1.05rem;
        line-height: 1.62;
        letter-spacing: 0;
    }

    .du-fieldset {
        display: grid;
        gap: 0.95rem;
        margin: 0;
        padding: 0;
        border: 0;
        min-width: 0;
    }

    .du-fieldset legend {
        margin: 0 0 0.7rem;
        padding: 0;
        color: var(--du-dark);
        font-family: var(--font-ui);
        font-size: 1rem;
        font-weight: 850;
        line-height: 1.2;
        letter-spacing: 0;
    }

    .du-identity-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 0.9rem;
    }

    .du-field {
        display: grid;
        gap: 0.52rem;
        min-width: 0;
    }

    .du-field span {
        color: rgba(1, 1, 1, 0.86);
        font-family: var(--font-ui);
        font-size: 1rem;
        font-weight: 750;
        line-height: 1.25;
        letter-spacing: 0;
    }

    .du-field input,
    .du-field textarea {
        width: 100%;
        border: 1px solid rgba(1, 1, 1, 0.18);
        border-radius: 8px;
        background: var(--du-light);
        color: var(--du-dark);
        font-family: var(--font-body);
        font-size: 1.0625rem;
        line-height: 1.55;
        letter-spacing: 0;
        padding: 0.95rem 1rem;
        outline: none;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.5);
        transition:
            border-color 0.18s ease,
            box-shadow 0.18s ease,
            background 0.18s ease;
        -webkit-appearance: none;
        appearance: none;
    }

    .du-field input {
        min-height: 3.55rem;
    }

    .du-field textarea {
        min-height: 10.5rem;
        resize: none;
        overflow: hidden;
        touch-action: pan-y;
    }

    .du-field textarea::placeholder,
    .du-field input::placeholder {
        color: rgba(1, 1, 1, 0.42);
        opacity: 1;
    }

    .du-field input:focus,
    .du-field textarea:focus {
        border-color: rgba(234, 42, 16, 0.78);
        background: #ffffff;
        box-shadow:
            0 0 0 4px rgba(234, 42, 16, 0.1),
            inset 0 1px 0 rgba(255, 255, 255, 0.64);
    }

    .du-response-fields {
        gap: 1rem;
    }

    .du-status {
        min-height: 1.55rem;
        margin: 0;
        color: rgba(1, 1, 1, 0.72);
        font-family: var(--font-ui);
        font-size: 1rem;
        font-weight: 650;
        line-height: 1.45;
        letter-spacing: 0;
    }

    .du-status[data-state="success"] {
        color: #146c31;
    }

    .du-status[data-state="error"] {
        color: var(--du-red);
    }

    .du-form-actions {
        position: sticky;
        bottom: 0;
        display: flex;
        justify-content: flex-end;
        margin: 0 -1.3rem -1.3rem;
        padding: 1rem 1.3rem calc(1rem + env(safe-area-inset-bottom));
        border-top: 1px solid rgba(1, 1, 1, 0.1);
        background: rgba(255, 253, 248, 0.92);
        backdrop-filter: blur(14px);
        border-radius: 0 0 8px 8px;
    }

    .du-submit-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3.55rem;
        min-width: 12rem;
        border: 1px solid var(--du-red);
        border-radius: 8px;
        background: var(--du-red);
        color: #ffffff;
        font-family: var(--font-ui);
        font-size: 1.04rem;
        font-weight: 850;
        line-height: 1;
        letter-spacing: 0;
        padding: 1rem 1.35rem;
        cursor: pointer;
        touch-action: manipulation;
        transition:
            transform 0.18s ease,
            box-shadow 0.18s ease,
            background 0.18s ease;
        box-shadow: 0 12px 24px rgba(234, 42, 16, 0.22);
    }

    .du-submit-button:hover,
    .du-submit-button:focus-visible {
        background: #c9210c;
        box-shadow: 0 14px 28px rgba(234, 42, 16, 0.27);
    }

    .du-submit-button:active {
        transform: translateY(1px);
    }

    .du-submit-button:disabled {
        cursor: wait;
        opacity: 0.72;
        box-shadow: none;
    }

    .du-honeypot {
        position: absolute;
        left: -10000px;
        width: 1px;
        height: 1px;
        overflow: hidden;
    }

    .du-footer-spacer {
        position: relative;
        z-index: 1;
        height: clamp(4rem, 12svh, 8rem);
    }

    @media (min-width: 1180px) {
        .du-feedback-intro h1 {
            font-size: 3.35rem;
        }
    }

    @media (max-width: 1120px) and (min-width: 961px) {
        .du-feedback-shell {
            grid-template-columns: minmax(250px, 0.72fr) minmax(390px, 1.28fr);
            width: min(1060px, calc(100% - 1.25rem));
        }

        .du-feedback-intro {
            padding: 1.2rem;
            gap: 0.95rem;
        }

        .du-feedback-intro h1 {
            font-size: 2.35rem;
        }

        .du-intro-copy {
            font-size: 1.02rem;
            line-height: 1.52;
        }
    }

    @media (max-width: 960px) {
        .du-feedback-shell {
            grid-template-columns: 1fr;
            width: min(760px, calc(100% - 1rem));
            min-height: auto;
            gap: 0.85rem;
            padding: 0.85rem 0 1.5rem;
        }

        .du-feedback-intro {
            position: relative;
            top: auto;
            gap: 0.9rem;
            padding: clamp(1rem, 3.5vw, 1.25rem);
        }

        .du-feedback-intro h1 {
            max-width: 18ch;
            font-size: clamp(1.85rem, 6.4vw, 2.35rem);
            line-height: 1.04;
        }

        .du-intro-copy,
        .du-gratitude-note p {
            font-size: 1rem;
            line-height: 1.5;
        }

        .du-gratitude-note {
            padding-top: 0.8rem;
        }

        .du-footer-spacer {
            height: clamp(3.25rem, 10svh, 5.5rem);
        }
    }

    @media (max-width: 640px) {
        .du-feedback-page {
            background-size:
                100% 100%,
                32px 32px,
                32px 32px,
                auto;
        }

        .du-feedback-shell {
            width: min(100% - 0.7rem, 640px);
            gap: 0.75rem;
            padding: 0.55rem 0 0.85rem;
        }

        .du-feedback-intro,
        .du-feedback-form,
        .du-thank-you-card {
            padding: 0.95rem;
        }

        .du-feedback-intro h1 {
            max-width: 16ch;
            font-size: clamp(1.78rem, 8.4vw, 2.05rem);
            line-height: 1.06;
        }

        .du-intro-copy,
        .du-form-head p:not(.du-form-eyebrow),
        .du-gratitude-note p {
            font-size: 1rem;
            line-height: 1.55;
        }

        .du-form-head h2 {
            font-size: clamp(1.52rem, 7vw, 1.65rem);
        }

        .du-thank-you-card {
            min-height: 20rem;
        }

        .du-feedback-page.is-submitted .du-feedback-shell {
            padding-top: 0.55rem;
        }

        .du-feedback-page.is-submitted .du-feedback-intro {
            display: none;
        }

        .du-thank-you-card h2 {
            max-width: none;
            font-size: clamp(1.95rem, 8.3vw, 2.35rem);
        }

        .du-thank-you-card p:not(.du-form-eyebrow) {
            font-size: 1rem;
            line-height: 1.58;
        }

        .du-identity-grid {
            grid-template-columns: 1fr;
        }

        .du-field input,
        .du-field textarea {
            font-size: 1.0625rem;
            padding: 0.92rem;
        }

        .du-field textarea {
            min-height: 10rem;
        }

        .du-form-actions {
            margin: 0 -1rem -1rem;
            padding: 0.8rem 1rem calc(0.8rem + env(safe-area-inset-bottom));
        }

        .du-submit-button,
        .du-download-button {
            width: 100%;
            min-width: 0;
            min-height: 3.65rem;
        }

        .du-footer-spacer {
            height: clamp(3rem, 9svh, 4.5rem);
        }
    }

    @media (max-width: 460px) {
        .du-feedback-intro h1 {
            max-width: 14ch;
        }

        .du-intro-copy {
            display: -webkit-box;
            overflow: hidden;
            -webkit-box-orient: vertical;
            -webkit-line-clamp: 4;
        }

        .du-gratitude-note p {
            font-size: 0.96rem;
        }
    }

    @media (max-width: 960px) and (max-height: 760px) {
        .du-feedback-intro {
            gap: 0.72rem;
        }

        .du-site-mark {
            font-size: 0.9rem;
        }

        .du-kicker {
            font-size: 0.88rem;
        }

        .du-feedback-intro h1 {
            font-size: clamp(1.65rem, 5.8vw, 2rem);
            max-width: none;
        }

        .du-intro-copy {
            font-size: 0.96rem;
            line-height: 1.45;
        }
    }
</style>

<script>
    const feedbackPage = document.querySelector(".du-feedback-page");
    const form = document.querySelector("[data-du-feedback-form]");
    const thankYouCard = document.querySelector("[data-du-feedback-thank-you]");
    const statusEl = document.querySelector("[data-du-feedback-status]");
    const submitButton = document.querySelector("[data-du-feedback-submit]");
    const autoGrowTextareas = Array.from(
        document.querySelectorAll("textarea[data-auto-grow]"),
    );
    const submittedStorageKey = "du_workshop_feedback_submitted_v1";

    const feedbackFieldNames = [
        "best_part",
        "improvements",
        "future_workshop_topics",
        "other_comments",
    ];

    function setStatus(message, state = "") {
        if (!statusEl) return;
        statusEl.textContent = message;
        if (state) {
            statusEl.setAttribute("data-state", state);
        } else {
            statusEl.removeAttribute("data-state");
        }
    }

    function hasSubmittedFeedback() {
        try {
            return localStorage.getItem(submittedStorageKey) === "true";
        } catch (_error) {
            return false;
        }
    }

    function markFeedbackSubmitted() {
        try {
            localStorage.setItem(submittedStorageKey, "true");
        } catch (_error) {
            // no-op
        }
    }

    function scrollToFeedbackTop() {
        const previousRootScrollBehavior = document.documentElement.style.scrollBehavior;
        const previousBodyScrollBehavior = document.body.style.scrollBehavior;
        document.documentElement.style.scrollBehavior = "auto";
        document.body.style.scrollBehavior = "auto";

        const forceTop = () => {
            window.scrollTo({ top: 0, left: 0, behavior: "auto" });
            document.documentElement.scrollTop = 0;
            document.body.scrollTop = 0;
        };

        forceTop();
        window.requestAnimationFrame(forceTop);
        window.setTimeout(forceTop, 80);
        window.setTimeout(forceTop, 240);
        window.setTimeout(forceTop, 520);
        window.setTimeout(() => {
            forceTop();
            document.documentElement.style.scrollBehavior = previousRootScrollBehavior;
            document.body.style.scrollBehavior = previousBodyScrollBehavior;
        }, 900);
    }

    function showThankYou({ persist = false, focus = false, scrollTop = false } = {}) {
        if (persist) {
            markFeedbackSubmitted();
        }

        if (feedbackPage instanceof HTMLElement) {
            feedbackPage.classList.add("is-submitted");
        }

        if (form instanceof HTMLFormElement) {
            form.hidden = true;
        }

        if (thankYouCard instanceof HTMLElement) {
            thankYouCard.hidden = false;
            if (focus) {
                thankYouCard.focus({ preventScroll: true });
            }
        }

        if (scrollTop) {
            scrollToFeedbackTop();
        }
    }

    function resizeTextarea(textarea) {
        if (!(textarea instanceof HTMLTextAreaElement)) return;

        textarea.style.height = "auto";
        textarea.style.height = `${textarea.scrollHeight}px`;
        textarea.style.overflowY = "hidden";
    }

    autoGrowTextareas.forEach((textarea) => {
        resizeTextarea(textarea);
        textarea.addEventListener("input", () => resizeTextarea(textarea));
    });

    window.addEventListener(
        "resize",
        () => {
            autoGrowTextareas.forEach((textarea) => resizeTextarea(textarea));
        },
        { passive: true },
    );

    if (hasSubmittedFeedback()) {
        showThankYou();
    }

    if (form instanceof HTMLFormElement) {
        form.addEventListener("submit", async (event) => {
            event.preventDefault();
            setStatus("");

            const formData = new FormData(form);
            const hasFeedback = feedbackFieldNames.some((fieldName) =>
                String(formData.get(fieldName) || "").trim(),
            );

            if (!hasFeedback) {
                setStatus("Please add at least one feedback response.", "error");
                const firstTextarea = form.querySelector("textarea[data-auto-grow]");
                if (firstTextarea instanceof HTMLTextAreaElement) {
                    firstTextarea.focus();
                }
                return;
            }

            const emailInput = form.querySelector("#du-email");
            if (emailInput instanceof HTMLInputElement && emailInput.value && !emailInput.validity.valid) {
                setStatus("Please enter a valid email ID, or leave it blank.", "error");
                emailInput.focus();
                return;
            }

            try {
                if (submitButton instanceof HTMLButtonElement) {
                    submitButton.disabled = true;
                    const buttonLabel = submitButton.querySelector("span");
                    if (buttonLabel) {
                        buttonLabel.textContent = "Submitting...";
                    }
                }

                const response = await fetch("/api/du-workshop-feedback", {
                    method: "POST",
                    body: formData,
                });
                const payload = await response.json().catch(() => ({}));

                if (!response.ok) {
                    throw new Error(payload.error || "Could not submit the form right now.");
                }

                if (document.activeElement instanceof HTMLElement) {
                    document.activeElement.blur();
                }

                form.reset();
                autoGrowTextareas.forEach((textarea) => resizeTextarea(textarea));
                showThankYou({ persist: true, focus: true, scrollTop: true });
            } catch (error) {
                setStatus(
                    error instanceof Error
                        ? error.message
                        : "Could not submit the form right now.",
                    "error",
                );
            } finally {
                if (submitButton instanceof HTMLButtonElement) {
                    submitButton.disabled = false;
                    const buttonLabel = submitButton.querySelector("span");
                    if (buttonLabel) {
                        buttonLabel.textContent = "Submit feedback";
                    }
                }
            }
        });
    }
</script>
