---
import BaseLayout from "../../layouts/BaseLayout.astro";

const pageTitle = "Video Editing & Storytelling: Class 2";
const description =
  "A focused browser-based teaching deck for pacing, editing cuts, J cuts, L cuts, transitions, rushes, markers, and sound support.";

const slides = [
  {
    number: "01",
    shortTitle: "Pacing",
    title: "Pacing is the Heart of Editing",
    preview: "Cut, hold, and shape what the audience feels.",
    subtext:
      "Editing is not about cutting fast. It is about knowing when to cut, when to hold, and what the audience should feel.",
    keyIdea:
      "A faster cut does not always mean better energy. Sometimes the strongest edit stays with a face, silence, or reaction.",
    activityLabel: "Opening exercise",
    activity:
      "Show one shot at three lengths: 3 seconds, 6 seconds, and 12 seconds. Ask when it felt emotional, awkward, or boring.",
    visual: "pacing",
  },
  {
    number: "02",
    shortTitle: "Fast vs Slow",
    title: "Speed of the Cut - Fast vs Slow",
    preview: "Rhythm comes from variation, pause, and release.",
    subtext:
      "Before learning specific cuts, notice rhythm. Editing rhythm comes from variation: fast, slow, pause, release.",
    keyIdea:
      "Fast-fast-fast becomes flat. Slow-fast-slow creates feeling. A slow cut can create intimacy, grief, suspense, or discomfort.",
    video: {
      url: "https://www.youtube.com/embed/p7Mds2k1bYI",
      title: "Thank You For Not Cutting Part 2",
      description:
        "This video supports the core pacing question: when should an editor resist cutting? Use it to discuss attention, duration, reaction, and the emotional power of holding a shot.",
    },
    activityLabel: "Activity",
    activity:
      "Show a reaction shot. Cut away early once, then hold longer once. Ask when we felt the character more.",
    visual: "rhythm",
  },
  {
    number: "03",
    shortTitle: "Cut Types",
    title: "The 7 Essential Cuts for Storytelling",
    preview: "A technique map for story, rhythm, and meaning.",
    subtext:
      "Different cuts solve different storytelling problems. The choice is not decorative; it changes attention, time, emotion, and continuity.",
    techniques: [
      {
        name: "Flow Cut",
        description: "Continues motion or attention across the cut.",
      },
      {
        name: "Smash Cut",
        description: "Breaks rhythm for shock, contrast, or tension.",
      },
      {
        name: "Jump Cut",
        description: "Skips forward in time inside the same setup.",
      },
      {
        name: "Action Cut",
        description: "Cuts during movement so the edit feels invisible.",
      },
      {
        name: "Wide-Medium-Close",
        description: "Moves from context to action to emotion or detail.",
      },
      {
        name: "Match Cut",
        description: "Links two shots through shape, motion, or idea.",
      },
      {
        name: "Speed of Cut",
        description: "Fast cuts build pressure; slow cuts add weight.",
      },
    ],
    activityLabel: "Prompt",
    activity:
      "Which cut would you use for comedy, tension, memory, or emotion?",
    visual: "cuts",
  },
  {
    number: "04",
    shortTitle: "J & L Cuts",
    title: "J Cut and L Cut",
    preview: "Sound can lead or linger across the visual cut.",
    subtext:
      "A J cut lets us hear the next shot before we see it. An L cut lets the previous sound continue after the image has changed.",
    keyIdea:
      "These cuts make scenes feel smoother, more natural, and more emotionally connected.",
    video: {
      url: "https://www.youtube.com/embed/eyH-a964kAs",
      title: "J cuts and L cuts explained",
      description:
        "This video explains how J cuts and L cuts use sound before or after the visual cut. It helps students understand that editing is not only visual; sound also controls flow.",
    },
    activityLabel: "Premiere exercise",
    activity:
      "Cut two clips normally. Then make one J cut and one L cut. Ask which version feels more natural.",
    visual: "jl",
  },
  {
    number: "05",
    shortTitle: "Transitions",
    title: "Transitions Have Psychology",
    preview: "Hard cuts, dissolves, and fades change how time feels.",
    subtext:
      "A hard cut feels immediate. A dissolve feels soft, emotional, dreamy, or time-based. A fade to black feels like a pause, ending, chapter break, or full stop.",
    keyIdea:
      "Do not use transitions because they look nice. Use them because they change how the viewer feels time, memory, or closure.",
    transitionCards: [
      {
        name: "Hard Cut",
        description: "Immediate. Present tense. No apology.",
      },
      {
        name: "Dissolve",
        description: "Softens time. Suggests memory, passage, or overlap.",
      },
      {
        name: "Fade / Dip to Black",
        description: "Creates pause, ending, chapter break, or emotional punctuation.",
      },
    ],
    referenceLinks: [
      {
        label: "Adobe: Dissolve transitions",
        href: "https://www.adobe.com/creativecloud/video/post-production/transitions/dissolve.html",
      },
      {
        label: "Film Editing Pro: Fades and dissolves",
        href: "https://www.filmeditingpro.com/fades-to-black-and-dissolves-what-you-need-to-know/",
      },
    ],
    activityLabel: "Activity",
    activity:
      "Show the same two shots as a hard cut, a cross-dissolve, and a fade to black. Ask which feels like memory and which feels like ending.",
    visual: "transitions",
  },
  {
    number: "06",
    shortTitle: "Rushes",
    title: "Rushes - Watch Before You Edit",
    preview: "Good editing begins before cutting.",
    subtext:
      "Rushes are the raw footage captured during production. Reviewing them carefully reveals hidden moments, alternate performances, cutaways, reactions, mistakes, and sound details.",
    keyIdea:
      "Good editing begins before cutting. It begins by watching carefully.",
    referenceLinks: [
      {
        label: "StudioBinder: Dailies",
        href: "https://www.studiobinder.com/blog/what-are-dailies-in-film/",
      },
      {
        label: "Netflix: Dailies best practices",
        href: "https://partnerhelp.netflixstudios.com/hc/en-us/articles/4415931246995-Dailies-Best-Practices",
      },
    ],
    activityLabel: "Viewing task",
    activity:
      "Review a small rushes folder and mark the best take, usable cutaway, weak shot, sound moment, and emotional moment.",
    visual: "rushes",
  },
  {
    number: "07",
    shortTitle: "Markers",
    title: "Markers Are Your Editing Memory",
    preview: "A simple color system turns watching into decisions.",
    subtext:
      "Markers help you remember good takes, emotional beats, mistakes, music hits, sound cues, and possible cut points.",
    markerSystem: [
      { color: "green", label: "Good moment" },
      { color: "red", label: "Problem" },
      { color: "blue", label: "Sound cue" },
      { color: "yellow", label: "Possible cut" },
      { color: "purple", label: "Emotional beat" },
    ],
    referenceLinks: [
      {
        label: "Adobe Premiere Pro: Markers",
        href: "https://helpx.adobe.com/in/premiere/desktop/organize-media/apply-labeling/overview-of-markers.html",
      },
    ],
    activityLabel: "Activity",
    activity:
      "Import rushes and add color/text markers before cutting anything.",
    visual: "markers",
  },
  {
    number: "08",
    shortTitle: "Sound Support",
    title: "Sound Makes Cuts Feel Invisible",
    preview: "Continuity often comes from the audio layer.",
    subtext:
      "Sound design is not only atmosphere. Room tone, breath, footsteps, cloth movement, ambience, whoosh, and silence can make cuts and transitions feel natural.",
    keyIdea:
      "A visual cut often becomes believable because the sound is continuous.",
    referenceLinks: [
      {
        label: "Film Editing Pro: Sound design",
        href: "https://www.filmeditingpro.com/how-to-sound-design-a-video-step-by-step-tutorial/",
      },
      {
        label: "Pro Sound Effects: Sound layering",
        href: "https://blog.prosoundeffects.com/sound-layering",
      },
    ],
    activityLabel: "Listening exercise",
    activity:
      "Play a cut without sound design. Add ambience, Foley, and one transition sound. Ask when the cut stopped feeling like a cut.",
    visual: "sound",
  },
  {
    number: "09",
    shortTitle: "Class Task",
    title: "Build a Pacing Exercise",
    preview: "A 30-45 second edit using cuts, markers, and sound layers.",
    subtext:
      "Create a short scene from rushes. The aim is not to show every technique; the aim is to choose cuts and sounds with intention.",
    taskItems: [
      "One J cut",
      "One L cut",
      "One hard cut",
      "One dissolve or fade",
      "At least three markers",
      "At least three sound layers",
      "One deliberately held shot",
    ],
    question: "What did you cut fast, what did you hold, and why?",
    activityLabel: "Final task",
    activity: "Build a 30-45 second scene and explain the pacing decisions.",
    visual: "task",
  },
];
---

<BaseLayout
  title={pageTitle}
  description={description}
  noindex={true}
  hideHeader={true}
  hideSideMenuRail={true}
  hideFooter={true}
  hideThemeToggle={true}
  fullWidth={true}
  showNewsletterPopup={false}
  showGlobalGrid={false}
  showCursor={false}
  bodyClass="research-workshop-deck-body"
>
  <section class="deck-app sidebar-collapsed" data-deck data-slide-count={slides.length}>
    <aside class="sidebar" aria-label="Slide navigation">
      <div class="sidebar-header">
        <p class="deck-kicker">Workshop deck</p>
        <h1>{pageTitle}</h1>
        <p class="deck-meta">Pacing / cuts / sound / workflow</p>
      </div>

      <nav class="thumbnail-list" aria-label="Slides">
        {
          slides.map((slide, index) => (
            <button
              class={`slide-thumbnail ${index === 0 ? "is-active" : ""}`}
              type="button"
              data-slide-target={index}
              aria-current={index === 0 ? "step" : "false"}
              aria-label={`Go to slide ${index + 1}: ${slide.title}`}
            >
              <span class="thumbnail-number">{slide.number}</span>
              <span class="thumbnail-copy">
                <span class="thumbnail-title">{slide.shortTitle}</span>
                <span class="thumbnail-preview">{slide.preview}</span>
              </span>
            </button>
          ))
        }
      </nav>
    </aside>

    <main class="deck-main" aria-label={pageTitle}>
      <header class="deck-topbar">
        <button
          class="sidebar-toggle"
          type="button"
          data-sidebar-toggle
          aria-expanded="false"
          aria-controls="deck-sidebar-state"
        >
          Slides
        </button>

        <div class="topbar-title" aria-hidden="true">
          <span>Video Editing &amp; Storytelling</span>
          <strong>Class 2</strong>
        </div>

        <div class="progress-indicator" aria-label="Deck progress">
          <span data-progress-label>Slide 1 of {slides.length}</span>
          <div
            class="progress-track"
            role="progressbar"
            aria-valuemin="1"
            aria-valuemax={slides.length}
            aria-valuenow="1"
            aria-valuetext={`Slide 1 of ${slides.length}`}
            data-progressbar
          >
            <span class="progress-fill" data-progress-fill></span>
          </div>
        </div>
      </header>

      <div id="deck-sidebar-state" class="sr-only" aria-live="polite">
        Slide navigation hidden.
      </div>

      <section class="slide-stage" aria-live="polite">
        <div class="slide-stack">
          {
            slides.map((slide, index) => (
              <article
                class={`slide-card ${index === 0 ? "is-active" : ""}`}
                data-slide={index}
                data-short-title={slide.shortTitle}
                aria-hidden={index === 0 ? "false" : "true"}
                tabindex="-1"
                hidden={index !== 0}
              >
                <header class="slide-header">
                  <span class="slide-number">{slide.number}</span>
                  <span class="slide-tag">Class 2 / Pacing &amp; Cuts</span>
                </header>

                <div class={`slide-content ${slide.video ? "has-video" : ""}`}>
                  <div class="slide-copy">
                    <h2>{slide.title}</h2>
                    <p class="slide-subtext">{slide.subtext}</p>

                    {slide.keyIdea && (
                      <div class="key-idea">
                        <span>Key idea</span>
                        <p>{slide.keyIdea}</p>
                      </div>
                    )}

                    {slide.techniques && slide.visual !== "cuts" && (
                      <div class="technique-list" aria-label="Seven editing cuts">
                        {slide.techniques.map((technique) => (
                          <div class="technique-pill">
                            <strong>{technique.name}</strong>
                            <span>{technique.description}</span>
                          </div>
                        ))}
                      </div>
                    )}

                    {slide.transitionCards && slide.visual !== "transitions" && (
                      <div class="transition-list" aria-label="Transition psychology">
                        {slide.transitionCards.map((transition) => (
                          <div class="transition-card">
                            <strong>{transition.name}</strong>
                            <span>{transition.description}</span>
                          </div>
                        ))}
                      </div>
                    )}

                    {slide.markerSystem && slide.visual !== "markers" && (
                      <div class="marker-list" aria-label="Marker color system">
                        {slide.markerSystem.map((marker) => (
                          <div class={`marker-row marker-${marker.color}`}>
                            <span></span>
                            <strong>{marker.label}</strong>
                          </div>
                        ))}
                      </div>
                    )}

                    {slide.taskItems && slide.visual !== "task" && (
                      <ul class="task-list">
                        {slide.taskItems.map((item) => (
                          <li>{item}</li>
                        ))}
                      </ul>
                    )}

                    <div class="activity-panel">
                      <span>{slide.activityLabel}</span>
                      <p>{slide.activity}</p>
                    </div>

                    {slide.question && (
                      <p class="question-line">{slide.question}</p>
                    )}

                  </div>

                  <div class="slide-visual-wrap">
                    {slide.video && (
                      <div class="video-panel">
                        <div class="video-copy">
                          <span>Watch together</span>
                          <p>{slide.video.description}</p>
                        </div>
                        <div class="video-frame">
                          <iframe
                            src={slide.video.url}
                            title={slide.video.title}
                            loading="lazy"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen
                          ></iframe>
                        </div>
                      </div>
                    )}

                    {!slide.video && slide.visual === "pacing" && (
                      <div
                        class="visual-board pacing-visual"
                        role="img"
                        aria-label="Three shot durations showing 3 seconds, 6 seconds, and 12 seconds."
                      >
                        <span class="visual-label">Hold vs cut</span>
                        {[
                          ["3 sec", "Information"],
                          ["6 sec", "Feeling"],
                          ["12 sec", "Pressure"],
                        ].map(([duration, meaning], itemIndex) => (
                          <div class={`pacing-row pacing-${itemIndex + 1}`}>
                            <span>{duration}</span>
                            <div>
                              <i></i>
                            </div>
                            <strong>{meaning}</strong>
                          </div>
                        ))}
                      </div>
                    )}

                    {!slide.video && slide.visual === "cuts" && (
                      <div
                        class="visual-board cuts-visual"
                        role="img"
                        aria-label="A map of essential storytelling cuts arranged as editing choices."
                      >
                        <span class="visual-label">Technique map</span>
                        <div class="cut-map">
                          {slide.techniques?.map((technique, itemIndex) => (
                            <div style={`--index: ${itemIndex}`}>
                              <strong>{technique.name}</strong>
                              <span>{technique.description}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}

                    {!slide.video && slide.visual === "transitions" && (
                      <div
                        class="visual-board transition-visual"
                        role="img"
                        aria-label="Hard cut, dissolve, and fade to black represented as transition states."
                      >
                        <span class="visual-label">Time feeling</span>
                        <div class="transition-strip hard">
                          <span>Shot A</span>
                          <b></b>
                          <span>Shot B</span>
                        </div>
                        <div class="transition-strip dissolve">
                          <span>Memory</span>
                          <b></b>
                          <span>Overlap</span>
                        </div>
                        <div class="transition-strip fade">
                          <span>Pause</span>
                          <b></b>
                          <span>End</span>
                        </div>
                      </div>
                    )}

                    {!slide.video && slide.visual === "rushes" && (
                      <div
                        class="visual-board rushes-visual"
                        role="img"
                        aria-label="A rushes bin with best take, cutaway, weak shot, sound, and emotional moment marked."
                      >
                        <span class="visual-label">Rushes review</span>
                        {[
                          ["A003", "Best take"],
                          ["B014", "Cutaway"],
                          ["C002", "Weak shot"],
                          ["D009", "Sound moment"],
                          ["E011", "Emotional beat"],
                        ].map(([clip, label]) => (
                          <div class="rush-row">
                            <span>{clip}</span>
                            <strong>{label}</strong>
                          </div>
                        ))}
                      </div>
                    )}

                    {!slide.video && slide.visual === "markers" && (
                      <div
                        class="visual-board markers-visual"
                        role="img"
                        aria-label="A timeline marker system using green, red, blue, yellow, and purple markers."
                      >
                        <span class="visual-label">Marker memory</span>
                        <div class="marker-timeline">
                          {slide.markerSystem?.map((marker) => (
                            <i class={`marker-dot marker-${marker.color}`}></i>
                          ))}
                        </div>
                        <div class="marker-legend">
                          {slide.markerSystem?.map((marker) => (
                            <span class={`marker-${marker.color}`}>{marker.label}</span>
                          ))}
                        </div>
                      </div>
                    )}

                    {!slide.video && slide.visual === "sound" && (
                      <div
                        class="visual-board sound-visual"
                        role="img"
                        aria-label="Audio continuity layers making a visual cut feel invisible."
                      >
                        <span class="visual-label">Continuity layer</span>
                        <div class="visual-cut">
                          <span>Shot A</span>
                          <b></b>
                          <span>Shot B</span>
                        </div>
                        {[
                          "Room tone",
                          "Breath",
                          "Footsteps",
                          "Ambience",
                          "Transition sound",
                        ].map((layer, itemIndex) => (
                          <div class="sound-layer" style={`--layer: ${itemIndex}`}>
                            <span>{layer}</span>
                          </div>
                        ))}
                      </div>
                    )}

                    {!slide.video && slide.visual === "task" && (
                      <div
                        class="visual-board task-visual"
                        role="img"
                        aria-label="A practical pacing exercise checklist."
                      >
                        <span class="visual-label">30-45 sec scene</span>
                        {slide.taskItems?.slice(0, 7).map((item) => (
                          <div class="task-check">
                            <span></span>
                            <strong>{item}</strong>
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
              </article>
            ))
          }
        </div>
      </section>

      <footer class="deck-controls" aria-label="Slide controls">
        <button class="control-button previous" type="button" data-prev disabled>
          <span aria-hidden="true">&larr;</span>
          <span>
            <small>Previous</small>
            <strong data-prev-label>Start</strong>
          </span>
        </button>

        <button class="control-button next" type="button" data-next>
          <span>
            <small>Next</small>
            <strong data-next-label>Fast vs Slow</strong>
          </span>
          <span aria-hidden="true">&rarr;</span>
        </button>
      </footer>
    </main>
  </section>

  <script>
    const app = document.querySelector("[data-deck]");
    const slideCards = Array.from(document.querySelectorAll("[data-slide]"));
    const thumbnails = Array.from(document.querySelectorAll("[data-slide-target]"));
    const previousButton = document.querySelector("[data-prev]");
    const nextButton = document.querySelector("[data-next]");
    const progressLabel = document.querySelector("[data-progress-label]");
    const progressBar = document.querySelector("[data-progressbar]");
    const progressFill = document.querySelector("[data-progress-fill]");
    const previousLabel = document.querySelector("[data-prev-label]");
    const nextLabel = document.querySelector("[data-next-label]");
    const sidebarToggle = document.querySelector("[data-sidebar-toggle]");
    const sidebarState = document.querySelector("#deck-sidebar-state");
    const smallViewport = window.matchMedia("(max-width: 760px)");
    const stackedViewport = window.matchMedia("(max-width: 900px)");
    let currentSlide = 0;

    if ("scrollRestoration" in history) {
      history.scrollRestoration = "manual";
    }

    const getTitle = (index) =>
      slideCards[index]?.getAttribute("data-short-title") || "";

    const keepActiveThumbnailVisible = () => {
      const activeThumbnail = thumbnails[currentSlide];
      const thumbnailList = activeThumbnail?.closest(".thumbnail-list");
      if (!(activeThumbnail instanceof HTMLElement) || !(thumbnailList instanceof HTMLElement)) {
        return;
      }

      const maxLeft = thumbnailList.scrollWidth - thumbnailList.clientWidth;
      const maxTop = thumbnailList.scrollHeight - thumbnailList.clientHeight;
      const targetLeft =
        activeThumbnail.offsetLeft -
        (thumbnailList.clientWidth - activeThumbnail.offsetWidth) / 2;
      const targetTop =
        activeThumbnail.offsetTop -
        (thumbnailList.clientHeight - activeThumbnail.offsetHeight) / 2;

      thumbnailList.scrollTo({
        left: Math.max(0, Math.min(targetLeft, maxLeft)),
        top: Math.max(0, Math.min(targetTop, maxTop)),
        behavior: "auto",
      });
    };

    const updateSidebarState = (isCollapsed) => {
      if (!app || !sidebarToggle || !sidebarState) return;
      app.classList.toggle("sidebar-collapsed", isCollapsed);
      sidebarToggle.setAttribute("aria-expanded", String(!isCollapsed));
      sidebarState.textContent = isCollapsed
        ? "Slide navigation hidden."
        : "Slide navigation visible.";

      if (!isCollapsed) {
        window.setTimeout(keepActiveThumbnailVisible, 0);
      }
    };

    const getSlideIndexFromHash = () => {
      const hashMatch = window.location.hash.match(/slide-(\d+)/);
      return hashMatch ? Number(hashMatch[1]) - 1 : 0;
    };

    const updateDeck = (targetIndex, options = {}) => {
      const nextIndex = Math.max(0, Math.min(targetIndex, slideCards.length - 1));
      currentSlide = nextIndex;

      slideCards.forEach((slide, index) => {
        const isActive = index === currentSlide;
        slide.hidden = !isActive;
        slide.classList.toggle("is-active", isActive);
        slide.setAttribute("aria-hidden", String(!isActive));
      });

      thumbnails.forEach((thumbnail, index) => {
        const isActive = index === currentSlide;
        thumbnail.classList.toggle("is-active", isActive);
        thumbnail.setAttribute("aria-current", isActive ? "step" : "false");
      });

      keepActiveThumbnailVisible();

      const slideNumber = currentSlide + 1;
      const totalSlides = slideCards.length;
      const remaining = totalSlides - slideNumber;
      const progressPercent = (slideNumber / totalSlides) * 100;

      if (previousButton instanceof HTMLButtonElement) {
        previousButton.disabled = currentSlide === 0;
      }

      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = currentSlide === totalSlides - 1;
      }

      if (progressLabel) {
        progressLabel.textContent = `Slide ${slideNumber} of ${totalSlides}`;
      }

      if (progressBar) {
        progressBar.setAttribute("aria-valuenow", String(slideNumber));
        progressBar.setAttribute("aria-valuetext", `Slide ${slideNumber} of ${totalSlides}`);
      }

      if (progressFill instanceof HTMLElement) {
        progressFill.style.width = `${progressPercent}%`;
      }

      if (previousLabel) {
        previousLabel.textContent =
          currentSlide > 0 ? getTitle(currentSlide - 1) : "Start";
      }

      if (nextLabel) {
        nextLabel.textContent =
          currentSlide < totalSlides - 1 ? getTitle(currentSlide + 1) : "Complete";
      }

      if (options.updateHash !== false) {
        history.replaceState(null, "", `#slide-${slideNumber}`);
      }

      if (options.focus) {
        slideCards[currentSlide]?.focus({ preventScroll: true });
      }

      if (stackedViewport.matches) {
        window.requestAnimationFrame(() => window.scrollTo(0, 0));
      }
    };

    thumbnails.forEach((thumbnail) => {
      thumbnail.addEventListener("click", () => {
        const target = Number(thumbnail.getAttribute("data-slide-target"));
        updateDeck(target);
        if (smallViewport.matches) {
          updateSidebarState(true);
        }
      });
    });

    previousButton?.addEventListener("click", () => updateDeck(currentSlide - 1));
    nextButton?.addEventListener("click", () => updateDeck(currentSlide + 1));

    sidebarToggle?.addEventListener("click", () => {
      const shouldCollapse = !app?.classList.contains("sidebar-collapsed");
      updateSidebarState(shouldCollapse);
    });

    document.addEventListener("keydown", (event) => {
      const activeElement = document.activeElement;
      const isTyping =
        activeElement instanceof HTMLInputElement ||
        activeElement instanceof HTMLTextAreaElement ||
        activeElement instanceof HTMLSelectElement ||
        activeElement instanceof HTMLIFrameElement ||
        activeElement?.hasAttribute("contenteditable");

      if (isTyping) return;

      if (event.key === "ArrowRight") {
        event.preventDefault();
        updateDeck(currentSlide + 1);
      }

      if (event.key === "ArrowLeft") {
        event.preventDefault();
        updateDeck(currentSlide - 1);
      }
    });

    window.addEventListener("hashchange", () => {
      const hashSlide = getSlideIndexFromHash();
      if (hashSlide !== currentSlide) {
        updateDeck(hashSlide, { updateHash: false });
      }
    });

    const initialSlide = getSlideIndexFromHash();
    updateSidebarState(smallViewport.matches);
    updateDeck(initialSlide, { updateHash: false });
  </script>
</BaseLayout>

