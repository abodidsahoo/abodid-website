---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlogFilter from "../../components/BlogFilter.jsx";
import { getAllPosts } from "../../lib/api";
import { breadcrumbJsonLd, personJsonLd } from "../../lib/seoData";

const recentPosts = await getAllPosts();
const pageTitle = "Blog";
const description =
  "Writing by Abodid Sahoo on creative technology, photography, filmmaking, research workflows, Obsidian, AI, visual culture, and learning.";
const structuredData = [
  personJsonLd(),
  breadcrumbJsonLd([
    { name: "Home", path: "/" },
    { name: "Blog", path: "/blog" },
  ]),
];
---

<BaseLayout title={pageTitle} description={description} structuredData={structuredData}>
  <header class="page-header">
    <h1>Blog</h1>
    <p class="section-intro">
      Notes on creative technology, photography, filmmaking, research workflows,
      Obsidian, AI, visual culture, and learning.
    </p>
  </header>

  <div class="blog-container">
    <BlogFilter posts={recentPosts} client:load />
  </div>
</BaseLayout>

<style>
  .blog-container {
    margin-bottom: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }

  .page-header {
    margin-bottom: 4rem;
    padding-top: 2rem;
    text-align: left;
  }

  h1 {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .section-intro {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--text-secondary);
    max-width: 600px;
    line-height: 1.6;
  }
</style>
