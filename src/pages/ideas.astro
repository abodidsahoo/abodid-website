---
export const prerender = false;

import IdeasBoard from "../components/IdeasBoard.jsx";
import BaseLayout from "../layouts/BaseLayout.astro";
import { supabase } from "../lib/supabase";

const { data, error } = await supabase
    .from("ideas_notes")
    .select("id, title, body, created_at")
    .order("created_at", { ascending: false })
    .limit(200);

const pageTitle = "Ideas in Motion | Abodid Sahoo";
const description = "An open public scratchpad for passing thoughts, reminders, and ideas in progress.";
---

<BaseLayout title={pageTitle} description={description} fullWidth={true}>
    <IdeasBoard
        client:load
        initialNotes={data || []}
        initialLoadError={error ? "The ideas board could not be loaded just now." : ""}
    />
</BaseLayout>
