---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    getFeaturedPhotography,
    getRecentPosts,
    getMediaMentions,
    getFilms,
} from "../lib/api";

import {
    featuredPhotography as mockPhotography,
    recentPosts as mockRecent,
} from "../utils/mockData";

import Showreel from "../components/Showreel.astro";

import PhotoGrid from "../components/PhotoGrid.astro";
import { personJsonLd, websiteJsonLd } from "../lib/seoData";

// LiquidCursor moved to BaseLayout
// EngagementCTA moved to LandingOrchestrator
import ForceDarkMode from "../components/ForceDarkMode.astro";
import uk2026 from "../data/uk2026.json";

const pageTitle = "Creative Technology Consultant & Obsidian Tutor";
const pageDescription =
    "Hire Abodid Sahoo for creative technology consulting, AI-assisted research workflows, Obsidian tutoring, photography, filmmaking, and visual storytelling.";

// Helper to safely fetch data
const safeFetch = async (fn, fallback) => {
    try {
        return await fn();
    } catch (e) {
        console.error("Data fetch failed:", e);
        return fallback;
    }
};

// Fetch data from Supabase with Fallback
const featuredPhotography = await safeFetch(
    getFeaturedPhotography,
    mockPhotography,
);
const recentPosts = (await safeFetch(getRecentPosts, mockRecent)).slice(0, 3);
const mediaMentions = await safeFetch(getMediaMentions, []);
const films = await safeFetch(getFilms, []);

const landingPhotographyProjectLimit = 7;
const pickFixedRandomProjects = (items, limit) => {
    const shuffled = Array.isArray(items) ? [...items] : [];

    for (let index = shuffled.length - 1; index > 0; index -= 1) {
        const swapIndex = Math.floor(Math.random() * (index + 1));
        [shuffled[index], shuffled[swapIndex]] = [
            shuffled[swapIndex],
            shuffled[index],
        ];
    }

    return shuffled.slice(0, limit);
};
const landingPhotographyProjects = pickFixedRandomProjects(
    featuredPhotography,
    landingPhotographyProjectLimit,
);

// Helper to find link by name match
const findLink = (name) => {
    const term = name.toLowerCase();

    // 1. Search Media Mentions (Publication or Title)
    const mediaMatch = mediaMentions.find(
        (m) =>
            (m.publication && m.publication.toLowerCase().includes(term)) ||
            (m.title && m.title.toLowerCase().includes(term)),
    );
    if (mediaMatch) return mediaMatch.url;

    // 2. Search Films (Title or Description)
    const filmMatch = films.find(
        (f) =>
            (f.title && f.title.toLowerCase().includes(term)) ||
            (f.description && f.description.toLowerCase().includes(term)),
    );
    if (filmMatch) return filmMatch.videoUrl || "/films"; // Fallback to /films if videoUrl missing

    return "/press"; // Default fallback
};

// Resolve Links for Showreel Notes - Direct URLs
const vh1Url =
    "https://www.edexlive.com/breaking/2021/Jan/05/four-roommates-shot-a-music-video-in-their-mumbai-flat-and-it-received-a-premiere-on-vh1-17053.html";
const rollingStoneUrl =
    "https://rollingstoneindia.com/watch-electronic-pop-duo-xys-cinematic-video-for-debut-single-show-me-the-way/";
const homegrownUrl =
    "https://homegrown.co.in/homegrown-explore/when-creative-minds-collide-xys-show-me-the-way-music-video-is-visual-pleasure";
const educateGirlsUrl = findLink("Educate Girls");
const curvesColorsUrl = findLink("Curves and Colors");
const pursuitUrl = "https://www.pursuitofportraits.com/";
const hermosaUrl = "https://www.youtube.com/watch?v=EMsZT9PCFms";
const budweiserUrl = "https://www.weareanimal.co/budweiser-streetwear";
const wiedenUrl = findLink("Wieden");
const animalUrl = findLink("Animal");
const jawaUrl = "http://youtube.com/watch?v=CSmZHXpr13E";
const odishaUrl = "https://vimeo.com/265220711";

const supportProjects = [
    {
        id: "cambridge-data-school",
        href: "/fundraising/cambridge-data-school",
        image: "https://wallpapersok.com/images/high/cambridge-university-hall-7n378cd5chdvjxdg.jpg",
        imageAlt: "University of Cambridge, United Kingdom",
        title: "Looking for Partners for Cultural Heritage Data School",
        description:
            "I have been offered a place in the Cultural Heritage Data School happening in April 2026 at the University of Cambridge with a program fee bursary.",
    },
    {
        id: "bsa-conference-2026",
        href: "/fundraising/bsa-conference-2026",
        image: "https://sociology.plus/wp-content/uploads/2022/07/British-Sociological-Association.png",
        imageAlt: "BSA Annual Conference 2026",
        title: "Looking for partners to support my BSA Conference 2026 journey",
        description:
            "Two peer-reviewed research works have been accepted at the BSA Annual Conference. My conference registration fee is already funded.",
    },
];
const showLandingSupportSection = false;

const heroHeadingLines = [
    ["Hi,", "I", "am", "Abodid."],
    ["I", "work", "at", "the", "intersection", "of", "..."],
];
const heroBioWords =
    "I help people and organizations build creative technology projects, research workflows, Obsidian systems, photographs, films, and visual stories that are thoughtful, useful, and human.".split(
        " ",
    );
const uk2026Feature = {
    href: "/uk2026",
    image: "/images/uk2026/cambridge-data-school.jpg",
    imageAlt:
        "Abodid Sahoo with Prof. Eleanor Dare at Cambridge Digital Humanities",
    kicker: "Read my Latest Memoir",
    title: uk2026.title,
    excerpt:
        "It all started when, on one winter evening around October 2025, Yashaswinee, my wife, shared a link with me about a conference in the UK. It was the British Sociological Association’s Annual Conference...",
    action: "Read the full memoir",
    description:
        "A memoir of my trip to the Annual Conference of the British Sociological Association and the Cultural Heritage Data School at the University of Cambridge last month.",
};

// Toggle between "typewriter" and "smooth-blur" for the landing hero copy.
const heroTextEffect = "smooth-blur";
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    imageAlt="Portfolio preview for Abodid Sahoo"
    useDynamicOgImage={false}
    bodyClass="landing-page"
    structuredData={[personJsonLd(), websiteJsonLd()]}
>
    <Fragment slot="head">
        {
            landingPhotographyProjects.slice(0, 4).map((project) => {
                const imageUrl = project?.image || project?.cover_image;
                return imageUrl ? (
                    <link rel="preload" as="image" href={imageUrl} />
                ) : null;
            })
        }
    </Fragment>

    <!-- Force dark mode on landing page - core to the experience -->
    <ForceDarkMode />

    <section class="narrative-section">
        <div class="hero-content">
            <h1 class="hero-title" data-hero-copy>
                {
                    heroHeadingLines.map((line) => (
                        <span class="hero-title-line" data-hero-word-line>
                            {line.map((word) => (
                                <span class="hero-word" data-hero-word>
                                    {word}
                                </span>
                            ))}
                        </span>
                    ))
                }
                <span
                    class="hero-title-line hero-title-line-dynamic"
                    data-hero-dynamic-line
                >
                    <span
                        id="typewriter-text"
                        class="typing-text"
                        data-text-effect={heroTextEffect}
                        aria-live="polite"
                        aria-atomic="true"
                    >
                        Creative technology, AI research workflows, Obsidian
                        tutoring, photography, and film.
                    </span>
                </span>
            </h1>
            <div class="bio-content">
                <p class="hero-bio-line" data-hero-word-line>
                    {
                        heroBioWords.map((word) => (
                            <span
                                class="hero-word hero-bio-word"
                                data-hero-word
                            >
                                {word}
                            </span>
                        ))
                    }
                </p>
            </div>
        </div>
    </section>

    <section class="section latest-note-section" aria-labelledby="uk2026-note-title">
        <a href={uk2026Feature.href} class="uk2026-card">
            <figure class="uk2026-media-group">
                <div class="uk2026-media">
                    <img
                        src={uk2026Feature.image}
                        alt={uk2026Feature.imageAlt}
                        loading="eager"
                        decoding="async"
                    />
                </div>
                <figcaption class="uk2026-caption">Abodid Sahoo (Left), Eleanor Dare (Right) - Convenor of the Cultural Heritage Data School, Cambridge Digital Humanities, University of Cambridge<span class="uk2026-photo-credit">Photograph by Yashaswinee Sahoo</span></figcaption>
            </figure>

            <div class="uk2026-content">
                <div class="uk2026-header-panel">
                    <p class="uk2026-kicker">{uk2026Feature.kicker}</p>
                    <h2 id="uk2026-note-title" set:html={uk2026Feature.title.replace("beloved ", "beloved&nbsp;")} />
                </div>
                <div class="uk2026-footer-panel">
                    <p class="uk2026-meta-desc">{uk2026Feature.description}</p>
                    <span class="uk2026-action">{uk2026Feature.action}</span>
                </div>
            </div>
        </a>
    </section>

    <!-- Blog Section -->
    <section class="section blog-section">
        <div class="section-header">
            <h2 class="section-title">Writings</h2>
            <a href="/blog" class="link-arrow mobile-btn section-cta"
                >Read All</a
            >
        </div>

        <div class="blog-list">
            {
                recentPosts.map((post) => (
                    <a href={post.href} class="blog-card">
                        <div class="blog-image-wrapper">
                            {post.image ? (
                                <img
                                    src={post.image}
                                    alt={post.title}
                                    class="blog-image"
                                    loading="lazy"
                                />
                            ) : (
                                <div class="blog-image-placeholder" />
                            )}
                        </div>

                        <div class="blog-content">
                            <span class="blog-date">{post.date}</span>
                            <h3 class="blog-title">{post.title}</h3>
                            <div class="blog-category">
                                {post.category &&
                                    (Array.isArray(post.category)
                                        ? post.category[0]
                                        : post.category)}
                            </div>
                        </div>

                        <div class="blog-action">
                            <span>VIEW MORE</span>
                            <span class="arrow">→</span>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>

    <!-- Showreel Section - edge-to-edge silent autoplay -->
    <section class="section writings-section">
        <Showreel
            vh1Url={vh1Url}
            rollingStoneUrl={rollingStoneUrl}
            homegrownUrl={homegrownUrl}
            educateGirlsUrl={educateGirlsUrl}
            curvesColorsUrl={curvesColorsUrl}
            pursuitUrl={pursuitUrl}
            hermosaUrl={hermosaUrl}
            budweiserUrl={budweiserUrl}
            wiedenUrl={wiedenUrl}
            animalUrl={animalUrl}
            jawaUrl={jawaUrl}
            odishaUrl={odishaUrl}
        />
    </section>

    <!-- Massive Spacer 3 (Showreel to Featured) -->
    <!-- Responsive Spacer -->
    <div class="responsive-spacer" aria-hidden="true"></div>

    <!-- Photo Stories -->
    <section class="section contained-section">
        <div class="section-header">
            <h2 class="section-title">Photography Projects</h2>
            <a
                href="/photography"
                class="link-arrow mobile-btn section-cta photo-projects-cta"
                >View All</a
            >
        </div>

        <!-- Contained Carousel Row 1 (Left) -->
        <PhotoGrid
            projects={landingPhotographyProjects}
            maxItems={landingPhotographyProjectLimit}
            columns={2}
            contained={true}
        />
    </section>

    {
        showLandingSupportSection && (
            <>
                <div class="major-section-separator writing-support-separator" />

                <section class="section support-section">
                    <div class="section-header">
                        <h2 class="section-title">Support Me</h2>
                        <a
                            href="/fundraising"
                            class="link-arrow mobile-btn section-cta"
                        >
                            View All
                        </a>
                    </div>

                    <div class="support-projects">
                        {supportProjects.map((project) => (
                            <article class="support-project" id={project.id}>
                                <a
                                    href={project.href}
                                    class="support-project-image-link"
                                >
                                    <img
                                        src={project.image}
                                        alt={project.imageAlt}
                                        class="support-project-image"
                                        loading="lazy"
                                    />
                                </a>

                                <div class="support-project-content">
                                    <a
                                        href={project.href}
                                        class="support-project-title-link"
                                    >
                                        <h3 class="support-project-title">
                                            {project.title}
                                        </h3>
                                    </a>
                                    <p class="support-project-description">
                                        {project.description}
                                    </p>
                                    <a
                                        href={project.href}
                                        class="support-project-action"
                                    >
                                        View support details →
                                    </a>
                                </div>
                            </article>
                        ))}
                    </div>
                </section>
            </>
        )
    }
</BaseLayout>

<style>
    :global(body.landing-page .header-padding) {
        padding-top: clamp(28px, 4vh, 56px) !important;
    }

    .narrative-section {
        position: relative;
        z-index: 100;
        min-height: auto;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        gap: clamp(1.5rem, 3.5vh, 3rem);
        padding: clamp(2rem, 5.5vh, 4.5rem) 24px clamp(1.5rem, 4vh, 2.5rem);
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        margin-bottom: 0;
    }

    .hero-content {
        --hero-copy-stage-shift: 0px;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: clamp(2.5rem, 5vh, 4.5rem);
        margin-top: clamp(16px, 2vh, 24px);
        max-width: min(100%, 980px);
        transform: translate3d(0, calc(var(--hero-copy-stage-shift) * -1), 0);
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform;
    }

    .hero-title {
        margin: 0;
        display: grid;
        gap: 0.06em;
        font-family: var(--feature-typewriter-main-font, var(--font-sans));
        font-size: clamp(
            2.35rem,
            1.35rem + 2.55vw,
            var(--feature-typewriter-main-size, 3.5rem)
        );
        font-weight: var(--feature-typewriter-main-weight, 700);
        line-height: var(--feature-typewriter-main-line-height, 1.1);
        letter-spacing: var(--feature-typewriter-main-letter-spacing, 0em);
        color: var(--feature-typewriter-main-color, var(--text-primary));
        width: 100%;
        max-width: 100%;
    }

    .hero-title-line {
        --hero-line-shift: 0px;
        --hero-line-opacity: 1;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.12em 0.18em;
        width: 100%;
        min-width: 0;
        max-width: 100%;
        opacity: var(--hero-line-opacity);
        transform: translate3d(0, calc(var(--hero-line-shift) * -1), 0);
        transition:
            opacity 0.32s linear,
            transform 0.58s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
    }

    .hero-title-line-dynamic {
        --hero-dynamic-shift: 0px;
        --hero-dynamic-opacity: 1;
        width: 100%;
        max-width: min(100%, calc(100vw - 48px));
        opacity: var(--hero-dynamic-opacity);
        transform: translate3d(0, calc(var(--hero-dynamic-shift) * -1), 0);
        transition:
            opacity 0.32s linear,
            transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
    }

    .hero-word {
        display: inline-block;
        backface-visibility: hidden;
    }

    .bio-content {
        max-width: min(100%, 840px);
    }

    .hero-bio-line {
        --hero-line-shift: 0px;
        --hero-line-opacity: 1;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.16em 0.24em;
        font-family: var(--feature-typewriter-bio-font, var(--font-body));
        font-size: clamp(
            1.2rem,
            0.78rem + 1.58vw,
            var(--feature-typewriter-bio-size, 2.2rem)
        );
        font-weight: var(--feature-typewriter-bio-weight, 300);
        line-height: var(--feature-typewriter-bio-line-height, 1.2);
        letter-spacing: var(--feature-typewriter-bio-letter-spacing, 0em);
        color: var(--feature-typewriter-bio-color, var(--text-secondary));
        opacity: var(--hero-line-opacity);
        transform: translate3d(0, calc(var(--hero-line-shift) * -1), 0);
        transition:
            opacity 0.32s linear,
            transform 0.58s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
    }

    @media (max-width: 1800px) and (min-width: 980px) {
        :global(body.landing-page .header-padding) {
            padding-top: clamp(32px, 4.5vh, 60px) !important;
        }

        .narrative-section {
            gap: clamp(1.6rem, 3vh, 2.6rem);
            padding-top: clamp(2.6rem, 6vh, 4.75rem);
            padding-bottom: clamp(2.4rem, 5.5vh, 4rem);
            max-width: 1100px;
        }

        .hero-content {
            gap: clamp(2.7rem, 4.8vh, 4.1rem);
            max-width: min(100%, 1020px);
        }

        .hero-title {
            font-size: clamp(2.96rem, 2.16rem + 1.98vw, 3.9rem);
        }

        .bio-content {
            max-width: min(100%, 940px);
        }

        .hero-bio-line {
            font-size: clamp(1.92rem, 1.39rem + 1.29vw, 2.52rem);
        }

        #typewriter-text {
            font-size: 1.56em;
        }

        .writings-section {
            padding-top: 0;
        }
    }

    @media (max-width: 979px) {
        :global(body.landing-page .header-padding) {
            padding-top: clamp(24px, 3.5vh, 42px) !important;
        }

        .narrative-section {
            gap: 1.25rem;
            padding-top: clamp(2.1rem, 5.5vh, 3.8rem);
        }

        .hero-content {
            gap: 1.9rem;
            margin-top: clamp(12px, 1.7vh, 18px);
            max-width: min(100%, 780px);
        }

        .hero-title {
            font-size: clamp(2rem, 1.4rem + 1.6vw, 2.55rem);
        }

        .hero-bio-line {
            font-size: clamp(1.34rem, 1rem + 1.05vw, 1.78rem);
        }
    }

    .major-section-separator {
        height: 30vh;
        min-height: 220px;
        width: 100%;
    }

    :global(body.landing-page .contained-section .photography-card) {
        --photo-card-image-scale-hover: 1.006;
        --photo-card-image-transition: transform 1.5s
            cubic-bezier(0.23, 1, 0.32, 1);
    }

    @media (max-width: 768px) {
        :global(body.landing-page .header-padding) {
            padding-top: clamp(18px, 3vh, 30px) !important;
        }

        .narrative-section {
            min-height: auto;
            padding-top: clamp(1.25rem, 4vh, 2.4rem);
            padding-left: 0;
            padding-right: 0;
            padding-bottom: 2.5rem;
            margin-bottom: 1.5rem;
            gap: clamp(1.8rem, 5vh, 2.6rem);
        }

        .hero-title {
            font-size: min(
                calc(var(--feature-typewriter-main-size, 3.5rem) * 0.5),
                2.5rem
            ) !important;
            line-height: 1.3 !important;
        }

        .hero-title-line {
            gap: 0.12em 0.16em;
        }

        #typewriter-text {
            margin-top: 0.5rem;
            min-height: 6.25em;
            overflow: hidden;
        }

        #typewriter-text[data-text-effect="typewriter"] {
            display: block;
        }

        #typewriter-text[data-text-effect="smooth-blur"] {
            display: grid;
        }

        .hero-bio-line {
            font-size: min(
                calc(var(--feature-typewriter-bio-size, 2.2rem) * 0.52),
                1.125rem
            ) !important;
            line-height: 1.5 !important;
        }

        .note-grid {
            display: none !important;
        }

        .section {
            margin-bottom: 5rem;
        }

        .blog-card {
            grid-template-columns: 1fr;
            padding: 0;
            margin-left: 0;
            margin-right: 0;
            margin-bottom: 2rem;
            border-bottom: none;
            gap: 0;
            width: 100%;
        }

        .blog-list {
            display: flex;
            flex-direction: column;
            gap: 0;
            width: 100%;
            padding: 0;
            margin: 0;
        }

        .blog-image-wrapper {
            width: 100%;
            height: 200px;
        }

        .blog-action {
            display: block;
            margin-top: 0.5rem;
            font-size: 0.75rem;
        }
    }

    /* ... type writer styles ... */

    /* Desktop alignment for Showreel & Notes to match Narrative block width */
    /* REMOVED: Now handled by wrapper .section with padding */
    /* :global(.showreel-container),
    :global(.note-grid) {
        padding-left: 4vw;
        padding-right: 4vw;
    } */

    @media (max-width: 768px) {
        .major-section-separator {
            height: 16vh;
            min-height: 128px;
        }
    }

    .italic {
        font-style: italic;
        font-weight: 400;
    }

    .section {
        margin-bottom: clamp(5rem, 10vh, 7.5rem);
        /* Ensure sections align with the grid */
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 24px;
        padding-right: 24px;
    }

    .latest-note-section {
        margin-top: clamp(1rem, 3vh, 2.25rem);
        margin-bottom: clamp(4.5rem, 8vh, 6.5rem);
    }

    .uk2026-card {
        display: grid;
        grid-template-columns: 1.15fr 1fr;
        border: 1px solid #e2e8f0;
        border-radius: 0;
        background: #ffffff;
        color: #0f172a;
        text-decoration: none;
        padding: 0;
        transition:
            border-color 220ms ease,
            background-color 220ms ease,
            transform 220ms ease,
            box-shadow 220ms ease;
    }

    .uk2026-card:hover,
    .uk2026-card:focus-visible {
        border-color: #0f172a;
        background-color: #ffffff;
        transform: translateY(-2px);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.08);
        outline: none;
    }

    .uk2026-media-group {
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: clamp(1.5rem, 3vw, 3rem);
        border-right: 1px solid #e2e8f0;
    }

    .uk2026-media {
        position: relative;
        margin: 0;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-radius: 0;
        background: #f1f5f9;
    }

    .uk2026-caption {
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 450;
        line-height: 1.5;
        color: #475569;
        text-align: left;
        margin-top: 0.5rem;
    }

    .uk2026-photo-credit {
        display: block;
        margin-top: 0.4rem;
        font-size: 0.7rem;
        font-weight: 500;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .uk2026-media img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
        transition: transform 900ms cubic-bezier(0.23, 1, 0.32, 1);
    }

    .uk2026-card:hover .uk2026-media img,
    .uk2026-card:focus-visible .uk2026-media img {
        transform: scale(1.015);
    }

    .uk2026-content {
        display: grid;
        grid-template-rows: 1fr auto;
    }

    .uk2026-header-panel {
        padding: clamp(1.5rem, 3vw, 3rem);
