    /* Refined hero / statement font styling — matched to image */
</style>

<script>
    const clampProgress = (value) => Math.min(1, Math.max(0, value));
    const smoothstep = (value) => {
        const clamped = clampProgress(value);
        return clamped * clamped * (3 - 2 * clamped);
    };

    const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    );
    const heroContent = document.querySelector(".hero-content");
    const heroCopy = document.querySelector("[data-hero-copy]");
    const textElement = document.getElementById("typewriter-text");
    const heroTextMode = textElement?.dataset.textEffect ?? "typewriter";
    const heroWordLines = Array.from(
        document.querySelectorAll("[data-hero-word-line]"),
    );
    const heroWords = Array.from(document.querySelectorAll("[data-hero-word]"));
    const heroDynamicLine = document.querySelector("[data-hero-dynamic-line]");

    let heroCopyFrame = 0;
    let heroCopyAnchorTop = null;

    const setHeroWordState = (word, { shift = 0, opacity = 1, blur = 0 }) => {
        word.style.setProperty("--hero-word-shift", `${shift.toFixed(2)}px`);
        word.style.setProperty("--hero-word-opacity", opacity.toFixed(3));
        word.style.setProperty("--hero-word-blur", `${blur.toFixed(2)}px`);
    };

    const setSmoothBlurWordLabelState = (
        wordLabel,
        { shift = 0, opacity = 1, blur = 0 },
    ) => {
        wordLabel.style.setProperty(
            "--smooth-blur-scroll-shift",
            `${shift.toFixed(2)}px`,
        );
        wordLabel.style.setProperty(
            "--smooth-blur-scroll-opacity",
            opacity.toFixed(3),
        );
        wordLabel.style.setProperty(
            "--smooth-blur-scroll-blur",
            `${blur.toFixed(2)}px`,
        );
    };

    const resetHeroCopyMotion = () => {
        heroContent?.style.setProperty("--hero-copy-stage-shift", "0px");

        heroWords.forEach((word) => {
            setHeroWordState(word, { shift: 0, opacity: 1, blur: 0 });
        });

        heroDynamicLine?.style.setProperty("--hero-dynamic-shift", "0px");
        heroDynamicLine?.style.setProperty("--hero-dynamic-opacity", "1");
        heroDynamicLine?.style.setProperty("--hero-dynamic-blur", "0px");

        textElement
            ?.querySelectorAll(".smooth-blur-word-label")
            ?.forEach((wordLabel) => {
                setSmoothBlurWordLabelState(wordLabel, {
                    shift: 0,
                    opacity: 1,
                    blur: 0,
                });
            });
    };

    const updateHeroCopyMotion = () => {
        heroCopyFrame = 0;

        if (!heroCopy || heroWordLines.length === 0) return;

        if (prefersReducedMotion.matches) {
            resetHeroCopyMotion();
            return;
        }

        if (window.scrollY <= 4 || heroCopyAnchorTop === null) {
            heroCopyAnchorTop = heroCopy.getBoundingClientRect().top;
        }

        const headerHeight =
            document.querySelector(".fixed-nav")?.getBoundingClientRect()
                .height ?? 80;
        const viewportHeight = Math.max(window.innerHeight, 1);
        const heroRect = heroCopy.getBoundingClientRect();
        const exitStart = Math.max(headerHeight + 120, heroCopyAnchorTop - 10);
        const exitDistance = Math.max(viewportHeight * 0.34, 260);
        const rawProgress = clampProgress(
            (exitStart - heroRect.top) / Math.max(exitDistance, 1),
        );
        const progress = smoothstep(rawProgress);

        heroContent?.style.setProperty(
            "--hero-copy-stage-shift",
            `${(progress * 16).toFixed(2)}px`,
        );

        heroWordLines.forEach((line, lineIndex) => {
            const words = Array.from(line.querySelectorAll("[data-hero-word]"));
            const lineStart = lineIndex * 0.18;
            const lineWindow = lineIndex === heroWordLines.length - 1 ? 0.52 : 0.42;
            const wordSpread = Math.min(0.18, words.length * 0.028);
            const wordStep =
                words.length > 1 ? wordSpread / Math.max(words.length - 1, 1) : 0;

            words.forEach((word, wordIndex) => {
                const start = lineStart + wordIndex * wordStep;
                const wordProgress = smoothstep(
                    (progress - start) / Math.max(lineWindow, 0.01),
                );
                const blurProgress = smoothstep(
                    (wordProgress - 0.64) / 0.3,
                );
                const shift =
                    progress * 16 + wordProgress * 24 + blurProgress * 6;
                const opacity = clampProgress(
                    1 -
                        (wordProgress * 0.74 +
                            progress * 0.16 +
                            blurProgress * 0.08),
                );

                setHeroWordState(word, {
                    shift,
                    opacity,
                    blur: blurProgress * 2.8,
                });
            });
        });

        if (heroDynamicLine) {
            const dynamicProgress = smoothstep((progress - 0.28) / 0.44);
            const dynamicBlurProgress = smoothstep((progress - 0.72) / 0.2);
            const dynamicShift =
                progress * 16 + dynamicProgress * 20 + dynamicBlurProgress * 6;
            const dynamicOpacity = clampProgress(
                1 -
                    (dynamicProgress * 0.7 +
                        progress * 0.18 +
                        dynamicBlurProgress * 0.08),
            );

            heroDynamicLine.style.setProperty(
                "--hero-dynamic-shift",
                `${dynamicShift.toFixed(2)}px`,
            );
            heroDynamicLine.style.setProperty(
                "--hero-dynamic-opacity",
                dynamicOpacity.toFixed(3),
            );
            heroDynamicLine.style.setProperty(
                "--hero-dynamic-blur",
                `${(dynamicBlurProgress * 2.4).toFixed(2)}px`,
            );
        }

        if (textElement && heroTextMode === "smooth-blur") {
            const smoothBlurPhrases = Array.from(
                textElement.querySelectorAll(".smooth-blur-phrase"),
            );

            smoothBlurPhrases.forEach((phrase, phraseIndex) => {
                const wordLabels = Array.from(
                    phrase.querySelectorAll(".smooth-blur-word-label"),
                );
                const phraseStart = 0.24 + phraseIndex * 0.04;
                const phraseWindow = 0.34;
                const wordSpread = Math.min(0.2, wordLabels.length * 0.05);
                const wordStep =
                    wordLabels.length > 1
                        ? wordSpread / Math.max(wordLabels.length - 1, 1)
                        : 0;

                wordLabels.forEach((wordLabel, wordIndex) => {
                    const start = phraseStart + wordIndex * wordStep;
                    const wordProgress = smoothstep(
                        (progress - start) / Math.max(phraseWindow, 0.01),
                    );
                    const blurProgress = smoothstep(
                        (wordProgress - 0.68) / 0.24,
                    );
                    const shift =
                        progress * 8 + wordProgress * 18 + blurProgress * 4;
                    const opacity = clampProgress(
                        1 -
                            (wordProgress * 0.74 +
                                progress * 0.12 +
                                blurProgress * 0.08),
                    );

                    setSmoothBlurWordLabelState(wordLabel, {
                        shift,
                        opacity,
                        blur: blurProgress * 1.8,
                    });
                });
            });
        }
    };

    const requestHeroCopyMotionUpdate = () => {
        if (heroCopyFrame !== 0) return;
        heroCopyFrame = window.requestAnimationFrame(updateHeroCopyMotion);
    };

    if (heroCopy) {
        updateHeroCopyMotion();
        window.addEventListener("scroll", requestHeroCopyMotionUpdate, {
            passive: true,
        });
        window.addEventListener("resize", requestHeroCopyMotionUpdate);
        prefersReducedMotion.addEventListener?.(
            "change",
            requestHeroCopyMotionUpdate,
        );
    }

    const phrases = [
        "Images, Code & Culture.",
        "Design & Technology.",
        "Writing & Storytelling.",
        "Travel, Fashion & Music.",
        "Photography, Film & Art.",
        "AI, Sociology & Research.",
    ];

    const colors = [
        "#D35E7F", // Cinnamon Satin
        "#D7E97B", // Manz
        "#A999EB", // Max Blue Purple
        "#9BCDEF", // Baby Blue Eyes
    ];

    const typingSpeed = { min: 40, max: 100 };
    const backspaceSpeed = { min: 30, max: 50 };
    const pauseEnd = 2000;
    const pauseStart = 500;

    const heroTextTimers = new Set();

    const queueHeroTextTimer = (callback, delay) => {
        const timerId = window.setTimeout(() => {
            heroTextTimers.delete(timerId);
            callback();
        }, delay);

        heroTextTimers.add(timerId);
        return timerId;
    };

    window.addEventListener(
        "pagehide",
        () => {
            heroTextTimers.forEach((timerId) => window.clearTimeout(timerId));
            heroTextTimers.clear();
        },
        { once: true },
    );

    const runOnNextFrame = (callback) => {
        window.requestAnimationFrame(() => {
            window.requestAnimationFrame(callback);
        });
    };

    function parsePhrase(phrase) {
        const words = phrase.split(" ").filter(Boolean);
        const fallbackTextColor = textElement
            ? getComputedStyle(textElement).color
            : "#FFFFFF";
        const palette = colors.length > 0 ? colors : [fallbackTextColor];
        let phraseColors = [...palette];

        // Simple shuffle for variety
        phraseColors.sort(() => Math.random() - 0.5);

        // Ensure we have enough colors
        while (phraseColors.length < words.length) {
            phraseColors = phraseColors.concat(
                [...palette].sort(() => Math.random() - 0.5),
            );
        }

        return words.map((word, index) => {
            return {
                text: index === words.length - 1 ? word : `${word} `,
                plainText: word,
                color: phraseColors[index],
            };
        });
    }

    function startTypewriter() {
        let phraseIndex = 0;
        let charIndex = 0;
        let isDeleting = false;
        let currentPhraseObjects = [];

        function renderText() {
            if (!textElement) return;
            let charCount = 0;
            let html = "";

            for (const obj of currentPhraseObjects) {
                if (charCount >= charIndex) break;
                const remaining = charIndex - charCount;
                const textToDisplay = obj.text.substring(0, remaining);
                html += `<span style="color: ${obj.color}">${textToDisplay}</span>`;
                charCount += obj.text.length;
                if (charCount > charIndex) break;
            }

            textElement.innerHTML = html;
        }

        function getTotalLength() {
            return currentPhraseObjects.reduce(
                (acc, obj) => acc + obj.text.length,
                0,
            );
        }

        function type() {
            if (!textElement) return;

            if (charIndex === 0 && !isDeleting) {
                currentPhraseObjects = parsePhrase(phrases[phraseIndex]);
            }

            const totalLen = getTotalLength();
            let speed =
                Math.random() * (typingSpeed.max - typingSpeed.min) +
                typingSpeed.min;

            if (isDeleting) {
                charIndex--;
                renderText();
                speed =
                    Math.random() * (backspaceSpeed.max - backspaceSpeed.min) +
                    backspaceSpeed.min;
            } else {
                charIndex++;
                renderText();
            }

            if (!isDeleting && charIndex === totalLen) {
                isDeleting = true;
                queueHeroTextTimer(type, pauseEnd);
            } else if (isDeleting && charIndex === 0) {
                isDeleting = false;
                phraseIndex = (phraseIndex + 1) % phrases.length;
                queueHeroTextTimer(type, pauseStart);
            } else {
                queueHeroTextTimer(type, speed);
            }
        }

        queueHeroTextTimer(type, 1000);
    }

    function createSmoothBlurPhrase(phrase) {
        const phraseElement = document.createElement("span");
        phraseElement.className = "smooth-blur-phrase";
        phraseElement.setAttribute("aria-hidden", "true");

        parsePhrase(phrase).forEach((word, index) => {
            const wordElement = document.createElement("span");
            wordElement.className = "smooth-blur-word";
            wordElement.style.color = word.color;
            wordElement.style.setProperty(
                "--word-delay",
                `${(index * 190) / 1000}s`,
            );
            const wordLabel = document.createElement("span");
            wordLabel.className = "smooth-blur-word-label";
            wordLabel.textContent = word.plainText;
            wordElement.append(wordLabel);
            phraseElement.append(wordElement);
        });

        return phraseElement;
    }

    function getSmoothBlurPhraseDuration(phrase) {
        const wordCount = phrase.split(" ").filter(Boolean).length;

        return 3200 + Math.min(Math.max(wordCount - 1, 0) * 220, 960);
    }

    function startSmoothBlurText() {
        if (!textElement) return;

        let phraseIndex = 0;
        let activePhraseElement = createSmoothBlurPhrase(phrases[phraseIndex]);

        textElement.replaceChildren(activePhraseElement);
        textElement.setAttribute("aria-label", phrases[phraseIndex]);
        requestHeroCopyMotionUpdate();

        runOnNextFrame(() => {
            activePhraseElement.classList.add("is-visible");
        });

        const cyclePhrases = () => {
            const outgoingPhraseElement = activePhraseElement;
            phraseIndex = (phraseIndex + 1) % phrases.length;

            const incomingPhraseElement = createSmoothBlurPhrase(
                phrases[phraseIndex],
            );

            textElement.append(incomingPhraseElement);
            textElement.setAttribute("aria-label", phrases[phraseIndex]);
            requestHeroCopyMotionUpdate();

            runOnNextFrame(() => {
                incomingPhraseElement.classList.add("is-visible");
                outgoingPhraseElement?.classList.add("is-fading");
            });

            activePhraseElement = incomingPhraseElement;

            queueHeroTextTimer(() => {
                outgoingPhraseElement?.remove();
            }, 1900);

            queueHeroTextTimer(
                cyclePhrases,
                getSmoothBlurPhraseDuration(phrases[phraseIndex]),
            );
        };

        queueHeroTextTimer(
            cyclePhrases,
            1050 + getSmoothBlurPhraseDuration(phrases[phraseIndex]),
        );
    }

    if (textElement && phrases.length > 0) {
        if (heroTextMode === "smooth-blur") {
            startSmoothBlurText();
        } else {
            startTypewriter();
        }
    }
</script>
