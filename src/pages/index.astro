---
export const prerender = false;
import BaseLayout from "../layouts/BaseLayout.astro";
import {
    getFeaturedPhotography,
    getRecentPosts,
    getMediaMentions,
    getFilms,
} from "../lib/api";

import {
    featuredPhotography as mockPhotography,
    recentPosts as mockRecent,
} from "../utils/mockData";

import Showreel from "../components/Showreel.astro";

import PhotoGrid from "../components/PhotoGrid.astro";

// LiquidCursor moved to BaseLayout
// EngagementCTA moved to LandingOrchestrator
import ForceDarkMode from "../components/ForceDarkMode.astro";

const pageTitle = "Portfolio";
const pageDescription =
    "Portfolio of Abodid Sahoo, a photographer, researcher, and creative technologist building work across images, code, culture, and interactive media.";

// Helper to safely fetch data
const safeFetch = async (fn, fallback) => {
    try {
        return await fn();
    } catch (e) {
        console.error("Data fetch failed:", e);
        return fallback;
    }
};

// Fetch data from Supabase with Fallback
const featuredPhotography = await safeFetch(
    getFeaturedPhotography,
    mockPhotography,
);
const recentPosts = (await safeFetch(getRecentPosts, mockRecent)).slice(0, 3);
const mediaMentions = await safeFetch(getMediaMentions, []);
const films = await safeFetch(getFilms, []);

// Helper to find link by name match
const findLink = (name) => {
    const term = name.toLowerCase();

    // 1. Search Media Mentions (Publication or Title)
    const mediaMatch = mediaMentions.find(
        (m) =>
            (m.publication && m.publication.toLowerCase().includes(term)) ||
            (m.title && m.title.toLowerCase().includes(term)),
    );
    if (mediaMatch) return mediaMatch.url;

    // 2. Search Films (Title or Description)
    const filmMatch = films.find(
        (f) =>
            (f.title && f.title.toLowerCase().includes(term)) ||
            (f.description && f.description.toLowerCase().includes(term)),
    );
    if (filmMatch) return filmMatch.videoUrl || "/films"; // Fallback to /films if videoUrl missing

    return "#"; // Default fallback
};

// Resolve Links for Showreel Notes - Direct URLs
const vh1Url =
    "https://www.edexlive.com/breaking/2021/Jan/05/four-roommates-shot-a-music-video-in-their-mumbai-flat-and-it-received-a-premiere-on-vh1-17053.html";
const rollingStoneUrl =
    "https://rollingstoneindia.com/watch-electronic-pop-duo-xys-cinematic-video-for-debut-single-show-me-the-way/";
const homegrownUrl =
    "https://homegrown.co.in/homegrown-explore/when-creative-minds-collide-xys-show-me-the-way-music-video-is-visual-pleasure";
const educateGirlsUrl = findLink("Educate Girls");
const curvesColorsUrl = findLink("Curves and Colors");
const pursuitUrl = "https://www.pursuitofportraits.com/";
const hermosaUrl = "https://www.youtube.com/watch?v=EMsZT9PCFms";
const budweiserUrl = "https://www.weareanimal.co/budweiser-streetwear";
const wiedenUrl = findLink("Wieden");
const animalUrl = findLink("Animal");
const jawaUrl = "http://youtube.com/watch?v=CSmZHXpr13E";
const odishaUrl = "https://vimeo.com/265220711";

const supportProjects = [
    {
        id: "cambridge-data-school",
        href: "/fundraising/cambridge-data-school",
        image: "https://wallpapersok.com/images/high/cambridge-university-hall-7n378cd5chdvjxdg.jpg",
        imageAlt: "University of Cambridge, United Kingdom",
        title: "Looking for Partners for Cultural Heritage Data School",
        description:
            "I have been offered a place in the Cultural Heritage Data School happening in April 2026 at the University of Cambridge with a program fee bursary.",
    },
    {
        id: "bsa-conference-2026",
        href: "/fundraising/bsa-conference-2026",
        image: "https://sociology.plus/wp-content/uploads/2022/07/British-Sociological-Association.png",
        imageAlt: "BSA Annual Conference 2026",
        title: "Looking for partners to support my BSA Conference 2026 journey",
        description:
            "Two peer-reviewed research works have been accepted at the BSA Annual Conference. My conference registration fee is already funded.",
    },
];

const heroHeadingLines = [
    ["Hi,", "I", "am", "Abodid."],
    ["I", "have", "worked", "across..."],
];
const heroBioWords =
    "With over 8+ years of experience in photography, film and interactive media, I design authentic creative experiences for brands and organizations working in the culture and technology space.".split(
        " ",
    );

// Toggle between "typewriter" and "smooth-blur" for the landing hero copy.
const heroTextEffect = "smooth-blur";
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    imageAlt="Portfolio preview for Abodid Sahoo"
>
    <Fragment slot="head">
        {
            featuredPhotography.slice(0, 4).map((project) => {
                const imageUrl = project?.image || project?.cover_image;
                return imageUrl ? (
                    <link rel="preload" as="image" href={imageUrl} />
                ) : null;
            })
        }
    </Fragment>

    <!-- Force dark mode on landing page - core to the experience -->
    <ForceDarkMode />

    <section class="narrative-section">
        <div class="hero-content">
            <h1 class="hero-title" data-hero-copy>
                {
                    heroHeadingLines.map((line) => (
                        <span class="hero-title-line" data-hero-word-line>
                            {line.map((word) => (
                                <span class="hero-word" data-hero-word>
                                    {word}
                                </span>
                            ))}
                        </span>
                    ))
                }
                <span
                    class="hero-title-line hero-title-line-dynamic"
                    data-hero-dynamic-line
                >
                    <span
                        id="typewriter-text"
                        class="typing-text"
                        data-text-effect={heroTextEffect}
                        aria-live="polite"
                        aria-atomic="true"></span>
                </span>
            </h1>
            <div class="bio-content">
                <p class="hero-bio-line" data-hero-word-line>
                    {heroBioWords.map((word) => (
                        <span class="hero-word hero-bio-word" data-hero-word>
                            {word}
                        </span>
                    ))}
                </p>
            </div>
        </div>

    </section>

    <!-- Showreel Section - Wrapped for Alignment -->
    <section class="section writings-section">
        <Showreel
            vh1Url={vh1Url}
            rollingStoneUrl={rollingStoneUrl}
            homegrownUrl={homegrownUrl}
            educateGirlsUrl={educateGirlsUrl}
            curvesColorsUrl={curvesColorsUrl}
            pursuitUrl={pursuitUrl}
            hermosaUrl={hermosaUrl}
            budweiserUrl={budweiserUrl}
            wiedenUrl={wiedenUrl}
            animalUrl={animalUrl}
            jawaUrl={jawaUrl}
            odishaUrl={odishaUrl}
        />

        <!-- Filmmaking Background Note -->
        <!-- Content moved to manifesto section - removed duplicate -->
    </section>

    <!-- Massive Spacer 3 (Showreel to Featured) -->
    <!-- Responsive Spacer -->
    <div class="responsive-spacer" aria-hidden="true"></div>

    <!-- Photo Stories -->
    <section class="section contained-section">
        <div class="section-header">
            <h2 class="section-title">Photography Projects</h2>
            <a
                href="/photography"
                class="link-arrow mobile-btn section-cta photo-projects-cta"
                >View All</a
            >
        </div>

        <!-- Contained Carousel Row 1 (Left) -->
        <PhotoGrid
            projects={featuredPhotography}
            maxItems={7}
            columns={2}
            contained={true}
        />
    </section>

    <!-- MAJOR SPACER to separate sections completely -->
    <div class="major-section-separator"></div>

    <!-- Blog Section -->
    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Writings</h2>
            <a href="/blog" class="link-arrow mobile-btn section-cta"
                >Read All</a
            >
        </div>

        <div class="blog-list">
            {
                recentPosts.map((post) => (
                    <a href={post.href} class="blog-card">
                        <div class="blog-image-wrapper">
                            {post.image ? (
                                <img
                                    src={post.image}
                                    alt={post.title}
                                    class="blog-image"
                                    loading="lazy"
                                />
                            ) : (
                                <div class="blog-image-placeholder" />
                            )}
                        </div>

                        <div class="blog-content">
                            <span class="blog-date">{post.date}</span>
                            <h3 class="blog-title">{post.title}</h3>
                            <div class="blog-category">
                                {post.category &&
                                    (Array.isArray(post.category)
                                        ? post.category[0]
                                        : post.category)}
                            </div>
                        </div>

                        <div class="blog-action">
                            <span>VIEW MORE</span>
                            <span class="arrow">→</span>
                        </div>
                    </a>
                ))
            }
        </div>
    </section>

    <div class="major-section-separator writing-support-separator"></div>

    <section class="section support-section">
        <div class="section-header">
            <h2 class="section-title">Support Me</h2>
            <a href="/fundraising" class="link-arrow mobile-btn section-cta"
                >View All</a
            >
        </div>

        <div class="support-projects">
            {
                supportProjects.map((project) => (
                    <article class="support-project" id={project.id}>
                        <a
                            href={project.href}
                            class="support-project-image-link"
                        >
                            <img
                                src={project.image}
                                alt={project.imageAlt}
                                class="support-project-image"
                                loading="lazy"
                            />
                        </a>

                        <div class="support-project-content">
                            <a
                                href={project.href}
                                class="support-project-title-link"
                            >
                                <h3 class="support-project-title">
                                    {project.title}
                                </h3>
                            </a>
                            <p class="support-project-description">
                                {project.description}
                            </p>
                            <a
                                href={project.href}
                                class="support-project-action"
                            >
                                View support details →
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</BaseLayout>

<style>
    .narrative-section {
        position: relative;
        z-index: 100;
        min-height: auto;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        gap: clamp(2rem, 5vh, 4rem);
        padding: clamp(7rem, 14vh, 9rem) 24px clamp(1.5rem, 4vh, 2.5rem);
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        margin-bottom: 0;
    }

    .hero-content {
        --hero-copy-stage-shift: 0px;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: clamp(2rem, 5vh, 4rem);
        max-width: 980px;
        transform: translate3d(
            0,
            calc(var(--hero-copy-stage-shift) * -1),
            0
        );
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform;
    }

    .hero-title {
        margin: 0;
        display: grid;
        gap: 0.06em;
        font-family: var(--feature-typewriter-main-font, var(--font-sans));
        font-size: var(--feature-typewriter-main-size, 3.5rem);
        font-weight: var(--feature-typewriter-main-weight, 700);
        line-height: var(--feature-typewriter-main-line-height, 1.1);
        letter-spacing: var(--feature-typewriter-main-letter-spacing, 0em);
        color: var(--feature-typewriter-main-color, var(--text-primary));
        width: fit-content;
        max-width: 100%;
    }

    .hero-title-line {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.12em 0.18em;
        width: fit-content;
        max-width: 100%;
    }

    .hero-title-line-dynamic {
        --hero-dynamic-shift: 0px;
        --hero-dynamic-opacity: 1;
        --hero-dynamic-blur: 0px;
        opacity: var(--hero-dynamic-opacity);
        transform: translate3d(0, calc(var(--hero-dynamic-shift) * -1), 0);
        filter: blur(var(--hero-dynamic-blur));
        transition:
            opacity 0.32s linear,
            transform 0.6s cubic-bezier(0.22, 1, 0.36, 1),
            filter 0.48s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform, filter;
    }

    .hero-word {
        --hero-word-shift: 0px;
        --hero-word-opacity: 1;
        --hero-word-blur: 0px;
        display: inline-block;
        opacity: var(--hero-word-opacity);
        transform: translate3d(0, calc(var(--hero-word-shift) * -1), 0);
        filter: blur(var(--hero-word-blur));
        transition:
            opacity 0.32s linear,
            transform 0.58s cubic-bezier(0.22, 1, 0.36, 1),
            filter 0.5s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform, filter;
        backface-visibility: hidden;
    }

    .bio-content {
        max-width: 900px;
    }

    .hero-bio-line {
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.16em 0.24em;
        font-family: var(--feature-typewriter-bio-font, var(--font-body));
        font-size: var(--feature-typewriter-bio-size, 2.2rem);
        font-weight: var(--feature-typewriter-bio-weight, 300);
        line-height: var(--feature-typewriter-bio-line-height, 1.2);
        letter-spacing: var(--feature-typewriter-bio-letter-spacing, 0em);
        color: var(--feature-typewriter-bio-color, var(--text-secondary));
    }

    .major-section-separator {
        height: 20vh;
        min-height: 140px;
        width: 100%;
    }

    @media (max-width: 768px) {
        .narrative-section {
            min-height: auto;
            padding-top: 100px;
            padding-left: 0;
            padding-right: 0;
            padding-bottom: 2.5rem;
            margin-bottom: 1.5rem;
            gap: 2.5rem;
        }

        .hero-title {
            font-size: min(
                calc(var(--feature-typewriter-main-size, 3.5rem) * 0.5),
                2.5rem
            ) !important;
            line-height: 1.3 !important;
        }

        .hero-title-line {
            gap: 0.12em 0.16em;
        }

        #typewriter-text {
            margin-top: 0.5rem;
            min-height: 6.25em;
            overflow: hidden;
        }

        #typewriter-text[data-text-effect="typewriter"] {
            display: block;
        }

        #typewriter-text[data-text-effect="smooth-blur"] {
            display: grid;
        }

        .hero-bio-line {
            font-size: min(
                calc(var(--feature-typewriter-bio-size, 2.2rem) * 0.52),
                1.125rem
            ) !important;
            line-height: 1.5 !important;
        }

        .note-grid {
            display: none !important;
        }

        .section {
            margin-bottom: 4rem;
        }

        .blog-card {
            grid-template-columns: 1fr;
            padding: 0;
            margin-left: 0;
            margin-right: 0;
            margin-bottom: 2rem;
            border-bottom: none;
            gap: 0;
            width: 100%;
        }

        .blog-list {
            display: flex;
            flex-direction: column;
            gap: 0;
            width: 100%;
            padding: 0;
            margin: 0;
        }

        .blog-image-wrapper {
            width: 100%;
            height: 200px;
        }

        .blog-action {
            display: block;
            margin-top: 0.5rem;
            font-size: 0.75rem;
        }
    }

    /* ... type writer styles ... */

    /* Desktop alignment for Showreel & Notes to match Narrative block width */
    /* REMOVED: Now handled by wrapper .section with padding */
    /* :global(.showreel-container),
    :global(.note-grid) {
        padding-left: 4vw;
        padding-right: 4vw;
    } */

    @media (max-width: 768px) {
        .major-section-separator {
            height: 10vh;
            min-height: 80px;
        }
    }

    .italic {
        font-style: italic;
        font-weight: 400;
    }

    .section {
        margin-bottom: var(--space-2xl);
        /* Ensure sections align with the grid */
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 24px;
        padding-right: 24px;
    }

    .contained-section {
        /* Inherits padding from .section or explicit override? 
           Let's just use .section styles for all mainly, but if contained-section was separate: */
        padding-left: 24px;
        padding-right: 24px;
    }

    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: var(--space-lg);
        border-bottom: 1px solid var(--border-subtle);
        padding-bottom: var(--space-md);
        /* Remove margin-left/right if any existed */
    }

    @media (max-width: 600px) {
        .section-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 0.25rem; /* TIGHTER gap between title and button */
            margin-bottom: 1rem; /* Compact header */
        }

        /* Mobile Spacing for Sections - REMOVED EXTRA PADDING to align with Showreel */
        .section,
        .contained-section {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .section-title {
            font-size: 2rem; /* Ensure it fits one line if possible, or wrap cleanly */
            line-height: 1.1;
        }

        /* Minimal Sleek Button Mobile */
        .mobile-btn {
            display: inline-block;
            width: auto;
            text-align: left;
            padding: 0; /* Remove button padding */
            border: none; /* Remove border */
            background: none;
            margin-top: 0;
            font-size: 0.7rem; /* Tiny text */
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255, 255, 255, 0.6); /* Subtle color */
            font-weight: 400;
        }

        .mobile-btn::after {
            content: " →";
            display: inline;
            opacity: 0.6;
        }
    }

    .link-arrow {
        font-size: var(--text-sm);
        font-weight: 500;
        position: relative;
        padding-right: 1.2em;
    }

    .section-cta {
        font-family: var(--feature-writing-action-font, var(--font-ui));
        font-size: var(--feature-writing-action-size, 0.8rem);
        font-weight: var(--feature-writing-action-weight, 500);
        line-height: var(--feature-writing-action-line-height, 1.2);
        letter-spacing: var(--feature-writing-action-letter-spacing, 0.05em);
        text-transform: uppercase;
        color: var(--feature-writing-action-color, var(--text-tertiary));
    }

    .link-arrow::after {
        content: "→";
        position: absolute;
        right: 0;
        transition: transform 0.2s ease;
    }

    .link-arrow:hover::after {
        transform: translateX(4px);
    }

    .blog-list {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .blog-card {
        display: grid;
        grid-template-columns: 280px 1fr auto;
        gap: 2rem;
        padding: 1.5rem 0; /* Remove side padding for cleaner alignment with header */
        text-decoration: none;
        color: var(--text-primary);
        border-bottom: 1px solid var(--border-subtle); /* Subtle separator instead of box */
        /* border-radius removed */
        transition: transform 0.3s ease;
        align-items: center;
    }

    .blog-card:hover {
        transform: translateY(-2px);
        /* border-color removed */
    }

    .blog-image-wrapper {
        width: 280px;
        aspect-ratio: 16 / 9;
        height: auto;
        overflow: hidden;
        border-radius: 6px;
        background: var(--bg-surface);
    }

    .blog-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .blog-image-placeholder {
        width: 100%;
        height: 100%;
        background: var(--bg-surface);
    }

    .blog-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .blog-date {
        font-family: var(--feature-writing-date-font, var(--font-mono));
        font-size: var(--feature-writing-date-size, 0.75rem);
        font-weight: var(--feature-writing-date-weight, 400);
        line-height: var(--feature-writing-date-line-height, 1.2);
        letter-spacing: var(--feature-writing-date-letter-spacing, 0.05em);
        text-transform: uppercase;
        color: var(--feature-writing-date-color, var(--text-tertiary));
        margin-bottom: 0.5rem;
    }

    .blog-title {
        font-family: var(--feature-writing-title-font, var(--font-serif));
        font-size: var(--feature-writing-title-size, 1.5rem);
        font-weight: var(--feature-writing-title-weight, 400);
        line-height: var(--feature-writing-title-line-height, 1.2);
        letter-spacing: var(--feature-writing-title-letter-spacing, 0em);
        color: var(--feature-writing-title-color, var(--text-primary));
        margin: 0 0 0.5rem 0;
        max-width: 38ch; /* Force wrapping after ~9-12 words */
    }

    .blog-category {
        font-family: var(--feature-writing-category-font, var(--font-sans));
        font-size: var(--feature-writing-category-size, 0.85rem);
        font-weight: var(--feature-writing-category-weight, 400);
        line-height: var(--feature-writing-category-line-height, 1.2);
        letter-spacing: var(--feature-writing-category-letter-spacing, 0em);
        color: var(--feature-writing-category-color, var(--text-secondary));
    }

    .blog-action {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--feature-writing-action-font, var(--font-ui));
        font-size: var(--feature-writing-action-size, 0.8rem);
        font-weight: var(--feature-writing-action-weight, 500);
        line-height: var(--feature-writing-action-line-height, 1.2);
        letter-spacing: var(--feature-writing-action-letter-spacing, 0.05em);
        text-transform: uppercase;
        color: var(--feature-writing-action-color, var(--text-tertiary));
        transition: color 0.3s ease;
    }

    .blog-card:hover .blog-action {
        color: var(--text-primary);
    }

    .blog-card:hover .arrow {
        transform: translateX(4px);
        transition: transform 0.2s ease;
    }

    .writings-section {
        padding-top: clamp(5rem, 10vh, 8rem);
        margin-bottom: 0;
    }

    .support-section {
        margin-top: 0;
        margin-bottom: clamp(8rem, 18vh, 15rem);
    }

    .support-projects {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .support-project {
        display: grid;
        grid-template-columns: 320px 1fr;
        gap: 1.5rem;
        align-items: center;
        padding: 1.25rem;
        border: 1px solid var(--border-subtle);
        border-radius: 10px;
        background: var(--bg-surface);
    }

    .support-project-image-link {
        display: block;
        width: 100%;
        border-radius: 8px;
        overflow: hidden;
        background: var(--bg-surface);
    }

    .support-project-image {
        width: 100%;
        height: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
    }

    .support-project-content {
        display: flex;
        flex-direction: column;
        gap: 0.65rem;
    }

    .support-project-title-link {
        text-decoration: none;
        color: inherit;
    }

    .support-project-title {
        margin: 0;
        font-family: var(--feature-writing-title-font, var(--font-serif));
        font-size: 1.45rem;
        line-height: 1.2;
        color: var(--feature-writing-title-color, var(--text-primary));
    }

    .support-project-description {
        margin: 0;
        font-family: var(--feature-writing-category-font, var(--font-sans));
        font-size: 0.96rem;
        line-height: 1.55;
        color: var(--feature-writing-category-color, var(--text-secondary));
        max-width: 58ch;
    }

    .support-project-action {
        margin-top: 0.25rem;
        display: inline-block;
        text-decoration: none;
        font-family: var(--feature-writing-action-font, var(--font-ui));
        font-size: var(--feature-writing-action-size, 0.8rem);
