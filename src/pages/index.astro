---
import BaseLayout from "../layouts/BaseLayout.astro";
import ForceDarkMode from "../components/ForceDarkMode.astro";
import { personJsonLd, websiteJsonLd } from "../lib/seoData";

const pageTitle = "Abodid Sahoo | Creative Director, Artist & Researcher";
const pageDescription =
    "Abodid Sahoo helps people use stories to communicate, educate, and bring communities together through creative direction, art, research, films, exhibitions, and digital experiences.";

const heroHeadingLines = [
    ["Hi,", "I", "am", "Abodid."],
    ["I", "work", "at", "the", "intersection", "of", "..."],
];

const heroTextEffect = "smooth-blur";
---

<BaseLayout
    title={pageTitle}
    description={pageDescription}
    useDynamicOgImage={false}
    showNewsletterPopup={false}
    bodyClass="landing-page landing-redesign-page"
    structuredData={[personJsonLd(), websiteJsonLd()]}
>
    <ForceDarkMode />

    <section class="narrative-section" aria-labelledby="landing-copy-title">
        <div class="hero-content">
            <h1 id="landing-copy-title" class="hero-title" data-hero-copy>
                {
                    heroHeadingLines.map((line) => (
                        <span class="hero-title-line" data-hero-word-line>
                            {line.map((word) => (
                                <span class="hero-word" data-hero-word>
                                    {word}
                                </span>
                            ))}
                        </span>
                    ))
                }
                <span
                    class="hero-title-line hero-title-line-dynamic"
                    data-hero-dynamic-line
                >
                    <span
                        id="typewriter-text"
                        class="typing-text"
                        data-text-effect={heroTextEffect}
                        aria-live="polite"
                        aria-atomic="true"
                    >
                        Photography, Film & Art.
                    </span>
                </span>
            </h1>
            <p class="hero-lede">
                <span>
                    I help people use stories to communicate, educate and bring
                    communities together.
                </span>
            </p>
        </div>
    </section>

    <article class="landing-copy-body" aria-label="Landing page body copy">
        <p>
            As a creative director, artist, and researcher, I enjoy pushing the
            boundaries of storytelling, turning it into memorable, participatory
            &quot;experiences&quot; that spark conversations and help build deeper
            connections.
        </p>

        <p>
            From art installations and exhibitions to films and digital
            experiences, I create research-driven work that is intuitive and
            accessible. As a creative consultant, I work with
            <a class="copy-link" href="/services">exhibition design teams</a>,
            design studios, and corporate clients, leading the creative
            direction and early-stage concept ideation for research-driven
            storytelling products of the future.
        </p>

        <p>
            Sometimes I work as a
            <a class="copy-link" href="/services">super connector</a>, mapping a
            brand&apos;s complex ecosystem and emerging ideas with brilliant
            creative minds across the globe.
        </p>

        <p>
            I also write extremely raw memoirs on my lived experiences to help
            emerging creatives navigate the creative ecosystem more effectively
            and with confidence. I also
            <a class="copy-link" href="/blog">speak about culture, art, and
            technology</a> at international conferences, events, and panel
            discussions, inspiring audiences to see storytelling differently and
            to explore a more human-centred, medium-agnostic approach.
        </p>

        <p>
            Additionally, I lead hands-on
            <a class="copy-link" href="/workshops">filmmaking workshops</a>
            focused on ethics, documentation, and research. I give students
            situations to think about and text prompts to craft their own
            narratives.
        </p>

        <p>
            I have worked with the
            <a class="copy-link" href="/education">Royal College of Art London</a>
            (world&apos;s No.1 Art and Design college - QS ranking), to design,
            build and document globally renowned year-end graduate shows and art
            exhibitions happening across campus in central London, and highly
            sought-after immersive venues like
            <a class="copy-link" href="/photography/outernet-london-2025">Outernet</a>,
            <a class="copy-link" href="/photography/frameless-london-rca-exhibition">Frameless</a>,
            and British Film Institute.
        </p>

        <p>
            I have worked with international organisations, agencies and design
            studios such as Wieden+Kennedy, Pursuit of Portraits, Hermosa Design
            Studio and Odisha Tourism to create
            <a class="copy-link" href="/films">brand films, commercials, and
            social media content</a>.
        </p>

        <p>
            My work has been featured on RCA&apos;s official pages. My
            <a class="copy-link" href="/films">music video</a> was broadcast on
            VH1. I have had multiple
            <a class="copy-link" href="/press">media mentions</a> in Homegrown,
            The Indian Express, Rolling Stone India, and others.
        </p>

        <p>
            I&apos;m a recipient of the Apple Scholarship, which
            covered my entire tuition fees at the Royal College of Art in
            London. Here&apos;s a
            <a class="copy-link" href="/blog/how-apple-funded-my-dream-at-rca">long-form article</a>
            I wrote that dives deep into the international education ecosystem
            and scholarships to help students navigate higher studies at Tier 1
            international institutions.
        </p>

        <p>
            I recently received a full bursary for attending the
            <a class="copy-link" href="/uk2026">Cultural Heritage Data School at
            the University of Cambridge</a> (UOC), organised by the Cambridge
            Digital Humanities (CDH). This is a long-form memoir of the entire
            experience, from the application process and fundraising to all the
            activities we did there and the fun moments we had.
        </p>

        <p>
            Curious about how I think? Ask my
            <a class="copy-link" href="/research/obsidian-vault">AI-powered
            Obsidian Vault</a> - a searchable space of my notes, ideas,
            questions and unfinished thoughts.
        </p>
    </article>
</BaseLayout>

<style>
    :global(body.landing-redesign-page .header-padding) {
        padding-top: clamp(28px, 4vh, 56px) !important;
    }

    :global(body.landing-redesign-page .global-grid-bg) {
        opacity: 0.18;
        background-size: 72px 72px;
        -webkit-mask-image: none;
        mask-image: none;
    }

    :global(body.landing-redesign-page .global-glow-bg) {
        display: none;
    }

    .narrative-section {
        position: relative;
        z-index: 100;
        display: flex;
        flex-direction: column;
        justify-content: flex-start;
        padding: clamp(2rem, 5.5vh, 4.5rem) 24px clamp(2rem, 4.5vh, 3.5rem);
        max-width: 1100px;
        margin-left: auto;
        margin-right: auto;
    }

    .hero-content {
        --hero-copy-stage-shift: 0px;
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        gap: clamp(1.8rem, 3.8vh, 3.2rem);
        margin-top: clamp(16px, 2vh, 24px);
        max-width: min(100%, 1040px);
        transform: translate3d(0, calc(var(--hero-copy-stage-shift) * -1), 0);
        transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: transform;
    }

    .hero-title {
        margin: 0;
        display: grid;
        gap: 0.06em;
        font-family: var(--feature-typewriter-main-font, var(--font-sans));
        font-size: clamp(
            2.95rem,
            1.45rem + 3vw,
            4.75rem
        );
        font-weight: var(--feature-typewriter-main-weight, 700);
        line-height: var(--feature-typewriter-main-line-height, 1.1);
        letter-spacing: var(--feature-typewriter-main-letter-spacing, 0em);
        color: var(--feature-typewriter-main-color, var(--text-primary));
        width: 100%;
        max-width: 100%;
    }

    .hero-title-line {
        --hero-line-shift: 0px;
        --hero-line-opacity: 1;
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 0.12em 0.18em;
        width: 100%;
        min-width: 0;
        max-width: 100%;
        opacity: var(--hero-line-opacity);
        transform: translate3d(0, calc(var(--hero-line-shift) * -1), 0);
        transition:
            opacity 0.32s linear,
            transform 0.58s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
    }

    .hero-title-line-dynamic {
        --hero-dynamic-shift: 0px;
        --hero-dynamic-opacity: 1;
        width: 100%;
        max-width: min(100%, calc(100vw - 48px));
        opacity: var(--hero-dynamic-opacity);
        transform: translate3d(0, calc(var(--hero-dynamic-shift) * -1), 0);
        transition:
            opacity 0.32s linear,
            transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
    }

    .hero-word {
        display: inline-block;
        backface-visibility: hidden;
    }

    .hero-lede {
        max-width: 1040px;
        margin: 0;
        color: rgba(224, 232, 246, 0.78);
        font-family: var(--font-body);
        font-size: clamp(1.72rem, 1.05rem + 1.52vw, 2.74rem);
        font-weight: 260;
        line-height: 1.43;
        letter-spacing: 0em;
    }

    .hero-lede span {
        background: transparent;
        padding: 0;
    }

    #typewriter-text {
        --smooth-blur-mask-start: color-mix(
            in srgb,
            var(--bg-color) 82%,
            transparent
        );
        --smooth-blur-mask-mid: color-mix(
            in srgb,
            var(--bg-color) 70%,
            transparent
        );
        --smooth-blur-mask-end: color-mix(
            in srgb,
            var(--bg-color) 34%,
            transparent
        );
        font-family: var(
            --feature-typewriter-text-font,
            var(--feature-typewriter-main-font, var(--font-sans))
        );
        font-size: 1.18em;
        font-weight: var(
            --feature-typewriter-text-weight,
            var(--feature-typewriter-main-weight, 700)
        );
        line-height: var(--feature-typewriter-text-line-height, 1.1);
        letter-spacing: var(--feature-typewriter-text-letter-spacing, 0em);
        color: var(
            --feature-typewriter-text-color,
            var(--feature-typewriter-main-color, var(--text-primary))
        );
        min-height: 1.2em;
        margin-top: 0;
        position: relative;
        top: -2px;
        width: 100%;
        min-width: 0;
        max-width: min(100%, calc(100vw - 48px));
        white-space: nowrap;
        overflow-wrap: break-word;
    }

    #typewriter-text[data-text-effect="smooth-blur"] {
        display: inline-grid;
        grid-template-areas: "stack";
        align-items: baseline;
        vertical-align: top;
        width: 100%;
        white-space: normal;
        isolation: isolate;
        overflow: visible;
        padding-top: 0.14em;
        padding-bottom: 0.18em;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase) {
        grid-area: stack;
        position: relative;
        display: inline-flex;
        flex-wrap: nowrap;
        align-items: baseline;
        align-content: flex-start;
        justify-content: flex-start;
        gap: 0.14em 0.2em;
        width: 100%;
        max-width: 100%;
        white-space: nowrap;
        overflow: visible;
        opacity: 0;
        filter: blur(12px);
        transform: translate3d(0, 0.18em, 0);
        pointer-events: none;
        transition:
            opacity 1.35s cubic-bezier(0.22, 1, 0.36, 1),
            transform 1.85s cubic-bezier(0.22, 1, 0.36, 1),
            filter 1.85s cubic-bezier(0.22, 1, 0.36, 1),
            text-shadow 1.2s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform, filter, text-shadow;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-visible) {
        opacity: 1;
        filter: blur(0.15px);
        transform: translate3d(0, 0, 0);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-fading) {
        opacity: 0;
        filter: blur(9px);
        transform: translate3d(0.16em, -0.05em, 0);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-word) {
        display: inline-block;
        flex: 0 1 auto;
        max-width: 100%;
        opacity: 0;
        filter: blur(8px);
        transform: translate3d(-0.24em, 0.15em, 0);
        text-shadow: 0 0 6px color-mix(in srgb, currentColor 30%, transparent);
        transition:
            opacity 1.15s linear,
            transform 1.55s cubic-bezier(0.22, 1, 0.36, 1),
            filter 1.55s cubic-bezier(0.22, 1, 0.36, 1),
            text-shadow 1.15s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--word-delay, 0s);
        will-change: opacity, transform, filter, text-shadow;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-word-label) {
        display: inline-block;
        max-width: 100%;
        overflow-wrap: break-word;
        backface-visibility: hidden;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-visible .smooth-blur-word) {
        opacity: 1;
        filter: blur(0.08px);
        transform: translate3d(0, 0, 0);
        text-shadow: 0 0 1px color-mix(in srgb, currentColor 14%, transparent);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-fading .smooth-blur-word) {
        opacity: 0;
        filter: blur(6px);
        transform: translate3d(0.18em, -0.04em, 0);
        text-shadow: 0 0 4px color-mix(in srgb, currentColor 22%, transparent);
        transition-delay: 0s;
    }

    .landing-copy-body {
        position: relative;
        z-index: 2;
        max-width: 1100px;
        margin: clamp(0.4rem, 1.6vh, 1.25rem) auto clamp(7rem, 14vh, 10rem);
        padding: 0 24px;
        color: rgba(224, 232, 246, 0.78);
        font-family: var(--font-body);
        font-size: clamp(1.72rem, 1.05rem + 1.52vw, 2.74rem);
        font-weight: 260;
        line-height: 1.43;
        letter-spacing: 0em;
    }

    .landing-copy-body p {
        max-width: 1040px;
        margin: 0 0 clamp(2.4rem, 5vh, 4.5rem);
        color: rgba(224, 232, 246, 0.78);
        font-family: var(--font-body);
        font-size: clamp(1.72rem, 1.05rem + 1.52vw, 2.74rem);
        font-weight: 260;
        line-height: 1.43;
        letter-spacing: 0em;
    }

    .copy-link {
        color: inherit;
        text-decoration: underline;
        text-decoration-color: rgba(224, 232, 246, 0.42);
        text-decoration-thickness: 0.045em;
        text-underline-offset: 0.18em;
        border-radius: 3px;
        transition:
            color 160ms ease,
            background-color 160ms ease,
            text-decoration-color 160ms ease;
    }

    .copy-link:hover,
    .copy-link:focus-visible {
        color: #ffffff;
        background-color: var(--color-brand-red);
        text-decoration-color: transparent;
        outline: none;
    }

    .copy-link:focus-visible {
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-brand-red) 55%, transparent);
    }

    @media (max-width: 979px) {
        :global(body.landing-redesign-page .header-padding) {
            padding-top: clamp(24px, 3.5vh, 42px) !important;
        }

        .narrative-section {
            padding-top: clamp(2.1rem, 5.5vh, 3.8rem);
        }

        .hero-content {
            gap: 1.55rem;
            margin-top: clamp(12px, 1.7vh, 18px);
            max-width: min(100%, 780px);
        }

        .hero-title {
            font-size: clamp(2.25rem, 1.55rem + 2vw, 3rem);
        }

        .hero-lede {
            font-size: clamp(1.28rem, 1.08rem + 1.1vw, 1.62rem);
            line-height: 1.55;
        }
    }

    @media (max-width: 768px) {
        :global(body.landing-redesign-page .header-padding) {
            padding-top: clamp(18px, 3vh, 30px) !important;
        }

        .narrative-section {
            padding-top: clamp(1.25rem, 4vh, 2.4rem);
            padding-left: 0;
            padding-right: 0;
            padding-bottom: 0.75rem;
        }

        .hero-content {
            gap: clamp(1.1rem, 3.5vh, 1.65rem);
        }

        .hero-title {
            font-size: min(
                calc(var(--feature-typewriter-main-size, 3.5rem) * 0.58),
                2.85rem
            ) !important;
            line-height: 1.3 !important;
        }

        .hero-title-line {
            gap: 0.12em 0.16em;
        }

        #typewriter-text {
            margin-top: 0.35rem;
            min-height: 1.45em;
            overflow: hidden;
            font-size: 1em;
            line-height: inherit;
            white-space: nowrap;
        }

        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-phrase) {
            flex-wrap: nowrap;
            white-space: nowrap;
        }

        .landing-copy-body {
            padding-left: 0;
            padding-right: 0;
            font-size: clamp(1.28rem, 1.08rem + 1.1vw, 1.62rem);
            line-height: 1.55;
        }

        .landing-copy-body p {
            margin-bottom: 2.35rem;
            font-size: clamp(1.28rem, 1.08rem + 1.1vw, 1.62rem);
            line-height: 1.55;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-content,
        .hero-word,
        .hero-title-line,
        .hero-title-line-dynamic {
            transition: none;
            filter: none;
            transform: none;
        }

        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-phrase),
        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-word),
        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-word-label) {
            transition: none;
            filter: none;
            transform: none;
        }
    }
</style>

<script>
    const clampProgress = (value) => Math.min(1, Math.max(0, value));
    const smoothstep = (value) => {
        const clamped = clampProgress(value);
        return clamped * clamped * (3 - 2 * clamped);
    };

    const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
    );
    const heroContent = document.querySelector(".hero-content");
    const heroCopy = document.querySelector("[data-hero-copy]");
    const textElement = document.getElementById("typewriter-text");
    const heroTextMode = textElement?.dataset.textEffect ?? "smooth-blur";
    const heroWordLines = Array.from(
        document.querySelectorAll("[data-hero-word-line]"),
    );
    const heroDynamicLine = document.querySelector("[data-hero-dynamic-line]");

    let heroCopyFrame = 0;

    const setHeroLineState = (line, { shift = 0, opacity = 1 }) => {
        line.style.setProperty("--hero-line-shift", `${shift.toFixed(2)}px`);
        line.style.setProperty("--hero-line-opacity", opacity.toFixed(3));
    };

    const resetHeroCopyMotion = () => {
        heroContent?.style.setProperty("--hero-copy-stage-shift", "0px");

        heroWordLines.forEach((line) => {
            setHeroLineState(line, { shift: 0, opacity: 1 });
        });

        heroDynamicLine?.style.setProperty("--hero-dynamic-shift", "0px");
        heroDynamicLine?.style.setProperty("--hero-dynamic-opacity", "1");
    };

    const updateHeroCopyMotion = () => {
        heroCopyFrame = 0;

        if (!heroCopy || heroWordLines.length === 0) return;

        if (prefersReducedMotion.matches) {
            resetHeroCopyMotion();
            return;
        }

        const headerHeight =
            document.querySelector(".top-menu-shell")?.getBoundingClientRect()
                .height ??
            document.querySelector(".fixed-nav")?.getBoundingClientRect()
                .height ??
            88;
        const viewportHeight = Math.max(window.innerHeight, 1);
        const fadeStart = Math.max(headerHeight + 84, viewportHeight * 0.22);
        const exitDistance = Math.max(viewportHeight * 0.85, 680);
        const rawProgress = clampProgress(
            (window.scrollY - fadeStart) / Math.max(exitDistance, 1),
        );
        const progress = smoothstep(rawProgress);

        heroContent?.style.setProperty(
            "--hero-copy-stage-shift",
            `${(progress * 16).toFixed(2)}px`,
        );

        heroWordLines.forEach((line, lineIndex) => {
            const lineStart =
                lineIndex === 0 ? 0 : lineIndex === 1 ? 0.38 : 0.68;
            const lineWindow =
                lineIndex === 0 ? 0.58 : lineIndex === 1 ? 0.68 : 0.76;
            const lineProgress = smoothstep(
                (progress - lineStart) / Math.max(lineWindow, 0.01),
            );
            const lineFadeStrength =
                lineIndex === 0 ? 1 : lineIndex === 1 ? 0.44 : 0.22;
            const lineOpacityDrop =
                lineIndex === 0 ? 0.78 : lineIndex === 1 ? 0.24 : 0.14;
            const shift = (progress * 10 + lineProgress * 22) * lineFadeStrength;
            const opacity = clampProgress(
                1 - (lineProgress * lineOpacityDrop + progress * 0.025),
            );

            setHeroLineState(line, { shift, opacity });
        });

        if (heroDynamicLine) {
            const dynamicProgress = smoothstep((progress - 0.58) / 0.54);
            const dynamicShift = progress * 5 + dynamicProgress * 10;
            const dynamicOpacity = clampProgress(
                1 - (dynamicProgress * 0.28 + progress * 0.035),
            );

            heroDynamicLine.style.setProperty(
                "--hero-dynamic-shift",
                `${dynamicShift.toFixed(2)}px`,
            );
            heroDynamicLine.style.setProperty(
                "--hero-dynamic-opacity",
                dynamicOpacity.toFixed(3),
            );
        }
    };

    const requestHeroCopyMotionUpdate = () => {
        if (heroCopyFrame !== 0) return;
        heroCopyFrame = window.requestAnimationFrame(updateHeroCopyMotion);
    };

    if (heroCopy) {
        updateHeroCopyMotion();
        window.addEventListener("scroll", requestHeroCopyMotionUpdate, {
            passive: true,
        });
        window.addEventListener("resize", requestHeroCopyMotionUpdate);
        prefersReducedMotion.addEventListener?.(
            "change",
            requestHeroCopyMotionUpdate,
        );
    }

    const phrases = [
        "Photography, Film & Art.",
        "Culture & Technology.",
        "Research & Writing.",
        "Design, Code & Creativity.",
    ];

    const colors = ["#D35E7F", "#D7E97B", "#A999EB", "#9BCDEF"];
    const heroTextTimers = new Set();

    const queueHeroTextTimer = (callback, delay) => {
        const timerId = window.setTimeout(() => {
            heroTextTimers.delete(timerId);
            callback();
        }, delay);

        heroTextTimers.add(timerId);
        return timerId;
    };

    window.addEventListener(
        "pagehide",
        () => {
            heroTextTimers.forEach((timerId) => window.clearTimeout(timerId));
            heroTextTimers.clear();
        },
        { once: true },
    );

    const runOnNextFrame = (callback) => {
        window.requestAnimationFrame(() => {
            window.requestAnimationFrame(callback);
        });
    };

    function parsePhrase(phrase) {
        const words = phrase.split(" ").filter(Boolean);
        const fallbackTextColor = textElement
            ? getComputedStyle(textElement).color
            : "#FFFFFF";
        const palette = colors.length > 0 ? colors : [fallbackTextColor];
        let phraseColors = [...palette];

        phraseColors.sort(() => Math.random() - 0.5);

        while (phraseColors.length < words.length) {
            phraseColors = phraseColors.concat(
                [...palette].sort(() => Math.random() - 0.5),
            );
        }

        return words.map((word, index) => {
            return {
                text: index === words.length - 1 ? word : `${word} `,
                plainText: word,
                color: phraseColors[index],
            };
        });
    }

    function createSmoothBlurPhrase(phrase) {
        const phraseElement = document.createElement("span");
        phraseElement.className = "smooth-blur-phrase";
        phraseElement.setAttribute("aria-hidden", "true");

        const phraseWords = parsePhrase(phrase);
        phraseWords.forEach((word, index) => {
            const wordElement = document.createElement("span");
            wordElement.className = "smooth-blur-word";
            wordElement.style.color = word.color;
            wordElement.style.setProperty(
                "--word-delay",
                `${(index * 190) / 1000}s`,
            );
            const wordLabel = document.createElement("span");
            wordLabel.className = "smooth-blur-word-label";
            wordLabel.textContent =
                index === phraseWords.length - 1
                    ? word.plainText
                    : `${word.plainText} `;
            wordElement.append(wordLabel);
            phraseElement.append(wordElement);
        });

        return phraseElement;
    }

    function getSmoothBlurPhraseDuration(phrase) {
        const wordCount = phrase.split(" ").filter(Boolean).length;

        return 3200 + Math.min(Math.max(wordCount - 1, 0) * 220, 960);
    }

    function startSmoothBlurText() {
        if (!textElement) return;

        let phraseIndex = 0;
        let activePhraseElement = createSmoothBlurPhrase(phrases[phraseIndex]);

        textElement.replaceChildren(activePhraseElement);
        textElement.setAttribute("aria-label", phrases[phraseIndex]);
        requestHeroCopyMotionUpdate();

        runOnNextFrame(() => {
            activePhraseElement.classList.add("is-visible");
        });

        const cyclePhrases = () => {
            const outgoingPhraseElement = activePhraseElement;
            phraseIndex = (phraseIndex + 1) % phrases.length;

            const incomingPhraseElement = createSmoothBlurPhrase(
                phrases[phraseIndex],
            );

            textElement.append(incomingPhraseElement);
            textElement.setAttribute("aria-label", phrases[phraseIndex]);
            requestHeroCopyMotionUpdate();

            runOnNextFrame(() => {
                incomingPhraseElement.classList.add("is-visible");
                outgoingPhraseElement?.classList.add("is-fading");
            });

            activePhraseElement = incomingPhraseElement;

            queueHeroTextTimer(() => {
                outgoingPhraseElement?.remove();
            }, 1900);

            queueHeroTextTimer(
                cyclePhrases,
                getSmoothBlurPhraseDuration(phrases[phraseIndex]),
            );
        };

        queueHeroTextTimer(
            cyclePhrases,
            1050 + getSmoothBlurPhraseDuration(phrases[phraseIndex]),
        );
    }

    if (textElement && phrases.length > 0 && heroTextMode === "smooth-blur") {
        startSmoothBlurText();
    }
</script>
