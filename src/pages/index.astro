    #typewriter-text {
        --smooth-blur-mask-start: color-mix(
            in srgb,
            var(--bg-color) 82%,
            transparent
        );
        --smooth-blur-mask-mid: color-mix(
            in srgb,
            var(--bg-color) 70%,
            transparent
        );
        --smooth-blur-mask-end: color-mix(
            in srgb,
            var(--bg-color) 34%,
            transparent
        );
        font-family: var(
            --feature-typewriter-text-font,
            var(--feature-typewriter-main-font, var(--font-sans))
        );
        font-size: var(--feature-typewriter-text-size, 1.35em);
        font-weight: var(
            --feature-typewriter-text-weight,
            var(--feature-typewriter-main-weight, 700)
        );
        line-height: var(--feature-typewriter-text-line-height, 1.1);
        letter-spacing: var(--feature-typewriter-text-letter-spacing, 0em);
        color: var(
            --feature-typewriter-text-color,
            var(--feature-typewriter-main-color, var(--text-primary))
        );
        min-height: 1.2em; /* Reserve space */
        margin-top: 0;
        position: relative;
        top: -2px; /* Shift upwards to balance */
        width: 100%;
        min-width: 0;
        max-width: min(100%, calc(100vw - 48px));
        white-space: normal;
        overflow-wrap: break-word;
    }

    [data-theme="light"] #typewriter-text {
        --smooth-blur-mask-start: color-mix(
            in srgb,
            var(--bg-color) 68%,
            transparent
        );
        --smooth-blur-mask-mid: color-mix(
            in srgb,
            var(--bg-color) 48%,
            transparent
        );
        --smooth-blur-mask-end: color-mix(
            in srgb,
            var(--bg-color) 16%,
            transparent
        );
    }

    #typewriter-text[data-text-effect="typewriter"] {
        display: inline-block;
        max-width: 100%;
        white-space: normal;
        transition: opacity 0.1s ease; /* Makes disappearance smoother */
    }

    #typewriter-text[data-text-effect="smooth-blur"] {
        display: inline-grid;
        grid-template-areas: "stack";
        align-items: baseline;
        vertical-align: top;
        width: 100%;
        white-space: normal;
        isolation: isolate;
        overflow: visible;
        padding-top: 0.14em;
        padding-bottom: 0.18em;
    }

    @media (max-width: 600px) {
        #typewriter-text {
            white-space: normal; /* Allow wrapping on mobile */
            word-break: break-word;
        }

        #typewriter-text[data-text-effect="typewriter"] {
            display: inline; /* changing to inline allows wrapping naturally */
        }
    }

    #typewriter-text[data-text-effect="typewriter"] :global(span) {
        /* Smooth individual character removal */
        transition: opacity 0.08s ease;
        text-shadow:
            2px 2px 0 rgba(0, 0, 0, 0.34),
            4px 3px 0 rgba(0, 0, 0, 0.18);
    }

    [data-theme="light"]
        #typewriter-text[data-text-effect="typewriter"]
        :global(span) {
        text-shadow:
            2px 2px 0 rgba(15, 23, 42, 0.42),
            4px 3px 0 rgba(15, 23, 42, 0.22);
    }

    #typewriter-text[data-text-effect="typewriter"]::after {
        content: "";
        display: inline-block;

        /* Cursor dimensions - adjust these */
        width: 14px; /* Width of cursor */
        height: 0.8em; /* Height of cursor */

        /* Cursor appearance */
        background-color: var(--text-primary);
        border-radius: 1px;

        /* Positioning */
        margin-left: 5px; /* Space from text */
        vertical-align: top; /* Align with text baseline */
        position: relative;
        top: 0.1em; /* Fine-tune vertical position */

        /* Animation */
        animation: blink 1.2s infinite; /* Slightly slower blink for calmer feel */
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase) {
        grid-area: stack;
        position: relative;
        display: inline-flex;
        flex-wrap: wrap;
        align-items: baseline;
        align-content: flex-start;
        justify-content: flex-start;
        gap: 0.14em 0.2em;
        width: 100%;
        max-width: 100%;
        white-space: normal;
        overflow: visible;
        opacity: 0;
        filter: blur(12px);
        transform: translate3d(0, 0.18em, 0);
        pointer-events: none;
        transition:
            opacity 1.35s cubic-bezier(0.22, 1, 0.36, 1),
            transform 1.85s cubic-bezier(0.22, 1, 0.36, 1),
            filter 1.85s cubic-bezier(0.22, 1, 0.36, 1),
            text-shadow 1.2s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform, filter, text-shadow;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase)::after {
        content: none;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-visible) {
        opacity: 1;
        filter: blur(0.15px);
        transform: translate3d(0, 0, 0);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-visible)::after {
        opacity: 0;
        transform: translate3d(112%, 0, 0);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-fading) {
        opacity: 0;
        filter: blur(9px);
        transform: translate3d(0.16em, -0.05em, 0);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-word) {
        display: inline-block;
        flex: 0 1 auto;
        max-width: 100%;
        opacity: 0;
        filter: blur(8px);
        transform: translate3d(-0.24em, 0.15em, 0);
        text-shadow: 0 0 6px color-mix(in srgb, currentColor 30%, transparent);
        transition:
            opacity 1.15s linear,
            transform 1.55s cubic-bezier(0.22, 1, 0.36, 1),
            filter 1.55s cubic-bezier(0.22, 1, 0.36, 1),
            text-shadow 1.15s cubic-bezier(0.22, 1, 0.36, 1);
        transition-delay: var(--word-delay, 0s);
        will-change: opacity, transform, filter, text-shadow;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-word-label) {
        display: inline-block;
        max-width: 100%;
        overflow-wrap: break-word;
        backface-visibility: hidden;
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-visible .smooth-blur-word) {
        opacity: 1;
        filter: blur(0.08px);
        transform: translate3d(0, 0, 0);
        text-shadow: 0 0 1px color-mix(in srgb, currentColor 14%, transparent);
    }

    #typewriter-text[data-text-effect="smooth-blur"]
        :global(.smooth-blur-phrase.is-fading .smooth-blur-word) {
        opacity: 0;
        filter: blur(6px);
        transform: translate3d(0.18em, -0.04em, 0);
        text-shadow: 0 0 4px color-mix(in srgb, currentColor 22%, transparent);
        transition-delay: 0s;
    }

    @media (max-width: 600px) {
        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-phrase) {
            flex-wrap: wrap;
            white-space: normal;
        }
    }

    :global(body.landing-page .global-grid-bg) {
        opacity: 0.18;
        background-size: 72px 72px;
        -webkit-mask-image: none;
        mask-image: none;
    }

    :global(body.landing-page .global-glow-bg) {
        display: none;
    }

    @media (prefers-reduced-motion: reduce) {
        .hero-content,
        .hero-word,
        .hero-title-line,
        .hero-bio-line,
        .hero-title-line-dynamic {
            transition: none;
            filter: none;
            transform: none;
        }

        #typewriter-text[data-text-effect="typewriter"]::after {
            animation: none;
        }

        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-phrase),
        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-word),
        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-word-label),
        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-phrase)::after {
            transition: none;
            filter: none;
            transform: none;
        }

        #typewriter-text[data-text-effect="smooth-blur"]
            :global(.smooth-blur-phrase)::after {
            opacity: 0;
        }
    }

    @keyframes blink {
        0%,
        50% {
            opacity: 1;
        }
        51%,
