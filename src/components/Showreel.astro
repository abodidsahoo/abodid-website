---
interface Props {
    vh1Url?: string;
    rollingStoneUrl?: string;
    homegrownUrl?: string;
    educateGirlsUrl?: string;
    curvesColorsUrl?: string;
    pursuitUrl?: string;
    hermosaUrl?: string;
    budweiserUrl?: string;
    wiedenUrl?: string;
    animalUrl?: string;
    jawaUrl?: string;
    odishaUrl?: string;
}

const videoUrl = "/videos/showreel-2025.mp4";
---

<div class="showreel-shell">
    <div class="showreel-container">
        <video
            id="showreel-video"
            class="showreel-video"
            src={videoUrl}
            autoplay
            loop
            muted
            playsinline
            webkit-playsinline
            preload="metadata"
            controlslist="nodownload noplaybackrate noremoteplayback"
            disablepictureinpicture
            disableremoteplayback
        >
        </video>

        <button
            id="volume-toggle-btn"
            class="volume-toggle-btn"
            type="button"
            title="Turn sound on"
            aria-label="Turn showreel sound on"
        >
            <svg id="icon-volume-on" viewBox="0 0 24 24" aria-hidden="true" hidden>
                <path d="M3 9v6h4l5 4V5L7 9H3zm13.5 3a4.5 4.5 0 0 0-2.5-4.04v8.08A4.5 4.5 0 0 0 16.5 12zm-2.5-8.5v2.06a7 7 0 0 1 0 12.88v2.06a9 9 0 0 0 0-17z"></path>
            </svg>
            <svg id="icon-volume-off" viewBox="0 0 28 24" aria-hidden="true">
                <path class="speaker-mark" d="M3 9v6h4l5 4V5L7 9H3z"></path>
                <path class="mute-mark" d="M19 9l5 5m0-5-5 5"></path>
            </svg>
        </button>
    </div>

    <div class="showreel-credits">
        <div class="showreel-meta-line">
            <p class="credits-roles">
                <span class="role-label">ROLE:</span> Director / Editor / Sound Designer / Cinematographer / Colourist / Creative Producer
            </p>
            <div class="thin-line"></div>
            <a href="/films" class="view-all-link">VIEW ALL FILMS</a>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const video = document.getElementById("showreel-video");
        const volumeToggleBtn = document.getElementById("volume-toggle-btn");
        const iconVolumeOn = document.getElementById("icon-volume-on");
        const iconVolumeOff = document.getElementById("icon-volume-off");

        if (!video || !volumeToggleBtn) return;

        const syncVolume = () => {
            const isMuted = video.muted || video.volume === 0;

            iconVolumeOn?.toggleAttribute("hidden", isMuted);
            iconVolumeOff?.toggleAttribute("hidden", !isMuted);

            volumeToggleBtn.setAttribute(
                "aria-label",
                isMuted ? "Turn showreel sound on" : "Turn showreel sound off",
            );
            volumeToggleBtn.setAttribute(
                "title",
                isMuted ? "Turn sound on" : "Turn sound off",
            );
        };

        volumeToggleBtn.addEventListener("click", () => {
            if (video.muted || video.volume === 0) {
                if (video.volume === 0) video.volume = 0.85;
                video.muted = false;
                video.play().catch(() => undefined);
                syncVolume();
                return;
            }

            video.muted = true;
            syncVolume();
        });

        video.addEventListener("volumechange", syncVolume);
        video.play().catch(() => undefined);
        syncVolume();
    });
</script>

<style>
    .showreel-shell {
        width: 100vw;
        max-width: none;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
        padding: clamp(4px, 0.65vw, 8px);
        position: relative;
    }

    .showreel-container {
        width: 100%;
        position: relative;
        overflow: hidden;
        border-radius: 0;
        background: #050505;
    }

    .showreel-video {
        width: 100%;
        aspect-ratio: 16 / 9;
        object-fit: cover;
        display: block;
        background: #000;
    }

    .showreel-video::-webkit-media-controls,
    .showreel-video::-webkit-media-controls-panel,
    .showreel-video::-webkit-media-controls-enclosure {
        display: none !important;
    }

    .volume-toggle-btn {
        position: absolute;
        right: clamp(12px, 1.6vw, 22px);
        bottom: clamp(12px, 1.6vw, 22px);
        z-index: 2;
        width: clamp(42px, 4vw, 54px);
        height: clamp(42px, 4vw, 54px);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255, 255, 255, 0.22);
        border-radius: 999px;
        background: rgba(8, 8, 8, 0.72);
        color: #fff;
        cursor: pointer;
        box-shadow: 0 12px 34px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(10px);
        transition:
            background 0.18s ease,
            border-color 0.18s ease,
            transform 0.18s ease;
    }

    .volume-toggle-btn:hover,
    .volume-toggle-btn:focus-visible {
        background: rgba(8, 8, 8, 0.9);
        border-color: rgba(255, 255, 255, 0.46);
        outline: none;
        transform: translateY(-1px);
    }

    .volume-toggle-btn svg {
        width: 24px;
        height: 21px;
        fill: currentColor;
    }

    .volume-toggle-btn .mute-mark {
        fill: none;
        stroke: currentColor;
        stroke-linecap: round;
        stroke-width: 2.2;
    }

    .volume-toggle-btn svg[hidden] {
        display: none;
    }

    .showreel-credits {
        width: 100%;
        margin-top: clamp(8px, 1.5vh, 16px);
        margin-bottom: clamp(1rem, 2vh, 2rem);
    }

    .showreel-meta-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1.5rem;
        background-color: #ffffff;
        color: #000000;
        padding: 16px 24px;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        line-height: 1;
        border-radius: 0;
    }

    .credits-roles {
        flex-shrink: 0;
        margin: 0;
        color: #000000;
        white-space: nowrap;
        font-size: 0.75rem;
    }

    .role-label {
        color: #000000;
        margin-right: 0.5rem;
    }

    .thin-line {
        flex-grow: 1;
        height: 1px;
        background-color: #000000;
        opacity: 0.25;
    }

    .view-all-link {
        flex-shrink: 0;
        color: #000000;
        text-decoration: none;
        white-space: nowrap;
        font-size: 0.75rem;
        transition: opacity 0.22s ease;
        cursor: pointer;
    }

    .view-all-link:hover,
    .view-all-link:focus-visible {
        color: #000000;
        opacity: 0.6;
        outline: none;
    }

    @media (max-width: 900px) {
        .showreel-shell {
            padding: 4px;
        }

        .showreel-credits {
            padding: 0;
        }

        .showreel-meta-line {
            flex-direction: column;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            text-align: center;
        }

        .credits-roles {
            white-space: normal;
            line-height: 1.5;
        }

        .thin-line {
            display: none;
        }

        .view-all-link {
            width: 100%;
            padding-top: 12px;
            border-top: 1px solid rgba(0, 0, 0, 0.1);
        }
    }
</style>
