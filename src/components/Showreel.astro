---
interface Props {
    vh1Url?: string;
    rollingStoneUrl?: string;
    homegrownUrl?: string;
    educateGirlsUrl?: string;
    curvesColorsUrl?: string;
    pursuitUrl?: string;
    hermosaUrl?: string;
    budweiserUrl?: string;
    wiedenUrl?: string;
    animalUrl?: string;
    jawaUrl?: string;
    odishaUrl?: string;
}

const {
    vh1Url = "#",
    rollingStoneUrl = "#",
    homegrownUrl = "#",
    educateGirlsUrl = "#",
    curvesColorsUrl = "#",
    pursuitUrl = "#",
    hermosaUrl = "#",
    budweiserUrl = "#",
    wiedenUrl = "#",
    animalUrl = "#",
    jawaUrl = "#",
    odishaUrl = "#",
} = Astro.props;

const videoUrl = "/videos/showreel-2025.mp4";
---

<div class="showreel-container">
    <video
        id="showreel-video"
        class="showreel-video"
        loop
        muted
        playsinline
        webkit-playsinline
        preload="metadata"
        autoplay
    >
        <!-- Source will be added via JS with proper type -->
    </video>

    <button
        id="playback-toggle-btn"
        class="playback-toggle-btn"
        type="button"
        aria-label="Pause showreel video"
        title="Pause"
    >
        <span id="playback-toggle-text">Pause</span>
    </button>

    <!-- Video Controls -->
    <div class="video-controls">
        <!-- Fullscreen Button -->
        <button
            id="fullscreen-btn"
            class="control-btn"
            title="Toggle Fullscreen"
        >
            <!-- Enter Fullscreen Icon (Default) -->
            <svg id="icon-enter-fullscreen" viewBox="0 0 24 24">
                <path
                    d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"
                ></path>
            </svg>
            <!-- Exit Fullscreen Icon -->
            <svg
                id="icon-exit-fullscreen"
                viewBox="0 0 24 24"
                style="display: none;"
            >
                <path
                    d="M5 16h3v3h2v-5H5v2zm3-8H5v2h5V5H8v3zm6 11h2v-3h3v-2h-5v5zm2-11V5h-2v5h5V8h-3z"
                ></path>
            </svg>
        </button>

        <!-- Mute/Unmute Button -->
        <button id="mute-btn" class="control-btn" title="Toggle Sound">
            <!-- Muted Icon (Default) -->
            <svg id="icon-muted" viewBox="0 0 24 24">
                <path
                    d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73 4.27 3zM12 4L9.91 6.09 12 8.18V4z"
                ></path>
            </svg>
            <!-- Unmuted Icon -->
            <svg id="icon-unmuted" viewBox="0 0 24 24" style="display: none;">
                <path
                    d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"
                ></path>
            </svg>
        </button>
    </div>
</div>

<!-- Credits Section (Separate from video) -->
<div class="showreel-credits">
    <p class="credits-roles">
        <span class="role-label">ROLE:</span> Director / Editor / Sound Designer /
        Cinematographer / Colourist / Creative Producer
    </p>
    <div class="credits-buttons-row">
        <a href="/films" class="view-all-btn">VIEW ALL FILMS</a>
    </div>
</div>



<script define:vars={{ videoUrl }}>
    document.addEventListener("DOMContentLoaded", () => {
        const container = document.querySelector(".showreel-container");
        const video = document.getElementById("showreel-video");
        const playbackToggleBtn = document.getElementById("playback-toggle-btn");
        const playbackToggleText = document.getElementById(
            "playback-toggle-text",
        );
        const muteBtn = document.getElementById("mute-btn");
        const iconMuted = document.getElementById("icon-muted");
        const iconUnmuted = document.getElementById("icon-unmuted");
        const fullscreenBtn = document.getElementById("fullscreen-btn");
        const iconEnterFullscreen = document.getElementById(
            "icon-enter-fullscreen",
        );
        const iconExitFullscreen = document.getElementById(
            "icon-exit-fullscreen",
        );
        let userPausedVideo = false;
        let lastFinePointerPosition = null;
        const playbackTogglePointerOffsetY = 12;

        if (!container || !video) return;

        const setPointerInside = (isInside) => {
            container.dataset.pointerInside = isInside ? "true" : "false";
        };

        const isPointerInsideContainer = (clientX, clientY) => {
            const rect = container.getBoundingClientRect();

            return (
                clientX >= rect.left &&
                clientX <= rect.right &&
                clientY >= rect.top &&
                clientY <= rect.bottom
            );
        };

        const updatePlaybackTogglePosition = (clientX, clientY) => {
            if (!playbackToggleBtn) return;

            const rect = container.getBoundingClientRect();
            const buttonWidth = playbackToggleBtn.offsetWidth || 112;
            const buttonHeight = playbackToggleBtn.offsetHeight || 44;
            const horizontalPadding = buttonWidth / 2 + 16;
            const verticalPadding = buttonHeight / 2 + 16;
            const relativeX = clientX - rect.left;
            const relativeY = clientY - rect.top - playbackTogglePointerOffsetY;
            const clampedX = Math.min(
                Math.max(relativeX, horizontalPadding),
                rect.width - horizontalPadding,
            );
            const clampedY = Math.min(
                Math.max(relativeY, verticalPadding),
                rect.height - verticalPadding,
            );

            // Use transform directly — no CSS transition on position, so it follows instantly
            playbackToggleBtn.style.transform = `translate(calc(${clampedX}px - 50%), calc(${clampedY}px - 50%)) scale(1)`;
        };

        const syncPlaybackToggle = () => {
            const isPaused = video.paused;
            container.dataset.playbackState = isPaused ? "paused" : "playing";

            if (playbackToggleText) {
                playbackToggleText.textContent = isPaused ? "Play" : "Pause";
            }

            if (playbackToggleBtn) {
                const label = isPaused ? "Play showreel video" : "Pause showreel video";
                playbackToggleBtn.setAttribute("aria-label", label);
                playbackToggleBtn.setAttribute(
                    "title",
                    isPaused ? "Play" : "Pause",
                );
            }
        };

        const hidePlaybackToggle = () => {
            setPointerInside(false);

            if (
                playbackToggleBtn &&
                document.activeElement === playbackToggleBtn &&
                !playbackToggleBtn.matches(":focus-visible")
            ) {
                playbackToggleBtn.blur();
            }
        };

        const syncPlaybackToggleToPointer = () => {
            if (!lastFinePointerPosition) {
                hidePlaybackToggle();
                return;
            }

            if (
                !isPointerInsideContainer(
                    lastFinePointerPosition.clientX,
                    lastFinePointerPosition.clientY,
                )
            ) {
                hidePlaybackToggle();
                return;
            }

            setPointerInside(true);
            updatePlaybackTogglePosition(
                lastFinePointerPosition.clientX,
                lastFinePointerPosition.clientY,
            );
        };

        const handlePointerUpdate = (event) => {
            if (event.pointerType === "touch") return;

            lastFinePointerPosition = {
                clientX: event.clientX,
                clientY: event.clientY,
            };

            if (!isPointerInsideContainer(event.clientX, event.clientY)) {
                hidePlaybackToggle();
                return;
            }

            setPointerInside(true);
            updatePlaybackTogglePosition(event.clientX, event.clientY);
        };

        setPointerInside(false);

        container.addEventListener("pointerenter", handlePointerUpdate);
        container.addEventListener("pointermove", handlePointerUpdate);
        container.addEventListener("pointerleave", () => {
            lastFinePointerPosition = null;
            hidePlaybackToggle();
        });
        container.addEventListener("mouseleave", () => {
            lastFinePointerPosition = null;
            hidePlaybackToggle();
        });

        document.addEventListener("pointermove", (event) => {
            if (event.pointerType === "touch") return;

            lastFinePointerPosition = {
                clientX: event.clientX,
                clientY: event.clientY,
            };

            if (!isPointerInsideContainer(event.clientX, event.clientY)) {
                hidePlaybackToggle();
            }
        });

        window.addEventListener("scroll", syncPlaybackToggleToPointer, {
            passive: true,
        });
        window.addEventListener("resize", syncPlaybackToggleToPointer);
        window.addEventListener("blur", () => {
            lastFinePointerPosition = null;
            hidePlaybackToggle();
        });

        if (playbackToggleBtn) {
            playbackToggleBtn.addEventListener("click", (event) => {
                event.stopPropagation();

                if (video.paused) {
                    userPausedVideo = false;
                    video.play().catch(() => {
                        syncPlaybackToggle();
                    });
                    return;
                }

                userPausedVideo = true;
                video.pause();
            });
        }

        video.addEventListener("play", syncPlaybackToggle);
        video.addEventListener("pause", syncPlaybackToggle);
        video.addEventListener("loadeddata", syncPlaybackToggle);
        video.addEventListener("ended", syncPlaybackToggle);

        // Toggle Mute Logic
        if (muteBtn) {
            muteBtn.addEventListener("click", () => {
                video.muted = !video.muted;
                if (video.muted) {
                    iconMuted.style.display = "block";
                    iconUnmuted.style.display = "none";
                } else {
                    iconMuted.style.display = "none";
                    iconUnmuted.style.display = "block";
                }
            });
        }

        // Toggle Fullscreen Logic
        if (fullscreenBtn) {
            fullscreenBtn.addEventListener("click", () => {
                if (!document.fullscreenElement) {
                    // Enter fullscreen
                    container
                        .requestFullscreen()
                        .then(() => {
                            iconEnterFullscreen.style.display = "none";
                            iconExitFullscreen.style.display = "block";
                        })
                        .catch((err) => {
                            console.error("Error entering fullscreen:", err);
                        });
                } else {
                    // Exit fullscreen
                    document
                        .exitFullscreen()
                        .then(() => {
                            iconEnterFullscreen.style.display = "block";
                            iconExitFullscreen.style.display = "none";
                        })
                        .catch((err) => {
                            console.error("Error exiting fullscreen:", err);
                        });
                }
            });

            // Listen for fullscreen changes (e.g., ESC key)
            document.addEventListener("fullscreenchange", () => {
                if (!document.fullscreenElement) {
                    iconEnterFullscreen.style.display = "block";
                    iconExitFullscreen.style.display = "none";
                }
            });
        }

        // Simplified Loading Strategy - Direct Load, No Flicker
        const loadShowreel = () => {
            if (!video.src) {
                // Set video source
                video.src = videoUrl;

                // Show container immediately
                container.style.display = "block";
                syncPlaybackToggle();

                // Try to play
                video.play().catch(() => {
                    console.log("Autoplay blocked, waiting for interaction");
                    syncPlaybackToggle();
                });

                // Simple check loop to ensure playback if possible
                const ensurePlay = () => {
                    if (!userPausedVideo && video.paused && !video.ended) {
                        video.play().catch(() => {
                            syncPlaybackToggle();
                        });
                    }
                };

                // Check a few times
                setTimeout(ensurePlay, 500);
                setTimeout(ensurePlay, 1000);
            }
        };

        // Load immediately on mount (or very short delay)
        loadShowreel();



        syncPlaybackToggle();
    });
</script>

<style>
    :root {
        --sci-fi-cyan: #00f3ff;
        --sci-fi-glow: rgba(0, 243, 255, 0.2);
    }

    .showreel-container {
        --playback-toggle-x: 50%;
        --playback-toggle-y: 50%;
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        margin-top: 0;
        margin-bottom: 0;

        position: relative;

        /* Will be animated from 0 to full height */
        /* Height will be set dynamically based on aspect ratio */

        background-color: #050a10;

        /* Sci-Fi Theme Styling */
        border-radius: 12px; /* APPLY RADIUS TO CONTAINER */
        overflow: hidden; /* FORCE MASKING for all views */
        border: 1px solid rgba(0, 243, 255, 0.3);
        box-shadow:
            0 10px 40px rgba(0, 0, 0, 0.6),
            0 0 20px var(--sci-fi-glow);

        /* Smooth transitions will be applied via JS */
    }

    /* Corner Accents (Pseudo-elements) */
    .showreel-container::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: 12px;
        box-shadow: inset 0 0 20px rgba(0, 243, 255, 0.1);
        pointer-events: none;
        z-index: 2; /* Ensure overlay is ON TOP of video */
    }

    .showreel-video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        aspect-ratio: 16 / 9;
        /* Ensure video stays behind the container mask/border effects */
        position: relative;
        z-index: 1;
    }

    .playback-toggle-btn {
        position: absolute;
        /* Positioned at top-left origin; actual position applied via transform in JS */
        top: 0;
        left: 0;
        z-index: 9;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 80px;
        padding: 0.6rem 1rem;
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.9);
        color: #111;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        box-shadow:
            0 4px 15px rgba(0, 0, 0, 0.15),
            0 0 0 1px rgba(255, 255, 255, 0.8) inset;
        cursor: pointer;
        opacity: 0;
        pointer-events: none;
        /* Initial hidden state — transform is overridden by JS on every mousemove, no transition on position */
        transform: translate(-50%, -50%) scale(0.92);
        transition:
            opacity 0.28s ease,
            background 0.28s ease,
            border-color 0.28s ease,
            box-shadow 0.28s ease;
    }

    .playback-toggle-btn span {
        display: inline-block;
        animation: playback-toggle-float 4.2s ease-in-out infinite;
    }

    .playback-toggle-btn:hover,
    .playback-toggle-btn:focus-visible {
        background: #ffffff;
        border-color: #ffffff;
        box-shadow:
            0 6px 20px rgba(0, 0, 0, 0.2),
            0 0 0 1px #ffffff inset;
        outline: none;
    }

    /* Video Controls Container */
    .video-controls {
        position: absolute;
        bottom: 20px;
        right: 20px;
        z-index: 10;
        display: flex;
        gap: 12px;
    }

    /* Control Button Styling (Mute & Fullscreen) */
    .control-btn {
        background: rgba(5, 10, 16, 0.8);
        border: 1px solid var(--sci-fi-cyan);
        color: var(--sci-fi-cyan);
        border-radius: 50%;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transform: translateY(10px);
        transition: all 0.3s ease;
        backdrop-filter: blur(4px);
    }

    .control-btn:hover {
        background: rgba(0, 243, 255, 0.1);
        box-shadow: 0 0 15px rgba(0, 243, 255, 0.3);
    }

    .control-btn svg {
        width: 20px;
        height: 20px;
        fill: currentColor;
    }

    /* Show buttons on container hover */
    .showreel-container:hover .control-btn {
        opacity: 1;
        transform: translateY(0);
    }

    .showreel-container[data-pointer-inside="true"] .playback-toggle-btn,
    .playback-toggle-btn:focus-visible {
        opacity: 1;
        pointer-events: auto;
        /* Scale override is handled by JS via transform; only opacity is toggled via CSS */
    }

    @keyframes playback-toggle-float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-2px);
        }
    }

    /* Credits Section (Now separate from video container) */
    .showreel-credits {
        width: 100%;
        max-width: var(--max-width);
        margin: 0 auto;
        margin-top: 2rem;
        margin-bottom: var(--space-2xl);
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        padding: 0;
    }

    .credits-roles {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-secondary);
        margin: 0;
        line-height: 1.6;
    }

    .role-label {
        color: var(--text-secondary);
        font-weight: 600;
        margin-right: 0.5rem;
    }

    .view-all-btn {
        display: inline-block;
        width: fit-content;
        font-family: var(--font-mono);
        font-size: 0.9rem;
        color: var(--text-primary);
        background: transparent;
        border: 1px solid var(--border-subtle);
        padding: 0.75rem 1.5rem;
        border-radius: 2px;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .view-all-btn:hover {
        background: var(--text-primary);
        color: #000; /* Dark text for visibility */
        border-color: var(--text-primary);
    }

    /* Buttons Row Layout */
    .credits-buttons-row {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .manifesto-toggle {
        cursor: pointer;
    }

    /* Manifesto Section Styles */
    .manifesto-section {
        width: 100%;
        max-width: var(--max-width);
        margin: 0.5rem auto 0; /* Tightened gap further */
        overflow: hidden;
        transition:
            max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
            opacity 0.4s ease;
    }

    .manifesto-content {
        padding: 1rem 0 2rem; /* Reduced top padding to close gap */
    }

    .manifesto-boxes {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .manifesto-box {
        padding: 2rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .manifesto-box-red {
        background: linear-gradient(
            135deg,
            rgba(208, 0, 0, 0.15) 0%,
            rgba(150, 0, 0, 0.08) 100%
        );
        border-color: rgba(208, 0, 0, 0.3);
    }

    .manifesto-box-blue {
        background: linear-gradient(
            135deg,
            rgba(0, 100, 200, 0.15) 0%,
            rgba(0, 50, 150, 0.08) 100%
        );
        border-color: rgba(0, 100, 200, 0.3);
    }

    .manifesto-box h3 {
        font-family: var(--font-mono);
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        margin-bottom: 1rem;
        color: var(--text-primary);
        font-weight: 700; /* Bold */
    }

    .manifesto-box p {
        font-family: var(--font-mono);
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--text-secondary);
    }

    .manifesto-journey {
        padding: 2rem;
        background: rgba(255, 255, 255, 0.02);
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .manifesto-journey h2 {
        font-family: var(--font-mono);
        font-size: 1.2rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        margin-bottom: 1.5rem;
        color: var(--text-primary);
        font-weight: 700; /* Bold */
    }

    .manifesto-journey p {
        font-family: var(--font-mono);
        font-size: 1rem;
        line-height: 1.8;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
    }

    .manifesto-journey p:last-child {
        margin-bottom: 0;
    }

    /* Clickable Links in Manifesto */
    .manifesto-journey a {
        color: var(--text-primary);
        text-decoration: none;
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .manifesto-journey a:hover {
        color: #ffffff;
        border-bottom-color: #ffffff;
        cursor: pointer;
    }

    @media (max-width: 768px) {
        .showreel-container {
            border-radius: 12px; /* APPLY RADIUS TO CONTAINER (Mask) */
            border: none;
            box-shadow: none;
            margin-left: 0;
            width: 100%;
            max-width: none;
            overflow: hidden; /* FORCE MASKING of video */
            /* Remove any padding/gap that might cause "weird spacing" */
            padding: 0;
            background: black; /* seamless bg */
            aspect-ratio: 16/9; /* Enforce ratio on container */
        }

        .showreel-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 0; /* Let container handle the mask */
            display: block;
        }

        .playback-toggle-btn {
            min-width: 72px;
            padding: 0.5rem 0.8rem;
            font-size: 0.6rem;
            letter-spacing: 0.12em;
            opacity: 1;
            pointer-events: auto;
            transform: translate(-50%, -50%);
        }

        /* Always show control buttons on mobile since there is no hover */
        .control-btn {
            opacity: 1;
            transform: translateY(0);
        }

        .video-controls {
            bottom: 16px;
            right: 16px;
        }

        /* Manifesto Mobile Styles */
        .credits-buttons-row {
            flex-direction: column;
            gap: 0.75rem;
        }

        .view-all-btn,
        .manifesto-toggle {
            width: 100%;
            text-align: center;
        }

        .manifesto-boxes {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            margin-bottom: 2rem;
        }

        .manifesto-box {
            padding: 1.5rem;
        }

        .manifesto-journey {
            padding: 1.5rem;
        }

        .manifesto-journey h2 {
            font-size: 1rem;
        }

        .manifesto-journey p {
            font-size: 0.85rem;
        }
    }

    @media (hover: none) {
        .playback-toggle-btn {
            opacity: 1;
            transform: translate(-50%, -50%);
        }
    }
</style>
