---
export interface Props {
    title?: string;
    description?: string;
    image?: string;
    type?: "website" | "article";
    imageAlt?: string;
    useDynamicOgImage?: boolean;
    noindex?: boolean;
    structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

import { getCanonicalPageUrl } from "../lib/urlNormalization.js";

const {
    title,
    description = "Abodid Sahoo is a creative technologist, photographer, filmmaker, researcher, and tutor available for consulting, workshops, Obsidian tutoring, and visual storytelling.",
    image,
    type = "website",
    imageAlt,
    useDynamicOgImage = true,
    noindex = false,
    structuredData,
} = Astro.props;

const siteName = "Abodid Sahoo";
const canonicalURL = getCanonicalPageUrl(
    Astro.site?.toString() || Astro.url.origin,
    Astro.url.pathname,
);
const resolvedImage = image ? new URL(image, Astro.site).toString() : undefined;
const formatTitle = (value?: string) => {
    const trimmedTitle = value?.trim();

    if (!trimmedTitle) return siteName;

    return trimmedTitle.toLowerCase().includes(siteName.toLowerCase())
        ? trimmedTitle
        : `${trimmedTitle} | ${siteName}`;
};
const formattedTitle = formatTitle(title);

const ogImageUrl = new URL(`/api/og`, Astro.url);
ogImageUrl.searchParams.set("title", formattedTitle);
ogImageUrl.searchParams.set("description", description);
if (image) {
    ogImageUrl.searchParams.set("image", image);
}
const ogImage =
    !useDynamicOgImage && resolvedImage ? resolvedImage : ogImageUrl.toString();
const socialImageAlt = imageAlt || `${formattedTitle} preview image`;
const jsonLdItems = Array.isArray(structuredData)
    ? structuredData
    : structuredData
      ? [structuredData]
      : [];
const serializeJsonLd = (item: Record<string, unknown>) =>
    JSON.stringify(item).replace(/</g, "\\u003c");
---

<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{formattedTitle}</title>
<meta name="title" content={formattedTitle} />
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={formattedTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:alt" content={socialImageAlt} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={formattedTitle} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImage} />
<meta property="twitter:image:alt" content={socialImageAlt} />

{
    jsonLdItems.map((item) => (
        <script type="application/ld+json" set:html={serializeJsonLd(item)} />
    ))
}
