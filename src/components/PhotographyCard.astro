---
interface Props {
  title: string;
  category: string;
  image: string;
  href: string;
}

const { title, category, image, href } = Astro.props;
---

<a href={href} class="photography-card group">
  <div class="image-container">
    <img
      src={image}
      alt={title}
      class="slide-image active"
      loading="lazy"
      sizes="(max-width: 600px) 100vw, (max-width: 1024px) 50vw, 33vw"
    />

    <!-- Sci-Fi Overlay -->
    <div class="meta-overlay">
      <h3 class="title">{title}</h3>
      <span class="category">{category}</span>

      <!-- Corner Accents -->
      <div class="corner top-left"></div>
      <div class="corner bottom-right"></div>
    </div>
  </div>
</a>

<style>
  .photography-card {
    display: block;
    cursor: pointer;
    position: relative;
    --photo-card-image-scale-hover: 1.01;
    --photo-card-image-transition:
      transform 1.35s cubic-bezier(0.23, 1, 0.32, 1);
    --photo-card-hover-border: var(--sci-fi-cyan, #00f3ff);
    --photo-card-hover-shadow: 0 0 15px rgba(0, 243, 255, 0.15);
    --photo-card-image-filter: brightness(0.6);
    --photo-card-overlay-bg: rgba(10, 15, 20, 0.8);
    --photo-card-overlay-border: rgba(0, 243, 255, 0.3);
    --photo-card-overlay-shadow:
      0 12px 30px rgba(0, 0, 0, 0.28),
      0 0 18px rgba(0, 243, 255, 0.12);
    --photo-card-title-color: #fff;
    --photo-card-title-shadow: 0 0 10px rgba(0, 243, 255, 0.5);
    --photo-card-category-color: var(--sci-fi-cyan, #00f3ff);
    --photo-card-corner-color: var(--sci-fi-cyan, #00f3ff);
  }

  .image-container {
    background-color: var(--bg-surface);
    overflow: hidden;
    border-radius: 6px;
    aspect-ratio: 16/9; /* Reverted to 16:9 Landscape as requested */
    border: 1px solid var(--border-subtle);
    transition:
      border-color 0.35s ease,
      box-shadow 0.7s ease-in-out;
    position: relative;
    height: auto;
    will-change: box-shadow;
  }

  /* Revert mobile to 16:9 or keep same as desktop */
  @media (max-width: 600px) {
    .image-container {
      aspect-ratio: 16/9 !important;
      border-width: 1px; /* Ensure tiny border */
    }
  }

  .photography-card:hover .image-container {
    border-color: var(--photo-card-hover-border);
    box-shadow: var(--photo-card-hover-shadow);
  }

  .slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1);
    transform-origin: center center;
    transition: var(--photo-card-image-transition), opacity 2s ease-in-out;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    will-change: transform, opacity;
  }

  .slide-image.active {
    opacity: 1;
    pointer-events: none; /* Prevent images from interfering with hover */
  }

  /* Slow image-only zoom with a single stable transition */
  .photography-card:hover .slide-image {
    transform: scale(var(--photo-card-image-scale-hover));
  }

  /* Overlay Styling (Hidden by default) */
  .meta-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 30; /* Higher z-index to stay on top during image transitions */

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;

    padding: 1rem 1.5rem;
    min-width: 60%;

    background: var(--photo-card-overlay-bg);
    backdrop-filter: blur(4px);
    border: 1px solid var(--photo-card-overlay-border);
    border-radius: 4px;
    box-shadow: var(--photo-card-overlay-shadow);

    opacity: 0; /* Hidden */
    transition:
      opacity 0.45s ease,
      transform 0.45s ease;
    pointer-events: none; /* Let clicks pass through to link */

    /* Prevent overlay from being affected by image transitions */
    will-change: opacity, transform;
  }

  .photography-card:hover .meta-overlay {
    opacity: 1;
    transform: translate(-50%, -50%);
  }

  .title {
    font-family: var(--feature-photo-overlay-title-font, var(--font-ui));
    font-size: var(--feature-photo-overlay-title-size, 1.4rem);
    font-weight: var(--feature-photo-overlay-title-weight, 700);
    line-height: var(--feature-photo-overlay-title-line-height, 1.1);
    letter-spacing: var(--feature-photo-overlay-title-letter-spacing, -0.02em);
    color: var(
      --feature-photo-overlay-title-color,
      var(--photo-card-title-color)
    );
    margin: 0 0 0.25rem 0;
    text-transform: uppercase;
    text-shadow: var(--photo-card-title-shadow);
  }

  .category {
    font-family: var(--feature-photo-overlay-meta-font, var(--font-mono));
    font-size: var(--feature-photo-overlay-meta-size, 0.8rem);
    font-weight: var(--feature-photo-overlay-meta-weight, 400);
    line-height: var(--feature-photo-overlay-meta-line-height, 1.2);
    text-transform: uppercase;
    letter-spacing: var(--feature-photo-overlay-meta-letter-spacing, 0.1em);
    color: var(
      --feature-photo-overlay-meta-color,
      var(--photo-card-category-color)
    );
  }

  /* Corner Accents */
  .corner {
    position: absolute;
    width: 8px;
    height: 8px;
    border: 1px solid transparent;
    transition: all 0.3s ease;
  }

  .corner.top-left {
    top: -1px;
    left: -1px;
    border-top: 2px solid var(--photo-card-corner-color);
    border-left: 2px solid var(--photo-card-corner-color);
  }

  .corner.bottom-right {
    bottom: -1px;
    right: -1px;
    border-bottom: 2px solid var(--photo-card-corner-color);
    border-right: 2px solid var(--photo-card-corner-color);
  }

  :global([data-theme="light"]) .photography-card {
    --feature-photo-overlay-title-color: #fff;
    --feature-photo-overlay-meta-color: #fff;
    --photo-card-image-scale-hover: 1.008;
    --photo-card-hover-border: rgba(15, 23, 42, 0.18);
    --photo-card-hover-shadow:
      0 16px 34px rgba(15, 23, 42, 0.12),
      0 0 18px rgba(255, 255, 255, 0.18);
    --photo-card-image-filter: brightness(0.72) saturate(0.92);
    --photo-card-overlay-bg: linear-gradient(
      180deg,
      rgba(163, 0, 33, 0.76) 0%,
      rgba(163, 0, 33, 0.84) 100%
    );
    --photo-card-overlay-border: rgba(255, 255, 255, 0.22);
    --photo-card-overlay-shadow:
      0 14px 30px rgba(163, 0, 33, 0.2),
      0 10px 22px rgba(15, 23, 42, 0.12),
      0 0 18px rgba(255, 255, 255, 0.14),
      0 0 6px rgba(255, 255, 255, 0.1);
    --photo-card-title-color: #fff;
    --photo-card-title-shadow: 0 0 8px rgba(255, 255, 255, 0.12);
    --photo-card-category-color: #fff;
    --photo-card-corner-color: rgba(255, 255, 255, 0.55);
  }
</style>
