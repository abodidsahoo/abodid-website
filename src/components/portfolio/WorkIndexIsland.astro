---
import WorkIndex from "./WorkIndex.jsx";
import { getPublishedPortfolioIndex } from "../../lib/portfolio/services";

const projects = await getPublishedPortfolioIndex();
const workIndexProps = { projects } as any;

Astro.response.headers.set("Cache-Control", "public, max-age=0, must-revalidate");
Astro.response.headers.set(
  "Vercel-CDN-Cache-Control",
  "s-maxage=300, stale-while-revalidate=86400",
);
---

<WorkIndex {...workIndexProps} client:load />
