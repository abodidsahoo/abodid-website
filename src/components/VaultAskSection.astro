        border-radius: 32px;
        background: rgba(8, 8, 8, 0.76);
        box-shadow: 0 20px 80px rgba(0, 0, 0, 0.35);
        backdrop-filter: blur(14px);
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease,
            background 0.2s ease;
    }

    .vault-ask-box:focus-within {
        border-color: rgba(255, 255, 255, 0.34);
        background: rgba(10, 10, 10, 0.86);
        box-shadow:
            0 0 0 1px rgba(255, 255, 255, 0.08),
            0 24px 90px rgba(0, 0, 0, 0.45);
    }

    .vault-ask-box textarea {
        display: block;
        width: 100%;
        min-height: 40px;
        padding: 0.34rem 0;
        border: 0;
        outline: 0;
        resize: none;
        overflow: hidden;
        background: transparent;
        color: #f5f5f5;
        font: inherit;
        font-size: 1.05rem;
        line-height: 1.45;
    }

    .vault-ask-box textarea::placeholder {
        color: rgba(255, 255, 255, 0.48);
    }

    .vault-ask-box textarea:disabled {
        opacity: 0.72;
    }

    .vault-ask-submit {
        position: absolute;
        right: 0.85rem;
        bottom: 0.85rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 84px;
        min-height: 46px;
        border: 1px solid rgba(255, 255, 255, 0.16);
        border-radius: 999px;
        background: #f5f5f5;
        color: #050505;
        font: inherit;
        font-size: 0.92rem;
        font-weight: 650;
        cursor: pointer;
        transition:
            transform 0.18s ease,
            opacity 0.18s ease,
            background 0.18s ease;
    }

    .vault-ask-submit:hover:not(:disabled) {
        transform: translateY(-1px);
        background: #ffffff;
    }

    .vault-ask-submit:disabled {
        cursor: wait;
        opacity: 0.62;
    }

    .vault-ask-status,
    .vault-ask-error {
        margin: 0.85rem 1.4rem 0;
        font-size: 0.92rem;
        line-height: 1.5;
    }

    .vault-ask-status {
        color: var(--text-secondary);
    }

