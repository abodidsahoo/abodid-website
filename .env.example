PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
RESEND_API_KEY=re_your-resend-api-key-here
PUBLIC_TURNSTILE_SITE_KEY=your-site-key
TURNSTILE_SECRET_KEY=your-secret-key
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-programmable-search-engine-id-here
OWNER_NOTIFICATION_EMAIL=you@example.com
OPENALEX_API_KEY=your-openalex-api-key-here
RESEARCH_WORKSPACE_CONTACT_EMAIL=you@example.com
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_RESEARCH_MODELS=openrouter/auto,openai/gpt-4o-mini,google/gemini-2.5-flash
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small
OPENROUTER_EMBEDDING_DIMENSIONS=1536
OPENROUTER_CHAT_MODEL=google/gemini-2.5-flash
OPENROUTER_VAULT_CHAT_MODELS=google/gemini-2.5-flash,openai/gpt-4.1-mini,google/gemini-2.5-pro,openai/gpt-4o-mini,openai/gpt-4.1
VAULT_CHAT_ENABLE_QUERY_REWRITE=true
VAULT_CHAT_ALLOW_MODEL_KNOWLEDGE=true
GITHUB_OWNER=abodidsahoo
GITHUB_REPO=obsidian-vault
GITHUB_BRANCH=main
OBSIDIAN_VAULT_INDEX_PATHS=6 - Main Notes
OBSIDIAN_VAULT_EXCLUDE_PATHS=.git,.obsidian,node_modules,.trash,trash,7 - Assets,Attachments,attachments
OBSIDIAN_VAULT_PRIVATE_PATHS=
OBSIDIAN_VAULT_PATH=
